    "SmtpUsername": "YOUR_MAILTRAP_USERNAME",
    "SmtpPassword": "YOUR_MAILTRAP_PASSWORD",
    "EnableSsl": true,
    "AppBaseUrl": "https://localhost:5001"
  },
  "AllowedHosts": "*"
}