@page "/customer-statements"
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@rendermode InteractiveServer
@layout MainLayout
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using PosPlatform.Web.Components.Layout
@using PosPlatform.Web.Models.CustomerStatements
@using PosPlatform.Web.Models.Settings
@using PosPlatform.Web.Services
@inject CustomerStatementService CustomerStatementService
@inject BusinessSettingsService BusinessSettingsService
@inject UserAccessService UserAccessService
@inject NavigationManager NavigationManager

<PageTitle>Customer Statements</PageTitle>

<section class="statement-page">
    <div class="statement-header">
        <div>
            <div class="statement-kicker">
                <i class="bi bi-journal-text"></i>
                Customer account history
            </div>
            <h1>Customer Statements</h1>
            <p>View invoices, payments, balances and sales history per customer.</p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <div class="statement-alert danger">
            <i class="bi bi-exclamation-triangle"></i>
            <span>@_message</span>
            <button type="button" @onclick="ClearMessage">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
    }

    <div class="statement-search-card">
        <div class="statement-form-grid">
            <div>
                <label>Search Customer</label>
                <input class="statement-input"
                       @bind="_customerSearch"
                       @bind:event="oninput"
                       placeholder="Search by name, phone or email" />
            </div>

            <div class="align-end">
                <button type="button" class="statement-secondary-btn full" @onclick="SearchCustomersAsync">
                    <i class="bi bi-search"></i>
                    Search
                </button>
            </div>

            <div>
                <label>From Date</label>
                <input type="date" class="statement-input" @bind="_fromDate" />
            </div>

            <div>
                <label>To Date</label>
                <input type="date" class="statement-input" @bind="_toDate" />
            </div>
        </div>

        @if (_customers.Count > 0)
        {
            <div class="statement-customer-list">
                @foreach (var customer in _customers)
                {
                    <button type="button" @onclick="() => SelectCustomerAsync(customer)">
                        <div>
                            <strong>@customer.DisplayName</strong>
                            <span>@customer.CustomerType · @(customer.Phone ?? "-") · @(customer.Email ?? "-")</span>
                        </div>
                        <i class="bi bi-chevron-right"></i>
                    </button>
                }
            </div>
        }
    </div>

    @if (_loading)
    {
        <div class="statement-empty">
            <strong>Loading statement...</strong>
            <span>Please wait.</span>
        </div>
    }
    else if (_statement == null)
    {
        <div class="statement-empty">
            <strong>No customer selected</strong>
            <span>Search and select a customer to view their statement.</span>
        </div>
    }
    else
    {
        <div class="statement-profile-card">
            <div>
                <span>Customer</span>
                <strong>@_statement.CustomerName</strong>
                <p>@(_statement.CustomerPhone ?? "-") · @(_statement.CustomerEmail ?? "-")</p>
            </div>

            <button type="button" class="statement-secondary-btn" @onclick="ReloadStatementAsync">
                <i class="bi bi-arrow-clockwise"></i>
                Refresh
            </button>
        </div>

        <div class="statement-summary-grid">
            <div>
                <span>Total Invoices</span>
                <strong>@Money(_statement.TotalInvoices)</strong>
                <p>@_statement.InvoiceCount invoice(s)</p>
            </div>

            <div>
                <span>Total Payments</span>
                <strong>@Money(_statement.TotalPayments)</strong>
                <p>@_statement.PaymentCount payment(s)</p>
            </div>

            <div>
                <span>Balance Due</span>
                <strong>@Money(_statement.BalanceDue)</strong>
                <p>Outstanding account balance</p>
            </div>

            <div>
                <span>Sales History</span>
                <strong>@Money(_statement.TotalSales)</strong>
                <p>@_statement.SalesCount sale(s)</p>
            </div>
        </div>

        <div class="statement-card">
            <div class="statement-card-header">
                <div>
                    <h2>Account Statement</h2>
                    <p>Invoices and payments for the selected period.</p>
                </div>
            </div>

            @if (_statement.Lines.Count == 0)
            {
                <div class="statement-empty small">
                    <strong>No account entries</strong>
                    <span>No invoices or payments found for this period.</span>
                </div>
            }
            else
            {
                <div class="statement-table-wrap">
                    <table class="statement-table">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Type</th>
                                <th>Reference</th>
                                <th>Description</th>
                                <th class="right">Debit</th>
                                <th class="right">Credit</th>
                                <th class="right">Balance</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var line in _statement.Lines)
                            {
                                <tr>
                                    <td>@line.Date.ToString("yyyy-MM-dd")</td>
                                    <td>
                                        <span class="statement-pill @GetLineClass(line.Type)">
                                            @line.Type
                                        </span>
                                    </td>
                                    <td>@line.Reference</td>
                                    <td>@line.Description</td>
                                    <td class="right">@Money(line.Debit)</td>
                                    <td class="right">@Money(line.Credit)</td>
                                    <td class="right statement-money">@Money(line.Balance)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <div class="statement-card">
            <div class="statement-card-header">
                <div>
                    <h2>Sales History</h2>
                    <p>Completed sales linked to this customer.</p>
                </div>
            </div>

            @if (_statement.SalesHistory.Count == 0)
            {
                <div class="statement-empty small">
                    <strong>No sales found</strong>
                    <span>No sales linked to this customer for this period.</span>
                </div>
            }
            else
            {
                <div class="statement-table-wrap">
                    <table class="statement-table">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Sale Number</th>
                                <th>Payment</th>
                                <th>Status</th>
                                <th class="right">Total</th>
                                <th class="right">Paid</th>
                                <th class="right">Change</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var sale in _statement.SalesHistory)
                            {
                                <tr>
                                    <td>@sale.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                    <td>@sale.SaleNumber</td>
                                    <td>@sale.PaymentMethod</td>
                                    <td>@sale.Status</td>
                                    <td class="right statement-money">@Money(sale.TotalAmount)</td>
                                    <td class="right">@Money(sale.AmountPaid)</td>
                                    <td class="right">@Money(sale.ChangeAmount)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    }
</section>

<style>
    .statement-page {
        animation: statementIn .22s ease both;
    }

    .statement-header {
        margin-bottom: 18px;
    }

    .statement-kicker {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: #2563eb;
        font-size: .74rem;
        font-weight: 750;
        letter-spacing: .06em;
        text-transform: uppercase;
        margin-bottom: 8px;
    }

    .statement-header h1 {
        margin: 0;
        color: #0f172a;
        font-size: 1.45rem;
        font-weight: 680;
        letter-spacing: -.03em;
    }

    .statement-header p {
        margin: 6px 0 0;
        color: #64748b;
        font-size: .88rem;
    }

    .statement-alert {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 14px;
        margin-bottom: 16px;
        border-radius: 14px;
        font-size: .84rem;
        font-weight: 600;
        border: 1px solid;
    }

        .statement-alert.danger {
            color: #991b1b;
            background: #fef2f2;
            border-color: #fecaca;
        }

        .statement-alert span {
            flex: 1;
        }

        .statement-alert button {
            border: 0;
            background: transparent;
            color: inherit;
        }

    .statement-search-card,
    .statement-profile-card,
    .statement-card {
        border-radius: 20px;
        background: #fff;
        border: 1px solid #e7edf5;
        box-shadow: 0 16px 34px rgba(15,23,42,.055);
        margin-bottom: 16px;
    }

    .statement-search-card {
        padding: 16px;
    }

    .statement-form-grid {
        display: grid;
        grid-template-columns: minmax(260px, 1fr) 130px 160px 160px;
        gap: 12px;
    }

        .statement-form-grid label {
            display: block;
            margin-bottom: 5px;
            color: #64748b;
            font-size: .72rem;
            font-weight: 700;
        }

    .statement-input {
        width: 100%;
        min-height: 40px;
        border-radius: 12px;
        border: 1px solid #e5e7eb;
        background: #fff;
        color: #0f172a;
        padding: 0 12px;
        font-size: .84rem;
        outline: none;
    }

    .align-end {
        align-self: end;
    }

    .full {
        width: 100%;
    }

    .statement-secondary-btn {
        min-height: 40px;
        border-radius: 11px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 0 14px;
        font-size: .8rem;
        font-weight: 650;
        border: 0;
        color: #2563eb;
        background: #eef5ff;
        white-space: nowrap;
    }

    .statement-customer-list {
        display: grid;
        gap: 8px;
        margin-top: 14px;
    }

        .statement-customer-list button {
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: space-between;
            text-align: left;
            gap: 12px;
            border: 1px solid #e7edf5;
            background: #f8fafc;
            border-radius: 14px;
            padding: 12px;
            color: #0f172a;
        }

        .statement-customer-list strong,
        .statement-customer-list span {
            display: block;
        }

        .statement-customer-list span {
            margin-top: 3px;
            color: #64748b;
            font-size: .76rem;
        }

    .statement-empty {
        margin-bottom: 16px;
        padding: 34px 20px;
        border-radius: 16px;
        background: #f8fafc;
        border: 1px dashed #dbe3ef;
        text-align: center;
    }

        .statement-empty.small {
            margin: 18px;
        }

        .statement-empty strong,
        .statement-empty span {
            display: block;
        }

        .statement-empty strong {
            color: #0f172a;
            font-size: .9rem;
        }

        .statement-empty span {
            margin-top: 4px;
            color: #64748b;
            font-size: .78rem;
        }

    .statement-profile-card {
        display: flex;
        justify-content: space-between;
        gap: 14px;
        align-items: center;
        padding: 16px;
    }

        .statement-profile-card span {
            color: #64748b;
            font-size: .72rem;
            font-weight: 700;
            text-transform: uppercase;
        }

        .statement-profile-card strong {
            display: block;
            margin-top: 4px;
            color: #0f172a;
            font-size: 1rem;
            font-weight: 740;
        }

        .statement-profile-card p {
            margin: 4px 0 0;
            color: #64748b;
            font-size: .82rem;
        }

    .statement-summary-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 10px;
        margin-bottom: 16px;
    }

        .statement-summary-grid div {
            padding: 14px;
            border-radius: 18px;
            background: #fff;
            border: 1px solid #e7edf5;
            box-shadow: 0 12px 28px rgba(15,23,42,.04);
        }

        .statement-summary-grid span {
            display: block;
            color: #64748b;
            font-size: .72rem;
            font-weight: 650;
        }

        .statement-summary-grid strong {
            display: block;
            margin-top: 5px;
            color: #0f172a;
            font-size: 1rem;
            font-weight: 760;
        }

        .statement-summary-grid p {
            margin: 4px 0 0;
            color: #94a3b8;
            font-size: .74rem;
        }

    .statement-card {
        overflow: hidden;
    }

    .statement-card-header {
        padding: 17px 18px;
        border-bottom: 1px solid #edf2f7;
    }

        .statement-card-header h2 {
            margin: 0;
            color: #0f172a;
            font-size: .92rem;
            font-weight: 720;
        }

        .statement-card-header p {
            margin: 4px 0 0;
            color: #94a3b8;
            font-size: .76rem;
        }

    .statement-table-wrap {
        overflow-x: auto;
    }

    .statement-table {
        width: 100%;
        min-width: 920px;
        border-collapse: collapse;
    }

        .statement-table th {
            padding: 12px 16px;
            background: #f8fafc;
            color: #64748b;
            font-size: .7rem;
            font-weight: 750;
            text-transform: uppercase;
            border-bottom: 1px solid #e7edf5;
            white-space: nowrap;
        }

        .statement-table td {
            padding: 14px 16px;
            color: #334155;
            font-size: .82rem;
            border-bottom: 1px solid #f1f5f9;
            vertical-align: middle;
        }

    .right {
        text-align: right;
    }

    .statement-money {
        color: #0f172a;
        font-weight: 750;
    }

    .statement-pill {
        display: inline-flex;
        min-height: 27px;
        align-items: center;
        padding: 0 9px;
        border-radius: 999px;
        font-size: .72rem;
        font-weight: 750;
    }

        .statement-pill.invoice {
            color: #2563eb;
            background: #eff6ff;
        }

        .statement-pill.payment {
            color: #15803d;
            background: #ecfdf5;
        }

    @@keyframes statementIn {
        from {
            opacity: 0;
            transform: translateY(8px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@media (max-width: 1199px) {
        .statement-form-grid,
        .statement-summary-grid {
            grid-template-columns: 1fr;
        }

        .statement-profile-card {
            flex-direction: column;
            align-items: flex-start;
        }

        .statement-secondary-btn {
            width: 100%;
        }
    }
</style>

@code {
    private BusinessSettingsFormModel _settings = new();

    private string? _customerSearch;
    private List<CustomerStatementCustomerOptionViewModel> _customers = new();

    private int? _selectedCustomerId;
    private CustomerStatementViewModel? _statement;

    private DateTime? _fromDate = DateTime.Today.AddDays(-30);
    private DateTime? _toDate = DateTime.Today;

    private bool _loading;
    private string? _message;

    private string CurrencyLabel =>
        string.IsNullOrWhiteSpace(_settings.CurrencySymbol)
            ? "R"
            : _settings.CurrencySymbol;

    protected override async Task OnInitializedAsync()
    {
        if (!await UserAccessService.CanAccessAsync("customer-statements"))
        {
            NavigationManager.NavigateTo("/dashboard");
            return;
        }

        _settings = await BusinessSettingsService.GetSettingsAsync();
    }

    private async Task SearchCustomersAsync()
    {
        _message = null;
        _customers = await CustomerStatementService.SearchCustomersAsync(_customerSearch);

        if (_customers.Count == 0)
        {
            _message = "No customers found. Try another name, phone number or email.";
        }
    }

    private async Task SelectCustomerAsync(CustomerStatementCustomerOptionViewModel customer)
    {
        _selectedCustomerId = customer.Id;
        _customerSearch = customer.DisplayName;
        _customers.Clear();

        await ReloadStatementAsync();
    }

    private async Task ReloadStatementAsync()
    {
        if (!_selectedCustomerId.HasValue)
        {
            _message = "Select a customer first.";
            return;
        }

        _loading = true;
        _message = null;

        _statement = await CustomerStatementService.GetStatementAsync(
            _selectedCustomerId.Value,
            _fromDate,
            _toDate);

        _loading = false;

        if (_statement == null)
        {
            _message = "Customer statement could not be loaded.";
        }
    }

    private string Money(decimal value)
    {
        return $"{CurrencyLabel} {value:0.00}";
    }

    private string GetLineClass(string type)
    {
        return type switch
        {
            "Invoice" => "invoice",
            "Payment" => "payment",
            _ => "invoice"
        };
    }

    private void ClearMessage()
    {
        _message = null;
    }
}