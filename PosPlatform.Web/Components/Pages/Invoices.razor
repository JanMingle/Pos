@page "/invoices"
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@rendermode InteractiveServer
@layout MainLayout
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Web
@using PosPlatform.Web.Components.Layout
@using PosPlatform.Web.Models.Invoices
@using PosPlatform.Web.Models.Settings
@using PosPlatform.Web.Services
@inject InvoiceService InvoiceService
@inject BusinessSettingsService BusinessSettingsService
@inject UserAccessService UserAccessService
@inject NavigationManager NavigationManager
@inject DocumentEmailService DocumentEmailService

<PageTitle>Invoices</PageTitle>

<section class="invoices-page">
    <div class="invoices-top">
        <div>
            <div class="invoices-kicker">
                <i class="bi bi-receipt"></i>
                Customer billing
            </div>

            <h1>Invoices</h1>
            <p>View invoices, send customer documents, print invoices and record customer payments.</p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <div class="invoices-alert @(_isSuccess ? "success" : "danger")">
            <i class="bi @(_isSuccess ? "bi-check-circle" : "bi-exclamation-triangle")"></i>
            <span>@_message</span>
            <button type="button" @onclick="ClearMessage">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
    }

    <div class="invoices-summary-grid">
        <div class="invoices-summary-card hero">
            <div class="invoices-summary-icon">
                <i class="bi bi-cash-stack"></i>
            </div>
            <span>Total Value</span>
            <strong>@Money(_invoices.Sum(x => x.TotalAmount))</strong>
            <small>For the selected period</small>
        </div>

        <div class="invoices-summary-card">
            <div class="invoices-summary-icon green">
                <i class="bi bi-check2-circle"></i>
            </div>
            <span>Paid</span>
            <strong>@PaidInvoices</strong>
            <small>Fully settled invoices</small>
        </div>

        <div class="invoices-summary-card">
            <div class="invoices-summary-icon amber">
                <i class="bi bi-hourglass-split"></i>
            </div>
            <span>Partially Paid</span>
            <strong>@PartiallyPaidInvoices</strong>
            <small>Invoices with part payments</small>
        </div>

        <div class="invoices-summary-card">
            <div class="invoices-summary-icon red">
                <i class="bi bi-exclamation-circle"></i>
            </div>
            <span>Balance Due</span>
            <strong>@Money(_invoices.Sum(x => x.BalanceDue))</strong>
            <small>Outstanding amount</small>
        </div>
    </div>

    <div class="invoices-settings-strip">
        <div>
            <span>Business</span>
            <strong>@_settings.BusinessName</strong>
        </div>

        <div>
            <span>Invoices Showing</span>
            <strong>@TotalInvoices</strong>
        </div>

        <div>
            <span>Currency</span>
            <strong>@CurrencyLabel</strong>
        </div>

        <div>
            <span>Overdue</span>
            <strong>@OverdueInvoices</strong>
        </div>
    </div>

    <div class="invoices-control-panel">
        <input type="date" @bind="_fromDate" />
        <input type="date" @bind="_toDate" />

        <select value="@_statusFilter" @onchange="StatusFilterChanged">
            <option value="all">All statuses</option>
            <option value="Unpaid">Unpaid</option>
            <option value="Partially Paid">Partially Paid</option>
            <option value="Paid">Paid</option>
            <option value="Cancelled">Cancelled</option>
        </select>

        <div class="invoices-search">
            <i class="bi bi-search"></i>
            <input @bind="_searchTerm"
                   @bind:event="oninput"
                   @onkeydown="HandleSearchKeyDown"
                   placeholder="Search invoice, quote or customer" />
        </div>

        <button type="button" class="invoices-secondary-btn" @onclick="ApplyFiltersAsync">
            <i class="bi bi-filter"></i>
            Filter
        </button>

        <button type="button" class="invoices-ghost-btn" @onclick="ResetFiltersAsync">
            <i class="bi bi-arrow-counterclockwise"></i>
            Reset
        </button>
    </div>

    <div class="invoices-table-card">
        <div class="invoices-table-header">
            <div>
                <h2>Invoice List</h2>
                <p>Showing @InvoicePageStart - @InvoicePageEnd of @TotalInvoices invoice@(InvoicePlural).</p>
            </div>
        </div>

        @if (_loading)
        {
            <div class="invoices-empty">
                <div class="invoices-empty-icon">
                    <i class="bi bi-hourglass-split"></i>
                </div>
                <strong>Loading invoices...</strong>
                <span>Please wait while we load matching invoices.</span>
            </div>
        }
        else if (_invoices.Count == 0)
        {
            <div class="invoices-empty">
                <div class="invoices-empty-icon">
                    <i class="bi bi-receipt"></i>
                </div>
                <strong>No invoices found</strong>
                <span>Accepted quotes can be converted into invoices.</span>
            </div>
        }
        else
        {
            <div class="invoices-table-wrap">
                <table class="invoices-table">
                    <thead>
                        <tr>
                            <th>Invoice</th>
                            <th>Quote</th>
                            <th>Customer</th>
                            <th>Date</th>
                            <th>Due</th>
                            <th>Items</th>
                            <th>Total</th>
                            <th>Paid</th>
                            <th>Balance</th>
                            <th>Status</th>
                            <th class="invoices-actions-col">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var invoice in PaginatedInvoices)
                        {
                            <tr>
                                <td>
                                    <strong>@invoice.InvoiceNumber</strong>
                                </td>
                                <td>@(invoice.QuoteNumber ?? "-")</td>
                                <td>@invoice.CustomerName</td>
                                <td>@invoice.InvoiceDate.ToString("yyyy-MM-dd")</td>
                                <td>@(invoice.DueDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                                <td>@invoice.ItemCount</td>
                                <td class="invoices-money">@Money(invoice.TotalAmount)</td>
                                <td>@Money(invoice.AmountPaid)</td>
                                <td class="invoices-money">@Money(invoice.BalanceDue)</td>
                                <td>
                                    <span class="invoices-pill @GetStatusClass(invoice.Status)">
                                        @invoice.Status
                                    </span>
                                </td>
                                <td class="invoices-actions-cell">
                                    <div class="invoices-action-menu">
                                        <button type="button"
                                                class="invoices-action-toggle"
                                                @onclick="() => ToggleActionMenu(invoice.Id)">
                                            <span>Actions</span>
                                            <i class="bi bi-chevron-down"></i>
                                        </button>

                                        @if (_openActionInvoiceId == invoice.Id)
                                        {
                                            <div class="invoices-action-dropdown">
                                                <button type="button" @onclick="() => ViewInvoiceAsync(invoice.Id)">
                                                    <i class="bi bi-eye"></i>
                                                    <span>View invoice</span>
                                                </button>

                                                <button type="button" @onclick="() => PrintInvoice(invoice.Id)">
                                                    <i class="bi bi-printer"></i>
                                                    <span>Print invoice</span>
                                                </button>

                                                <button type="button" @onclick="() => SendInvoiceEmailAsync(invoice.Id)">
                                                    <i class="bi bi-envelope"></i>
                                                    <span>Email invoice</span>
                                                </button>
                                            </div>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="invoices-pagination">
                <div class="invoices-page-info">
                    Showing
                    <strong>@InvoicePageStart</strong>
                    -
                    <strong>@InvoicePageEnd</strong>
                    of
                    <strong>@TotalInvoices</strong>
                </div>

                <div class="invoices-page-controls">
                    <button type="button"
                            class="@PreviousInvoicePageClass"
                            @onclick="PreviousInvoicePage">
                        <i class="bi bi-chevron-left"></i>
                        Previous
                    </button>

                    <span class="invoices-page-count">
                        Page @_invoicePage of @InvoiceTotalPages
                    </span>

                    <button type="button"
                            class="@NextInvoicePageClass"
                            @onclick="NextInvoicePage">
                        Next
                        <i class="bi bi-chevron-right"></i>
                    </button>
                </div>
            </div>
        }
    </div>
</section>

@if (_selectedInvoice != null)
{
    <div class="invoices-modal-backdrop">
        <div class="invoices-modal">
            <div class="invoices-modal-header">
                <div>
                    <span>@_selectedInvoice.Status</span>
                    <h4>@_selectedInvoice.InvoiceNumber</h4>
                    <p>@(_selectedInvoice.CustomerName ?? "Walk-in / Unsaved") · @Money(_selectedInvoice.TotalAmount)</p>
                </div>

                <button type="button" class="invoices-close-btn" @onclick="CloseDetails">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <div class="invoices-detail-grid">
                <div>
                    <span>Invoice Date</span>
                    <strong>@_selectedInvoice.InvoiceDate.ToString("yyyy-MM-dd")</strong>
                </div>

                <div>
                    <span>Due Date</span>
                    <strong>@(_selectedInvoice.DueDate?.ToString("yyyy-MM-dd") ?? "-")</strong>
                </div>

                <div>
                    <span>Quote</span>
                    <strong>@(_selectedInvoice.QuoteNumber ?? "-")</strong>
                </div>

                <div>
                    <span>Customer Phone</span>
                    <strong>@(_selectedInvoice.CustomerPhone ?? "-")</strong>
                </div>

                <div>
                    <span>Amount Paid</span>
                    <strong>@Money(_selectedInvoice.AmountPaid)</strong>
                </div>

                <div>
                    <span>Balance Due</span>
                    <strong>@Money(_selectedInvoice.BalanceDue)</strong>
                </div>
            </div>

            <div class="invoices-detail-actions top-actions">
                <button type="button" class="invoices-secondary-btn full" @onclick="() => PrintInvoice(_selectedInvoice.Id)">
                    <i class="bi bi-printer"></i>
                    Print Invoice
                </button>

                <button type="button" class="invoices-secondary-btn full" @onclick="() => SendInvoiceEmailAsync(_selectedInvoice.Id)">
                    <i class="bi bi-envelope"></i>
                    Email Invoice
                </button>
            </div>

            <div class="invoices-table-wrap compact-wrap">
                <table class="invoices-table compact">
                    <thead>
                        <tr>
                            <th>Item</th>
                            <th>SKU</th>
                            <th>Qty</th>
                            <th>Unit</th>
                            <th>Total</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in _selectedInvoice.Items)
                        {
                            <tr>
                                <td>@item.ProductName</td>
                                <td>@item.SKU</td>
                                <td>@item.Quantity</td>
                                <td>@Money(item.UnitPrice)</td>
                                <td>@Money(item.LineTotal)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="invoices-summary">
                <div>
                    <span>Subtotal</span>
                    <strong>@Money(_selectedInvoice.Subtotal)</strong>
                </div>

                <div>
                    <span>Discount</span>
                    <strong>@Money(_selectedInvoice.DiscountAmount)</strong>
                </div>

                <div>
                    <span>Tax</span>
                    <strong>@Money(_selectedInvoice.TaxAmount)</strong>
                </div>

                <div>
                    <span>Total</span>
                    <strong>@Money(_selectedInvoice.TotalAmount)</strong>
                </div>

                <div>
                    <span>Amount Paid</span>
                    <strong>@Money(_selectedInvoice.AmountPaid)</strong>
                </div>

                <div class="final">
                    <span>Balance Due</span>
                    <strong>@Money(_selectedInvoice.BalanceDue)</strong>
                </div>
            </div>

            @if (_selectedInvoice.Status != "Paid" && _selectedInvoice.Status != "Cancelled" && _selectedInvoice.BalanceDue > 0)
            {
                <button type="button" class="invoices-primary-btn full" @onclick="OpenPaymentModal">
                    <i class="bi bi-cash-coin"></i>
                    Record Payment
                </button>
            }

            <div class="invoices-payment-history">
                <h5>Payment History</h5>

                @if (_selectedInvoice.Payments.Count == 0)
                {
                    <div class="invoices-empty small">
                        <strong>No payments yet</strong>
                        <span>Payments recorded for this invoice will appear here.</span>
                    </div>
                }
                else
                {
                    <div class="invoices-table-wrap compact-wrap">
                        <table class="invoices-table compact">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Method</th>
                                    <th>Reference</th>
                                    <th>Received By</th>
                                    <th>Amount</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var payment in _selectedInvoice.Payments)
                                {
                                    <tr>
                                        <td>@payment.PaymentDate.ToString("yyyy-MM-dd")</td>
                                        <td>@payment.PaymentMethod</td>
                                        <td>@(payment.ReferenceNumber ?? "-")</td>
                                        <td>@payment.ReceivedByName</td>
                                        <td class="invoices-money">@Money(payment.Amount)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
}

@if (_showPaymentModal && _selectedInvoice != null)
{
    <div class="invoices-modal-backdrop">
        <div class="invoices-modal small">
            <div class="invoices-modal-header">
                <div>
                    <span>Invoice Payment</span>
                    <h4>@_selectedInvoice.InvoiceNumber</h4>
                    <p>Balance due: @Money(_selectedInvoice.BalanceDue)</p>
                </div>

                <button type="button" class="invoices-close-btn" @onclick="ClosePaymentModal">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <div class="invoices-form-grid">
                <div>
                    <label>Payment Date</label>
                    <input type="date" @bind="_paymentModel.PaymentDate" />
                </div>

                <div>
                    <label>Amount</label>
                    <input type="number" min="0.01" step="0.01" @bind="_paymentModel.Amount" />
                </div>

                <div>
                    <label>Payment Method</label>
                    <select @bind="_paymentModel.PaymentMethod">
                        <option value="Cash">Cash</option>
                        <option value="Card">Card</option>
                        <option value="EFT">EFT</option>
                        <option value="Bank Transfer">Bank Transfer</option>
                        <option value="Other">Other</option>
                    </select>
                </div>

                <div>
                    <label>Reference Number</label>
                    <input @bind="_paymentModel.ReferenceNumber" placeholder="Optional" />
                </div>

                <div class="span-2">
                    <label>Notes</label>
                    <textarea @bind="_paymentModel.Notes" placeholder="Optional payment notes"></textarea>
                </div>
            </div>

            <button type="button" class="invoices-primary-btn full mt @(_savingPayment ? "is-disabled" : "")" @onclick="SavePaymentAsync">
                <i class="bi bi-check-circle"></i>
                @(_savingPayment ? "Saving..." : "Save Payment")
            </button>
        </div>
    </div>
}

<style>
    .invoices-page {
        animation: invoicesIn .22s ease both;
    }

    .invoices-top {
        margin-bottom: 16px;
    }

    .invoices-kicker {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: #8FA6A1;
        font-size: .72rem;
        font-weight: 760;
        letter-spacing: .08em;
        text-transform: uppercase;
        margin-bottom: 8px;
    }

    .invoices-top h1 {
        margin: 0;
        color: #111827;
        font-size: 1.45rem;
        font-weight: 720;
        letter-spacing: -.035em;
    }

    .invoices-top p {
        margin: 6px 0 0;
        color: #667085;
        font-size: .88rem;
    }

    .invoices-primary-btn,
    .invoices-secondary-btn,
    .invoices-ghost-btn,
    .invoices-page-btn {
        min-height: 38px;
        border-radius: 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 0 14px;
        font-size: .8rem;
        font-weight: 680;
        border: 0;
        white-space: nowrap;
        transition: transform .18s ease;
    }

    .invoices-primary-btn {
        color: #fff;
        background: #252525;
        box-shadow: 0 12px 24px rgba(17,24,39,.12);
    }

    .invoices-secondary-btn {
        color: #8FA6A1;
        background: #f2f6f5;
        border: 1px solid #dce7e4;
    }

    .invoices-ghost-btn,
    .invoices-page-btn {
        color: #475569;
        background: #fff;
        border: 1px solid #e5e7eb;
    }

        .invoices-primary-btn:hover,
        .invoices-secondary-btn:hover,
        .invoices-ghost-btn:hover,
        .invoices-page-btn:hover {
            transform: translateY(-1px);
        }

        .invoices-primary-btn.is-disabled,
        .invoices-page-btn.is-disabled {
            opacity: .45;
            cursor: not-allowed;
            transform: none;
        }

    .invoices-alert {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 14px;
        margin-bottom: 16px;
        border-radius: 14px;
        font-size: .84rem;
        font-weight: 600;
        border: 1px solid;
    }

        .invoices-alert.success {
            color: #166534;
            background: #f0fdf4;
            border-color: #bbf7d0;
        }

        .invoices-alert.danger {
            color: #991b1b;
            background: #fef2f2;
            border-color: #fecaca;
        }

        .invoices-alert span {
            flex: 1;
        }

        .invoices-alert button {
            border: 0;
            background: transparent;
            color: inherit;
        }

    .invoices-summary-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 12px;
        margin-bottom: 16px;
    }

    .invoices-summary-card {
        padding: 15px;
        border-radius: 20px;
        background: #ffffff;
        border: 1px solid #e8eaef;
        box-shadow: 0 14px 32px rgba(17, 24, 39, .045);
    }

        .invoices-summary-card.hero {
            background: #252525;
            border-color: #252525;
        }

        .invoices-summary-card span,
        .invoices-summary-card strong,
        .invoices-summary-card small {
            display: block;
        }

        .invoices-summary-card span {
            margin-top: 11px;
            color: #667085;
            font-size: .72rem;
            font-weight: 700;
        }

        .invoices-summary-card strong {
            margin-top: 6px;
            color: #111827;
            font-size: 1.05rem;
            font-weight: 760;
            letter-spacing: -.02em;
        }

        .invoices-summary-card small {
            margin-top: 4px;
            color: #98a2b3;
            font-size: .72rem;
            line-height: 1.35;
        }

        .invoices-summary-card.hero span,
        .invoices-summary-card.hero strong,
        .invoices-summary-card.hero small {
            color: #ffffff;
        }

    .invoices-summary-icon {
        width: 36px;
        height: 36px;
        border-radius: 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #ffffff;
        color: #252525;
        box-shadow: 0 10px 22px rgba(17, 24, 39, .08);
    }

        .invoices-summary-icon.green {
            color: #8FA6A1;
            background: #f2f6f5;
        }

        .invoices-summary-icon.amber {
            color: #b7791f;
            background: #fffbeb;
        }

        .invoices-summary-icon.red {
            color: #d92d20;
            background: #fef3f2;
        }

    .invoices-settings-strip {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 10px;
        margin-bottom: 16px;
    }

        .invoices-settings-strip div {
            padding: 13px;
            border-radius: 16px;
            background: #fff;
            border: 1px solid #e8eaef;
            box-shadow: 0 10px 24px rgba(17,24,39,.035);
        }

        .invoices-settings-strip span,
        .invoices-settings-strip strong {
            display: block;
        }

        .invoices-settings-strip span {
            color: #98a2b3;
            font-size: .7rem;
            font-weight: 700;
            letter-spacing: .03em;
            text-transform: uppercase;
        }

        .invoices-settings-strip strong {
            margin-top: 4px;
            color: #111827;
            font-size: .84rem;
            font-weight: 720;
        }

    .invoices-control-panel {
        display: grid;
        grid-template-columns: 150px 150px 170px minmax(240px, 1fr) auto auto;
        gap: 10px;
        padding: 14px;
        margin-bottom: 16px;
        border-radius: 18px;
        background: #fff;
        border: 1px solid #e8eaef;
        box-shadow: 0 10px 24px rgba(17,24,39,.035);
    }

        .invoices-control-panel input,
        .invoices-control-panel select {
            width: 100%;
            min-height: 40px;
            border-radius: 12px;
            border: 1px solid #e5e7eb;
            background: #fff;
            color: #111827;
            padding: 0 12px;
            font-size: 16px;
            outline: none;
        }

    .invoices-search {
        min-height: 42px;
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 0 13px;
        border-radius: 14px;
        background: #fafafa;
        border: 1px solid #e5e7eb;
        color: #98a2b3;
    }

        .invoices-search input {
            width: 100%;
            border: 0;
            outline: none;
            background: transparent;
            color: #111827;
            font-size: 16px;
        }

    .invoices-table-card {
        overflow: visible;
        border-radius: 22px;
        background: #fff;
        border: 1px solid #e8eaef;
        box-shadow: 0 14px 32px rgba(17,24,39,.045);
    }

    .invoices-table-header {
        padding: 16px 18px;
        border-bottom: 1px solid #f1f2f5;
    }

        .invoices-table-header h2 {
            margin: 0;
            color: #111827;
            font-size: .94rem;
            font-weight: 720;
        }

        .invoices-table-header p {
            margin: 4px 0 0;
            color: #98a2b3;
            font-size: .75rem;
        }

    .invoices-table-wrap {
        overflow-x: auto;
        padding-bottom: 100px;
    }

        .invoices-table-wrap.compact-wrap {
            padding-bottom: 0;
        }

    .invoices-table {
        width: 100%;
        min-width: 1080px;
        border-collapse: collapse;
    }

        .invoices-table.compact {
            min-width: 650px;
        }

        .invoices-table th {
            padding: 12px 16px;
            background: #fafafa;
            color: #667085;
            font-size: .7rem;
            font-weight: 750;
            text-transform: uppercase;
            border-bottom: 1px solid #e8eaef;
            white-space: nowrap;
        }

        .invoices-table td {
            padding: 14px 16px;
            color: #334155;
            font-size: .82rem;
            border-bottom: 1px solid #f1f2f5;
            vertical-align: middle;
        }

    .invoices-money {
        color: #111827;
        font-weight: 750;
    }

    .invoices-pill {
        display: inline-flex;
