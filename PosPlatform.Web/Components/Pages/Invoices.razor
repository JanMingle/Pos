@code {
    private BusinessSettingsFormModel _settings = new();
    private List<InvoiceListItemViewModel> _invoices = new();

    private bool _loading = true;

    private DateTime? _fromDate = DateTime.Today.AddDays(-30);
    private DateTime? _toDate = DateTime.Today;
    private string _statusFilter = "all";
    private string? _searchTerm;

    private string? _message;
    private bool _isSuccess;

    private InvoiceDetailsViewModel? _selectedInvoice;

    private bool _showPaymentModal;
    private bool _savingPayment;
    private RecordInvoicePaymentModel _paymentModel = new();

    private int _invoicePage = 1;
    private int _invoicePageSize = 10;
    private int? _openActionInvoiceId;

    private string CurrencyLabel =>
        string.IsNullOrWhiteSpace(_settings.CurrencySymbol)
            ? "R"
            : _settings.CurrencySymbol;

    private List<InvoiceListItemViewModel> OrderedInvoices =>
        _invoices
            .OrderByDescending(x => x.InvoiceDate)
            .ToList();

    private int TotalInvoices => OrderedInvoices.Count;

    private string InvoicePlural => TotalInvoices == 1 ? "" : "s";

    private int PaidInvoices => _invoices.Count(x => x.Status == "Paid");

    private int PartiallyPaidInvoices => _invoices.Count(x => x.Status == "Partially Paid");

    private int OverdueInvoices =>
        _invoices.Count(x =>
            x.DueDate.HasValue &&
            x.DueDate.Value.Date < DateTime.Today &&
            x.BalanceDue > 0 &&
            x.Status != "Paid" &&
            x.Status != "Cancelled");

    private int InvoiceTotalPages =>
        TotalInvoices == 0
            ? 1
            : (int)Math.Ceiling(TotalInvoices / (double)_invoicePageSize);

    private int SafeInvoicePage =>
        Math.Min(Math.Max(_invoicePage, 1), InvoiceTotalPages);

    private int InvoicePageStart =>
        TotalInvoices == 0
            ? 0
            : ((SafeInvoicePage - 1) * _invoicePageSize) + 1;

    private int InvoicePageEnd =>
        TotalInvoices == 0
            ? 0
            : Math.Min(SafeInvoicePage * _invoicePageSize, TotalInvoices);

    private List<InvoiceListItemViewModel> PaginatedInvoices =>
        OrderedInvoices
            .Skip((SafeInvoicePage - 1) * _invoicePageSize)
            .Take(_invoicePageSize)
            .ToList();

    private string PreviousInvoicePageClass =>
        _invoicePage <= 1 ? "invoices-page-btn is-disabled" : "invoices-page-btn";

    private string NextInvoicePageClass =>
        _invoicePage >= InvoiceTotalPages ? "invoices-page-btn is-disabled" : "invoices-page-btn";

    protected override async Task OnInitializedAsync()
    {
        if (!await UserAccessService.CanAccessAsync("invoices"))
        {
            NavigationManager.NavigateTo("/dashboard");
            return;
        }

        _settings = await BusinessSettingsService.GetSettingsAsync();
        await LoadInvoicesAsync();
    }

    private async Task LoadInvoicesAsync()
    {
        _loading = true;
        _openActionInvoiceId = null;

        _invoices = await InvoiceService.GetInvoicesAsync(
            _fromDate,
            _toDate,
            _statusFilter,
            _searchTerm);

        if (_invoicePage > InvoiceTotalPages)
        {
            _invoicePage = InvoiceTotalPages;
        }

        _loading = false;
    }

    private async Task ApplyFiltersAsync()
    {
        _invoicePage = 1;
        await LoadInvoicesAsync();
    }

    private async Task HandleSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await ApplyFiltersAsync();
        }
    }

    private void StatusFilterChanged(ChangeEventArgs e)
    {
        _statusFilter = e.Value?.ToString() ?? "all";
        _invoicePage = 1;
    }

    private async Task ResetFiltersAsync()
    {
        _fromDate = DateTime.Today.AddDays(-30);
        _toDate = DateTime.Today;
        _statusFilter = "all";
        _searchTerm = null;
        _invoicePage = 1;

        await LoadInvoicesAsync();
    }

    private void NextInvoicePage()
    {
        if (_invoicePage < InvoiceTotalPages)
        {
            _invoicePage++;
            _openActionInvoiceId = null;
        }
    }

    private void PreviousInvoicePage()
    {
        if (_invoicePage > 1)
        {
            _invoicePage--;
            _openActionInvoiceId = null;
        }
    }

    private void ToggleActionMenu(int invoiceId)
    {
        _openActionInvoiceId = _openActionInvoiceId == invoiceId ? null : invoiceId;
    }

    private async Task ViewInvoiceAsync(int invoiceId)
    {
        _openActionInvoiceId = null;
        _selectedInvoice = await InvoiceService.GetInvoiceDetailsAsync(invoiceId);
    }

    private void CloseDetails()
    {
        _selectedInvoice = null;
        _showPaymentModal = false;
    }

    private void OpenPaymentModal()
    {
        if (_selectedInvoice == null)
        {
            return;
        }

        _paymentModel = new RecordInvoicePaymentModel
        {
            InvoiceId = _selectedInvoice.Id,
            Amount = _selectedInvoice.BalanceDue,
            PaymentMethod = "Cash",
            PaymentDate = DateTime.Today
        };

        _showPaymentModal = true;
    }

    private void ClosePaymentModal()
    {
        _showPaymentModal = false;
    }

    private async Task SavePaymentAsync()
    {
        if (_savingPayment)
        {
            return;
        }

        if (_paymentModel.Amount <= 0)
        {
            ShowMessage("Payment amount must be greater than zero.", false);
            return;
        }

        if (_selectedInvoice != null && _paymentModel.Amount > _selectedInvoice.BalanceDue)
        {
            ShowMessage("Payment cannot be greater than the invoice balance.", false);
            return;
        }

        _savingPayment = true;

        var result = await InvoiceService.RecordPaymentAsync(_paymentModel);

        _savingPayment = false;

        ShowMessage(result.Message, result.Success);

        if (result.Success)
        {
            _showPaymentModal = false;

            if (_selectedInvoice != null)
            {
                _selectedInvoice = await InvoiceService.GetInvoiceDetailsAsync(_selectedInvoice.Id);
            }

            await LoadInvoicesAsync();
        }
    }

    private string Money(decimal value)
    {
        return $"{CurrencyLabel} {value:0.00}";
    }

    private void ShowMessage(string message, bool success)
    {
        _message = message;
        _isSuccess = success;
    }

    private void ClearMessage()
    {
        _message = null;
    }

    private string GetStatusClass(string status)
    {
        return status switch
        {
            "Unpaid" => "unpaid",
            "Partially Paid" => "partial",
            "Paid" => "paid",
            "Cancelled" => "cancelled",
            _ => "unpaid"
        };
    }

    private void PrintInvoice(int invoiceId)
    {
        _openActionInvoiceId = null;
        NavigationManager.NavigateTo($"/invoices/print/{invoiceId}");
    }

    private async Task SendInvoiceEmailAsync(int invoiceId)
    {
        _openActionInvoiceId = null;

        var result = await DocumentEmailService.SendInvoiceEmailAsync(invoiceId);
        ShowMessage(result.Message, result.Success);

        if (result.Success)
        {
            await LoadInvoicesAsync();

            if (_selectedInvoice?.Id == invoiceId)
            {
                _selectedInvoice = await InvoiceService.GetInvoiceDetailsAsync(invoiceId);
            }
        }
    }
}