@code {
    private BusinessSettingsFormModel _settings = new();
    private List<BranchListItemViewModel> _branches = new();

    private BranchFormModel _form = new();

    private bool _loading = true;
    private bool _saving;
    private bool _showModal;
    private bool _showDeleteConfirm;

    private string? _searchTerm;
    private string _statusFilter = "all";

    private int _deleteId;
    private string _deleteBranchName = string.Empty;

    private string? _message;
    private bool _isSuccess;

    protected override async Task OnInitializedAsync()
    {
        if (!await UserAccessService.CanAccessAsync("branches"))
        {
            NavigationManager.NavigateTo("/dashboard");
            return;
        }

        _settings = await BusinessSettingsService.GetSettingsAsync();

        await BranchService.EnsureMainBranchExistsAsync();
        await LoadBranchesAsync();
    }

    private async Task LoadBranchesAsync()
    {
        _loading = true;
        _branches = await BranchService.GetBranchesAsync(_searchTerm, _statusFilter);
        _loading = false;
    }

    private async Task ResetFiltersAsync()
    {
        _searchTerm = null;
        _statusFilter = "all";
        await LoadBranchesAsync();
    }

    private void OpenAddModal()
    {
        _form = new BranchFormModel
        {
            IsActive = true
        };

        if (!_branches.Any())
        {
            _form.IsMainBranch = true;
        }

        _showModal = true;
    }

    private async Task OpenEditModal(int id)
    {
        var model = await BranchService.GetByIdAsync(id);

        if (model == null)
        {
            ShowMessage("Branch not found.", false);
            return;
        }

        _form = model;
        _showModal = true;
    }

    private void CloseModal()
    {
        _showModal = false;
        _form = new BranchFormModel();
    }

    private async Task SaveBranchAsync()
    {
        _saving = true;

        var result = await BranchService.SaveAsync(_form);

        _saving = false;
        ShowMessage(result.Message, result.Success);

        if (result.Success)
        {
            _showModal = false;
            _form = new BranchFormModel();
            await LoadBranchesAsync();
        }
    }

    private async Task ToggleStatusAsync(int id)
    {
        var result = await BranchService.ToggleStatusAsync(id);
        ShowMessage(result.Message, result.Success);

        if (result.Success)
        {
            await LoadBranchesAsync();
        }
    }

    private void ConfirmDelete(int id, string name)
    {
        _deleteId = id;
        _deleteBranchName = name;
        _showDeleteConfirm = true;
    }

    private void CancelDelete()
    {
        _deleteId = 0;
        _deleteBranchName = string.Empty;
        _showDeleteConfirm = false;
    }

    private async Task DeleteConfirmedAsync()
    {
        var result = await BranchService.DeleteAsync(_deleteId);

        ShowMessage(result.Message, result.Success);

        _deleteId = 0;
        _deleteBranchName = string.Empty;
        _showDeleteConfirm = false;

        if (result.Success)
        {
            await LoadBranchesAsync();
        }
    }

    private string Money(decimal value)
    {
        var symbol = string.IsNullOrWhiteSpace(_settings.CurrencySymbol)
            ? "R"
            : _settings.CurrencySymbol;

        return $"{symbol} {value:0.00}";
    }

    private string GetInitials(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "B";
        }

        var words = value
            .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Take(2)
            .Select(x => x[0].ToString().ToUpper());

        return string.Join("", words);
    }

    private void ShowMessage(string message, bool success)
    {
        _message = message;
        _isSuccess = success;
    }

    private void ClearMessage()
    {
        _message = null;
    }
}