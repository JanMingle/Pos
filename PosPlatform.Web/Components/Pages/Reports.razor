@code {
    private BusinessSettingsFormModel _settings = new();
    private ReportsDashboardViewModel _dashboard = new();

    private bool _loading = true;

    private DateTime? _fromDate = DateTime.Today;
    private DateTime? _toDate = DateTime.Today;

    protected override async Task OnInitializedAsync()
    {
        if (!await UserAccessService.CanAccessAsync("reports"))
        {
            NavigationManager.NavigateTo("/dashboard");
            return;
        }

        _settings = await BusinessSettingsService.GetSettingsAsync();
        await LoadReportsAsync();
    }

    private async Task LoadReportsAsync()
    {
        _loading = true;
        _dashboard = await ReportsService.GetDashboardAsync(_fromDate, _toDate);
        _loading = false;
    }

    private string Money(decimal value)
    {
        var symbol = string.IsNullOrWhiteSpace(_settings.CurrencySymbol)
            ? "R"
            : _settings.CurrencySymbol;

        return $"{symbol} {value:0.00}";
    }

    private string GetDifferenceClass(decimal value)
    {
        if (value > 0)
        {
            return "good";
        }

        if (value < 0)
        {
            return "bad";
        }

        return "";
    }

    private string GetDifferenceTextClass(decimal value)
    {
        if (value > 0)
        {
            return "difference-good";
        }

        if (value < 0)
        {
            return "difference-bad";
        }

        return "difference-neutral";
    }
}