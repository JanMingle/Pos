@code {
    private BusinessSettingsFormModel _settings = new();

    private List<SupplierOptionViewModel> _suppliers = new();
    private List<PurchaseProductOptionViewModel> _products = new();
    private List<StockPurchaseListItemViewModel> _purchases = new();
    private List<BranchOptionViewModel> _branches = new();

    private CreateStockPurchaseModel _purchase = new();

    private bool _loadingPurchases = true;
    private bool _savingPurchase;
    private bool _showReceivePanel;

    private DateTime? _fromDate = DateTime.Today.AddDays(-30);
    private DateTime? _toDate = DateTime.Today;
    private string? _searchTerm;
    private int? _branchFilter;

    private string? _message;
    private bool _isSuccess;

    private string CurrencyLabel =>
        string.IsNullOrWhiteSpace(_settings.CurrencySymbol)
            ? "R"
            : _settings.CurrencySymbol;

    private decimal PurchaseSubtotal =>
        _purchase.Items.Sum(x => GetLineTotal(x));

    private decimal PurchaseTotal =>
        PurchaseSubtotal + _purchase.TaxAmount;

    private decimal FilteredPurchaseSubtotal => _purchases.Sum(x => x.Subtotal);
    private decimal FilteredPurchaseTax => _purchases.Sum(x => x.TaxAmount);
    private decimal FilteredPurchaseTotal => _purchases.Sum(x => x.TotalAmount);
    private decimal FilteredPurchaseQuantity => _purchases.Sum(x => x.TotalQuantity);

    protected override async Task OnInitializedAsync()
    {
        if (!await UserAccessService.CanAccessAsync("stock-purchases"))
        {
            NavigationManager.NavigateTo("/dashboard");
            return;
        }

        _settings = await BusinessSettingsService.GetSettingsAsync();

        _branches = await BranchService.GetBranchOptionsAsync();
        _suppliers = await SupplierService.GetSupplierOptionsAsync();
        _products = await StockPurchaseService.GetStockProductOptionsAsync();

        ResetPurchaseForm();
        await LoadPurchasesAsync();
    }

    private async Task LoadPurchasesAsync()
    {
        _loadingPurchases = true;
        _purchases = await StockPurchaseService.GetPurchasesAsync(_fromDate, _toDate, _searchTerm, _branchFilter);
        _loadingPurchases = false;
    }

    private void OpenReceivePanel()
    {
        _showReceivePanel = true;

        if (_purchase.Items.Count == 0)
        {
            AddLine();
        }
    }

    private void CloseReceivePanel()
    {
        _showReceivePanel = false;
    }

    private void ResetPurchaseForm()
    {
        _purchase = new CreateStockPurchaseModel
        {
            PurchaseDate = DateTime.Today,
            UpdateProductCostPrice = true,
            Items = new List<CreateStockPurchaseItemModel>()
        };

        AddLine();
    }

    private void AddLine()
    {
        _purchase.Items.Add(new CreateStockPurchaseItemModel
        {
            Quantity = 1,
            UnitCost = 0
        });
    }

    private void RemoveLine(CreateStockPurchaseItemModel line)
    {
        _purchase.Items.Remove(line);
    }

    private void ProductChanged(CreateStockPurchaseItemModel line, string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            line.ProductId = 0;
            line.ProductVariantId = null;
            line.UnitCost = 0;
            return;
        }

        var product = _products.FirstOrDefault(x => x.OptionKey == value);

        if (product == null)
        {
            line.ProductId = 0;
            line.ProductVariantId = null;
            line.UnitCost = 0;
            return;
        }

        line.ProductId = product.ProductId;
        line.ProductVariantId = product.ProductVariantId;

        if (line.UnitCost <= 0)
        {
            line.UnitCost = product.CostPrice;
        }
    }

    private async Task SavePurchaseAsync()
    {
        _savingPurchase = true;

        _purchase.Items = _purchase.Items
            .Where(x => x.ProductId > 0 && x.Quantity > 0)
            .ToList();

        var result = await StockPurchaseService.CreateAndReceiveAsync(_purchase);

        _savingPurchase = false;

        ShowMessage(result.Message, result.Success);

        if (result.Success)
        {
            _products = await StockPurchaseService.GetStockProductOptionsAsync();
            _suppliers = await SupplierService.GetSupplierOptionsAsync();

            ResetPurchaseForm();
            _showReceivePanel = false;

            await LoadPurchasesAsync();
        }
    }

    private decimal GetLineTotal(CreateStockPurchaseItemModel line)
    {
        return line.Quantity * line.UnitCost;
    }

    private string GetLineOptionKey(CreateStockPurchaseItemModel line)
    {
        if (line.ProductVariantId.HasValue)
        {
            return $"v:{line.ProductVariantId.Value}";
        }

        return line.ProductId > 0 ? $"p:{line.ProductId}" : "";
    }

    private string GetProductOptionText(PurchaseProductOptionViewModel product)
    {
        var unit = string.IsNullOrWhiteSpace(product.UnitOfMeasure) ? "" : $" {product.UnitOfMeasure}";
        var label = string.IsNullOrWhiteSpace(product.DisplayName) ? product.ProductName : product.DisplayName;
        var variantTag = product.IsVariant ? " · Variant" : "";

        return $"{label} ({product.SKU}){variantTag} · Stock {product.CurrentStock:0.##}{unit}";
    }

    private string Money(decimal value)
    {
        return $"{CurrencyLabel} {value:0.00}";
    }

    private void ShowMessage(string message, bool success)
    {
        _message = message;
        _isSuccess = success;
    }

    private void ClearMessage()
    {
        _message = null;
    }
}