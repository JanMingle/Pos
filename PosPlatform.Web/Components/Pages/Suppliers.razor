</style>

@code {
    private BusinessSettingsFormModel _settings = new();
    private List<SupplierListItemViewModel> _suppliers = new();

    private SupplierFormModel _form = new();

    private bool _loading = true;
    private bool _saving;
    private bool _showModal;
    private bool _showDeleteConfirm;

    private string? _searchTerm;
    private string _statusFilter = "all";

    private int _deleteId;
    private string _deleteSupplierName = string.Empty;

    private string? _message;
    private bool _isSuccess;

    private int TotalSuppliers => _suppliers.Count;
    private int ActiveSuppliers => _suppliers.Count(x => x.IsActive);
    private int TotalPurchases => _suppliers.Sum(x => x.TotalPurchases);
    private decimal TotalSpent => _suppliers.Sum(x => x.TotalSpent);

    protected override async Task OnInitializedAsync()
    {
        if (!await UserAccessService.CanAccessAsync("suppliers"))
        {
            NavigationManager.NavigateTo("/dashboard");
            return;
        }

        _settings = await BusinessSettingsService.GetSettingsAsync();
        await LoadSuppliersAsync();
    }

    private async Task LoadSuppliersAsync()
    {
        _loading = true;
        _suppliers = await SupplierService.GetSuppliersAsync(_searchTerm, _statusFilter);
        _loading = false;
    }

    private async Task ResetFiltersAsync()
    {
        _searchTerm = null;
        _statusFilter = "all";
        await LoadSuppliersAsync();
    }

    private void OpenAddModal()
    {
        _form = new SupplierFormModel
        {
            IsActive = true
        };

        _showModal = true;
    }

    private async Task OpenEditModal(int id)
    {
        var model = await SupplierService.GetByIdAsync(id);

        if (model == null)
        {
            ShowMessage("Supplier not found.", false);
            return;
        }

        _form = model;
        _showModal = true;
    }

    private void CloseModal()
    {
        _showModal = false;
        _form = new SupplierFormModel();
    }

    private async Task SaveSupplierAsync()
    {
        _saving = true;

        var result = await SupplierService.SaveAsync(_form);

        _saving = false;
        ShowMessage(result.Message, result.Success);

        if (result.Success)
        {
            _showModal = false;
            _form = new SupplierFormModel();
            await LoadSuppliersAsync();
        }
    }

    private async Task ToggleStatusAsync(int id)
    {
        var result = await SupplierService.ToggleStatusAsync(id);
        ShowMessage(result.Message, result.Success);

        if (result.Success)
        {
            await LoadSuppliersAsync();
        }
    }

    private void ConfirmDelete(int id, string name)
    {
        _deleteId = id;
        _deleteSupplierName = name;
        _showDeleteConfirm = true;
    }

    private void CancelDelete()
    {
        _deleteId = 0;
        _deleteSupplierName = string.Empty;
        _showDeleteConfirm = false;
    }

    private async Task DeleteConfirmedAsync()
    {
        var result = await SupplierService.DeleteAsync(_deleteId);

        ShowMessage(result.Message, result.Success);

        _deleteId = 0;
        _deleteSupplierName = string.Empty;
        _showDeleteConfirm = false;

        if (result.Success)
        {
            await LoadSuppliersAsync();
        }
    }

    private string Money(decimal value)
    {
        var symbol = string.IsNullOrWhiteSpace(_settings.CurrencySymbol)
            ? "R"
            : _settings.CurrencySymbol;

        return $"{symbol} {value:0.00}";
    }

    private string GetInitials(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "S";
        }

        var words = value
            .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Take(2)
            .Select(x => x[0].ToString().ToUpper());

        return string.Join("", words);
    }

    private void ShowMessage(string message, bool success)
    {
        _message = message;
        _isSuccess = success;
    }

    private void ClearMessage()
    {
        _message = null;
    }
}