@page "/suppliers"
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@rendermode InteractiveServer
@layout MainLayout
@attribute [Authorize]
@using Microsoft.AspNetCore.Components.Web
@using PosPlatform.Web.Components.Layout
@using PosPlatform.Web.Models.Settings
@using PosPlatform.Web.Models.Suppliers
@using PosPlatform.Web.Services
@inject SupplierService SupplierService
@inject BusinessSettingsService BusinessSettingsService
@inject UserAccessService UserAccessService
@inject NavigationManager NavigationManager

<PageTitle>Suppliers</PageTitle>

<section class="suppliers-page">
    <div class="suppliers-top">
        <div>
            <div class="suppliers-kicker">
                <i class="bi bi-truck"></i>
                Supplier management
            </div>

            <h1>Suppliers</h1>
            <p>Manage supplier contacts, purchase history and stock receiving partners.</p>
        </div>

        <button type="button" class="suppliers-primary-btn" @onclick="OpenAddModal">
            <i class="bi bi-plus-lg"></i>
            Add Supplier
        </button>
    </div>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <div class="suppliers-alert @(_isSuccess ? "success" : "danger")">
            <i class="bi @(_isSuccess ? "bi-check-circle" : "bi-exclamation-triangle")"></i>
            <span>@_message</span>
            <button type="button" @onclick="ClearMessage">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
    }

    <div class="suppliers-settings-strip">
        <div>
            <span>Business</span>
            <strong>@_settings.BusinessName</strong>
        </div>

        <div>
            <span>Business Type</span>
            <strong>@_settings.BusinessType</strong>
        </div>

        <div>
            <span>Currency</span>
            <strong>@_settings.CurrencyCode · @_settings.CurrencySymbol</strong>
        </div>

        <div>
            <span>Stock Tracking</span>
            <strong>@(_settings.StockTrackingEnabled ? "Enabled" : "Disabled")</strong>
        </div>
    </div>

    <div class="suppliers-summary-grid">
        <div class="suppliers-summary-card hero">
            <div class="suppliers-summary-icon">
                <i class="bi bi-truck"></i>
            </div>
            <span>Total Suppliers</span>
            <strong>@TotalSuppliers</strong>
            <small>All supplier records</small>
        </div>

        <div class="suppliers-summary-card">
            <div class="suppliers-summary-icon green">
                <i class="bi bi-check2-circle"></i>
            </div>
            <span>Active</span>
            <strong>@ActiveSuppliers</strong>
            <small>Available for stock receiving</small>
        </div>

        <div class="suppliers-summary-card">
            <div class="suppliers-summary-icon amber">
                <i class="bi bi-receipt"></i>
            </div>
            <span>Total Purchases</span>
            <strong>@TotalPurchases</strong>
            <small>Purchase records linked</small>
        </div>

        <div class="suppliers-summary-card">
            <div class="suppliers-summary-icon blue">
                <i class="bi bi-cash-stack"></i>
            </div>
            <span>Total Spent</span>
            <strong>@Money(TotalSpent)</strong>
            <small>Purchase value recorded</small>
        </div>
    </div>

    <div class="suppliers-control-panel">
        <div class="suppliers-search">
            <i class="bi bi-search"></i>
            <input @bind="_searchTerm"
                   @bind:event="oninput"
                   @onkeydown="HandleSearchKeyDown"
                   placeholder="Search supplier, contact, phone or email" />
        </div>

        <select class="suppliers-filter" value="@_statusFilter" @onchange="StatusFilterChanged">
            <option value="all">All suppliers</option>
            <option value="active">Active only</option>
            <option value="inactive">Inactive only</option>
        </select>

        <button type="button" class="suppliers-secondary-btn" @onclick="ApplyFiltersAsync">
            <i class="bi bi-filter"></i>
            Apply
        </button>

        <button type="button" class="suppliers-ghost-btn" @onclick="ResetFiltersAsync">
            <i class="bi bi-arrow-counterclockwise"></i>
            Reset
        </button>
    </div>

    <div class="suppliers-panel">
        <div class="suppliers-panel-header">
            <div>
                <h2>Supplier List</h2>
                <p>Showing @PageStart - @PageEnd of @TotalFilteredSuppliers supplier@(SupplierPlural).</p>
            </div>

            <a href="/stock-purchases" class="suppliers-secondary-link">
                <i class="bi bi-box-arrow-in-down"></i>
                Receive Stock
            </a>
        </div>

        @if (_loading)
        {
            <div class="suppliers-empty">
                <div class="suppliers-empty-icon">
                    <i class="bi bi-hourglass-split"></i>
                </div>
                <strong>Loading suppliers...</strong>
                <span>Please wait while we fetch supplier records.</span>
            </div>
        }
        else if (TotalFilteredSuppliers == 0)
        {
            <div class="suppliers-empty">
                <div class="suppliers-empty-icon">
                    <i class="bi bi-truck"></i>
                </div>
                <strong>No suppliers found</strong>
                <span>Add your first supplier before receiving stock purchases.</span>

                <button type="button" class="suppliers-primary-btn" @onclick="OpenAddModal">
                    <i class="bi bi-plus-lg"></i>
                    Add Supplier
                </button>
            </div>
        }
        else
        {
            <div class="suppliers-table-wrap">
                <table class="suppliers-table">
                    <thead>
                        <tr>
                            <th>Supplier</th>
                            <th>Contact</th>
                            <th>Purchases</th>
                            <th>Total Spent</th>
                            <th>Last Purchase</th>
                            <th>Status</th>
                            <th class="suppliers-actions-col">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var supplier in PaginatedSuppliers)
                        {
                            <tr>
                                <td>
                                    <div class="suppliers-cell">
                                        <div class="suppliers-avatar">@GetInitials(supplier.SupplierName)</div>
                                        <div>
                                            <strong>@supplier.SupplierName</strong>
                                            <span>Created @supplier.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd")</span>
                                        </div>
                                    </div>
                                </td>

                                <td>
                                    <div class="suppliers-contact">
                                        <strong>@(string.IsNullOrWhiteSpace(supplier.ContactPerson) ? "-" : supplier.ContactPerson)</strong>
                                        <span>@(string.IsNullOrWhiteSpace(supplier.Phone) ? "No phone" : supplier.Phone)</span>
                                        <span>@(string.IsNullOrWhiteSpace(supplier.Email) ? "No email" : supplier.Email)</span>
                                    </div>
                                </td>

                                <td>@supplier.TotalPurchases</td>
                                <td class="suppliers-money">@Money(supplier.TotalSpent)</td>
                                <td>@(supplier.LastPurchaseDate.HasValue? supplier.LastPurchaseDate.Value.ToLocalTime().ToString("yyyy-MM-dd") : "-")</td>

                                <td>
                                    <span class="suppliers-status-pill @(supplier.IsActive ? "active" : "inactive")">
                                        @(supplier.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>

                                <td class="suppliers-actions-cell">
                                    <div class="suppliers-action-menu">
                                        <button type="button"
                                                class="suppliers-action-toggle"
                                                @onclick="() => ToggleActionMenu(supplier.Id)">
                                            <span>Actions</span>
                                            <i class="bi bi-chevron-down"></i>
                                        </button>

                                        @if (_openActionSupplierId == supplier.Id)
                                        {
                                            <div class="suppliers-action-dropdown">
                                                <button type="button" @onclick="() => OpenEditModal(supplier.Id)">
                                                    <i class="bi bi-pencil"></i>
                                                    <span>Edit supplier</span>
                                                </button>

                                                <button type="button" @onclick="() => ToggleStatusAsync(supplier.Id)">
                                                    <i class="bi @(supplier.IsActive ? "bi-pause-circle" : "bi-play-circle")"></i>
                                                    <span>@(supplier.IsActive ? "Pause supplier" : "Activate supplier")</span>
                                                </button>

                                                <button type="button" class="danger" @onclick="() => ConfirmDelete(supplier.Id, supplier.SupplierName)">
                                                    <i class="bi bi-trash"></i>
                                                    <span>Delete supplier</span>
                                                </button>
                                            </div>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="suppliers-pagination">
                <div class="suppliers-page-info">
                    Showing
                    <strong>@PageStart</strong>
                    -
                    <strong>@PageEnd</strong>
                    of
                    <strong>@TotalFilteredSuppliers</strong>
                </div>

                <div class="suppliers-page-controls">
                    <button type="button"
                            class="@PreviousPageClass"
                            @onclick="PreviousPage">
                        <i class="bi bi-chevron-left"></i>
                        Previous
                    </button>

                    <span class="suppliers-page-count">
                        Page @_currentPage of @TotalPages
                    </span>

                    <button type="button"
                            class="@NextPageClass"
                            @onclick="NextPage">
                        Next
                        <i class="bi bi-chevron-right"></i>
                    </button>
                </div>
            </div>
        }
    </div>
</section>

@if (_showModal)
{
    <div class="suppliers-modal-backdrop">
        <div class="suppliers-modal">
            <div class="suppliers-modal-header">
                <div>
                    <span>Supplier setup</span>
                    <h4>@(_form.Id.HasValue ? "Edit Supplier" : "Add Supplier")</h4>
                    <p>Capture supplier contact details for stock receiving and purchase history.</p>
                </div>

                <button type="button" class="suppliers-close-btn" @onclick="CloseModal">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <EditForm Model="_form" OnValidSubmit="SaveSupplierAsync">
                <DataAnnotationsValidator />
                <ValidationSummary class="suppliers-validation" />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="suppliers-label">Supplier Name</label>
                        <InputText class="suppliers-input" @bind-Value="_form.SupplierName" />
                    </div>

                    <div class="col-md-6">
                        <label class="suppliers-label">Contact Person</label>
                        <InputText class="suppliers-input" @bind-Value="_form.ContactPerson" />
                    </div>

                    <div class="col-md-6">
                        <label class="suppliers-label">Phone</label>
                        <InputText class="suppliers-input" @bind-Value="_form.Phone" />
                    </div>

                    <div class="col-md-6">
                        <label class="suppliers-label">Email</label>
                        <InputText class="suppliers-input" @bind-Value="_form.Email" />
                    </div>

                    <div class="col-md-6">
                        <label class="suppliers-label">Tax Number</label>
                        <InputText class="suppliers-input" @bind-Value="_form.TaxNumber" />
                    </div>

                    <div class="col-md-6">
                        <label class="suppliers-label">Address</label>
                        <InputText class="suppliers-input" @bind-Value="_form.Address" />
                    </div>

                    <div class="col-12">
                        <label class="suppliers-label">Notes</label>
                        <InputTextArea class="suppliers-input suppliers-textarea" @bind-Value="_form.Notes" />
                    </div>

                    <div class="col-12">
                        <label class="suppliers-check">
                            <InputCheckbox @bind-Value="_form.IsActive" />
                            <span>
                                <strong>Active supplier</strong>
                                <small>Allow this supplier to be used when receiving stock.</small>
                            </span>
                        </label>
                    </div>
                </div>

                <div class="suppliers-modal-actions">
                    <button type="button" class="suppliers-ghost-btn" @onclick="CloseModal">Cancel</button>

                    <button type="submit" class="suppliers-primary-btn @(_saving ? "is-disabled" : "")">
                        <i class="bi bi-check2-circle"></i>
                        @(_saving ? "Saving..." : "Save Supplier")
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

@if (_showDeleteConfirm)
{
    <div class="suppliers-modal-backdrop">
        <div class="suppliers-modal suppliers-delete-modal">
            <div class="suppliers-delete-icon">
                <i class="bi bi-trash"></i>
            </div>

            <h4>Delete Supplier</h4>
            <p>
                Are you sure you want to delete <strong>@_deleteSupplierName</strong>?
                If this supplier has purchase history, they will be deactivated instead.
            </p>

            <div class="suppliers-modal-actions">
                <button type="button" class="suppliers-ghost-btn" @onclick="CancelDelete">Cancel</button>
                <button type="button" class="suppliers-danger-btn" @onclick="DeleteConfirmedAsync">
                    <i class="bi bi-trash"></i>
                    Delete
                </button>
            </div>
        </div>
    </div>
}

<style>
    .suppliers-page {
        animation: suppliersIn .22s ease both;
    }

    .suppliers-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: 18px;
        margin-bottom: 16px;
    }

    .suppliers-kicker {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: #8FA6A1;
        font-size: .72rem;
        font-weight: 760;
        letter-spacing: .08em;
        text-transform: uppercase;
        margin-bottom: 8px;
    }

    .suppliers-top h1 {
        margin: 0;
        color: #111827;
        font-size: 1.45rem;
        font-weight: 720;
        letter-spacing: -.035em;
    }

    .suppliers-top p {
        margin: 6px 0 0;
        color: #667085;
        font-size: .88rem;
    }

    .suppliers-primary-btn,
    .suppliers-secondary-btn,
    .suppliers-ghost-btn,
    .suppliers-danger-btn,
    .suppliers-secondary-link,
    .suppliers-page-btn {
        min-height: 38px;
        border-radius: 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 0 14px;
        font-size: .8rem;
        font-weight: 680;
        border: 0;
        transition: transform .18s ease;
        white-space: nowrap;
        text-decoration: none;
    }

    .suppliers-primary-btn {
        color: #ffffff;
        background: #252525;
        box-shadow: 0 12px 24px rgba(17, 24, 39, .12);
    }

    .suppliers-secondary-btn,
    .suppliers-secondary-link {
        color: #8FA6A1;
        background: #f2f6f5;
        border: 1px solid #dce7e4;
    }

    .suppliers-ghost-btn,
    .suppliers-page-btn {
        color: #475569;
        background: #ffffff;
        border: 1px solid #e5e7eb;
    }

    .suppliers-danger-btn {
        color: #ffffff;
        background: #d92d20;
    }

        .suppliers-primary-btn:hover,
        .suppliers-secondary-btn:hover,
        .suppliers-ghost-btn:hover,
        .suppliers-danger-btn:hover,
        .suppliers-secondary-link:hover,
        .suppliers-page-btn:hover {
            transform: translateY(-1px);
        }

    .suppliers-primary-btn.is-disabled,
    .suppliers-page-btn.is-disabled {
        opacity: .45;
        cursor: not-allowed;
        transform: none;
    }

    .suppliers-alert {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 14px;
        margin-bottom: 16px;
        border-radius: 14px;
        font-size: .84rem;
        font-weight: 600;
        border: 1px solid;
    }

        .suppliers-alert.success {
            color: #166534;
            background: #f0fdf4;
            border-color: #bbf7d0;
        }

        .suppliers-alert.danger {
            color: #991b1b;
            background: #fef2f2;
            border-color: #fecaca;
        }

        .suppliers-alert span {
            flex: 1;
        }

        .suppliers-alert button {
            border: 0;
            background: transparent;
            color: inherit;
        }

    .suppliers-settings-strip {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 10px;
        margin-bottom: 16px;
    }

        .suppliers-settings-strip div {
            padding: 13px;
            border-radius: 16px;
            background: #ffffff;
            border: 1px solid #e8eaef;
            box-shadow: 0 10px 24px rgba(17, 24, 39, .035);
        }

        .suppliers-settings-strip span,
        .suppliers-settings-strip strong {
            display: block;
        }

        .suppliers-settings-strip span {
            color: #98a2b3;
            font-size: .7rem;
            font-weight: 700;
            letter-spacing: .03em;
            text-transform: uppercase;
        }

        .suppliers-settings-strip strong {
            margin-top: 4px;
            color: #111827;
            font-size: .84rem;
            font-weight: 720;
        }

    .suppliers-summary-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 12px;
        margin-bottom: 16px;
    }

    .suppliers-summary-card {
        padding: 15px;
        border-radius: 20px;
        background: #ffffff;
        border: 1px solid #e8eaef;
        box-shadow: 0 14px 32px rgba(17, 24, 39, .045);
    }

        .suppliers-summary-card.hero {
            background: #252525;
            border-color: #252525;
        }

        .suppliers-summary-card span,
        .suppliers-summary-card strong,
        .suppliers-summary-card small {
            display: block;
        }

        .suppliers-summary-card span {
            margin-top: 11px;
            color: #667085;
            font-size: .72rem;
            font-weight: 700;
        }

        .suppliers-summary-card strong {
            margin-top: 6px;
            color: #111827;
            font-size: 1.05rem;
            font-weight: 760;
            letter-spacing: -.02em;
        }

        .suppliers-summary-card small {
            margin-top: 4px;
            color: #98a2b3;
            font-size: .72rem;
            line-height: 1.35;
        }

        .suppliers-summary-card.hero span,
        .suppliers-summary-card.hero strong,
        .suppliers-summary-card.hero small {
            color: #ffffff;
        }

    .suppliers-summary-icon {
        width: 36px;
        height: 36px;
        border-radius: 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #ffffff;
        color: #252525;
        box-shadow: 0 10px 22px rgba(17, 24, 39, .08);
    }

        .suppliers-summary-icon.green {
            color: #8FA6A1;
            background: #f2f6f5;
        }

        .suppliers-summary-icon.amber {
            color: #b7791f;
            background: #fffbeb;
        }

        .suppliers-summary-icon.blue {
            color: #2563eb;
            background: #eff6ff;
        }

    .suppliers-control-panel {
        display: grid;
        grid-template-columns: minmax(260px, 1fr) 180px auto auto;
        gap: 10px;
        padding: 14px;
        margin-bottom: 16px;
        border-radius: 18px;
        background: #ffffff;
        border: 1px solid #e8eaef;
        box-shadow: 0 10px 24px rgba(17, 24, 39, .035);
    }

    .suppliers-search {
        min-height: 42px;
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 0 13px;
        border-radius: 14px;
        background: #fafafa;
        border: 1px solid #e5e7eb;
        color: #98a2b3;
    }

        .suppliers-search input,
        .suppliers-filter,
        .suppliers-input {
            width: 100%;
            min-height: 40px;
            border-radius: 12px;
            border: 1px solid #e5e7eb;
            background: #ffffff;
            color: #111827;
            padding: 0 12px;
            font-size: 16px;
            outline: none;
        }

        .suppliers-search input {
            border: 0;
            background: transparent;
            padding: 0;
        }

    .suppliers-panel {
        background: #ffffff;
        border: 1px solid #e8eaef;
        border-radius: 22px;
        box-shadow: 0 14px 32px rgba(17, 24, 39, .045);
        overflow: visible;
    }

    .suppliers-panel-header {
        padding: 16px 18px;
        border-bottom: 1px solid #f1f2f5;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
    }

        .suppliers-panel-header h2 {
            margin: 0;
            color: #111827;
            font-size: .94rem;
            font-weight: 720;
        }

        .suppliers-panel-header p {
            margin: 4px 0 0;
            color: #98a2b3;
            font-size: .75rem;
        }

    .suppliers-table-wrap {
        overflow-x: auto;
        padding-bottom: 90px;
    }

    .suppliers-table {
        width: 100%;
        min-width: 980px;
        border-collapse: collapse;
    }

        .suppliers-table th {
            padding: 12px 16px;
            background: #fafafa;
            color: #667085;
            font-size: .7rem;
            font-weight: 750;
            text-transform: uppercase;
            letter-spacing: .05em;
            border-bottom: 1px solid #e8eaef;
            white-space: nowrap;
        }

        .suppliers-table td {
            padding: 14px 16px;
            color: #334155;
            font-size: .82rem;
            border-bottom: 1px solid #f1f2f5;
            vertical-align: middle;
        }

    .suppliers-cell {
        display: flex;
        align-items: center;
        gap: 11px;
    }

    .suppliers-avatar {
        width: 38px;
        height: 38px;
        border-radius: 14px;
        background: #f2f6f5;
        color: #8FA6A1;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .78rem;
        font-weight: 750;
    }

    .suppliers-cell strong,
    .suppliers-contact strong {
        display: block;
        color: #111827;
        font-size: .85rem;
        font-weight: 720;
    }

    .suppliers-cell span,
    .suppliers-contact span {
        display: block;
        margin-top: 2px;
        color: #98a2b3;
        font-size: .72rem;
    }

    .suppliers-status-pill {
        display: inline-flex;
        min-height: 26px;
        align-items: center;
        padding: 0 9px;
        border-radius: 999px;
        font-size: .72rem;
        font-weight: 750;
    }

        .suppliers-status-pill.active {
            color: #15803d;
            background: #ecfdf5;
        }

        .suppliers-status-pill.inactive {
            color: #667085;
            background: #f3f4f6;
        }

    .suppliers-money {
        color: #111827 !important;
        font-weight: 750;
    }

    .suppliers-actions-col,
    .suppliers-actions-cell {
        text-align: right;
    }

    .suppliers-actions-cell {
        position: relative;
        min-width: 150px;
    }

    .suppliers-action-menu {
        position: relative;
        display: inline-block;
    }

    .suppliers-action-toggle {
        min-height: 34px;
        border-radius: 11px;
        border: 1px solid #e5e7eb;
        background: #ffffff;
        color: #252525;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 0 11px;
        font-size: .74rem;
        font-weight: 750;
        cursor: pointer;
        box-shadow: 0 8px 18px rgba(17, 24, 39, .04);
    }

    .suppliers-action-dropdown {
        position: absolute;
        top: calc(100% + 8px);
        right: 0;
        width: 195px;
        padding: 7px;
        border-radius: 15px;
        background: #ffffff;
        border: 1px solid #e8eaef;
        box-shadow: 0 18px 38px rgba(17, 24, 39, .14);
        z-index: 100;
        display: grid;
        gap: 4px;
        text-align: left;
    }

        .suppliers-action-dropdown button {
            width: 100%;
            min-height: 36px;
            border: 0;
            border-radius: 11px;
            background: transparent;
            color: #344054;
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 0 10px;
