@code {
    private List<StockProductRowViewModel> _products = new();
    private List<StockMovementRowViewModel> _movements = new();
    private List<BranchOptionViewModel> _branches = new();

    private StockSummaryViewModel _summary = new();
    private BusinessSettingsFormModel _settings = new();

    private StockAdjustmentModel _adjustment = new()
    {
        AdjustmentType = "Stock In",
        Quantity = 1
    };

    private bool _loadingStock = true;
    private bool _loadingMovements = true;
    private bool _savingAdjustment;

    private string? _searchTerm;
    private string _statusFilter = "all";
    private int? _branchFilter;
    private string? _barcodeValue;
    private bool _barcodeScanning;

    private DateTime? _fromDate = DateTime.Today;
    private DateTime? _toDate = DateTime.Today;

    private string? _message;
    private bool _isSuccess;

    private bool StockEnabled => _settings.StockTrackingEnabled;

    protected override async Task OnInitializedAsync()
    {
        if (!await UserAccessService.CanAccessAsync("stock"))
        {
            NavigationManager.NavigateTo("/dashboard");
            return;
        }

        _settings = await BusinessSettingsService.GetSettingsAsync();
        _branches = await BranchService.GetBranchOptionsAsync();

        await LoadAllAsync();
    }

    private async Task LoadAllAsync()
    {
        if (StockEnabled)
        {
            await LoadStockAsync();
        }
        else
        {
            _products = new List<StockProductRowViewModel>();
            _summary = new StockSummaryViewModel();
            _loadingStock = false;
        }

        await LoadMovementsAsync();
    }

    private async Task LoadStockAsync()
    {
        _loadingStock = true;

        _products = await StockService.GetStockProductsAsync(_searchTerm, _statusFilter, _branchFilter);
        _summary = await StockService.GetStockSummaryAsync(_branchFilter);

        _loadingStock = false;
    }

    private async Task LoadMovementsAsync()
    {
        _loadingMovements = true;

        _movements = await StockService.GetMovementsAsync(_fromDate, _toDate, _searchTerm, _branchFilter);

        _loadingMovements = false;
    }

    private async Task ApplyStockFiltersAsync()
    {
        await LoadStockAsync();
        await LoadMovementsAsync();
    }

    private async Task HandleBarcodeKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await ScanBarcodeAsync();
        }
    }

    private async Task ScanBarcodeAsync()
    {
        var code = _barcodeValue?.Trim();

        if (string.IsNullOrWhiteSpace(code))
        {
            ShowMessage("Scan or type a barcode/SKU first.", false);
            return;
        }

        _barcodeScanning = true;

        _searchTerm = code;
        _statusFilter = "all";

        await LoadStockAsync();
        await LoadMovementsAsync();

        _barcodeScanning = false;

        if (_products.Count == 0)
        {
            ShowMessage($"No stock item found for barcode or SKU: {code}", false);
            return;
        }

        ShowMessage($"{_products.Count} stock item found for: {code}", true);
        _barcodeValue = null;
    }

    private void OpenAdjustment()
    {
        _adjustment = new StockAdjustmentModel
        {
            AdjustmentType = "Stock In",
            Quantity = 1
        };
    }

    private void OpenAdjustment(int productId)
    {
        _adjustment = new StockAdjustmentModel
        {
            ProductId = productId,
            AdjustmentType = "Stock In",
            Quantity = 1
        };
    }

    private async Task SaveAdjustmentAsync()
    {
        _savingAdjustment = true;

        var result = await StockService.AdjustStockAsync(_adjustment);

        _savingAdjustment = false;
        ShowMessage(result.Message, result.Success);

        if (result.Success)
        {
            _adjustment = new StockAdjustmentModel
            {
                AdjustmentType = "Stock In",
                Quantity = 1
            };

            await LoadAllAsync();
        }
    }

    private async Task ResetFiltersAsync()
    {
        _searchTerm = null;
        _barcodeValue = null;
        _statusFilter = "all";
        _branchFilter = null;

        await LoadAllAsync();
    }

    private string Money(decimal value)
    {
        var symbol = string.IsNullOrWhiteSpace(_settings.CurrencySymbol)
            ? "R"
            : _settings.CurrencySymbol;

        return $"{symbol} {value:0.00}";
    }

    private string GetTypeClass(string? productType)
    {
        return productType switch
        {
            "Service" => "service",
            "Package / Bundle" => "package",
            "Voucher" => "voucher",
            "Digital Product" => "digital",
            _ => "physical"
        };
    }

    private string GetMovementClass(string movementType)
    {
        return movementType switch
        {
            "Sale" => "blue",
            "Purchase" => "success",
            "Stock In" => "success",
            "Stock Out" => "warning",
            "Correction" => "gray",
            _ => "gray"
        };
    }

    private string GetUnitLabel(string? unit)
    {
        return string.IsNullOrWhiteSpace(unit) ? "" : unit;
    }

    private void ShowMessage(string message, bool success)
    {
        _message = message;
        _isSuccess = success;
    }

    private void ClearMessage()
    {
        _message = null;
    }

    private string GetInitials(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "P";
        }

        var words = value
            .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Take(2)
            .Select(x => x[0].ToString().ToUpper());

        return string.Join("", words);
    }
}