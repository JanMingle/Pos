        min-height: 40px;
        border-radius: 12px;
        border: 1px solid #e5e7eb;
        background: #ffffff;
        color: #0f172a;
        padding: 0 12px;
        font-size: .84rem;
        outline: none;
    }

    .shift-textarea {
        min-height: 86px;
        padding-top: 10px;
        resize: vertical;
    }

    .shift-primary-btn,
    .shift-secondary-btn,
    .shift-danger-btn {
        min-height: 38px;
        border-radius: 11px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 0 14px;
        font-size: .8rem;
        font-weight: 650;
        border: 0;
        white-space: nowrap;
    }

    .shift-primary-btn {
        color: #ffffff;
        background: #111827;
    }

    .shift-secondary-btn {
        color: #2563eb;
