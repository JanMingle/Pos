@page "/cashier-shift"
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@rendermode InteractiveServer
@layout MainLayout
@attribute [Authorize]
@using PosPlatform.Web.Components.Layout
@using PosPlatform.Web.Models.Settings
@using PosPlatform.Web.Models.Shifts
@using PosPlatform.Web.Services
@inject CashierShiftService CashierShiftService
@inject BusinessSettingsService BusinessSettingsService
@inject UserAccessService UserAccessService
@inject NavigationManager NavigationManager

<PageTitle>Cashier Shift</PageTitle>

<section class="shift-page">
    <div class="shift-top">
        <div>
            <div class="shift-kicker">
                <i class="bi bi-cash-coin"></i>
                Till session
            </div>

            <h1>Cashier Shift</h1>
            <p>Open your till, record cash movements, monitor payment totals and close your shift accurately.</p>
        </div>

        <div class="shift-top-actions">
            @if (_openShift == null)
            {
                <span class="shift-top-pill warning">
                    <i class="bi bi-exclamation-circle"></i>
                    No open shift
                </span>
            }
            else
            {
                <span class="shift-top-pill success">
                    <i class="bi bi-check2-circle"></i>
                    Shift open
                </span>
            }

            <button type="button" class="shift-ghost-btn" @onclick="LoadAsync">
                <i class="bi bi-arrow-clockwise"></i>
                Refresh
            </button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <div class="shift-alert @(_isSuccess ? "success" : "danger")">
            <i class="bi @(_isSuccess ? "bi-check-circle" : "bi-exclamation-triangle")"></i>
            <span>@_message</span>
            <button type="button" @onclick="ClearMessage">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
    }

    @if (_loading)
    {
        <div class="shift-empty">
            <div class="shift-empty-icon">
                <i class="bi bi-hourglass-split"></i>
            </div>
            <strong>Loading cashier shift...</strong>
            <span>Please wait while we prepare your till session.</span>
        </div>
    }
    else
    {
        <div class="shift-summary-grid">
            <div class="shift-summary-card hero">
                <div class="shift-summary-icon">
                    <i class="bi bi-wallet2"></i>
                </div>
                <span>Expected Cash</span>
                <strong>@Money(_openShift?.ExpectedCash ?? 0)</strong>
                <small>Opening cash + cash sales + cash in - cash out</small>
            </div>

            <div class="shift-summary-card">
                <div class="shift-summary-icon green">
                    <i class="bi bi-cash-stack"></i>
                </div>
                <span>Cash Sales</span>
                <strong>@Money(_openShift?.CashSales ?? 0)</strong>
                <small>Cash transactions in this shift</small>
            </div>

            <div class="shift-summary-card">
                <div class="shift-summary-icon blue">
                    <i class="bi bi-credit-card"></i>
                </div>
                <span>Card Sales</span>
                <strong>@Money(_openShift?.CardSales ?? 0)</strong>
                <small>Card payments recorded</small>
            </div>

            <div class="shift-summary-card">
                <div class="shift-summary-icon violet">
                    <i class="bi bi-bank"></i>
                </div>
                <span>EFT Sales</span>
                <strong>@Money(_openShift?.EftSales ?? 0)</strong>
                <small>Bank transfer payments</small>
            </div>
        </div>

        <div class="shift-main-grid">
            <div class="shift-left-column">
                <div class="shift-panel">
                    <div class="shift-panel-header">
                        <div>
                            <h2>Current Shift</h2>
                            <p>Manage your active till session before selling and after closing.</p>
                        </div>
                    </div>

                    @if (_openShift == null)
                    {
                        <EditForm Model="_openModel" OnValidSubmit="OpenShiftAsync">
                            <DataAnnotationsValidator />

                            <div class="shift-form">
                                <div class="shift-start-card">
                                    <div class="shift-start-icon">
                                        <i class="bi bi-play-circle"></i>
                                    </div>

                                    <div>
                                        <strong>Start your cashier session</strong>
                                        <span>Enter opening float before processing sales.</span>
                                    </div>
                                </div>

                                <div>
                                    <label>Opening Cash (@CurrencyLabel)</label>
                                    <InputNumber class="shift-input" @bind-Value="_openModel.OpeningCash" />
                                </div>

                                <div>
                                    <label>Opening Notes</label>
                                    <InputTextArea class="shift-input shift-textarea" @bind-Value="_openModel.OpeningNotes" />
                                </div>

                                <ValidationSummary class="shift-validation" />

                                <button type="submit"
                                        class="shift-primary-btn"
                                        disabled="@(_saving ? "disabled" : null)">
                                    <i class="bi bi-play-circle"></i>
                                    @(_saving ? "Opening..." : "Open Shift")
                                </button>
                            </div>
                        </EditForm>
                    }
                    else
                    {
                        <div class="shift-current">
                            <div class="shift-open-banner">
                                <div>
                                    <span>Status</span>
                                    <strong>@_openShift.Status</strong>
                                    <small>Opened @_openShift.OpenedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</small>
                                </div>

                                <div class="shift-open-total">
                                    <span>Total Sales</span>
                                    <strong>@Money(_openShift.TotalSales)</strong>
                                </div>
                            </div>

                            <div class="shift-stats-grid">
                                <div>
                                    <span>Opening Cash</span>
                                    <strong>@Money(_openShift.OpeningCash)</strong>
                                </div>

                                <div>
                                    <span>Cash Sales</span>
                                    <strong>@Money(_openShift.CashSales)</strong>
                                </div>

                                <div>
                                    <span>Card Sales</span>
                                    <strong>@Money(_openShift.CardSales)</strong>
                                </div>

                                <div>
                                    <span>EFT Sales</span>
                                    <strong>@Money(_openShift.EftSales)</strong>
                                </div>

                                <div>
                                    <span>Cash In</span>
                                    <strong>@Money(_openShift.CashIn)</strong>
                                </div>

                                <div>
                                    <span>Cash Out</span>
                                    <strong>@Money(_openShift.CashOut)</strong>
                                </div>

                                <div class="highlight">
                                    <span>Expected Cash</span>
                                    <strong>@Money(_openShift.ExpectedCash)</strong>
                                </div>

                                <div>
                                    <span>Cash Movements</span>
                                    <strong>@_openShift.CashMovements.Count</strong>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                @if (_openShift != null)
                {
                    <div class="shift-panel">
                        <div class="shift-panel-header">
                            <div>
                                <h2>Cash In / Cash Out</h2>
                                <p>Record extra float, cash drops, petty cash or till withdrawals.</p>
                            </div>
                        </div>

                        <EditForm Model="_movementModel" OnValidSubmit="RecordCashMovementAsync">
                            <DataAnnotationsValidator />

                            <div class="shift-form">
                                <div class="shift-movement-form">
                                    <div>
                                        <label>Movement Type</label>
                                        <InputSelect class="shift-input" @bind-Value="_movementModel.MovementType">
                                            <option value="Cash In">Cash In</option>
                                            <option value="Cash Out">Cash Out</option>
                                        </InputSelect>
                                    </div>

                                    <div>
                                        <label>Amount (@CurrencyLabel)</label>
                                        <InputNumber class="shift-input" @bind-Value="_movementModel.Amount" />
                                    </div>

                                    <div>
                                        <label>Reason</label>
                                        <InputText class="shift-input" @bind-Value="_movementModel.Reason" />
                                    </div>

                                    <div>
                                        <label>Notes</label>
                                        <InputTextArea class="shift-input shift-textarea" @bind-Value="_movementModel.Notes" />
                                    </div>
                                </div>

                                <ValidationSummary class="shift-validation" />

                                <button type="submit"
                                        class="shift-secondary-btn"
                                        disabled="@(_savingMovement ? "disabled" : null)">
                                    <i class="bi bi-plus-circle"></i>
                                    @(_savingMovement ? "Recording..." : "Record Cash Movement")
                                </button>
                            </div>
                        </EditForm>

                        @if (_openShift.CashMovements.Count == 0)
                        {
                            <div class="shift-empty compact">
                                <strong>No cash movements yet</strong>
                                <span>Cash in and cash out entries will appear here.</span>
                            </div>
                        }
                        else
                        {
                            <div class="shift-movement-list">
                                @foreach (var movement in _openShift.CashMovements.OrderByDescending(x => x.CreatedAt))
                                {
                                    <div class="shift-movement-item">
                                        <div>
                                            <span class="shift-movement-pill @(movement.MovementType == "Cash In" ? "in" : "out")">
                                                @movement.MovementType
                                            </span>
                                            <strong>@movement.Reason</strong>
                                            <small>@movement.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</small>

                                            @if (!string.IsNullOrWhiteSpace(movement.Notes))
                                            {
                                                <small>@movement.Notes</small>
                                            }
                                        </div>

                                        <div class="shift-movement-amount @(movement.MovementType == "Cash In" ? "in" : "out")">
                                            @Money(movement.Amount)
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <div class="shift-panel">
                        <div class="shift-panel-header">
                            <div>
                                <h2>Close Shift</h2>
                                <p>Count your cash and close the till session.</p>
                            </div>
                        </div>

                        <EditForm Model="_closeModel" OnValidSubmit="CloseShiftAsync">
                            <DataAnnotationsValidator />

                            <div class="shift-form">
                                <div class="shift-close-preview">
                                    <div>
                                        <span>Expected Cash</span>
                                        <strong>@Money(_openShift.ExpectedCash)</strong>
                                    </div>

                                    <div>
                                        <span>Closing Cash</span>
                                        <strong>@Money(_closeModel.ClosingCash)</strong>
                                    </div>

                                    <div>
                                        <span>Difference</span>
                                        <strong class="@GetDifferenceClass(_closeModel.ClosingCash - _openShift.ExpectedCash)">
                                            @Money(_closeModel.ClosingCash - _openShift.ExpectedCash)
                                        </strong>
                                    </div>
                                </div>

                                <div>
                                    <label>Closing Cash Counted (@CurrencyLabel)</label>
                                    <InputNumber class="shift-input" @bind-Value="_closeModel.ClosingCash" />
                                </div>

                                <div>
                                    <label>Closing Notes</label>
                                    <InputTextArea class="shift-input shift-textarea" @bind-Value="_closeModel.ClosingNotes" />
                                </div>

                                <ValidationSummary class="shift-validation" />

                                <button type="submit"
                                        class="shift-danger-btn"
                                        disabled="@(_saving ? "disabled" : null)">
                                    <i class="bi bi-stop-circle"></i>
                                    @(_saving ? "Closing..." : "Close Shift")
                                </button>
                            </div>
                        </EditForm>
                    </div>
                }
            </div>

            <div class="shift-right-column">
                <div class="shift-panel">
                    <div class="shift-panel-header">
                        <div>
                            <h2>How Till Totals Work</h2>
                            <p>Quick explanation for accurate balancing.</p>
                        </div>
                    </div>

                    <div class="shift-help">
                        <div>
                            <i class="bi bi-wallet2"></i>
                            <strong>Expected Cash</strong>
                            <span>Opening cash plus cash sales plus cash in, minus cash out.</span>
                        </div>

                        <div>
                            <i class="bi bi-calculator"></i>
                            <strong>Cash Difference</strong>
                            <span>Closing counted cash minus expected cash.</span>
                        </div>

                        <div>
                            <i class="bi bi-credit-card"></i>
                            <strong>Card and EFT</strong>
                            <span>Card and EFT are tracked separately because they are not physical cash in the till.</span>
                        </div>
                    </div>
                </div>

                <div class="shift-panel">
                    <div class="shift-panel-header">
                        <div>
                            <h2>Quick Checklist</h2>
                            <p>Use this before closing your shift.</p>
                        </div>
                    </div>

                    <div class="shift-checklist">
                        <div>
                            <i class="bi bi-check2"></i>
                            <span>Confirm all cash sales are captured.</span>
                        </div>

                        <div>
                            <i class="bi bi-check2"></i>
                            <span>Record any cash drops or petty cash.</span>
                        </div>

                        <div>
                            <i class="bi bi-check2"></i>
                            <span>Count physical cash before closing.</span>
                        </div>

                        <div>
                            <i class="bi bi-check2"></i>
                            <span>Add notes when there is a cash difference.</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="shift-panel shift-history-panel">
            <div class="shift-panel-header shift-history-header">
                <div>
                    <h2>My Shift History</h2>
                    <p>Showing @HistoryPageStart - @HistoryPageEnd of @TotalHistoryShifts shift@(@TotalHistoryShifts == 1 ? "" : "s").</p>
                </div>

                <div class="shift-date-filters">
                    <input type="date" @bind="_fromDate" />
                    <input type="date" @bind="_toDate" />

                    <button type="button" class="shift-secondary-btn" @onclick="ApplyHistoryFilterAsync">
                        <i class="bi bi-filter"></i>
                        Filter
                    </button>
                </div>
            </div>

            @if (TotalHistoryShifts == 0)
            {
                <div class="shift-empty">
                    <strong>No shifts found</strong>
                    <span>Open and close a shift to see history here.</span>
                </div>
            }
            else
            {
                <div class="shift-table-wrap">
                    <table class="shift-table">
                        <thead>
                            <tr>
                                <th>Status</th>
                                <th>Opened</th>
                                <th>Closed</th>
                                <th>Opening</th>
                                <th>Cash In</th>
                                <th>Cash Out</th>
                                <th>Cash Sales</th>
                                <th>Card</th>
                                <th>EFT</th>
                                <th>Total</th>
                                <th>Expected Cash</th>
                                <th>Closing Cash</th>
                                <th>Difference</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var shift in PaginatedShifts)
                            {
                                <tr>
                                    <td>
                                        <span class="shift-pill @(shift.Status == "Open" ? "open" : "closed")">
                                            @shift.Status
                                        </span>
                                    </td>
                                    <td>@shift.OpenedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                    <td>@(shift.ClosedAt.HasValue? shift.ClosedAt.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm") : "-")</td>
                                    <td>@Money(shift.OpeningCash)</td>
                                    <td>@Money(shift.CashIn)</td>
                                    <td>@Money(shift.CashOut)</td>
                                    <td>@Money(shift.CashSales)</td>
                                    <td>@Money(shift.CardSales)</td>
                                    <td>@Money(shift.EftSales)</td>
                                    <td class="shift-money">@Money(shift.TotalSales)</td>
                                    <td>@Money(shift.ExpectedCash)</td>
                                    <td>@Money(shift.ClosingCash)</td>
                                    <td class="@GetDifferenceClass(shift.CashDifference)">
                                        @Money(shift.CashDifference)
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="shift-pagination">
                    <button type="button"
                            class="shift-page-btn"
                            disabled="@(_historyPage <= 1 ? "disabled" : null)"
                            @onclick="PreviousHistoryPage">
                        <i class="bi bi-chevron-left"></i>
                        Previous
                    </button>

                    <span>Page @_historyPage of @HistoryTotalPages</span>

                    <button type="button"
                            class="shift-page-btn"
                            disabled="@(_historyPage >= HistoryTotalPages ? "disabled" : null)"
                            @onclick="NextHistoryPage">
                        Next
                        <i class="bi bi-chevron-right"></i>
                    </button>
                </div>
            }
        </div>
    }
</section>

<style>
    .shift-page {
        animation: shiftIn .22s ease both;
    }

    .shift-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: 18px;
        margin-bottom: 16px;
    }

    .shift-kicker {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: #8FA6A1;
        font-size: .72rem;
        font-weight: 760;
        letter-spacing: .08em;
        text-transform: uppercase;
        margin-bottom: 8px;
    }

    .shift-top h1 {
        margin: 0;
        color: #111827;
        font-size: 1.45rem;
        font-weight: 720;
        letter-spacing: -.035em;
    }

    .shift-top p {
        margin: 6px 0 0;
        color: #667085;
        font-size: .88rem;
    }

    .shift-top-actions {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 10px;
        flex-wrap: wrap;
    }

    .shift-top-pill {
        min-height: 38px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 0 13px;
        border-radius: 999px;
        font-size: .78rem;
        font-weight: 750;
        white-space: nowrap;
    }

        .shift-top-pill.success {
            color: #15803d;
            background: #ecfdf5;
            border: 1px solid #bbf7d0;
        }

        .shift-top-pill.warning {
            color: #b45309;
            background: #fffbeb;
            border: 1px solid #fde68a;
        }

    .shift-alert {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 14px;
        margin-bottom: 16px;
        border-radius: 14px;
        font-size: .84rem;
        font-weight: 600;
        border: 1px solid;
    }

        .shift-alert.success {
            color: #166534;
            background: #f0fdf4;
            border-color: #bbf7d0;
        }

        .shift-alert.danger {
            color: #991b1b;
            background: #fef2f2;
            border-color: #fecaca;
        }

        .shift-alert span {
            flex: 1;
        }

        .shift-alert button {
            border: 0;
            background: transparent;
            color: inherit;
        }

    .shift-summary-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 12px;
        margin-bottom: 16px;
    }

    .shift-summary-card {
        padding: 15px;
        border-radius: 20px;
        background: #ffffff;
        border: 1px solid #e8eaef;
        box-shadow: 0 14px 32px rgba(17, 24, 39, .045);
    }

        .shift-summary-card.hero {
            background: #252525;
            border-color: #252525;
        }

        .shift-summary-card span,
        .shift-summary-card strong,
        .shift-summary-card small {
            display: block;
        }

        .shift-summary-card span {
            margin-top: 11px;
            color: #667085;
            font-size: .72rem;
            font-weight: 700;
        }

        .shift-summary-card strong {
            margin-top: 6px;
            color: #111827;
            font-size: 1.05rem;
            font-weight: 760;
            letter-spacing: -.02em;
        }

        .shift-summary-card small {
            margin-top: 4px;
            color: #98a2b3;
            font-size: .72rem;
            line-height: 1.35;
        }

        .shift-summary-card.hero span,
        .shift-summary-card.hero strong,
        .shift-summary-card.hero small {
            color: #ffffff;
        }

    .shift-summary-icon {
        width: 36px;
        height: 36px;
        border-radius: 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #ffffff;
        color: #252525;
        box-shadow: 0 10px 22px rgba(17, 24, 39, .08);
    }

        .shift-summary-icon.green {
            color: #8FA6A1;
            background: #f2f6f5;
        }

        .shift-summary-icon.blue {
            color: #2563eb;
            background: #eff6ff;
        }

        .shift-summary-icon.violet {
            color: #7c3aed;
            background: #f5f3ff;
        }

    .shift-main-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.15fr) minmax(320px, .85fr);
        gap: 16px;
        align-items: start;
    }

    .shift-left-column,
    .shift-right-column {
        display: grid;
        gap: 16px;
    }

    .shift-panel {
        background: #ffffff;
        border: 1px solid #e8eaef;
        border-radius: 22px;
        box-shadow: 0 14px 32px rgba(17, 24, 39, .045);
        overflow: hidden;
    }

    .shift-panel-header {
        padding: 16px 18px;
        border-bottom: 1px solid #f1f2f5;
        display: flex;
        justify-content: space-between;
        gap: 14px;
        align-items: center;
    }

        .shift-panel-header h2 {
            margin: 0;
            color: #111827;
            font-size: .94rem;
            font-weight: 720;
        }

        .shift-panel-header p {
            margin: 4px 0 0;
            color: #98a2b3;
            font-size: .75rem;
        }

    .shift-form,
    .shift-current,
    .shift-help,
    .shift-checklist {
        padding: 18px;
        display: grid;
        gap: 13px;
    }

        .shift-form label {
            display: block;
            margin-bottom: 6px;
            color: #475569;
            font-size: .77rem;
            font-weight: 700;
        }

    .shift-input,
    .shift-date-filters input {
        width: 100%;
        min-height: 40px;
        border-radius: 12px;
        border: 1px solid #e5e7eb;
        background: #ffffff;
        color: #111827;
        padding: 0 12px;
        font-size: 16px;
        outline: none;
    }

    .shift-textarea {
        min-height: 86px;
        padding-top: 10px;
        resize: vertical;
    }

    .shift-primary-btn,
    .shift-secondary-btn,
    .shift-danger-btn,
    .shift-ghost-btn,
    .shift-page-btn {
        min-height: 38px;
        border-radius: 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 0 14px;
        font-size: .8rem;
        font-weight: 680;
        border: 0;
        white-space: nowrap;
        transition: transform .18s ease;
    }

    .shift-primary-btn {
        color: #ffffff;
        background: #252525;
    }

    .shift-secondary-btn {
        color: #8FA6A1;
        background: #f2f6f5;
        border: 1px solid #dce7e4;
    }

    .shift-danger-btn {
        color: #ffffff;
        background: #d92d20;
    }

    .shift-ghost-btn,
    .shift-page-btn {
        color: #475569;
        background: #ffffff;
        border: 1px solid #e5e7eb;
    }

        .shift-primary-btn:hover,
        .shift-secondary-btn:hover,
        .shift-danger-btn:hover,
        .shift-ghost-btn:hover,
        .shift-page-btn:hover {
            transform: translateY(-1px);
        }

        .shift-primary-btn:disabled,
        .shift-secondary-btn:disabled,
        .shift-danger-btn:disabled,
        .shift-page-btn:disabled {
            opacity: .45;
            cursor: not-allowed;
            transform: none;
        }

    .shift-empty {
        margin: 18px;
        padding: 34px 20px;
        border-radius: 18px;
        background: #fafafa;
        border: 1px dashed #d0d5dd;
        text-align: center;
    }

        .shift-empty.compact {
            margin: 0 18px 18px;
            padding: 24px 16px;
        }

    .shift-empty-icon {
        width: 42px;
        height: 42px;
        margin: 0 auto 10px;
        border-radius: 16px;
        background: #f2f6f5;
        color: #8FA6A1;
        display: flex;
        align-items: center;
