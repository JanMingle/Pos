        }
</style>

@code {
    private BusinessSettingsFormModel _settings = new();

    private CashierShiftViewModel? _openShift;
    private List<CashierShiftViewModel> _shifts = new();

    private OpenShiftModel _openModel = new();
    private CloseShiftModel _closeModel = new();
    private CashMovementModel _movementModel = new()
    {
        MovementType = "Cash In"
    };

    private bool _loading = true;
    private bool _saving;
    private bool _savingMovement;

    private string? _message;
    private bool _isSuccess;

    private DateTime? _fromDate = DateTime.Today.AddDays(-7);
    private DateTime? _toDate = DateTime.Today;

    private string CurrencyLabel =>
        string.IsNullOrWhiteSpace(_settings.CurrencySymbol)
            ? "R"
            : _settings.CurrencySymbol;

    protected override async Task OnInitializedAsync()
    {
        if (!await UserAccessService.CanAccessAsync("sales"))
        {
            NavigationManager.NavigateTo("/dashboard");
            return;
        }

        _settings = await BusinessSettingsService.GetSettingsAsync();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;

        _openShift = await CashierShiftService.GetOpenShiftAsync();
        _shifts = await CashierShiftService.GetMyShiftsAsync(_fromDate, _toDate);

        _loading = false;
    }

    private async Task OpenShiftAsync()
    {
        _saving = true;

        var result = await CashierShiftService.OpenShiftAsync(_openModel);

        _saving = false;
        ShowMessage(result.Message, result.Success);

        if (result.Success)
        {
            _openModel = new OpenShiftModel();
            await LoadAsync();
        }
    }

    private async Task RecordCashMovementAsync()
    {
        _savingMovement = true;

        var result = await CashierShiftService.RecordCashMovementAsync(_movementModel);

        _savingMovement = false;
        ShowMessage(result.Message, result.Success);

        if (result.Success)
        {
            _movementModel = new CashMovementModel
            {
                MovementType = "Cash In"
            };

            await LoadAsync();
        }
    }

    private async Task CloseShiftAsync()
    {
        _saving = true;

        var result = await CashierShiftService.CloseShiftAsync(_closeModel);

        _saving = false;
        ShowMessage(result.Message, result.Success);

        if (result.Success)
        {
            _closeModel = new CloseShiftModel();
            await LoadAsync();
        }
    }
    
    private string Money(decimal value)
    {
        return $"{CurrencyLabel} {value:0.00}";
    }

    private string GetDifferenceClass(decimal value)
    {
        if (value > 0)
        {
            return "difference-good";
        }

        if (value < 0)
        {
            return "difference-bad";
        }

        return "difference-neutral";
    }

    private void ShowMessage(string message, bool success)
    {
        _message = message;
        _isSuccess = success;
    }

    private void ClearMessage()
    {
        _message = null;
    }
}