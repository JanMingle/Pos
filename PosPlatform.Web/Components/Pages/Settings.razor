@page "/settings"
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@rendermode InteractiveServer
@layout MainLayout
@attribute [Authorize]
@using PosPlatform.Web.Components.Layout
@using PosPlatform.Web.Models.Settings
@using PosPlatform.Web.Services
@inject BusinessSettingsService BusinessSettingsService
@inject UserAccessService UserAccessService
@inject NavigationManager NavigationManager

<PageTitle>Settings</PageTitle>

<section class="settings-page">
    <div class="settings-header">
        <div>
            <div class="settings-kicker">
                <i class="bi bi-gear"></i>
                Business setup
            </div>
            <h1>Settings</h1>
            <p>Review the setup captured at registration and update your business configuration.</p>
        </div>

        <button type="button" class="settings-primary-btn" @onclick="SaveSettingsAsync" disabled="@_saving">
            <i class="bi bi-check2-circle"></i>
            @(_saving ? "Saving..." : "Save Settings")
        </button>
    </div>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <div class="settings-alert @(_isSuccess ? "success" : "danger")">
            <i class="bi @(_isSuccess ? "bi-check-circle" : "bi-exclamation-triangle")"></i>
            <span>@_message</span>
            <button type="button" @onclick="ClearMessage">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
    }

    @if (_loading)
    {
        <div class="settings-empty">
            <strong>Loading settings...</strong>
            <span>Please wait while we prepare your business configuration.</span>
        </div>
    }
    else
    {
        <div class="settings-snapshot">
            <div class="settings-snapshot-main">
                <div>
                    <span class="settings-snapshot-kicker">Registered setup</span>
                    <h2>@_form.BusinessName</h2>
                    <p>@_form.BusinessType</p>
                </div>

                <div class="settings-snapshot-badge">
                    @_form.CurrencyCode · @_form.CurrencySymbol
                </div>
            </div>

            <div class="settings-snapshot-grid">
                <div class="settings-snapshot-card">
                    <span>Tax / VAT</span>
                    <strong>@GetTaxLabel()</strong>
                </div>

                <div class="settings-snapshot-card">
                    <span>Stock Tracking</span>
                    <strong>@YesNo(_form.StockTrackingEnabled)</strong>
                </div>

                <div class="settings-snapshot-card">
                    <span>Services</span>
                    <strong>@YesNo(_form.ServicesEnabled)</strong>
                </div>

                <div class="settings-snapshot-card">
                    <span>Appointments</span>
                    <strong>@YesNo(_form.AppointmentsEnabled)</strong>
                </div>

                <div class="settings-snapshot-card">
                    <span>Customers</span>
                    <strong>@YesNo(_form.CustomersEnabled)</strong>
                </div>

                <div class="settings-snapshot-card">
                    <span>Age Restricted</span>
                    <strong>@YesNo(_form.AgeRestrictedProductsEnabled)</strong>
                </div>
            </div>

            <div class="settings-preview-row">
                <div class="settings-preview-card">
                    <h3>POS Rules</h3>

                    <div class="settings-preview-tags">
                        <span class="@GetTagClass(_form.AllowDiscounts)">
                            Discounts: @YesNo(_form.AllowDiscounts)
                        </span>

                        <span class="@GetTagClass(_form.AllowNegativeStock)">
                            Negative Stock: @YesNo(_form.AllowNegativeStock)
                        </span>

                        <span class="@GetTagClass(_form.RequireCustomerForSale)">
                            Customer Required: @YesNo(_form.RequireCustomerForSale)
                        </span>
                    </div>
                </div>

                <div class="settings-preview-card">
                    <h3>Receipt Preview</h3>

                    <div class="settings-receipt-mini">
                        <strong>@_form.BusinessName</strong>
                        <span>@_form.ReceiptTitle</span>

                        @if (!string.IsNullOrWhiteSpace(_form.ReceiptFooterMessage))
                        {
                            <small>@_form.ReceiptFooterMessage</small>
                        }

                        @if (!string.IsNullOrWhiteSpace(_form.ReturnPolicyText))
                        {
                            <em>@_form.ReturnPolicyText</em>
                        }
                    </div>
                </div>
            </div>
        </div>

        <EditForm Model="_form" OnValidSubmit="SaveSettingsAsync">
            <DataAnnotationsValidator />

            <div class="settings-grid">
                <div class="settings-panel">
                    <div class="settings-panel-header">
                        <h2>Business Profile</h2>
                        <p>This information appears across the system and on receipts.</p>
                    </div>

                    <div class="settings-form">
                        <div>
                            <label>Business Name</label>
                            <InputText class="settings-input" @bind-Value="_form.BusinessName" />
                        </div>

                        <div>
                            <label>Business Type</label>
                            <InputSelect class="settings-input" @bind-Value="_form.BusinessType">
                                @foreach (var option in _businessTypes)
                                {
                                    <option value="@option.Name">@option.Name</option>
                                }
                            </InputSelect>
                        </div>

                        <div class="settings-business-hint">
                            <strong>@_form.BusinessType</strong>
                            <span>@GetBusinessTypeDescription(_form.BusinessType)</span>
                        </div>

                        <div>
                            <label>Address</label>
                            <InputTextArea class="settings-input settings-textarea" @bind-Value="_form.Address" />
                        </div>

                        <div class="settings-two-col">
                            <div>
                                <label>Phone</label>
                                <InputText class="settings-input" @bind-Value="_form.Phone" />
                            </div>

                            <div>
                                <label>Email</label>
                                <InputText class="settings-input" @bind-Value="_form.Email" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="settings-panel">
                    <div class="settings-panel-header">
                        <h2>Currency & Tax</h2>
                        <p>Control how prices, tax and receipts display.</p>
                    </div>

                    <div class="settings-form">
                        <div class="settings-two-col">
                            <div>
                                <label>Currency Code</label>
                                <InputText class="settings-input" @bind-Value="_form.CurrencyCode" />
                            </div>

                            <div>
                                <label>Currency Symbol</label>
                                <InputText class="settings-input" @bind-Value="_form.CurrencySymbol" />
                            </div>
                        </div>

                        <label class="settings-switch-row">
                            <InputCheckbox @bind-Value="_form.TaxEnabled" />
                            <span>
                                <strong>Enable Tax / VAT</strong>
                                <small>Apply tax calculation rules to sales later.</small>
                            </span>
                        </label>

                        <div class="settings-two-col">
                            <div>
                                <label>Tax Name</label>
                                <InputText class="settings-input" @bind-Value="_form.TaxName" />
                            </div>

                            <div>
                                <label>Tax Rate %</label>
                                <InputNumber class="settings-input" @bind-Value="_form.TaxRate" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="settings-panel">
                    <div class="settings-panel-header">
                        <h2>Modules</h2>
                        <p>Choose which parts of the platform this business uses.</p>
                    </div>

                    <div class="settings-switch-list">
                        <label class="settings-switch-row">
                            <InputCheckbox @bind-Value="_form.ProductsEnabled" />
                            <span>
                                <strong>Products</strong>
                                <small>Enable product catalogue and item setup.</small>
                            </span>
                        </label>

                        <label class="settings-switch-row">
                            <InputCheckbox @bind-Value="_form.StockTrackingEnabled" />
                            <span>
                                <strong>Stock Tracking</strong>
                                <small>Track stock levels, stock movements and low-stock alerts.</small>
                            </span>
                        </label>

                        <label class="settings-switch-row">
                            <InputCheckbox @bind-Value="_form.ServicesEnabled" />
                            <span>
                                <strong>Services</strong>
                                <small>Useful for salons, repair shops and service businesses.</small>
                            </span>
                        </label>

                        <label class="settings-switch-row">
                            <InputCheckbox @bind-Value="_form.AppointmentsEnabled" />
                            <span>
                                <strong>Appointments</strong>
                                <small>Enable bookings and staff scheduling later.</small>
                            </span>
                        </label>

                        <label class="settings-switch-row">
                            <InputCheckbox @bind-Value="_form.CustomersEnabled" />
                            <span>
                                <strong>Customers</strong>
                                <small>Enable customer profiles and purchase history later.</small>
                            </span>
                        </label>

                        <label class="settings-switch-row">
                            <InputCheckbox @bind-Value="_form.AgeRestrictedProductsEnabled" />
                            <span>
                                <strong>Age-Restricted Products</strong>
                                <small>Useful for liquor stores and regulated products.</small>
                            </span>
                        </label>
                    </div>
                </div>

                <div class="settings-panel">
                    <div class="settings-panel-header">
                        <h2>POS Rules</h2>
                        <p>Set controls for checkout and stock handling.</p>
                    </div>

                    <div class="settings-switch-list">
                        <label class="settings-switch-row">
                            <InputCheckbox @bind-Value="_form.AllowDiscounts" />
                            <span>
                                <strong>Allow Discounts</strong>
                                <small>Users can apply discounts during sales.</small>
                            </span>
                        </label>

                        <label class="settings-switch-row">
                            <InputCheckbox @bind-Value="_form.AllowNegativeStock" />
                            <span>
                                <strong>Allow Negative Stock</strong>
                                <small>Allow sales even when stock is below zero.</small>
                            </span>
                        </label>

                        <label class="settings-switch-row">
                            <InputCheckbox @bind-Value="_form.RequireCustomerForSale" />
                            <span>
                                <strong>Require Customer for Sale</strong>
                                <small>Useful for service businesses and account customers.</small>
                            </span>
                        </label>
                    </div>
                </div>

                <div class="settings-panel settings-panel-wide">
                    <div class="settings-panel-header">
                        <h2>Receipt Settings</h2>
                        <p>Control the wording shown on printed sales slips.</p>
                    </div>

                    <div class="settings-form">
                        <div>
                            <label>Receipt Title</label>
                            <InputText class="settings-input" @bind-Value="_form.ReceiptTitle" />
                        </div>

                        <div>
                            <label>Footer Message</label>
                            <InputTextArea class="settings-input settings-textarea" @bind-Value="_form.ReceiptFooterMessage" />
                        </div>

                        <div>
                            <label>Return Policy Text</label>
                            <InputTextArea class="settings-input settings-textarea" @bind-Value="_form.ReturnPolicyText" />
                        </div>
                    </div>
                </div>
            </div>

            <ValidationSummary class="settings-validation" />

            <div class="settings-bottom-actions">
                <button type="button" class="settings-ghost-btn" @onclick="ReloadSettingsAsync">
                    <i class="bi bi-arrow-counterclockwise"></i>
                    Reset Changes
                </button>

                <button type="submit" class="settings-primary-btn" disabled="@_saving">
                    <i class="bi bi-check2-circle"></i>
                    @(_saving ? "Saving..." : "Save Settings")
                </button>
            </div>
        </EditForm>
    }
</section>

<style>
    .settings-page {
        animation: settingsIn .22s ease both;
    }

    .settings-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: 18px;
        margin-bottom: 18px;
    }

    .settings-kicker {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: #2563eb;
        font-size: .74rem;
        font-weight: 750;
        letter-spacing: .06em;
        text-transform: uppercase;
        margin-bottom: 8px;
    }

    .settings-header h1 {
        margin: 0;
        color: #0f172a;
        font-size: 1.45rem;
        font-weight: 680;
        letter-spacing: -.03em;
    }

    .settings-header p {
        margin: 6px 0 0;
        color: #64748b;
        font-size: .88rem;
    }

    .settings-primary-btn,
    .settings-ghost-btn {
        min-height: 38px;
        border-radius: 11px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 0 14px;
        font-size: .8rem;
        font-weight: 650;
        border: 0;
        transition: all .18s ease;
        white-space: nowrap;
    }

    .settings-primary-btn {
        color: #ffffff;
        background: #111827;
        box-shadow: 0 12px 24px rgba(15,23,42,.14);
    }

    .settings-ghost-btn {
        color: #475569;
        background: #ffffff;
        border: 1px solid #e5e7eb;
    }

    .settings-alert {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 14px;
        margin-bottom: 16px;
        border-radius: 14px;
        font-size: .84rem;
        font-weight: 600;
        border: 1px solid;
    }

        .settings-alert.success {
            color: #166534;
            background: #f0fdf4;
            border-color: #bbf7d0;
        }

        .settings-alert.danger {
            color: #991b1b;
            background: #fef2f2;
            border-color: #fecaca;
        }

        .settings-alert span {
            flex: 1;
        }

        .settings-alert button {
            border: 0;
            background: transparent;
            color: inherit;
        }

    .settings-snapshot {
        margin-bottom: 16px;
        border-radius: 22px;
        background: radial-gradient(circle at top right, rgba(37, 99, 235, .12), transparent 34%), linear-gradient(135deg, #ffffff, #f8fbff);
        border: 1px solid #e7edf5;
        box-shadow: 0 16px 34px rgba(15,23,42,.055);
        overflow: hidden;
    }

    .settings-snapshot-main {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 18px;
        padding: 20px;
        border-bottom: 1px solid #edf2f7;
    }

    .settings-snapshot-kicker {
        display: inline-flex;
        margin-bottom: 7px;
        color: #2563eb;
        font-size: .7rem;
        font-weight: 750;
        letter-spacing: .06em;
        text-transform: uppercase;
    }

    .settings-snapshot-main h2 {
        margin: 0;
        color: #0f172a;
        font-size: 1.18rem;
        font-weight: 720;
        letter-spacing: -.02em;
    }

    .settings-snapshot-main p {
        margin: 5px 0 0;
        color: #64748b;
        font-size: .84rem;
    }

    .settings-snapshot-badge {
        padding: 8px 11px;
        border-radius: 999px;
        background: #eef5ff;
        color: #2563eb;
        font-size: .76rem;
        font-weight: 750;
        white-space: nowrap;
    }

    .settings-snapshot-grid {
        display: grid;
        grid-template-columns: repeat(6, minmax(0, 1fr));
        gap: 10px;
        padding: 14px 18px;
        border-bottom: 1px solid #edf2f7;
    }

    .settings-snapshot-card {
        padding: 13px;
        border-radius: 16px;
        background: #ffffff;
        border: 1px solid #e7edf5;
    }

        .settings-snapshot-card span {
            display: block;
            color: #64748b;
            font-size: .72rem;
            font-weight: 650;
        }

        .settings-snapshot-card strong {
            display: block;
            margin-top: 4px;
            color: #0f172a;
            font-size: .86rem;
            font-weight: 720;
        }

    .settings-preview-row {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
        padding: 18px;
    }

    .settings-preview-card {
        padding: 15px;
        border-radius: 18px;
        background: #f8fafc;
        border: 1px solid #e7edf5;
    }

        .settings-preview-card h3 {
            margin: 0 0 10px;
            color: #0f172a;
            font-size: .9rem;
            font-weight: 720;
        }

    .settings-preview-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

        .settings-preview-tags span {
            display: inline-flex;
            min-height: 28px;
            align-items: center;
            padding: 0 10px;
            border-radius: 999px;
            font-size: .74rem;
            font-weight: 700;
        }

    .settings-tag-on {
        color: #15803d;
        background: #ecfdf5;
    }

    .settings-tag-off {
        color: #64748b;
        background: #f1f5f9;
    }

    .settings-receipt-mini {
        display: grid;
        gap: 5px;
        padding: 13px;
        border-radius: 14px;
        background: #ffffff;
        border: 1px dashed #cbd5e1;
    }

        .settings-receipt-mini strong {
            color: #0f172a;
            font-size: .9rem;
        }

        .settings-receipt-mini span {
            color: #334155;
            font-size: .78rem;
            font-weight: 700;
        }

        .settings-receipt-mini small,
        .settings-receipt-mini em {
            color: #64748b;
            font-size: .73rem;
            line-height: 1.4;
        }

    .settings-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 16px;
    }

    .settings-panel {
        background: #ffffff;
        border: 1px solid #e7edf5;
        border-radius: 20px;
        box-shadow: 0 16px 34px rgba(15,23,42,.055);
        overflow: hidden;
    }

    .settings-panel-wide {
        grid-column: 1 / -1;
    }

    .settings-panel-header {
        padding: 17px 18px;
        border-bottom: 1px solid #edf2f7;
    }

        .settings-panel-header h2 {
            margin: 0;
            color: #0f172a;
            font-size: .92rem;
            font-weight: 720;
        }

        .settings-panel-header p {
            margin: 4px 0 0;
            color: #94a3b8;
            font-size: .76rem;
        }

    .settings-form,
    .settings-switch-list {
        padding: 18px;
        display: grid;
        gap: 13px;
    }

    .settings-two-col {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
    }

    .settings-form label {
        display: block;
        margin-bottom: 6px;
        color: #475569;
        font-size: .77rem;
        font-weight: 700;
    }

    .settings-input {
        width: 100%;
        min-height: 40px;
        border-radius: 12px;
        border: 1px solid #e5e7eb;
        background: #ffffff;
        color: #0f172a;
        padding: 0 12px;
        font-size: .84rem;
        outline: none;
    }

    .settings-textarea {
        min-height: 86px;
        padding-top: 10px;
        resize: vertical;
    }

    .settings-business-hint,
    .settings-switch-row {
        padding: 13px;
        border-radius: 16px;
        background: #f8fafc;
        border: 1px solid #e7edf5;
    }

        .settings-business-hint strong,
        .settings-business-hint span {
            display: block;
        }

        .settings-business-hint strong {
            color: #0f172a;
            font-size: .86rem;
        }

        .settings-business-hint span {
            margin-top: 3px;
            color: #64748b;
            font-size: .76rem;
        }

    .settings-switch-row {
        display: flex;
        gap: 11px;
        align-items: flex-start;
        cursor: pointer;
    }

        .settings-switch-row input {
            margin-top: 4px;
        }

        .settings-switch-row strong,
        .settings-switch-row small {
            display: block;
        }

        .settings-switch-row strong {
            color: #0f172a;
            font-size: .84rem;
            font-weight: 720;
        }

        .settings-switch-row small {
            margin-top: 2px;
            color: #64748b;
            font-size: .74rem;
            line-height: 1.35;
        }

    .settings-validation {
        margin-top: 16px;
        padding: 12px 14px;
        border-radius: 14px;
        background: #fef2f2;
        color: #991b1b;
        font-size: .82rem;
    }

    .settings-bottom-actions {
        margin-top: 16px;
        display: flex;
        justify-content: flex-end;
        gap: 10px;
    }

    .settings-empty {
        padding: 34px 20px;
        border-radius: 16px;
        background: #ffffff;
        border: 1px dashed #dbe3ef;
        text-align: center;
    }

        .settings-empty strong,
        .settings-empty span {
            display: block;
        }

        .settings-empty strong {
            color: #0f172a;
            font-size: .9rem;
        }

        .settings-empty span {
            margin-top: 4px;
            color: #64748b;
            font-size: .78rem;
        }

    @@keyframes settingsIn {
        from {
            opacity: 0;
            transform: translateY(8px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@media (max-width: 1199px) {
        .settings-snapshot-grid {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }
    }

    @@media (max-width: 991px) {
        .settings-grid,
        .settings-two-col,
        .settings-preview-row {
            grid-template-columns: 1fr;
        }

        .settings-header,
        .settings-snapshot-main {
            flex-direction: column;
            align-items: flex-start;
        }

            .settings-header .settings-primary-btn {
                width: 100%;
            }

        .settings-snapshot-badge {
            width: fit-content;
        }
    }

    @@media (max-width: 640px) {
        .settings-snapshot-grid {
            grid-template-columns: 1fr;
        }

        .settings-bottom-actions {
            flex-direction: column-reverse;
        }

            .settings-bottom-actions button {
                width: 100%;
            }
    }
</style>

@code {
    private BusinessSettingsFormModel _form = new();
    private List<BusinessTypeOptionViewModel> _businessTypes = new();

    private bool _loading = true;
    private bool _saving;

    private string? _message;
    private bool _isSuccess;

    protected override async Task OnInitializedAsync()
    {
        if (!await UserAccessService.CanAccessAsync("settings"))
        {
            NavigationManager.NavigateTo("/dashboard");
            return;
        }

        _businessTypes = BusinessSettingsService.GetBusinessTypes();
        await ReloadSettingsAsync();
    }

    private async Task ReloadSettingsAsync()
    {
        _loading = true;
        _form = await BusinessSettingsService.GetSettingsAsync();
        _loading = false;
    }

    private async Task SaveSettingsAsync()
    {
        _saving = true;

        var result = await BusinessSettingsService.SaveSettingsAsync(_form);

        _saving = false;
        _message = result.Message;
        _isSuccess = result.Success;
    }

    private void ClearMessage()
    {
        _message = null;
    }

    private string GetBusinessTypeDescription(string businessType)
    {
        return _businessTypes.FirstOrDefault(x => x.Name == businessType)?.Description
            ?? "Flexible setup for this business.";
    }

    private string YesNo(bool value)
    {
        return value ? "Enabled" : "Disabled";
    }

    private string GetTagClass(bool enabled)
    {
        return enabled ? "settings-tag-on" : "settings-tag-off";
    }

    private string GetTaxLabel()
    {
        if (!_form.TaxEnabled)
        {
            return "Disabled";
        }

        var taxName = string.IsNullOrWhiteSpace(_form.TaxName) ? "Tax" : _form.TaxName;
        return $"{taxName} {_form.TaxRate:0.##}%";
    }
}