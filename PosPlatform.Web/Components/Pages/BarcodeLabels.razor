    .labels-product-cell strong,
    .labels-product-cell span {
        display: block;
    }

    .labels-product-cell strong {
        color: #0f172a;
        font-size: .85rem;
        font-weight: 720;
    }

    .labels-product-cell span {
        margin-top: 2px;
        color: #94a3b8;
        font-size: .72rem;
    }

    .labels-code {
        display: inline-flex;
        min-height: 27px;
        align-items: center;
        padding: 0 9px;
        border-radius: 999px;
        color: #475569;
        background: #f8fafc;
        border: 1px solid #e7edf5;
        font-size: .72rem;
        font-weight: 650;
    }

    .labels-price {
        color: #0f172a;
        font-weight: 750;
    }

    .labels-pill {
        display: inline-flex;
        min-height: 27px;
        align-items: center;
        padding: 0 9px;
        border-radius: 999px;
        font-size: .72rem;
        font-weight: 750;
    }

        .labels-pill.active {
            color: #15803d;
            background: #ecfdf5;
        }

        .labels-pill.inactive {
            color: #64748b;
            background: #f1f5f9;
        }

    .labels-queue {
        padding: 14px 18px;
        display: grid;
        gap: 10px;
    }

    .labels-queue-item {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 76px auto;
        gap: 10px;
        align-items: center;
        padding: 13px;
        border-radius: 16px;
        background: #f8fafc;
        border: 1px solid #e7edf5;
    }

        .labels-queue-item strong,
        .labels-queue-item span,
        .labels-queue-item small {
            display: block;
        }

        .labels-queue-item strong {
            color: #0f172a;
            font-size: .84rem;
            font-weight: 720;
        }

        .labels-queue-item span {
            margin-top: 3px;
            color: #64748b;
            font-size: .72rem;
        }

        .labels-queue-item small {
            margin-top: 4px;
            color: #111827;
            font-size: .78rem;
            font-weight: 750;
