        background: #fef2f2;
        color: #dc2626;
    }

    .labels-print-footer {
        padding: 14px 18px 18px;
        border-top: 1px solid #edf2f7;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
    }

        .labels-print-footer span,
        .labels-print-footer strong {
            display: block;
        }

        .labels-print-footer span {
            color: #64748b;
            font-size: .72rem;
            font-weight: 650;
        }

        .labels-print-footer strong {
            margin-top: 3px;
            color: #0f172a;
            font-size: .96rem;
            font-weight: 750;
        }

    .labels-empty {
        margin: 18px;
        padding: 34px 20px;
        border-radius: 16px;
        background: #f8fafc;
        border: 1px dashed #dbe3ef;
        text-align: center;
    }

        .labels-empty strong,
        .labels-empty span {
            display: block;
        }

        .labels-empty strong {
            color: #0f172a;
            font-size: .9rem;
        }

        .labels-empty span {
            margin-top: 4px;
            color: #64748b;
            font-size: .78rem;
        }

    @@keyframes labelsIn {
        from {
            opacity: 0;
            transform: translateY(8px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@media (max-width: 1199px) {
        .labels-grid,
        .labels-settings-strip {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 768px) {
        .labels-header,
        .labels-panel-header,
        .labels-print-footer {
            flex-direction: column;
            align-items: flex-start;
        }

            .labels-header .labels-primary-btn,
            .labels-print-footer .labels-primary-btn {
                width: 100%;
            }

        .labels-barcode-row,
        .labels-control-panel {
            grid-template-columns: 1fr;
        }

            .labels-barcode-row button,
            .labels-control-panel button {
                width: 100%;
            }

        .labels-queue-item {
            grid-template-columns: 1fr;
        }

        .labels-remove-btn {
            width: 100%;
        }
    }
</style>

@code {
    private BusinessSettingsFormModel _settings = new();
    private List<ProductListItemViewModel> _products = new();
    private List<BarcodeLabelQueueItem> _queue = new();

    private bool _loading = true;
    private bool _barcodeScanning;

    private string? _searchTerm;
    private string? _barcodeValue;

    private string? _message;
    private bool _isSuccess;

    private string CurrencyLabel =>
        string.IsNullOrWhiteSpace(_settings.CurrencySymbol)
            ? "R"
            : _settings.CurrencySymbol;

    private int TotalLabels =>
        _queue.Sum(x => x.Quantity < 1 ? 0 : x.Quantity);

    protected override async Task OnInitializedAsync()
    {
        if (!await UserAccessService.CanAccessAsync("barcode-labels"))
        {
            NavigationManager.NavigateTo("/dashboard");
            return;
        }

        _settings = await BusinessSettingsService.GetSettingsAsync();
        await LoadProductsAsync();
    }

    private async Task LoadProductsAsync()
    {
        _loading = true;
        _products = await ProductService.GetProductsAsync(_searchTerm);
        _loading = false;
    }

    private async Task HandleBarcodeKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await ScanBarcodeAsync();
        }
    }

    private async Task ScanBarcodeAsync()
    {
        var code = _barcodeValue?.Trim();

        if (string.IsNullOrWhiteSpace(code))
        {
            ShowMessage("Scan or type a barcode/SKU first.", false);
            return;
        }

        _barcodeScanning = true;

        _searchTerm = code;
        await LoadProductsAsync();

        _barcodeScanning = false;

        if (_products.Count == 0)
        {
            ShowMessage($"No item found for barcode or SKU: {code}", false);
            return;
        }

        if (_products.Count == 1)
        {
            AddToQueue(_products[0]);
            _barcodeValue = null;
            ShowMessage($"{_products[0].ProductName} added to label queue.", true);
            return;
        }

        _barcodeValue = null;
        ShowMessage($"{_products.Count} items found for: {code}. Select the correct one.", true);
    }

    private async Task ResetSearchAsync()
    {
        _searchTerm = null;
        _barcodeValue = null;
        await LoadProductsAsync();
    }

    private void AddToQueue(ProductListItemViewModel product)
    {
        var code = GetPrintableCode(product);

        if (string.IsNullOrWhiteSpace(code))
        {
            ShowMessage("This product does not have a barcode or SKU to print.", false);
            return;
        }

        var existing = _queue.FirstOrDefault(x => x.ProductId == product.Id);

        if (existing != null)
        {
            existing.Quantity += 1;
            ShowMessage($"{product.ProductName} label quantity increased.", true);
            return;
        }

        _queue.Add(new BarcodeLabelQueueItem
        {
            ProductId = product.Id,
            ProductName = product.ProductName,
            SKU = product.SKU,
            Barcode = product.Barcode,
            Code = code,
            SellingPrice = product.SellingPrice,
            Quantity = 1
        });

        ShowMessage($"{product.ProductName} added to label queue.", true);
    }

    private void RemoveFromQueue(BarcodeLabelQueueItem item)
    {
        _queue.Remove(item);
    }

    private void ClearQueue()
    {
        _queue.Clear();
    }

    private async Task PrintLabelsAsync()
    {
        var printable = _queue
            .Where(x => x.Quantity > 0 && !string.IsNullOrWhiteSpace(x.Code))
            .ToList();

        if (printable.Count == 0)
        {
            ShowMessage("Add at least one label before printing.", false);
            return;
        }

        await JS.InvokeVoidAsync("barcodeLabels.print", printable, CurrencyLabel);
    }

    private string? GetPrintableCode(ProductListItemViewModel product)
    {
        return !string.IsNullOrWhiteSpace(product.Barcode)
            ? product.Barcode.Trim()
            : !string.IsNullOrWhiteSpace(product.SKU)
                ? product.SKU.Trim()
                : null;
    }

    private string Money(decimal value)
    {
        return $"{CurrencyLabel} {value:0.00}";
    }

    private void ShowMessage(string message, bool success)
    {
        _message = message;
        _isSuccess = success;
    }

    private void ClearMessage()
    {
        _message = null;
    }

    private string GetInitials(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "P";
        }

        var words = value
            .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Take(2)
            .Select(x => x[0].ToString().ToUpper());

        return string.Join("", words);
    }

    private class BarcodeLabelQueueItem
    {
        public int ProductId { get; set; }
        public string ProductName { get; set; } = string.Empty;
        public string SKU { get; set; } = string.Empty;
