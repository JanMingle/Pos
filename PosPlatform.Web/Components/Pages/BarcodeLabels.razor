@page "/barcode-labels"
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@rendermode InteractiveServer
@layout MainLayout
@attribute [Authorize]
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@using PosPlatform.Web.Components.Layout
@using PosPlatform.Web.Models.Products
@using PosPlatform.Web.Models.Settings
@using PosPlatform.Web.Services
@inject ProductService ProductService
@inject BusinessSettingsService BusinessSettingsService
@inject UserAccessService UserAccessService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<PageTitle>Barcode Labels</PageTitle>

<section class="labels-page">
    <div class="labels-header">
        <div>
            <div class="labels-kicker">
                <i class="bi bi-upc-scan"></i>
                Barcode printing
            </div>
            <h1>Barcode Labels</h1>
            <p>Search products, add them to a print queue, choose quantity and print barcode labels.</p>
        </div>

        <button type="button"
                class="labels-primary-btn"
                disabled="@(_queue.Count == 0)"
                @onclick="PrintLabelsAsync">
            <i class="bi bi-printer"></i>
            Print Labels
        </button>
    </div>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <div class="labels-alert @(_isSuccess ? "success" : "danger")">
            <i class="bi @(_isSuccess ? "bi-check-circle" : "bi-exclamation-triangle")"></i>
            <span>@_message</span>
            <button type="button" @onclick="ClearMessage">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
    }

    <div class="labels-settings-strip">
        <div>
            <span>Business</span>
            <strong>@_settings.BusinessName</strong>
        </div>

        <div>
            <span>Currency</span>
            <strong>@_settings.CurrencyCode · @CurrencyLabel</strong>
        </div>

        <div>
            <span>Products</span>
            <strong>@_products.Count loaded</strong>
        </div>

        <div>
            <span>Queue</span>
            <strong>@TotalLabels label@((TotalLabels == 1) ? "" : "s")</strong>
        </div>
    </div>

    <div class="labels-barcode-row">
        <div class="labels-barcode-box">
            <i class="bi bi-upc-scan"></i>
            <input @bind="_barcodeValue"
                   @bind:event="oninput"
                   @onkeydown="HandleBarcodeKeyDown"
                   placeholder="Scan barcode or type SKU, then press Enter" />
        </div>

        <button type="button"
                class="labels-primary-btn"
                disabled="@_barcodeScanning"
                @onclick="ScanBarcodeAsync">
            <i class="bi bi-upc"></i>
            @(_barcodeScanning ? "Checking..." : "Find Item")
        </button>
    </div>

    <div class="labels-control-panel">
        <div class="labels-search">
            <i class="bi bi-search"></i>
            <input @bind="_searchTerm"
                   @bind:event="oninput"
                   placeholder="Search by product name, SKU, barcode or type" />
        </div>

        <button type="button" class="labels-secondary-btn" @onclick="LoadProductsAsync">
            <i class="bi bi-search"></i>
            Search
        </button>

        <button type="button" class="labels-ghost-btn" @onclick="ResetSearchAsync">
            <i class="bi bi-arrow-counterclockwise"></i>
            Reset
        </button>
    </div>

    <div class="labels-grid">
        <div class="labels-panel">
            <div class="labels-panel-header">
                <div>
                    <h2>Products</h2>
                    <p>Select products to add to the label queue.</p>
                </div>
            </div>

            @if (_loading)
            {
                <div class="labels-empty">
                    <strong>Loading products...</strong>
                    <span>Please wait while we fetch catalogue items.</span>
                </div>
            }
            else if (_products.Count == 0)
            {
                <div class="labels-empty">
                    <strong>No products found</strong>
                    <span>Search by product name, SKU or barcode.</span>
                </div>
            }
            else
            {
                <div class="labels-table-wrap">
                    <table class="labels-table">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th>SKU</th>
                                <th>Barcode</th>
                                <th>Price</th>
                                <th>Status</th>
                                <th class="text-end">Action</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in _products)
                            {
                                <tr>
                                    <td>
                                        <div class="labels-product-cell">
                                            <div class="labels-avatar">@GetInitials(item.ProductName)</div>
                                            <div>
                                                <strong>@item.ProductName</strong>
                                                <span>@item.ProductType</span>
                                            </div>
                                        </div>
                                    </td>

                                    <td>
                                        <span class="labels-code">@item.SKU</span>
                                    </td>

                                    <td>
                                        <span class="labels-code">
                                            @(string.IsNullOrWhiteSpace(item.Barcode) ? "No barcode" : item.Barcode)
                                        </span>
                                    </td>

                                    <td class="labels-price">@Money(item.SellingPrice)</td>

                                    <td>
                                        <span class="labels-pill @(item.IsActive ? "active" : "inactive")">
                                            @(item.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </td>

                                    <td class="text-end">
                                        <button type="button"
                                                class="labels-mini-btn"
                                                disabled="@string.IsNullOrWhiteSpace(GetPrintableCode(item))"
                                                @onclick="() => AddToQueue(item)">
                                            Add Label
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <div class="labels-panel">
            <div class="labels-panel-header">
                <div>
                    <h2>Print Queue</h2>
                    <p>@_queue.Count product@((_queue.Count == 1) ? "" : "s") selected.</p>
                </div>

                @if (_queue.Count > 0)
                {
                    <button type="button" class="labels-ghost-btn small" @onclick="ClearQueue">
                        Clear
                    </button>
                }
            </div>

            @if (_queue.Count == 0)
            {
                <div class="labels-empty">
                    <strong>No labels selected</strong>
                    <span>Add products from the list to prepare labels for printing.</span>
                </div>
            }
            else
            {
                <div class="labels-queue">
                    @foreach (var item in _queue)
                    {
                        <div class="labels-queue-item">
                            <div>
                                <strong>@item.ProductName</strong>
                                <span>@item.Code</span>
                                <small>@Money(item.SellingPrice)</small>
                            </div>

                            <div class="labels-qty-box">
                                <label>Qty</label>
                                <input type="number" min="1" max="500" @bind="item.Quantity" />
                            </div>

                            <button type="button" class="labels-remove-btn" @onclick="() => RemoveFromQueue(item)">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    }
                </div>

                <div class="labels-print-footer">
                    <div>
                        <span>Total labels</span>
                        <strong>@TotalLabels</strong>
                    </div>

                    <button type="button" class="labels-primary-btn" @onclick="PrintLabelsAsync">
                        <i class="bi bi-printer"></i>
                        Print Labels
                    </button>
                </div>
            }
        </div>
    </div>
</section>

<style>
    .labels-page {
        animation: labelsIn .22s ease both;
    }

    .labels-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: 18px;
        margin-bottom: 18px;
    }

    .labels-kicker {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: #2563eb;
        font-size: .74rem;
        font-weight: 750;
        letter-spacing: .06em;
        text-transform: uppercase;
        margin-bottom: 8px;
    }

    .labels-header h1 {
        margin: 0;
        color: #0f172a;
        font-size: 1.45rem;
        font-weight: 680;
        letter-spacing: -.03em;
    }

    .labels-header p {
        margin: 6px 0 0;
        color: #64748b;
        font-size: .88rem;
    }

    .labels-primary-btn,
    .labels-secondary-btn,
    .labels-ghost-btn,
    .labels-mini-btn {
