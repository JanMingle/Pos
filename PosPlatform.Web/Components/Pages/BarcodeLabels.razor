    .labels-barcode-box input {
        font-weight: 650;
    }

    .labels-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.35fr) minmax(340px, .65fr);
        gap: 16px;
        align-items: start;
    }

    .labels-panel {
        background: #ffffff;
        border: 1px solid #e7edf5;
        border-radius: 20px;
        box-shadow: 0 16px 34px rgba(15,23,42,.055);
        overflow: hidden;
    }

    .labels-panel-header {
        padding: 17px 18px;
        border-bottom: 1px solid #edf2f7;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
    }

        .labels-panel-header h2 {
            margin: 0;
            color: #0f172a;
            font-size: .92rem;
            font-weight: 720;
        }

        .labels-panel-header p {
            margin: 4px 0 0;
            color: #94a3b8;
            font-size: .76rem;
        }

    .labels-table-wrap {
        overflow-x: auto;
    }

    .labels-table {
        width: 100%;
        min-width: 840px;
        border-collapse: collapse;
    }

        .labels-table th {
            padding: 12px 16px;
            background: #f8fafc;
            color: #64748b;
            font-size: .7rem;
            font-weight: 750;
            text-transform: uppercase;
            letter-spacing: .05em;
            border-bottom: 1px solid #e7edf5;
            white-space: nowrap;
        }

        .labels-table td {
            padding: 14px 16px;
            color: #334155;
            font-size: .82rem;
            border-bottom: 1px solid #f1f5f9;
            vertical-align: middle;
        }

    .labels-product-cell {
        display: flex;
        align-items: center;
        gap: 11px;
    }

    .labels-avatar {
        width: 38px;
        height: 38px;
        border-radius: 14px;
        background: #eef5ff;
        color: #2563eb;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .78rem;
        font-weight: 750;
