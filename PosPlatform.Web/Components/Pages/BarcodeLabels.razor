            opacity: .55;
            cursor: not-allowed;
        }

    .labels-secondary-btn {
        color: #2563eb;
        background: #eef5ff;
    }

    .labels-ghost-btn {
        color: #475569;
        background: #ffffff;
        border: 1px solid #e5e7eb;
    }

        .labels-ghost-btn.small {
            min-height: 32px;
            padding: 0 10px;
            font-size: .74rem;
        }

    .labels-mini-btn {
        min-height: 30px;
        color: #2563eb;
        background: #eff6ff;
        border: 1px solid #bfdbfe;
        padding: 0 10px;
    }

    .labels-alert {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 14px;
        margin-bottom: 16px;
        border-radius: 14px;
        font-size: .84rem;
        font-weight: 600;
        border: 1px solid;
    }

        .labels-alert.success {
            color: #166534;
            background: #f0fdf4;
            border-color: #bbf7d0;
        }

        .labels-alert.danger {
            color: #991b1b;
            background: #fef2f2;
            border-color: #fecaca;
        }

        .labels-alert span {
            flex: 1;
        }

        .labels-alert button {
            border: 0;
            background: transparent;
            color: inherit;
        }

    .labels-settings-strip {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 10px;
        margin-bottom: 16px;
    }

        .labels-settings-strip div {
            padding: 13px;
            border-radius: 16px;
            background: #ffffff;
            border: 1px solid #e7edf5;
            box-shadow: 0 12px 28px rgba(15,23,42,.04);
        }

        .labels-settings-strip span,
        .labels-settings-strip strong {
            display: block;
        }

        .labels-settings-strip span {
            color: #64748b;
            font-size: .72rem;
            font-weight: 650;
        }

        .labels-settings-strip strong {
            margin-top: 4px;
            color: #0f172a;
            font-size: .84rem;
            font-weight: 720;
        }

    .labels-barcode-row,
    .labels-control-panel {
        display: grid;
        grid-template-columns: minmax(240px, 1fr) auto auto;
        gap: 10px;
        padding: 14px;
        margin-bottom: 16px;
        border-radius: 18px;
        background: #ffffff;
        border: 1px solid #e7edf5;
        box-shadow: 0 12px 28px rgba(15,23,42,.045);
    }

    .labels-barcode-row {
        grid-template-columns: minmax(240px, 1fr) auto;
    }

    .labels-barcode-box {
        min-height: 44px;
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 0 13px;
        border-radius: 14px;
        background: #ecfdf5;
        border: 1px solid #bbf7d0;
        color: #15803d;
    }

    .labels-search {
        min-height: 40px;
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 0 13px;
        border-radius: 12px;
        background: #f8fafc;
        border: 1px solid #e5e7eb;
        color: #94a3b8;
