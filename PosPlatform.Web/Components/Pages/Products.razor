@code {
    private List<ProductListItemViewModel> _products = new();
    private List<ProductCategoryOptionViewModel> _categories = new();
    private ProductFormModel _form = new();
    private BusinessSettingsFormModel _settings = new();

    private bool _loading = true;
    private string? _searchTerm;
    private string _statusFilter = "all";
    private string? _barcodeValue;
    private bool _barcodeScanning;
    private string? _message;
    private bool _isSuccess;
    private bool _showModal;
    private bool _showDeleteConfirm;
    private int _deleteId;
    private string _deleteProductName = string.Empty;

    private bool ProductsEnabled => _settings.ProductsEnabled;
    private bool StockEnabled => _settings.StockTrackingEnabled;
    private bool ServicesEnabled => _settings.ServicesEnabled;
    private bool AgeRestrictedEnabled => _settings.AgeRestrictedProductsEnabled;
    private bool CatalogueEnabled => ProductsEnabled || ServicesEnabled;

    private string CatalogueTitle => ServicesEnabled ? "Products & Services" : "Products";

    private string CatalogueDescription => ServicesEnabled
        ? "Manage physical products, services, pricing, stock rules and item availability."
        : "Manage pricing, stock levels, categories and product availability from one place.";

    private string AddButtonText => ServicesEnabled && !ProductsEnabled
        ? "Add Service"
        : ServicesEnabled
            ? "Add Item"
            : "Add Product";

    private string CurrencyLabel =>
        string.IsNullOrWhiteSpace(_settings.CurrencySymbol)
            ? "R"
            : _settings.CurrencySymbol;

    private List<string> ProductTypeOptions
    {
        get
        {
            var options = new List<string>();

            if (ProductsEnabled)
            {
                options.Add("Physical Product");
                options.Add("Package / Bundle");
                options.Add("Voucher");
                options.Add("Digital Product");
            }

            if (ServicesEnabled)
            {
                options.Add("Service");
            }

            if (!options.Contains(_form.ProductType) && !string.IsNullOrWhiteSpace(_form.ProductType))
            {
                options.Add(_form.ProductType);
            }

            return options.Count == 0 ? new List<string> { "Physical Product" } : options;
        }
    }

    private bool CanTrackStockForCurrentForm =>
        StockEnabled &&
        _form.TrackStock &&
        IsStockTrackableType(_form.ProductType);

    private int TotalProducts => _products.Count;
    private int ActiveProducts => _products.Count(x => x.IsActive);
    private int LowStockProducts => StockEnabled ? _products.Count(x => x.TrackStock && x.QuantityInStock <= x.ReorderLevel) : 0;
    private decimal InventoryValue => _products.Where(x => x.TrackStock).Sum(x => x.QuantityInStock * x.CostPrice);

    private List<ProductListItemViewModel> VisibleProducts =>
        _statusFilter switch
        {
            "active" => _products.Where(x => x.IsActive).ToList(),
            "inactive" => _products.Where(x => !x.IsActive).ToList(),
            "physical" => _products.Where(x => x.ProductType == "Physical Product").ToList(),
            "service" => _products.Where(x => x.ProductType == "Service").ToList(),
            "package" => _products.Where(x => x.ProductType == "Package / Bundle").ToList(),
            "voucher" => _products.Where(x => x.ProductType == "Voucher").ToList(),
            "digital" => _products.Where(x => x.ProductType == "Digital Product").ToList(),
            "low" when StockEnabled => _products.Where(x => x.TrackStock && x.QuantityInStock <= x.ReorderLevel).ToList(),
            "age" when AgeRestrictedEnabled => _products.Where(x => x.AgeRestricted).ToList(),
            _ => _products
        };

    protected override async Task OnInitializedAsync()
    {
        if (!await UserAccessService.CanAccessAsync("products"))
        {
            NavigationManager.NavigateTo("/dashboard");
            return;
        }

        _settings = await BusinessSettingsService.GetSettingsAsync();

        if (!CatalogueEnabled)
        {
            _loading = false;
            return;
        }

        await LoadCategories();
        await LoadProducts();
    }

    private async Task LoadProducts()
    {
        _loading = true;
        _products = await ProductService.GetProductsAsync(_searchTerm);
        _loading = false;
    }

    private async Task HandleBarcodeKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await ScanBarcodeAsync();
        }
    }

    private async Task ScanBarcodeAsync()
    {
        var code = _barcodeValue?.Trim();

        if (string.IsNullOrWhiteSpace(code))
        {
            ShowMessage("Scan or type a barcode/SKU first.", false);
            return;
        }

        _barcodeScanning = true;

        _searchTerm = code;
        _statusFilter = "all";

        await LoadProducts();

        _barcodeScanning = false;

        if (VisibleProducts.Count == 0)
        {
            ShowMessage($"No item found for barcode or SKU: {code}", false);
            return;
        }

        ShowMessage($"{VisibleProducts.Count} item found for: {code}", true);
        _barcodeValue = null;
    }

    private async Task LoadCategories()
    {
        _categories = await ProductService.GetCategoriesAsync();
    }

    private void OpenAddModal()
    {
        var defaultType = ServicesEnabled && !ProductsEnabled
            ? "Service"
            : "Physical Product";

        _form = new ProductFormModel
        {
            IsActive = true,
            ProductType = defaultType,
            TrackStock = StockEnabled && IsStockTrackableType(defaultType),
            UnitOfMeasure = defaultType == "Service" ? "Service" : "Each",
            QuantityInStock = 0,
            ReorderLevel = 0
        };

        _showModal = true;
    }

    private async Task OpenEditModal(int id)
    {
        var model = await ProductService.GetByIdAsync(id);

        if (model == null)
        {
            ShowMessage("Item not found.", false);
            return;
        }

        _form = model;

        if (!IsStockTrackableType(_form.ProductType))
        {
            _form.TrackStock = false;
        }

        _showModal = true;
    }

    private void CloseModal()
    {
        _showModal = false;
        _form = new ProductFormModel();
    }

    private async Task SaveProductAsync()
    {
        if (!IsStockTrackableType(_form.ProductType) || !StockEnabled)
        {
            _form.TrackStock = false;
            _form.QuantityInStock = 0;
            _form.ReorderLevel = 0;
        }

        if (_form.ProductType != "Service")
        {
            _form.DurationMinutes = null;
        }

        if (!AgeRestrictedEnabled)
        {
            _form.AgeRestricted = false;
        }

        var result = await ProductService.SaveAsync(_form);
        ShowMessage(result.Message, result.Success);

        if (result.Success)
        {
            _showModal = false;
            _form = new ProductFormModel();
            await LoadProducts();
        }
    }

    private async Task ToggleStatus(int id)
    {
        var result = await ProductService.ToggleStatusAsync(id);
        ShowMessage(result.Message, result.Success);

        if (result.Success)
        {
            await LoadProducts();
        }
    }

    private void ConfirmDelete(int id, string productName)
    {
        _deleteId = id;
        _deleteProductName = productName;
        _showDeleteConfirm = true;
    }

    private void CancelDelete()
    {
        _showDeleteConfirm = false;
        _deleteId = 0;
        _deleteProductName = string.Empty;
    }

    private async Task DeleteConfirmed()
    {
        var result = await ProductService.DeleteAsync(_deleteId);
        ShowMessage(result.Message, result.Success);

        _showDeleteConfirm = false;
        _deleteId = 0;
        _deleteProductName = string.Empty;

        if (result.Success)
        {
            await LoadProducts();
        }
    }

    private async Task ClearFilters()
    {
        _searchTerm = null;
        _barcodeValue = null;
        _statusFilter = "all";
        await LoadProducts();
    }

    private void HandleProductTypeChanged(ChangeEventArgs e)
    {
        var selected = e.Value?.ToString() ?? "Physical Product";

        _form.ProductType = selected;

        if (!IsStockTrackableType(selected))
        {
            _form.TrackStock = false;
            _form.QuantityInStock = 0;
            _form.ReorderLevel = 0;
        }
        else
        {
            _form.TrackStock = StockEnabled;
        }

        if (selected == "Service")
        {
            _form.UnitOfMeasure = "Service";
            _form.DurationMinutes ??= 30;
        }
        else if (string.IsNullOrWhiteSpace(_form.UnitOfMeasure) || _form.UnitOfMeasure == "Service")
        {
            _form.UnitOfMeasure = "Each";
            _form.DurationMinutes = null;
        }
    }

    private bool IsStockTrackableType(string? productType)
    {
        return productType is "Physical Product" or "Package / Bundle" or "Voucher";
    }

    private string GetProductTypeClass(string? productType)
    {
        return productType switch
        {
            "Physical Product" => "physical",
            "Service" => "service",
            "Package / Bundle" => "package",
            "Voucher" => "voucher",
            "Digital Product" => "digital",
            _ => "physical"
        };
    }

    private string GetUnitLabel(string? unit)
    {
        return string.IsNullOrWhiteSpace(unit) ? "" : unit;
    }

    private void ShowMessage(string message, bool success)
    {
        _message = message;
        _isSuccess = success;
    }

    private void ClearMessage()
    {
        _message = null;
    }

    private string Money(decimal value)
    {
        var symbol = string.IsNullOrWhiteSpace(_settings.CurrencySymbol)
            ? "R"
            : _settings.CurrencySymbol;

        return $"{symbol} {value:0.00}";
    }

    private string GetInitials(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "P";
        }

        var words = value
            .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Take(2)
            .Select(x => x[0].ToString().ToUpper());

        return string.Join("", words);
    }
}