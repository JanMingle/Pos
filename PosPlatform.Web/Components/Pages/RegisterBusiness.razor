@page "/register-business"
@layout PublicLayout
@using PosPlatform.Web.Components.Layout
@inject NavigationManager Nav
@inject PosPlatform.Infrastructure.Data.AppDbContext Db
@using Microsoft.EntityFrameworkCore

<PageTitle>Register Business | JMingle</PageTitle>

@code {
    private string? Error => GetQueryValue("error");
    private List<PosPlatform.Domain.Entities.SubscriptionPlan> Plans = new();

    protected override async Task OnInitializedAsync()
    {
        Plans = await Db.SubscriptionPlans
            .Where(x => x.IsActive)
            .OrderBy(x => x.PriceMonthly)
            .ToListAsync();
    }

    private string? GetQueryValue(string key)
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        return query.TryGetValue(key, out var value) ? value.ToString() : null;
    }
}

<div class="reg-shell">
    <div class="reg-card">
        <section class="reg-intro">
            <div class="reg-brand">
                <div class="reg-logo">J</div>
                <div>
                    <strong>JMingle</strong>
                    <span>Business registration</span>
                </div>
            </div>

            <div class="reg-copy">
                <span class="reg-kicker">
                    <i class="bi bi-stars"></i>
                    Start simple
                </span>

                <h1>Create your JMingle business account.</h1>

                <p>
                    Register with only the basic business and owner details. After verifying your email,
                    JMingle will guide you through VAT, modules, POS rules and receipt setup before opening the dashboard.
                </p>
            </div>

            <div class="reg-preview-card">
                <div class="reg-preview-top">
                    <div>
                        <span>Registration flow</span>
                        <strong>Simple onboarding</strong>
                    </div>

                    <div class="reg-preview-pill">3 steps</div>
                </div>

                <div class="reg-progress-line">
                    <div></div>
                </div>

                <div class="reg-preview-grid">
                    <div>
                        <span>Step 1</span>
                        <strong>Register</strong>
                    </div>

                    <div>
                        <span>Step 2</span>
                        <strong>Verify email</strong>
                    </div>

                    <div>
                        <span>Step 3</span>
                        <strong>Complete setup</strong>
                    </div>
                </div>
            </div>

            <div class="reg-steps">
                <div>
                    <strong>1</strong>
                    <span>Business details</span>
                </div>

                <div>
                    <strong>2</strong>
                    <span>Owner account</span>
                </div>

                <div>
                    <strong>3</strong>
                    <span>Email verification</span>
                </div>
            </div>
        </section>

        <section class="reg-form-panel">
            <div class="reg-form-header">
                <span>Register business</span>
                <h2>Create your JMingle account</h2>
                <p>You will complete business settings after email verification.</p>
            </div>

            @if (!string.IsNullOrWhiteSpace(Error))
            {
                <div class="reg-alert">
                    <i class="bi bi-exclamation-triangle"></i>
                    <span>@Error</span>
                </div>
            }

            <form method="post" action="/account/register-business" class="reg-form">
                <AntiforgeryToken />

                <div class="reg-section">
                    <div class="reg-section-heading">
                        <div class="reg-section-icon">
                            <i class="bi bi-building"></i>
                        </div>

                        <div>
                            <h3>Business Details</h3>
                            <p>Only the basic information needed to create your JMingle workspace.</p>
                        </div>
                    </div>

                    <div class="reg-grid">
                        <div>
                            <label>Business Name</label>
                            <input name="BusinessName" class="reg-input" required placeholder="Example: Thabo Mini Market" />
                        </div>

                        <div>
                            <label>Business Type</label>
                            <select name="BusinessType" class="reg-input" required>
                                <option value="">Select business type</option>
                                <option>General Business</option>
                                <option>Retail Store</option>
                                <option>Salon / Beauty</option>
                                <option>Liquor Store</option>
                                <option>Clothing Store</option>
                                <option>Service Business</option>
                                <option>Mini Market / Grocery</option>
                                <option>Restaurant / Cafe</option>
                                <option>Other</option>
                            </select>
                        </div>

                        <div>
                            <label>Business Email</label>
                            <input name="BusinessEmail" type="email" class="reg-input" required placeholder="business@email.co.za" />
                        </div>

                        <div>
                            <label>Business Phone</label>
                            <input name="BusinessPhone" class="reg-input" placeholder="+27..." />
                        </div>

                        <div class="reg-span-2">
                            <label>Business Address</label>
                            <input name="BusinessAddress" class="reg-input" placeholder="Street address, city, province" />
                        </div>
                    </div>
                </div>

                <div class="reg-section">
                    <div class="reg-section-heading">
                        <div class="reg-section-icon">
                            <i class="bi bi-shop"></i>
                        </div>

                        <div>
                            <h3>Main Branch</h3>
                            <p>JMingle will create your first branch automatically.</p>
                        </div>
                    </div>

                    <div class="reg-grid">
                        <div>
                            <label>Branch Name</label>
                            <input name="BranchName" class="reg-input" value="Main Branch" />
                        </div>

                        <div>
                            <label>Branch Code</label>
                            <input name="BranchCode" class="reg-input" value="MAIN" />
                        </div>
                    </div>
                </div>

                <div class="reg-section">
                    <div class="reg-section-heading">
                        <div class="reg-section-icon">
                            <i class="bi bi-person-badge"></i>
                        </div>

                        <div>
                            <h3>Owner Account</h3>
                            <p>This user will receive the verification email and owner access.</p>
                        </div>
                    </div>

                    <div class="reg-grid">
                        <div>
                            <label>Full Name</label>
                            <input name="OwnerFullName" class="reg-input" required placeholder="Owner full name" />
                        </div>

                        <div>
                            <label>Owner Email</label>
                            <input name="OwnerEmail" type="email" class="reg-input" required placeholder="owner@email.co.za" />
                        </div>

                        <div>
                            <label>Password</label>
                            <input name="Password" type="password" class="reg-input" required placeholder="Create password" />
                        </div>

                        <div>
                            <label>Plan</label>
                            <select name="SubscriptionPlanId" class="reg-input">
                                @if (Plans.Count == 0)
                                {
                                    <option value="">No active plan found</option>
                                }
                                else
                                {
                                    @foreach (var plan in Plans)
                                    {
                                        <option value="@plan.Id">@plan.Name - R @plan.PriceMonthly.ToString("0.00") / month</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>
                </div>

                <div class="reg-info-box">
                    <div>
                        <i class="bi bi-info-circle"></i>
                    </div>

                    <span>
                        After registration, verify your email. On your first login, JMingle will ask you to complete VAT, modules, POS rules and receipt settings before entering the dashboard.
                    </span>
                </div>

                <div class="reg-actions">
                    <a href="/login">Already have an account?</a>

                    <button type="submit" class="reg-submit">
                        Create Business Account
                        <i class="bi bi-arrow-right"></i>
                    </button>
                </div>
            </form>
        </section>
    </div>
</div>

<style>
    html,
    body {
        height: auto !important;
        min-height: 100%;
        overflow-y: auto !important;
        overflow-x: hidden !important;
    }

    .reg-shell {
        min-height: calc(100dvh - 90px);
        padding: 28px 24px 42px;
        background: radial-gradient(circle at 10% 5%, rgba(143, 166, 161, .24), transparent 28%), radial-gradient(circle at 90% 12%, rgba(37, 99, 235, .10), transparent 30%), linear-gradient(135deg, #ffffff 0%, #f6f7f9 48%, #f2f6f5 100%);
    }

    .reg-card {
        max-width: 1120px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 360px minmax(0, 1fr);
        border-radius: 32px;
        overflow: hidden;
        background: rgba(255, 255, 255, .96);
        border: 1px solid #e8eaef;
        box-shadow: 0 30px 90px rgba(17, 24, 39, .14);
        backdrop-filter: blur(18px);
    }

    .reg-intro {
        position: relative;
        padding: 34px;
        color: #ffffff;
        background: radial-gradient(circle at top right, rgba(143, 166, 161, .34), transparent 34%), radial-gradient(circle at bottom left, rgba(255, 255, 255, .10), transparent 30%), linear-gradient(135deg, #111827 0%, #252525 58%, #3a3a3a 100%);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        gap: 28px;
        overflow: hidden;
    }

        .reg-intro::after {
            content: "";
            position: absolute;
            inset: 0;
            background-image: linear-gradient(rgba(255,255,255,.045) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.045) 1px, transparent 1px);
            background-size: 34px 34px;
            mask-image: linear-gradient(180deg, rgba(0,0,0,.8), transparent 88%);
            pointer-events: none;
        }

    .reg-brand,
    .reg-copy,
    .reg-preview-card,
    .reg-steps {
        position: relative;
        z-index: 1;
    }

    .reg-brand {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .reg-logo {
        width: 46px;
        height: 46px;
        min-width: 46px;
        border-radius: 17px;
        background: #ffffff;
        color: #252525;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 850;
        box-shadow: 0 18px 40px rgba(0,0,0,.18);
    }

    .reg-brand strong,
    .reg-brand span {
        display: block;
    }

    .reg-brand strong {
        font-size: 1rem;
        font-weight: 800;
        letter-spacing: -.02em;
    }

    .reg-brand span {
        margin-top: 2px;
        color: rgba(255,255,255,.68);
        font-size: .72rem;
        font-weight: 650;
    }

    .reg-kicker {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        margin-bottom: 13px;
        padding: 8px 11px;
        border-radius: 999px;
        background: rgba(255,255,255,.12);
        border: 1px solid rgba(255,255,255,.16);
        color: rgba(255,255,255,.88);
        font-size: .7rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: .06em;
    }

    .reg-copy h1 {
        margin: 0;
        font-size: 1.85rem;
        line-height: 1.08;
        font-weight: 850;
        letter-spacing: -.055em;
    }

    .reg-copy p {
        margin: 14px 0 0;
        color: rgba(255,255,255,.74);
        font-size: .9rem;
        line-height: 1.7;
    }

    .reg-preview-card {
        padding: 16px;
        border-radius: 22px;
        background: rgba(255,255,255,.11);
        border: 1px solid rgba(255,255,255,.16);
        box-shadow: 0 22px 50px rgba(0,0,0,.14);
        backdrop-filter: blur(18px);
    }

    .reg-preview-top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 14px;
    }

        .reg-preview-top span,
        .reg-preview-top strong {
            display: block;
        }

        .reg-preview-top span {
            color: rgba(255,255,255,.62);
            font-size: .72rem;
            font-weight: 700;
        }

        .reg-preview-top strong {
            margin-top: 3px;
            color: #ffffff;
            font-size: .9rem;
            font-weight: 800;
        }

    .reg-preview-pill {
        min-height: 26px;
        display: inline-flex;
        align-items: center;
        padding: 0 10px;
        border-radius: 999px;
        background: rgba(143, 166, 161, .22);
        color: #ffffff;
        font-size: .7rem;
        font-weight: 800;
    }

    .reg-progress-line {
        height: 10px;
        border-radius: 999px;
        background: rgba(255,255,255,.12);
        overflow: hidden;
        margin-bottom: 13px;
    }

        .reg-progress-line div {
            width: 45%;
            height: 100%;
            border-radius: inherit;
            background: linear-gradient(90deg, #ffffff, #8FA6A1);
        }

    .reg-preview-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 8px;
    }

        .reg-preview-grid div {
            padding: 10px;
            border-radius: 14px;
            background: rgba(255,255,255,.10);
            border: 1px solid rgba(255,255,255,.12);
        }

        .reg-preview-grid span,
        .reg-preview-grid strong {
            display: block;
        }

        .reg-preview-grid span {
            color: rgba(255,255,255,.62);
            font-size: .68rem;
            font-weight: 700;
        }

        .reg-preview-grid strong {
            margin-top: 3px;
            color: #ffffff;
            font-size: .78rem;
            font-weight: 800;
        }

    .reg-steps {
        display: grid;
        gap: 10px;
    }

        .reg-steps div {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 11px;
            border-radius: 15px;
            background: rgba(255,255,255,.10);
            border: 1px solid rgba(255,255,255,.15);
        }

        .reg-steps strong {
            width: 28px;
            height: 28px;
            min-width: 28px;
            border-radius: 999px;
            background: rgba(255,255,255,.16);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: .75rem;
        }

        .reg-steps span {
            color: rgba(255,255,255,.82);
            font-size: .78rem;
            font-weight: 700;
        }

    .reg-form-panel {
        padding: 34px;
        background: radial-gradient(circle at top right, rgba(143, 166, 161, .12), transparent 30%), #ffffff;
    }

    .reg-form-header span {
        color: #8FA6A1;
        font-size: .74rem;
        font-weight: 820;
        letter-spacing: .08em;
        text-transform: uppercase;
    }

    .reg-form-header h2 {
        margin: 8px 0 0;
        color: #111827;
        font-size: 1.6rem;
        font-weight: 850;
        letter-spacing: -.045em;
    }

    .reg-form-header p {
        margin: 8px 0 0;
        color: #667085;
        font-size: .9rem;
        line-height: 1.55;
    }

    .reg-alert {
        margin-top: 18px;
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 14px;
        border-radius: 14px;
        background: #fef3f2;
        border: 1px solid #fecaca;
        color: #991b1b;
        font-size: .84rem;
        font-weight: 650;
    }

    .reg-form {
        margin-top: 24px;
        display: grid;
        gap: 16px;
    }

    .reg-section {
        padding: 18px;
        border-radius: 22px;
        border: 1px solid #e8eaef;
        background: rgba(255,255,255,.92);
        box-shadow: 0 14px 32px rgba(17,24,39,.045);
    }

    .reg-section-heading {
        margin-bottom: 15px;
        display: flex;
        align-items: flex-start;
        gap: 11px;
    }

    .reg-section-icon {
        width: 36px;
        height: 36px;
        min-width: 36px;
        border-radius: 14px;
        background: #f2f6f5;
        color: #8FA6A1;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .reg-section-heading h3 {
        margin: 0;
        color: #111827;
        font-size: .98rem;
        font-weight: 820;
    }

    .reg-section-heading p {
        margin: 4px 0 0;
        color: #98a2b3;
        font-size: .76rem;
        line-height: 1.45;
    }

    .reg-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
    }

    .reg-span-2 {
        grid-column: 1 / -1;
    }

    .reg-form label {
        display: block;
        margin-bottom: 7px;
        color: #475569;
        font-size: .78rem;
        font-weight: 760;
    }

    .reg-input {
        width: 100%;
        min-height: 44px;
        border-radius: 14px;
        border: 1px solid #e5e7eb;
        background: #fafafa;
        color: #111827;
        padding: 0 12px;
        font-size: 16px;
        outline: none;
        transition: border-color .18s ease, background .18s ease, box-shadow .18s ease;
    }

        .reg-input:focus {
            border-color: #cfd8d5;
            box-shadow: 0 0 0 4px rgba(143,166,161,.11);
            background: #ffffff;
        }

    .reg-info-box {
        display: flex;
        gap: 11px;
        align-items: flex-start;
        padding: 14px;
        border-radius: 18px;
        background: #f2f6f5;
        border: 1px solid #dce7e4;
        color: #475569;
        font-size: .8rem;
        line-height: 1.55;
    }

        .reg-info-box div {
            width: 32px;
            height: 32px;
            min-width: 32px;
            border-radius: 12px;
            background: #ffffff;
            color: #8FA6A1;
            display: flex;
            align-items: center;
            justify-content: center;
        }

    .reg-actions {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
        padding-top: 4px;
    }

        .reg-actions a {
            color: #252525;
            font-size: .84rem;
            font-weight: 780;
            text-decoration: none;
        }

            .reg-actions a:hover {
                text-decoration: underline;
            }

    .reg-submit {
        min-height: 46px;
        border: 0;
        border-radius: 15px;
        padding: 0 18px;
        background: #252525;
        color: #ffffff;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 9px;
        font-size: .9rem;
        font-weight: 780;
        box-shadow: 0 16px 34px rgba(17,24,39,.18);
        transition: transform .18s ease, box-shadow .18s ease;
    }

        .reg-submit:hover {
            transform: translateY(-1px);
            box-shadow: 0 20px 40px rgba(17,24,39,.22);
        }

    @@media (max-width: 1100px) {
        .reg-card {
            grid-template-columns: 1fr;
        }

        .reg-intro {
            padding: 28px;
        }

        .reg-preview-grid {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }
    }

    @@media (max-width: 768px) {
        .reg-shell {
            padding: 12px 12px 28px;
        }

        .reg-card {
            border-radius: 24px;
        }

        .reg-form-panel {
            padding: 22px;
        }

        .reg-copy h1 {
            font-size: 1.45rem;
        }

        .reg-grid,
        .reg-preview-grid {
            grid-template-columns: 1fr;
        }

        .reg-section-heading {
            align-items: flex-start;
        }

        .reg-actions {
            flex-direction: column-reverse;
            align-items: stretch;
        }

        .reg-submit {
            width: 100%;
        }
    }
</style>