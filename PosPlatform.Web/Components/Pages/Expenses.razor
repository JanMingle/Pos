</style>
@code {
    private BusinessSettingsFormModel _settings = new();

    private List<ExpenseListItemViewModel> _expenses = new();
    private List<ExpenseCategoryListItemViewModel> _categories = new();
    private List<ExpenseCategoryOptionViewModel> _categoryOptions = new();
    private List<BranchOptionViewModel> _branches = new();
    private int? _branchFilter;

    private ExpenseFormModel _expenseForm = new();
    private ExpenseCategoryFormModel _categoryForm = new();

    private bool _loadingExpenses = true;
    private bool _loadingCategories = true;
    private bool _savingExpense;
    private bool _savingCategory;
    private bool _showExpenseModal;
    private bool _showCategoryModal;

    private DateTime? _fromDate = DateTime.Today.AddDays(-30);
    private DateTime? _toDate = DateTime.Today;

    private string? _expenseSearch;
    private string? _categorySearch;
    private string _categoryStatus = "all";

    private string? _message;
    private bool _isSuccess;

    private decimal TotalExpenses => _expenses.Sum(x => x.TotalAmount);
    private decimal TotalTax => _expenses.Sum(x => x.TaxAmount);

    private string CurrencyLabel =>
        string.IsNullOrWhiteSpace(_settings.CurrencySymbol)
            ? "R"
            : _settings.CurrencySymbol;

    protected override async Task OnInitializedAsync()
    {
        if (!await UserAccessService.CanAccessAsync("expenses"))
        {
            NavigationManager.NavigateTo("/dashboard");
            return;
        }

        _settings = await BusinessSettingsService.GetSettingsAsync();
        _branches = await BranchService.GetBranchOptionsAsync();

        await LoadCategoriesAsync();
        await LoadExpensesAsync();
    }

    private async Task LoadCategoriesAsync()
    {
        _loadingCategories = true;

        _categories = await ExpenseService.GetCategoriesAsync(_categorySearch, _categoryStatus, _branchFilter);
        _categoryOptions = await ExpenseService.GetCategoryOptionsAsync();

        _loadingCategories = false;
    }

    private async Task LoadExpensesAsync()
    {
        _loadingExpenses = true;
        _expenses = await ExpenseService.GetExpensesAsync(_fromDate, _toDate, _expenseSearch, _branchFilter);
        _loadingExpenses = false;
    }

    private async Task ApplyExpenseFiltersAsync()
    {
        await LoadExpensesAsync();
        await LoadCategoriesAsync();
        await LoadCategoriesAsync();
    }

    private void OpenExpenseModal()
    {
        _expenseForm = new ExpenseFormModel
        {
            ExpenseDate = DateTime.Today,
            PaymentMethod = "Cash"
        };

        _showExpenseModal = true;
    }

    private async Task EditExpenseAsync(int id)
    {
        var model = await ExpenseService.GetExpenseByIdAsync(id);

        if (model == null)
        {
            ShowMessage("Expense not found.", false);
            return;
        }

        _expenseForm = model;
        _showExpenseModal = true;
    }

    private void CloseExpenseModal()
    {
        _showExpenseModal = false;
        _expenseForm = new ExpenseFormModel();
    }

    private async Task SaveExpenseAsync()
    {
        _savingExpense = true;

        var result = await ExpenseService.SaveExpenseAsync(_expenseForm);

        _savingExpense = false;
        ShowMessage(result.Message, result.Success);

        if (result.Success)
        {
            CloseExpenseModal();
            await LoadExpensesAsync();
            await LoadCategoriesAsync();
        }
    }

    private async Task DeleteExpenseAsync(int id)
    {
        var result = await ExpenseService.DeleteExpenseAsync(id);
        ShowMessage(result.Message, result.Success);

        if (result.Success)
        {
            await LoadExpensesAsync();
            await LoadCategoriesAsync();
        }
    }

    private void OpenCategoryModal()
    {
        _categoryForm = new ExpenseCategoryFormModel
        {
            IsActive = true
        };

        _showCategoryModal = true;
    }

    private async Task EditCategoryAsync(int id)
    {
        var model = await ExpenseService.GetCategoryByIdAsync(id);

        if (model == null)
        {
            ShowMessage("Expense category not found.", false);
            return;
        }

        _categoryForm = model;
        _showCategoryModal = true;
    }

    private void CloseCategoryModal()
    {
        _showCategoryModal = false;
        _categoryForm = new ExpenseCategoryFormModel();
    }

    private async Task SaveCategoryAsync()
    {
        _savingCategory = true;

        var result = await ExpenseService.SaveCategoryAsync(_categoryForm);

        _savingCategory = false;
        ShowMessage(result.Message, result.Success);

        if (result.Success)
        {
            CloseCategoryModal();
            await LoadCategoriesAsync();
        }
    }

    private async Task ToggleCategoryAsync(int id)
    {
        var result = await ExpenseService.ToggleCategoryStatusAsync(id);
        ShowMessage(result.Message, result.Success);

        if (result.Success)
        {
            await LoadCategoriesAsync();
        }
    }

    private async Task DeleteCategoryAsync(int id)
    {
        var result = await ExpenseService.DeleteCategoryAsync(id);
        ShowMessage(result.Message, result.Success);

        if (result.Success)
        {
            await LoadCategoriesAsync();
        }
    }

    private string Money(decimal value)
    {
        return $"{CurrencyLabel} {value:0.00}";
    }

    private void ShowMessage(string message, bool success)
    {
        _message = message;
        _isSuccess = success;
    }

    private void ClearMessage()
    {
        _message = null;
    }
}