@page "/customers"
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@rendermode InteractiveServer
@layout MainLayout
@attribute [Authorize]
@using PosPlatform.Web.Components.Layout
@using PosPlatform.Web.Models.Customers
@using PosPlatform.Web.Models.Settings
@using PosPlatform.Web.Services
@using Microsoft.AspNetCore.Components.Web
@inject CustomerService CustomerService
@inject BusinessSettingsService BusinessSettingsService
@inject UserAccessService UserAccessService
@inject NavigationManager NavigationManager

<PageTitle>Customers</PageTitle>

<section class="customers-page">
    <div class="customers-top">
        <div>
            <div class="customers-kicker">
                <i class="bi bi-person-lines-fill"></i>
                Customer records
            </div>

            <h1>Customers</h1>
            <p>Manage customer profiles, contact details, business customers and purchase history.</p>
        </div>

        @if (CustomersEnabled)
        {
            <button type="button" class="customers-primary-btn" @onclick="OpenAddModal">
                <i class="bi bi-person-plus"></i>
                Add Customer
            </button>
        }
    </div>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <div class="customers-alert @(_isSuccess ? "success" : "danger")">
            <i class="bi @(_isSuccess ? "bi-check-circle" : "bi-exclamation-triangle")"></i>
            <span>@_message</span>
            <button type="button" @onclick="ClearMessage">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
    }

    <div class="customers-settings-strip">
        <div>
            <span>Business</span>
            <strong>@_settings.BusinessName</strong>
        </div>

        <div>
            <span>Business Type</span>
            <strong>@_settings.BusinessType</strong>
        </div>

        <div>
            <span>Customers Module</span>
            <strong>@(CustomersEnabled ? "Enabled" : "Disabled")</strong>
        </div>

        <div>
            <span>Customer on Sale</span>
            <strong>@(_settings.RequireCustomerForSale ? "Required" : "Optional")</strong>
        </div>
    </div>

    @if (!CustomersEnabled)
    {
        <div class="customers-settings-warning">
            <div>
                <strong>Customers module is disabled</strong>
                <span>Enable customers in Business Settings if this business needs customer records.</span>
            </div>

            <a href="/settings" class="customers-settings-link">
                Open Settings
            </a>
        </div>
    }
    else
    {
        <div class="customers-summary-grid">
            <div class="customers-summary-card hero">
                <div class="customers-summary-icon">
                    <i class="bi bi-people"></i>
                </div>
                <span>Total Customers</span>
                <strong>@TotalCustomers</strong>
                <small>All records in this view</small>
            </div>

            <div class="customers-summary-card">
                <div class="customers-summary-icon green">
                    <i class="bi bi-check2-circle"></i>
                </div>
                <span>Active</span>
                <strong>@ActiveCustomers</strong>
                <small>Available during sales</small>
            </div>

            <div class="customers-summary-card">
                <div class="customers-summary-icon blue">
                    <i class="bi bi-person"></i>
                </div>
                <span>Individuals</span>
                <strong>@IndividualCustomers</strong>
                <small>Personal customer records</small>
            </div>

            <div class="customers-summary-card">
                <div class="customers-summary-icon violet">
                    <i class="bi bi-building"></i>
                </div>
                <span>Businesses</span>
                <strong>@BusinessCustomers</strong>
                <small>Company customer records</small>
            </div>

            <div class="customers-summary-card">
                <div class="customers-summary-icon amber">
                    <i class="bi bi-cash-stack"></i>
                </div>
                <span>Total Spent</span>
                <strong>@Money(TotalSpent)</strong>
                <small>Purchase value recorded</small>
            </div>
        </div>

        <div class="customers-control-panel">
            <div class="customers-search">
                <i class="bi bi-search"></i>
                <input @bind="_searchTerm"
                       @bind:event="oninput"
                       @onkeydown="HandleSearchKeyDown"
                       placeholder="Search by name, phone or email" />
            </div>

            <select class="customers-filter" value="@_statusFilter" @onchange="StatusFilterChanged">
                <option value="all">All customers</option>
                <option value="active">Active only</option>
                <option value="inactive">Inactive only</option>
                <option value="individual">Individuals</option>
                <option value="business">Businesses</option>
            </select>

            <button type="button" class="customers-secondary-btn" @onclick="ApplyFiltersAsync">
                <i class="bi bi-filter"></i>
                Apply
            </button>

            <button type="button" class="customers-ghost-btn" @onclick="ResetFiltersAsync">
                <i class="bi bi-arrow-counterclockwise"></i>
                Reset
            </button>
        </div>

        <div class="customers-panel">
            <div class="customers-panel-header">
                <div>
                    <h2>Customer List</h2>
                    <p>Showing @PageStart - @PageEnd of @TotalFilteredCustomers customer@(@TotalFilteredCustomers == 1 ? "" : "s").</p>
                </div>

                <span class="customers-status-note">
                    <i class="bi bi-shield-check"></i>
                    Tenant scoped
                </span>
            </div>

            @if (_loading)
            {
                <div class="customers-empty">
                    <div class="customers-empty-icon">
                        <i class="bi bi-hourglass-split"></i>
                    </div>
                    <strong>Loading customers...</strong>
                    <span>Please wait while we fetch customer records.</span>
                </div>
            }
            else if (TotalFilteredCustomers == 0)
            {
                <div class="customers-empty">
                    <div class="customers-empty-icon">
                        <i class="bi bi-person-x"></i>
                    </div>
                    <strong>No customers found</strong>
                    <span>Add your first customer or adjust the filters.</span>

                    <button type="button" class="customers-primary-btn" @onclick="OpenAddModal">
                        <i class="bi bi-person-plus"></i>
                        Add Customer
                    </button>
                </div>
            }
            else
            {
                <div class="customers-table-wrap">
                    <table class="customers-table">
                        <thead>
                            <tr>
                                <th>Customer</th>
                                <th>Type</th>
                                <th>Contact</th>
                                <th>Purchases</th>
                                <th>Total Spent</th>
                                <th>Last Purchase</th>
                                <th>Status</th>
                                <th class="customers-actions-col">Actions</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var customer in PaginatedCustomers)
                            {
                                <tr>
                                    <td>
                                        <div class="customers-cell">
                                            <div class="customers-avatar">@GetInitials(customer.DisplayName)</div>
                                            <div>
                                                <strong>@customer.DisplayName</strong>
                                                <span>Created @customer.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd")</span>
                                            </div>
                                        </div>
                                    </td>

                                    <td>
                                        <span class="customers-type-pill @(customer.CustomerType == "Business" ? "business" : "individual")">
                                            @customer.CustomerType
                                        </span>
                                    </td>

                                    <td>
                                        <div class="customers-contact">
                                            <strong>@(string.IsNullOrWhiteSpace(customer.Phone) ? "-" : customer.Phone)</strong>
                                            <span>@(string.IsNullOrWhiteSpace(customer.Email) ? "No email" : customer.Email)</span>
                                        </div>
                                    </td>

                                    <td>@customer.TotalPurchases</td>
                                    <td class="customers-money">@Money(customer.TotalSpent)</td>
                                    <td>@(customer.LastPurchaseDate.HasValue? customer.LastPurchaseDate.Value.ToLocalTime().ToString("yyyy-MM-dd") : "-")</td>

                                    <td>
                                        <span class="customers-status-pill @(customer.IsActive ? "active" : "inactive")">
                                            @(customer.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </td>

                                    <td class="customers-actions-cell">
                                        <div class="customers-action-menu">
                                            <button type="button"
                                                    class="customers-action-toggle"
                                                    @onclick="() => ToggleActionMenu(customer.Id)">
                                                <span>Actions</span>
                                                <i class="bi bi-chevron-down"></i>
                                            </button>

                                            @if (_openActionCustomerId == customer.Id)
                                            {
                                                <div class="customers-action-dropdown">
                                                    <button type="button" @onclick="() => OpenEditModal(customer.Id)">
                                                        <i class="bi bi-pencil"></i>
                                                        <span>Edit customer</span>
                                                    </button>

                                                    <button type="button" @onclick="() => ToggleStatusAsync(customer.Id)">
                                                        <i class="bi @(customer.IsActive ? "bi-pause-circle" : "bi-play-circle")"></i>
                                                        <span>@(customer.IsActive ? "Pause customer" : "Activate customer")</span>
                                                    </button>

                                                    <button type="button" class="danger" @onclick="() => ConfirmDelete(customer.Id, customer.DisplayName)">
                                                        <i class="bi bi-trash"></i>
                                                        <span>Delete customer</span>
                                                    </button>
                                                </div>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="customers-pagination">
                    <div class="customers-page-info">
                        Showing
                        <strong>@PageStart</strong>
                        -
                        <strong>@PageEnd</strong>
                        of
                        <strong>@TotalFilteredCustomers</strong>
                    </div>

                    <div class="customers-page-controls">
                        <button type="button"
                                class="customers-page-btn"
                                disabled="@(_currentPage <= 1)"
                                @onclick="PreviousPage">
                            <i class="bi bi-chevron-left"></i>
                            Previous
                        </button>

                        <span class="customers-page-count">
                            Page @_currentPage of @TotalPages
                        </span>

                        <button type="button"
                                class="customers-page-btn"
                                disabled="@(_currentPage >= TotalPages)"
                                @onclick="NextPage">
                            Next
                            <i class="bi bi-chevron-right"></i>
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</section>

@if (_showModal)
{
    <div class="customers-modal-backdrop">
        <div class="customers-modal">
            <div class="customers-modal-header">
                <div>
                    <span>Customer setup</span>
                    <h4>@(_form.Id.HasValue ? "Edit Customer" : "Add Customer")</h4>
                    <p>Create customer records for sales history, salons, service businesses and repeat buyers.</p>
                </div>

                <button type="button" class="customers-close-btn" @onclick="CloseModal">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <EditForm Model="_form" OnValidSubmit="SaveCustomerAsync">
                <DataAnnotationsValidator />
                <ValidationSummary class="customers-validation" />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="customers-label">Customer Type</label>
                        <InputSelect class="customers-input" @bind-Value="_form.CustomerType">
                            <option value="Individual">Individual</option>
                            <option value="Business">Business</option>
                        </InputSelect>
                    </div>

                    @if (_form.CustomerType == "Business")
                    {
                        <div class="col-md-6">
                            <label class="customers-label">Business Name</label>
                            <InputText class="customers-input" @bind-Value="_form.BusinessName" />
                        </div>
                    }
                    else
                    {
                        <div class="col-md-6">
                            <label class="customers-label">First Name</label>
                            <InputText class="customers-input" @bind-Value="_form.FirstName" />
                        </div>

                        <div class="col-md-6">
                            <label class="customers-label">Last Name</label>
                            <InputText class="customers-input" @bind-Value="_form.LastName" />
                        </div>
                    }

                    <div class="col-md-6">
                        <label class="customers-label">Phone</label>
                        <InputText class="customers-input" @bind-Value="_form.Phone" />
                    </div>

                    <div class="col-md-6">
                        <label class="customers-label">Email</label>
                        <InputText class="customers-input" @bind-Value="_form.Email" />
                    </div>

                    <div class="col-12">
                        <label class="customers-label">Notes</label>
                        <InputTextArea class="customers-input customers-textarea" @bind-Value="_form.Notes" />
                    </div>

                    <div class="col-12">
                        <label class="customers-check">
                            <InputCheckbox @bind-Value="_form.IsActive" />
                            <span>
                                <strong>Active customer</strong>
                                <small>Allow this customer to be selected during sales later.</small>
                            </span>
                        </label>
                    </div>
                </div>

                <div class="customers-modal-actions">
                    <button type="button" class="customers-ghost-btn" @onclick="CloseModal">Cancel</button>
                    <button type="submit" class="customers-primary-btn" disabled="@_saving">
                        <i class="bi bi-check2-circle"></i>
                        @(_saving ? "Saving..." : "Save Customer")
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

@if (_showDeleteConfirm)
{
    <div class="customers-modal-backdrop">
        <div class="customers-modal customers-delete-modal">
            <div class="customers-delete-icon">
                <i class="bi bi-trash"></i>
            </div>

            <h4>Delete Customer</h4>
            <p>
                Are you sure you want to delete <strong>@_deleteCustomerName</strong>?
                If this customer has sales history, they will be deactivated instead.
            </p>

            <div class="customers-modal-actions">
                <button type="button" class="customers-ghost-btn" @onclick="CancelDelete">Cancel</button>
                <button type="button" class="customers-danger-btn" @onclick="DeleteConfirmedAsync">
                    <i class="bi bi-trash"></i>
                    Delete
                </button>
            </div>
        </div>
    </div>
}

<style>
    .customers-page {
        animation: customersIn .22s ease both;
    }

    .customers-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: 18px;
        margin-bottom: 16px;
    }

    .customers-kicker {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: #8FA6A1;
        font-size: .72rem;
        font-weight: 760;
        letter-spacing: .08em;
        text-transform: uppercase;
        margin-bottom: 8px;
    }

    .customers-top h1 {
        margin: 0;
        color: #111827;
        font-size: 1.45rem;
        font-weight: 720;
        letter-spacing: -.035em;
    }

    .customers-top p {
        margin: 6px 0 0;
        color: #667085;
        font-size: .88rem;
    }

    .customers-primary-btn,
    .customers-secondary-btn,
    .customers-ghost-btn,
    .customers-danger-btn,
    .customers-page-btn {
        min-height: 38px;
        border-radius: 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 0 14px;
        font-size: .8rem;
        font-weight: 680;
        border: 0;
        transition: transform .18s ease;
        white-space: nowrap;
    }

    .customers-primary-btn {
        color: #ffffff;
        background: #252525;
        box-shadow: 0 12px 24px rgba(17, 24, 39, .12);
    }

    .customers-secondary-btn {
        color: #8FA6A1;
        background: #f2f6f5;
        border: 1px solid #dce7e4;
    }

    .customers-ghost-btn,
    .customers-page-btn {
        color: #475569;
        background: #ffffff;
        border: 1px solid #e5e7eb;
    }

    .customers-danger-btn {
        color: #ffffff;
        background: #d92d20;
    }

        .customers-primary-btn:hover,
        .customers-secondary-btn:hover,
        .customers-ghost-btn:hover,
        .customers-danger-btn:hover,
        .customers-page-btn:hover {
            transform: translateY(-1px);
        }

    .customers-page-btn:disabled,
    .customers-primary-btn:disabled {
        opacity: .45;
        cursor: not-allowed;
        transform: none;
    }

    .customers-alert {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 14px;
        margin-bottom: 16px;
        border-radius: 14px;
        font-size: .84rem;
        font-weight: 600;
        border: 1px solid;
    }

        .customers-alert.success {
            color: #166534;
            background: #f0fdf4;
            border-color: #bbf7d0;
        }

        .customers-alert.danger {
            color: #991b1b;
            background: #fef2f2;
            border-color: #fecaca;
        }

        .customers-alert span {
            flex: 1;
        }

        .customers-alert button {
            border: 0;
            background: transparent;
            color: inherit;
        }

    .customers-settings-strip {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 10px;
        margin-bottom: 16px;
    }

        .customers-settings-strip div {
            padding: 13px;
            border-radius: 16px;
            background: #ffffff;
            border: 1px solid #e8eaef;
            box-shadow: 0 10px 24px rgba(17, 24, 39, .035);
        }

        .customers-settings-strip span,
        .customers-settings-strip strong {
            display: block;
        }

        .customers-settings-strip span {
            color: #98a2b3;
            font-size: .7rem;
            font-weight: 700;
            letter-spacing: .03em;
            text-transform: uppercase;
        }

        .customers-settings-strip strong {
            margin-top: 4px;
            color: #111827;
            font-size: .84rem;
            font-weight: 720;
        }

    .customers-settings-warning {
        display: flex;
        justify-content: space-between;
        gap: 14px;
        align-items: center;
        margin-bottom: 16px;
        padding: 16px;
        border-radius: 18px;
        background: #fff7ed;
        border: 1px solid #fed7aa;
    }

        .customers-settings-warning strong,
        .customers-settings-warning span {
            display: block;
        }

        .customers-settings-warning strong {
            color: #9a3412;
            font-size: .9rem;
            font-weight: 750;
        }

        .customers-settings-warning span {
            margin-top: 3px;
            color: #c2410c;
            font-size: .78rem;
        }

    .customers-settings-link {
        min-height: 36px;
        border-radius: 10px;
        padding: 0 13px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #252525;
        color: #ffffff;
        font-size: .78rem;
        font-weight: 700;
        text-decoration: none;
        white-space: nowrap;
    }

    .customers-summary-grid {
        display: grid;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        gap: 12px;
        margin-bottom: 16px;
    }

    .customers-summary-card {
        padding: 15px;
        border-radius: 20px;
        background: #ffffff;
        border: 1px solid #e8eaef;
        box-shadow: 0 14px 32px rgba(17, 24, 39, .045);
    }

        .customers-summary-card.hero {
            background: #252525;
            border-color: #252525;
        }

        .customers-summary-card span,
        .customers-summary-card strong,
        .customers-summary-card small {
            display: block;
        }

        .customers-summary-card span {
            margin-top: 11px;
            color: #667085;
            font-size: .72rem;
            font-weight: 700;
        }

        .customers-summary-card strong {
            margin-top: 6px;
            color: #111827;
            font-size: 1.05rem;
            font-weight: 760;
            letter-spacing: -.02em;
        }

        .customers-summary-card small {
            margin-top: 4px;
            color: #98a2b3;
            font-size: .72rem;
            line-height: 1.35;
        }

        .customers-summary-card.hero span,
        .customers-summary-card.hero strong,
        .customers-summary-card.hero small {
            color: #ffffff;
        }

    .customers-summary-icon {
        width: 36px;
        height: 36px;
        border-radius: 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #ffffff;
        color: #252525;
        box-shadow: 0 10px 22px rgba(17, 24, 39, .08);
    }

        .customers-summary-icon.green {
            color: #8FA6A1;
            background: #f2f6f5;
        }

        .customers-summary-icon.blue {
            color: #2563eb;
            background: #eff6ff;
        }

        .customers-summary-icon.violet {
            color: #7c3aed;
            background: #f5f3ff;
        }

        .customers-summary-icon.amber {
            color: #b7791f;
            background: #fffbeb;
        }

    .customers-control-panel {
        display: grid;
        grid-template-columns: minmax(260px, 1fr) 180px auto auto;
        gap: 10px;
        padding: 14px;
        margin-bottom: 16px;
        border-radius: 18px;
        background: #ffffff;
        border: 1px solid #e8eaef;
        box-shadow: 0 10px 24px rgba(17, 24, 39, .035);
    }

    .customers-search {
        min-height: 40px;
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 0 13px;
        border-radius: 12px;
        background: #fafafa;
        border: 1px solid #e5e7eb;
        color: #98a2b3;
    }

        .customers-search input,
        .customers-filter,
        .customers-input {
            width: 100%;
            min-height: 40px;
            border-radius: 12px;
            border: 1px solid #e5e7eb;
            background: #ffffff;
            color: #111827;
            padding: 0 12px;
            font-size: 16px;
            outline: none;
        }

        .customers-search input {
            border: 0;
            background: transparent;
            padding: 0;
        }

    .customers-panel {
        background: #ffffff;
        border: 1px solid #e8eaef;
        border-radius: 22px;
        box-shadow: 0 14px 32px rgba(17, 24, 39, .045);
        overflow: visible;
    }

    .customers-panel-header {
        padding: 16px 18px;
        border-bottom: 1px solid #f1f2f5;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 14px;
    }

        .customers-panel-header h2 {
            margin: 0;
            color: #111827;
            font-size: .94rem;
            font-weight: 720;
        }

        .customers-panel-header p {
            margin: 4px 0 0;
            color: #98a2b3;
            font-size: .75rem;
        }

    .customers-status-note {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 7px 10px;
        border-radius: 999px;
        color: #8FA6A1;
        background: #f2f6f5;
        font-size: .74rem;
        font-weight: 700;
        white-space: nowrap;
    }

    .customers-table-wrap {
        overflow-x: auto;
        padding-bottom: 80px;
    }

    .customers-table {
        width: 100%;
        min-width: 980px;
        border-collapse: collapse;
    }

        .customers-table th {
            padding: 12px 16px;
            background: #fafafa;
            color: #667085;
            font-size: .7rem;
            font-weight: 750;
            text-transform: uppercase;
            letter-spacing: .05em;
            border-bottom: 1px solid #e8eaef;
            white-space: nowrap;
        }

        .customers-table td {
            padding: 14px 16px;
            color: #334155;
            font-size: .82rem;
            border-bottom: 1px solid #f1f2f5;
            vertical-align: middle;
        }

    .customers-cell {
        display: flex;
        align-items: center;
        gap: 11px;
    }

    .customers-avatar {
        width: 38px;
        height: 38px;
        border-radius: 14px;
        background: #f2f6f5;
        color: #8FA6A1;
        display: flex;
        align-items: center;
        justify-content: center;
