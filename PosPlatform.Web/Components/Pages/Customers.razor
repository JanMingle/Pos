@code {
    private BusinessSettingsFormModel _settings = new();
    private List<CustomerListItemViewModel> _customers = new();

    private CustomerFormModel _form = new();

    private bool _loading = true;
    private bool _saving;
    private bool _showModal;
    private bool _showDeleteConfirm;

    private string? _searchTerm;
    private string _statusFilter = "all";

    private int _deleteId;
    private string _deleteCustomerName = string.Empty;

    private string? _message;
    private bool _isSuccess;

    private bool CustomersEnabled => _settings.CustomersEnabled;

    private int TotalCustomers => _customers.Count;
    private int ActiveCustomers => _customers.Count(x => x.IsActive);
    private int IndividualCustomers => _customers.Count(x => x.CustomerType == "Individual");
    private int BusinessCustomers => _customers.Count(x => x.CustomerType == "Business");
    private decimal TotalSpent => _customers.Sum(x => x.TotalSpent);

    protected override async Task OnInitializedAsync()
    {
        if (!await UserAccessService.CanAccessAsync("customers"))
        {
            NavigationManager.NavigateTo("/dashboard");
            return;
        }

        _settings = await BusinessSettingsService.GetSettingsAsync();

        if (CustomersEnabled)
        {
            await LoadCustomersAsync();
        }
        else
        {
            _loading = false;
        }
    }

    private async Task LoadCustomersAsync()
    {
        _loading = true;
        _customers = await CustomerService.GetCustomersAsync(_searchTerm, _statusFilter);
        _loading = false;
    }

    private async Task ResetFiltersAsync()
    {
        _searchTerm = null;
        _statusFilter = "all";
        await LoadCustomersAsync();
    }

    private void OpenAddModal()
    {
        _form = new CustomerFormModel
        {
            CustomerType = "Individual",
            IsActive = true
        };

        _showModal = true;
    }

    private async Task OpenEditModal(int id)
    {
        var model = await CustomerService.GetByIdAsync(id);

        if (model == null)
        {
            ShowMessage("Customer not found.", false);
            return;
        }

        _form = model;
        _showModal = true;
    }

    private void CloseModal()
    {
        _showModal = false;
        _form = new CustomerFormModel();
    }

    private async Task SaveCustomerAsync()
    {
        _saving = true;

        var result = await CustomerService.SaveAsync(_form);

        _saving = false;
        ShowMessage(result.Message, result.Success);

        if (result.Success)
        {
            _showModal = false;
            _form = new CustomerFormModel();
            await LoadCustomersAsync();
        }
    }

    private async Task ToggleStatusAsync(int id)
    {
        var result = await CustomerService.ToggleStatusAsync(id);
        ShowMessage(result.Message, result.Success);

        if (result.Success)
        {
            await LoadCustomersAsync();
        }
    }

    private void ConfirmDelete(int id, string name)
    {
        _deleteId = id;
        _deleteCustomerName = name;
        _showDeleteConfirm = true;
    }

    private void CancelDelete()
    {
        _deleteId = 0;
        _deleteCustomerName = string.Empty;
        _showDeleteConfirm = false;
    }

    private async Task DeleteConfirmedAsync()
    {
        var result = await CustomerService.DeleteAsync(_deleteId);

        ShowMessage(result.Message, result.Success);

        _deleteId = 0;
        _deleteCustomerName = string.Empty;
        _showDeleteConfirm = false;

        if (result.Success)
        {
            await LoadCustomersAsync();
        }
    }

    private string Money(decimal value)
    {
        var symbol = string.IsNullOrWhiteSpace(_settings.CurrencySymbol)
            ? "R"
            : _settings.CurrencySymbol;

        return $"{symbol} {value:0.00}";
    }

    private string GetInitials(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "C";
        }

        var words = value
            .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Take(2)
            .Select(x => x[0].ToString().ToUpper());

        return string.Join("", words);
    }

    private void ShowMessage(string message, bool success)
    {
        _message = message;
        _isSuccess = success;
    }

    private void ClearMessage()
    {
        _message = null;
    }
}