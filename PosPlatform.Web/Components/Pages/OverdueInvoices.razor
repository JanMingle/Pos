@page "/overdue-invoices"
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@rendermode InteractiveServer
@layout MainLayout
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using PosPlatform.Web.Components.Layout
@using PosPlatform.Web.Models.Invoices
@using PosPlatform.Web.Models.Settings
@using PosPlatform.Web.Services
@inject OverdueInvoiceService OverdueInvoiceService
@inject InvoiceService InvoiceService
@inject BusinessSettingsService BusinessSettingsService
@inject UserAccessService UserAccessService
@inject NavigationManager NavigationManager

<PageTitle>Overdue Invoices</PageTitle>

<section class="overdue-page">
    <div class="overdue-header">
        <div>
            <div class="overdue-kicker">
                <i class="bi bi-exclamation-octagon"></i>
                Accounts receivable
            </div>
            <h1>Overdue Invoices</h1>
            <p>Track unpaid invoices that have passed their due date.</p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <div class="overdue-alert @(_isSuccess ? "success" : "danger")">
            <i class="bi @(_isSuccess ? "bi-check-circle" : "bi-exclamation-triangle")"></i>
            <span>@_message</span>
            <button type="button" @onclick="ClearMessage">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
    }

    <div class="overdue-summary-grid">
        <div>
            <span>Overdue Invoices</span>
            <strong>@_summary.Count</strong>
            <p>Currently outstanding</p>
        </div>

        <div>
            <span>Balance Due</span>
            <strong>@Money(_summary.TotalBalanceDue)</strong>
            <p>Total amount outstanding</p>
        </div>

        <div>
            <span>Invoice Value</span>
            <strong>@Money(_summary.TotalInvoiceValue)</strong>
            <p>Total invoice value</p>
        </div>

        <div>
            <span>Most Overdue</span>
            <strong>@_summary.MostOverdueDays day(s)</strong>
            <p>Oldest unpaid due date</p>
        </div>
    </div>

    <div class="overdue-control-panel">
        <div class="overdue-search">
            <i class="bi bi-search"></i>
            <input @bind="_searchTerm"
                   @bind:event="oninput"
                   placeholder="Search invoice, quote, customer, phone or email" />
        </div>

        <select @bind="_statusFilter">
            <option value="all">All overdue statuses</option>
            <option value="Unpaid">Unpaid</option>
            <option value="Partially Paid">Partially Paid</option>
        </select>

        <select @bind="_minimumDaysOverdue">
            <option value="0">All outstanding invoices</option>
            <option value="1">1+ days overdue</option>
            <option value="7">7+ days overdue</option>
            <option value="14">14+ days overdue</option>
            <option value="30">30+ days overdue</option>
            <option value="60">60+ days overdue</option>
            <option value="90">90+ days overdue</option>
        </select>

        <button type="button" class="overdue-secondary-btn" @onclick="LoadOverdueInvoicesAsync">
            <i class="bi bi-filter"></i>
            Filter
        </button>

        <button type="button" class="overdue-ghost-btn" @onclick="ResetFiltersAsync">
            <i class="bi bi-arrow-counterclockwise"></i>
            Reset
        </button>
    </div>

    <div class="overdue-table-card">
        <div class="overdue-table-header">
            <div>
                <h2>Overdue List</h2>
                <p>Invoices with due date already passed and balance still outstanding.</p>
            </div>
        </div>

        @if (_loading)
        {
            <div class="overdue-empty">
                <strong>Loading overdue invoices...</strong>
                <span>Please wait.</span>
            </div>
        }
        else if (_invoices.Count == 0)
        {
            <div class="overdue-empty">
                <strong>No overdue invoices</strong>
                <span>There are no overdue balances for the selected filters.</span>
            </div>
        }
        else
        {
            <div class="overdue-table-wrap">
                <table class="overdue-table">
                    <thead>
                        <tr>
                            <th>Invoice</th>
                            <th>Customer</th>
                            <th>Contact</th>
                            <th>Due Date</th>
                            <th>Days</th>
                            <th>Total</th>
                            <th>Paid</th>
                            <th>Balance</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var invoice in _invoices)
                        {
                            <tr>
                                <td>
                                    <strong>@invoice.InvoiceNumber</strong>
                                    @if (!string.IsNullOrWhiteSpace(invoice.QuoteNumber))
                                    {
                                        <span class="overdue-muted">Quote: @invoice.QuoteNumber</span>
                                    }
                                </td>

                                <td>@invoice.CustomerName</td>

                                <td>
                                    <span class="overdue-muted">@(!string.IsNullOrWhiteSpace(invoice.CustomerPhone) ? invoice.CustomerPhone : "-")</span>
                                    <span class="overdue-muted">@(!string.IsNullOrWhiteSpace(invoice.CustomerEmail) ? invoice.CustomerEmail : "-")</span>
                                </td>

                                <td>@(invoice.DueDate?.ToString("yyyy-MM-dd") ?? "-")</td>

                                <td>
                                    <span class="overdue-days @GetDaysClass(invoice.DaysOverdue)">
                                        @invoice.DaysOverdue day(s)
                                    </span>
                                </td>

                                <td>@Money(invoice.TotalAmount)</td>
                                <td>@Money(invoice.AmountPaid)</td>
                                <td class="overdue-money">@Money(invoice.BalanceDue)</td>

                                <td>
                                    <span class="overdue-pill @GetStatusClass(invoice.Status)">
                                        @invoice.Status
                                    </span>
                                </td>

                                <td class="text-end">
                                    <button type="button" class="overdue-mini-btn" @onclick="() => ViewInvoiceAsync(invoice.Id)">
                                        View
                                    </button>

                                    <button type="button" class="overdue-mini-btn" @onclick="() => OpenPaymentModal(invoice)">
                                        Pay
                                    </button>

                                    <button type="button" class="overdue-mini-btn" @onclick="() => PrintInvoice(invoice.Id)">
                                        Print
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</section>

@if (_selectedInvoice != null)
{
    <div class="overdue-modal-backdrop">
        <div class="overdue-modal">
            <div class="overdue-modal-header">
                <div>
                    <span>@_selectedInvoice.Status</span>
                    <h4>@_selectedInvoice.InvoiceNumber</h4>
                    <p>@(_selectedInvoice.CustomerName ?? "Walk-in / Unsaved") · @Money(_selectedInvoice.BalanceDue) due</p>
                </div>

                <button type="button" class="overdue-close-btn" @onclick="CloseInvoiceDetails">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <div class="overdue-detail-grid">
                <div>
                    <span>Invoice Date</span>
                    <strong>@_selectedInvoice.InvoiceDate.ToString("yyyy-MM-dd")</strong>
                </div>

                <div>
                    <span>Due Date</span>
                    <strong>@(_selectedInvoice.DueDate?.ToString("yyyy-MM-dd") ?? "-")</strong>
                </div>

                <div>
                    <span>Balance Due</span>
                    <strong>@Money(_selectedInvoice.BalanceDue)</strong>
                </div>

                <div>
                    <span>Customer Phone</span>
                    <strong>@(_selectedInvoice.CustomerPhone ?? "-")</strong>
                </div>

                <div>
                    <span>Customer Email</span>
                    <strong>@(_selectedInvoice.CustomerEmail ?? "-")</strong>
                </div>

                <div>
                    <span>Amount Paid</span>
                    <strong>@Money(_selectedInvoice.AmountPaid)</strong>
                </div>
            </div>

            <div class="overdue-actions">
                @if (_selectedInvoice.Status != "Paid" && _selectedInvoice.Status != "Cancelled" && _selectedInvoice.BalanceDue > 0)
                {
                    <button type="button" class="overdue-primary-btn full" @onclick="OpenPaymentModalFromDetails">
                        <i class="bi bi-cash-coin"></i>
                        Record Payment
                    </button>
                }

                <button type="button" class="overdue-secondary-btn full" @onclick="() => PrintInvoice(_selectedInvoice.Id)">
                    <i class="bi bi-printer"></i>
                    Print Invoice
                </button>
            </div>
        </div>
    </div>
}

@if (_showPaymentModal)
{
    <div class="overdue-modal-backdrop">
        <div class="overdue-modal small">
            <div class="overdue-modal-header">
                <div>
                    <span>Invoice Payment</span>
                    <h4>@_paymentInvoiceNumber</h4>
                    <p>Balance due: @Money(_paymentBalanceDue)</p>
                </div>

                <button type="button" class="overdue-close-btn" @onclick="ClosePaymentModal">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <div class="overdue-form-grid">
                <div>
                    <label>Payment Date</label>
                    <input type="date" @bind="_paymentModel.PaymentDate" />
                </div>

                <div>
                    <label>Amount</label>
                    <input type="number" min="0.01" step="0.01" @bind="_paymentModel.Amount" />
                </div>

                <div>
                    <label>Payment Method</label>
                    <select @bind="_paymentModel.PaymentMethod">
                        <option value="Cash">Cash</option>
                        <option value="Card">Card</option>
                        <option value="EFT">EFT</option>
                        <option value="Bank Transfer">Bank Transfer</option>
                        <option value="Other">Other</option>
                    </select>
                </div>

                <div>
                    <label>Reference Number</label>
                    <input @bind="_paymentModel.ReferenceNumber" placeholder="Optional" />
                </div>

                <div class="span-2">
                    <label>Notes</label>
                    <textarea @bind="_paymentModel.Notes" placeholder="Optional payment notes"></textarea>
                </div>
            </div>

            <button type="button" class="overdue-primary-btn full mt" disabled="@_savingPayment" @onclick="SavePaymentAsync">
                <i class="bi bi-check-circle"></i>
                @(_savingPayment ? "Saving..." : "Save Payment")
            </button>
        </div>
    </div>
}

<style>
    .overdue-page {
        animation: overdueIn .22s ease both;
    }

    .overdue-header {
        margin-bottom: 18px;
    }

    .overdue-kicker {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: #dc2626;
        font-size: .74rem;
        font-weight: 750;
        letter-spacing: .06em;
        text-transform: uppercase;
        margin-bottom: 8px;
    }

    .overdue-header h1 {
        margin: 0;
        color: #0f172a;
        font-size: 1.45rem;
        font-weight: 680;
        letter-spacing: -.03em;
    }

    .overdue-header p {
        margin: 6px 0 0;
        color: #64748b;
        font-size: .88rem;
    }

    .overdue-alert {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 14px;
        margin-bottom: 16px;
        border-radius: 14px;
        font-size: .84rem;
        font-weight: 600;
        border: 1px solid;
    }

        .overdue-alert.success {
            color: #166534;
            background: #f0fdf4;
            border-color: #bbf7d0;
        }

        .overdue-alert.danger {
            color: #991b1b;
            background: #fef2f2;
            border-color: #fecaca;
        }

        .overdue-alert span {
            flex: 1;
        }

        .overdue-alert button {
            border: 0;
            background: transparent;
            color: inherit;
        }

    .overdue-summary-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 10px;
        margin-bottom: 16px;
    }

        .overdue-summary-grid div,
        .overdue-table-card {
            border-radius: 20px;
            background: #fff;
            border: 1px solid #e7edf5;
            box-shadow: 0 16px 34px rgba(15,23,42,.055);
        }

        .overdue-summary-grid div {
            padding: 14px;
        }

        .overdue-summary-grid span {
            display: block;
            color: #64748b;
            font-size: .72rem;
            font-weight: 650;
        }

        .overdue-summary-grid strong {
            display: block;
            margin-top: 5px;
            color: #0f172a;
            font-size: 1rem;
            font-weight: 760;
        }

        .overdue-summary-grid p {
            margin: 4px 0 0;
            color: #94a3b8;
            font-size: .74rem;
        }

    .overdue-control-panel {
        display: grid;
        grid-template-columns: minmax(260px, 1fr) 180px 180px auto auto;
        gap: 10px;
        padding: 14px;
        margin-bottom: 16px;
        border-radius: 18px;
        background: #fff;
        border: 1px solid #e7edf5;
        box-shadow: 0 12px 28px rgba(15,23,42,.045);
    }

        .overdue-control-panel select,
        .overdue-form-grid input,
        .overdue-form-grid select,
        .overdue-form-grid textarea {
            width: 100%;
            min-height: 40px;
            border-radius: 12px;
            border: 1px solid #e5e7eb;
            background: #fff;
            color: #0f172a;
            padding: 0 12px;
            font-size: .84rem;
            outline: none;
        }

    .overdue-search {
        min-height: 40px;
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 0 13px;
        border-radius: 12px;
        background: #f8fafc;
        border: 1px solid #e5e7eb;
        color: #94a3b8;
    }

        .overdue-search input {
            width: 100%;
            border: 0;
            outline: none;
            background: transparent;
            color: #0f172a;
            font-size: .84rem;
        }

    .overdue-primary-btn,
    .overdue-secondary-btn,
    .overdue-ghost-btn,
    .overdue-mini-btn {
        min-height: 38px;
        border-radius: 11px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 0 14px;
        font-size: .8rem;
        font-weight: 650;
        border: 0;
        white-space: nowrap;
    }

    .overdue-primary-btn {
        color: #fff;
        background: #111827;
        box-shadow: 0 12px 24px rgba(15,23,42,.14);
    }

        .overdue-primary-btn:disabled {
            opacity: .55;
            cursor: not-allowed;
        }

    .overdue-secondary-btn {
        color: #2563eb;
        background: #eef5ff;
    }

    .overdue-ghost-btn {
        color: #475569;
        background: #fff;
        border: 1px solid #e5e7eb;
    }

    .overdue-mini-btn {
        min-height: 30px;
        color: #2563eb;
        background: #eff6ff;
        border: 1px solid #bfdbfe;
        padding: 0 10px;
    }

    .overdue-table-card {
        overflow: hidden;
    }

    .overdue-table-header {
        padding: 17px 18px;
        border-bottom: 1px solid #edf2f7;
    }

        .overdue-table-header h2 {
            margin: 0;
            color: #0f172a;
            font-size: .92rem;
            font-weight: 720;
        }

        .overdue-table-header p {
            margin: 4px 0 0;
            color: #94a3b8;
            font-size: .76rem;
        }

    .overdue-table-wrap {
        overflow-x: auto;
    }

    .overdue-table {
        width: 100%;
        min-width: 1120px;
        border-collapse: collapse;
    }

        .overdue-table th {
            padding: 12px 16px;
            background: #f8fafc;
            color: #64748b;
            font-size: .7rem;
            font-weight: 750;
            text-transform: uppercase;
            border-bottom: 1px solid #e7edf5;
            white-space: nowrap;
        }

        .overdue-table td {
            padding: 14px 16px;
            color: #334155;
            font-size: .82rem;
            border-bottom: 1px solid #f1f5f9;
            vertical-align: middle;
        }

    .overdue-muted {
        display: block;
        color: #64748b;
        font-size: .74rem;
        margin-top: 2px;
    }

    .overdue-money {
        color: #0f172a;
        font-weight: 760;
    }

    .overdue-pill,
    .overdue-days {
        display: inline-flex;
        min-height: 27px;
        align-items: center;
        padding: 0 9px;
        border-radius: 999px;
        font-size: .72rem;
        font-weight: 750;
    }

        .overdue-pill.unpaid {
            color: #dc2626;
            background: #fef2f2;
        }

        .overdue-pill.partial {
            color: #d97706;
            background: #fffbeb;
        }

        .overdue-days.low {
            color: #d97706;
            background: #fffbeb;
        }

        .overdue-days.medium {
            color: #ea580c;
            background: #fff7ed;
        }

        .overdue-days.high {
            color: #dc2626;
            background: #fef2f2;
        }

    .overdue-empty {
        margin: 18px;
        padding: 34px 20px;
        border-radius: 16px;
        background: #f8fafc;
        border: 1px dashed #dbe3ef;
        text-align: center;
    }

        .overdue-empty strong,
        .overdue-empty span {
            display: block;
        }

        .overdue-empty strong {
            color: #0f172a;
            font-size: .9rem;
        }

        .overdue-empty span {
            margin-top: 4px;
            color: #64748b;
            font-size: .78rem;
        }

    .overdue-modal-backdrop {
        position: fixed;
        inset: 0;
        z-index: 1050;
        padding: 20px;
        background: rgba(15, 23, 42, .44);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .overdue-modal {
        width: 100%;
        max-width: 820px;
        max-height: calc(100vh - 40px);
        overflow-y: auto;
        padding: 22px;
        border-radius: 22px;
        background: #fff;
        box-shadow: 0 24px 60px rgba(15, 23, 42, .24);
    }

        .overdue-modal.small {
            max-width: 620px;
        }

    .overdue-modal-header {
        display: flex;
        justify-content: space-between;
        gap: 18px;
        padding-bottom: 16px;
        margin-bottom: 18px;
        border-bottom: 1px solid #edf2f7;
    }

        .overdue-modal-header span {
            color: #dc2626;
            font-size: .72rem;
            font-weight: 750;
            letter-spacing: .06em;
            text-transform: uppercase;
        }

        .overdue-modal-header h4 {
            margin: 3px 0 0;
            color: #0f172a;
            font-size: 1.05rem;
            font-weight: 720;
        }

        .overdue-modal-header p {
            margin: 5px 0 0;
            color: #64748b;
            font-size: .84rem;
        }

    .overdue-close-btn {
        width: 34px;
        height: 34px;
        border-radius: 10px;
        border: 1px solid #e5e7eb;
        background: #fff;
        color: #64748b;
    }

    .overdue-detail-grid,
    .overdue-form-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px;
    }

        .overdue-detail-grid div {
            padding: 13px;
            border-radius: 16px;
            background: #f8fafc;
            border: 1px solid #e7edf5;
        }

        .overdue-detail-grid span,
        .overdue-detail-grid strong {
            display: block;
        }

        .overdue-detail-grid span,
        .overdue-form-grid label {
            color: #64748b;
            font-size: .72rem;
            font-weight: 700;
        }

        .overdue-detail-grid strong {
            margin-top: 4px;
            color: #0f172a;
            font-size: .84rem;
        }

        .overdue-form-grid label {
            display: block;
            margin-bottom: 5px;
        }

        .overdue-form-grid textarea {
            min-height: 80px;
            padding: 10px 12px;
            resize: vertical;
        }

    .overdue-actions {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px;
        margin-top: 14px;
    }

    .span-2 {
        grid-column: span 2;
    }

    .full {
        width: 100%;
    }

    .mt {
        margin-top: 14px;
    }

    @@keyframes overdueIn {
        from {
            opacity: 0;
            transform: translateY(8px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@media (max-width: 1199px) {
        .overdue-summary-grid,
        .overdue-control-panel,
        .overdue-detail-grid,
        .overdue-form-grid,
        .overdue-actions {
            grid-template-columns: 1fr;
        }

        .span-2 {
            grid-column: span 1;
        }

        .overdue-control-panel button {
            width: 100%;
        }
    }
</style>

@code {
    private BusinessSettingsFormModel _settings = new();
    private List<OverdueInvoiceViewModel> _invoices = new();
    private OverdueInvoiceSummaryViewModel _summary = new();

    private bool _loading = true;

    private string? _searchTerm;
    private string _statusFilter = "all";
    private int _minimumDaysOverdue = 0;

    private string? _message;
    private bool _isSuccess;

    private InvoiceDetailsViewModel? _selectedInvoice;

    private bool _showPaymentModal;
    private bool _savingPayment;
    private RecordInvoicePaymentModel _paymentModel = new();
    private string _paymentInvoiceNumber = string.Empty;
    private decimal _paymentBalanceDue;

    private string CurrencyLabel =>
        string.IsNullOrWhiteSpace(_settings.CurrencySymbol)
            ? "R"
            : _settings.CurrencySymbol;

    protected override async Task OnInitializedAsync()
    {
        if (!await UserAccessService.CanAccessAsync("overdue-invoices"))
        {
            NavigationManager.NavigateTo("/dashboard");
            return;
        }

        _settings = await BusinessSettingsService.GetSettingsAsync();
        await LoadOverdueInvoicesAsync();
    }

    private async Task LoadOverdueInvoicesAsync()
    {
        _loading = true;

        _invoices = await OverdueInvoiceService.GetOverdueInvoicesAsync(
            _searchTerm,
            _statusFilter,
            _minimumDaysOverdue);

        _summary = OverdueInvoiceService.BuildSummary(_invoices);

        _loading = false;
    }

    private async Task ResetFiltersAsync()
    {
        _searchTerm = null;
        _statusFilter = "all";
        _minimumDaysOverdue = 0;

        await LoadOverdueInvoicesAsync();
    }

    private async Task ViewInvoiceAsync(int invoiceId)
    {
        _selectedInvoice = await InvoiceService.GetInvoiceDetailsAsync(invoiceId);
    }

    private void CloseInvoiceDetails()
    {
        _selectedInvoice = null;
    }

    private void OpenPaymentModal(OverdueInvoiceViewModel invoice)
    {
        _paymentModel = new RecordInvoicePaymentModel
        {
            InvoiceId = invoice.Id,
            Amount = invoice.BalanceDue,
            PaymentMethod = "Cash",
            PaymentDate = DateTime.Today
        };

        _paymentInvoiceNumber = invoice.InvoiceNumber;
        _paymentBalanceDue = invoice.BalanceDue;
        _showPaymentModal = true;
    }

    private void OpenPaymentModalFromDetails()
    {
        if (_selectedInvoice == null)
        {
            return;
        }

        _paymentModel = new RecordInvoicePaymentModel
        {
            InvoiceId = _selectedInvoice.Id,
            Amount = _selectedInvoice.BalanceDue,
            PaymentMethod = "Cash",
            PaymentDate = DateTime.Today
        };

        _paymentInvoiceNumber = _selectedInvoice.InvoiceNumber;
        _paymentBalanceDue = _selectedInvoice.BalanceDue;
        _showPaymentModal = true;
    }

    private void ClosePaymentModal()
    {
        _showPaymentModal = false;
    }

    private async Task SavePaymentAsync()
    {
        if (_savingPayment)
        {
            return;
        }

        if (_paymentModel.Amount <= 0)
        {
            ShowMessage("Payment amount must be greater than zero.", false);
            return;
        }

        if (_paymentModel.Amount > _paymentBalanceDue)
        {
            ShowMessage("Payment cannot be greater than the invoice balance.", false);
            return;
        }

        _savingPayment = true;

        var result = await InvoiceService.RecordPaymentAsync(_paymentModel);

        _savingPayment = false;
        ShowMessage(result.Message, result.Success);

        if (result.Success)
        {
            _showPaymentModal = false;

            if (_selectedInvoice != null && _selectedInvoice.Id == _paymentModel.InvoiceId)
            {
                _selectedInvoice = await InvoiceService.GetInvoiceDetailsAsync(_paymentModel.InvoiceId);
            }

            await LoadOverdueInvoicesAsync();
        }
    }

    private void PrintInvoice(int invoiceId)
    {
        NavigationManager.NavigateTo($"/invoices/print/{invoiceId}");
    }

    private string Money(decimal value)
    {
        return $"{CurrencyLabel} {value:0.00}";
    }

    private string GetStatusClass(string status)
    {
        return status switch
        {
            "Unpaid" => "unpaid",
            "Partially Paid" => "partial",
            _ => "unpaid"
        };
    }

    private string GetDaysClass(int days)
    {
        if (days >= 30)
        {
            return "high";
        }

        if (days >= 14)
        {
            return "medium";
        }

        return "low";
    }

    private void ShowMessage(string message, bool success)
    {
        _message = message;
        _isSuccess = success;
    }

    private void ClearMessage()
    {
        _message = null;
    }
}