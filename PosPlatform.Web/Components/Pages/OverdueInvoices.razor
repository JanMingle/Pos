@page "/overdue-invoices"
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@rendermode InteractiveServer
@layout MainLayout
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Web
@using PosPlatform.Web.Components.Layout
@using PosPlatform.Web.Models.Invoices
@using PosPlatform.Web.Models.Settings
@using PosPlatform.Web.Services
@inject OverdueInvoiceService OverdueInvoiceService
@inject InvoiceService InvoiceService
@inject BusinessSettingsService BusinessSettingsService
@inject UserAccessService UserAccessService
@inject NavigationManager NavigationManager

<PageTitle>Overdue Invoices</PageTitle>

<section class="overdue-page">
    <div class="overdue-top">
        <div>
            <div class="overdue-kicker">
                <i class="bi bi-exclamation-octagon"></i>
                Accounts receivable
            </div>

            <h1>Overdue Invoices</h1>
            <p>Track unpaid invoices that have passed their due date and quickly record payments.</p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <div class="overdue-alert @(_isSuccess ? "success" : "danger")">
            <i class="bi @(_isSuccess ? "bi-check-circle" : "bi-exclamation-triangle")"></i>
            <span>@_message</span>
            <button type="button" @onclick="ClearMessage">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
    }

    <div class="overdue-summary-grid">
        <div class="overdue-summary-card hero">
            <div class="overdue-summary-icon">
                <i class="bi bi-exclamation-octagon"></i>
            </div>
            <span>Overdue Invoices</span>
            <strong>@_summary.Count</strong>
            <small>Currently outstanding</small>
        </div>

        <div class="overdue-summary-card">
            <div class="overdue-summary-icon red">
                <i class="bi bi-cash-stack"></i>
            </div>
            <span>Balance Due</span>
            <strong>@Money(_summary.TotalBalanceDue)</strong>
            <small>Total amount outstanding</small>
        </div>

        <div class="overdue-summary-card">
            <div class="overdue-summary-icon blue">
                <i class="bi bi-receipt"></i>
            </div>
            <span>Invoice Value</span>
            <strong>@Money(_summary.TotalInvoiceValue)</strong>
            <small>Total invoice value</small>
        </div>

        <div class="overdue-summary-card">
            <div class="overdue-summary-icon amber">
                <i class="bi bi-clock-history"></i>
            </div>
            <span>Most Overdue</span>
            <strong>@_summary.MostOverdueDays day(s)</strong>
            <small>Oldest unpaid due date</small>
        </div>
    </div>

    <div class="overdue-control-panel">
        <div class="overdue-search">
            <i class="bi bi-search"></i>
            <input @bind="_searchTerm"
                   @bind:event="oninput"
                   @onkeydown="HandleSearchKeyDown"
                   placeholder="Search invoice, quote, customer, phone or email" />
        </div>

        <select value="@_statusFilter" @onchange="StatusFilterChanged">
            <option value="all">All overdue statuses</option>
            <option value="Unpaid">Unpaid</option>
            <option value="Partially Paid">Partially Paid</option>
        </select>

        <select value="@_minimumDaysOverdue" @onchange="MinimumDaysChanged">
            <option value="0">All outstanding invoices</option>
            <option value="1">1+ days overdue</option>
            <option value="7">7+ days overdue</option>
            <option value="14">14+ days overdue</option>
            <option value="30">30+ days overdue</option>
            <option value="60">60+ days overdue</option>
            <option value="90">90+ days overdue</option>
        </select>

        <button type="button" class="overdue-secondary-btn" @onclick="ApplyFiltersAsync">
            <i class="bi bi-filter"></i>
            Filter
        </button>

        <button type="button" class="overdue-ghost-btn" @onclick="ResetFiltersAsync">
            <i class="bi bi-arrow-counterclockwise"></i>
            Reset
        </button>
    </div>

    <div class="overdue-table-card">
        <div class="overdue-table-header">
            <div>
                <h2>Overdue List</h2>
                <p>Showing @PageStart - @PageEnd of @TotalOverdue invoice@(OverduePlural).</p>
            </div>
        </div>

        @if (_loading)
        {
            <div class="overdue-empty">
                <div class="overdue-empty-icon">
                    <i class="bi bi-hourglass-split"></i>
                </div>
                <strong>Loading overdue invoices...</strong>
                <span>Please wait while we fetch overdue balances.</span>
            </div>
        }
        else if (_invoices.Count == 0)
        {
            <div class="overdue-empty">
                <div class="overdue-empty-icon">
                    <i class="bi bi-check2-circle"></i>
                </div>
                <strong>No overdue invoices</strong>
                <span>There are no overdue balances for the selected filters.</span>
            </div>
        }
        else
        {
            <div class="overdue-table-wrap">
                <table class="overdue-table">
                    <thead>
                        <tr>
                            <th>Invoice</th>
                            <th>Customer</th>
                            <th>Contact</th>
                            <th>Due Date</th>
                            <th>Days</th>
                            <th>Total</th>
                            <th>Paid</th>
                            <th>Balance</th>
                            <th>Status</th>
                            <th class="overdue-actions-col">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var invoice in PaginatedInvoices)
                        {
                            <tr>
                                <td>
                                    <strong>@invoice.InvoiceNumber</strong>
                                    @if (!string.IsNullOrWhiteSpace(invoice.QuoteNumber))
                                    {
                                        <span class="overdue-muted">Quote: @invoice.QuoteNumber</span>
                                    }
                                </td>

                                <td>@invoice.CustomerName</td>

                                <td>
                                    <span class="overdue-muted">@(!string.IsNullOrWhiteSpace(invoice.CustomerPhone) ? invoice.CustomerPhone : "-")</span>
                                    <span class="overdue-muted">@(!string.IsNullOrWhiteSpace(invoice.CustomerEmail) ? invoice.CustomerEmail : "-")</span>
                                </td>

                                <td>@(invoice.DueDate?.ToString("yyyy-MM-dd") ?? "-")</td>

                                <td>
                                    <span class="overdue-days @GetDaysClass(invoice.DaysOverdue)">
                                        @invoice.DaysOverdue day(s)
                                    </span>
                                </td>

                                <td>@Money(invoice.TotalAmount)</td>
                                <td>@Money(invoice.AmountPaid)</td>
                                <td class="overdue-money">@Money(invoice.BalanceDue)</td>

                                <td>
                                    <span class="overdue-pill @GetStatusClass(invoice.Status)">
                                        @invoice.Status
                                    </span>
                                </td>

                                <td class="overdue-actions-cell">
                                    <div class="overdue-action-menu">
                                        <button type="button"
                                                class="overdue-action-toggle"
                                                @onclick="() => ToggleActionMenu(invoice.Id)">
                                            <span>Actions</span>
                                            <i class="bi bi-chevron-down"></i>
                                        </button>

                                        @if (_openActionInvoiceId == invoice.Id)
                                        {
                                            <div class="overdue-action-dropdown">
                                                <button type="button" @onclick="() => ViewInvoiceAsync(invoice.Id)">
                                                    <i class="bi bi-eye"></i>
                                                    <span>View invoice</span>
                                                </button>

                                                <button type="button" @onclick="() => OpenPaymentModal(invoice)">
                                                    <i class="bi bi-cash-coin"></i>
                                                    <span>Record payment</span>
                                                </button>

                                                <button type="button" @onclick="() => PrintInvoice(invoice.Id)">
                                                    <i class="bi bi-printer"></i>
                                                    <span>Print invoice</span>
                                                </button>
                                            </div>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="overdue-pagination">
                <div class="overdue-page-info">
                    Showing
                    <strong>@PageStart</strong>
                    -
                    <strong>@PageEnd</strong>
                    of
                    <strong>@TotalOverdue</strong>
                </div>

                <div class="overdue-page-controls">
                    <button type="button"
                            class="@PreviousPageClass"
                            @onclick="PreviousPage">
                        <i class="bi bi-chevron-left"></i>
                        Previous
                    </button>

                    <span class="overdue-page-count">
                        Page @_currentPage of @TotalPages
                    </span>

                    <button type="button"
                            class="@NextPageClass"
                            @onclick="NextPage">
                        Next
                        <i class="bi bi-chevron-right"></i>
                    </button>
                </div>
            </div>
        }
    </div>
</section>

@if (_selectedInvoice != null)
{
    <div class="overdue-modal-backdrop">
        <div class="overdue-modal">
            <div class="overdue-modal-header">
                <div>
                    <span>@_selectedInvoice.Status</span>
                    <h4>@_selectedInvoice.InvoiceNumber</h4>
                    <p>@(_selectedInvoice.CustomerName ?? "Walk-in / Unsaved") · @Money(_selectedInvoice.BalanceDue) due</p>
                </div>

                <button type="button" class="overdue-close-btn" @onclick="CloseInvoiceDetails">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <div class="overdue-detail-grid">
                <div>
                    <span>Invoice Date</span>
                    <strong>@_selectedInvoice.InvoiceDate.ToString("yyyy-MM-dd")</strong>
                </div>

                <div>
                    <span>Due Date</span>
                    <strong>@(_selectedInvoice.DueDate?.ToString("yyyy-MM-dd") ?? "-")</strong>
                </div>

                <div>
                    <span>Balance Due</span>
                    <strong>@Money(_selectedInvoice.BalanceDue)</strong>
                </div>

                <div>
                    <span>Customer Phone</span>
                    <strong>@(_selectedInvoice.CustomerPhone ?? "-")</strong>
                </div>

                <div>
                    <span>Customer Email</span>
                    <strong>@(_selectedInvoice.CustomerEmail ?? "-")</strong>
                </div>

                <div>
                    <span>Amount Paid</span>
                    <strong>@Money(_selectedInvoice.AmountPaid)</strong>
                </div>
            </div>

            <div class="overdue-detail-actions">
                @if (_selectedInvoice.Status != "Paid" && _selectedInvoice.Status != "Cancelled" && _selectedInvoice.BalanceDue > 0)
                {
                    <button type="button" class="overdue-primary-btn full" @onclick="OpenPaymentModalFromDetails">
                        <i class="bi bi-cash-coin"></i>
                        Record Payment
                    </button>
                }

                <button type="button" class="overdue-secondary-btn full" @onclick="() => PrintInvoice(_selectedInvoice.Id)">
                    <i class="bi bi-printer"></i>
                    Print Invoice
                </button>
            </div>
        </div>
    </div>
}

@if (_showPaymentModal)
{
    <div class="overdue-modal-backdrop">
        <div class="overdue-modal small">
            <div class="overdue-modal-header">
                <div>
                    <span>Invoice Payment</span>
                    <h4>@_paymentInvoiceNumber</h4>
                    <p>Balance due: @Money(_paymentBalanceDue)</p>
                </div>

                <button type="button" class="overdue-close-btn" @onclick="ClosePaymentModal">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <div class="overdue-form-grid">
                <div>
                    <label>Payment Date</label>
                    <input type="date" @bind="_paymentModel.PaymentDate" />
                </div>

                <div>
                    <label>Amount</label>
                    <input type="number" min="0.01" step="0.01" @bind="_paymentModel.Amount" />
                </div>

                <div>
                    <label>Payment Method</label>
                    <select @bind="_paymentModel.PaymentMethod">
                        <option value="Cash">Cash</option>
                        <option value="Card">Card</option>
                        <option value="EFT">EFT</option>
                        <option value="Bank Transfer">Bank Transfer</option>
                        <option value="Other">Other</option>
                    </select>
                </div>

                <div>
                    <label>Reference Number</label>
                    <input @bind="_paymentModel.ReferenceNumber" placeholder="Optional" />
                </div>

                <div class="span-2">
                    <label>Notes</label>
                    <textarea @bind="_paymentModel.Notes" placeholder="Optional payment notes"></textarea>
                </div>
            </div>

            <button type="button" class="overdue-primary-btn full mt @(_savingPayment ? "is-disabled" : "")" @onclick="SavePaymentAsync">
                <i class="bi bi-check-circle"></i>
                @(_savingPayment ? "Saving..." : "Save Payment")
            </button>
        </div>
    </div>
}

<style>
    .overdue-page {
        animation: overdueIn .22s ease both;
    }

    .overdue-top {
        margin-bottom: 16px;
    }

    .overdue-kicker {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: #d92d20;
        font-size: .72rem;
        font-weight: 760;
        letter-spacing: .08em;
        text-transform: uppercase;
        margin-bottom: 8px;
    }

    .overdue-top h1 {
        margin: 0;
        color: #111827;
        font-size: 1.45rem;
        font-weight: 720;
        letter-spacing: -.035em;
    }

    .overdue-top p {
        margin: 6px 0 0;
        color: #667085;
        font-size: .88rem;
    }

    .overdue-primary-btn,
    .overdue-secondary-btn,
    .overdue-ghost-btn,
    .overdue-page-btn {
        min-height: 38px;
        border-radius: 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 0 14px;
        font-size: .8rem;
        font-weight: 680;
        border: 0;
        white-space: nowrap;
        transition: transform .18s ease;
    }

    .overdue-primary-btn {
        color: #fff;
        background: #252525;
        box-shadow: 0 12px 24px rgba(17,24,39,.12);
    }

    .overdue-secondary-btn {
        color: #8FA6A1;
        background: #f2f6f5;
        border: 1px solid #dce7e4;
    }

    .overdue-ghost-btn,
    .overdue-page-btn {
        color: #475569;
        background: #fff;
        border: 1px solid #e5e7eb;
    }

        .overdue-primary-btn:hover,
        .overdue-secondary-btn:hover,
        .overdue-ghost-btn:hover,
        .overdue-page-btn:hover {
            transform: translateY(-1px);
        }

        .overdue-primary-btn.is-disabled,
        .overdue-page-btn.is-disabled {
            opacity: .45;
            cursor: not-allowed;
            transform: none;
        }

    .overdue-alert {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 14px;
        margin-bottom: 16px;
        border-radius: 14px;
        font-size: .84rem;
        font-weight: 600;
        border: 1px solid;
    }

        .overdue-alert.success {
            color: #166534;
            background: #f0fdf4;
            border-color: #bbf7d0;
        }

        .overdue-alert.danger {
            color: #991b1b;
            background: #fef2f2;
            border-color: #fecaca;
        }

        .overdue-alert span {
            flex: 1;
        }

        .overdue-alert button {
            border: 0;
            background: transparent;
            color: inherit;
        }

    .overdue-summary-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 12px;
        margin-bottom: 16px;
    }

    .overdue-summary-card {
        padding: 15px;
        border-radius: 20px;
        background: #ffffff;
        border: 1px solid #e8eaef;
        box-shadow: 0 14px 32px rgba(17, 24, 39, .045);
    }

        .overdue-summary-card.hero {
            background: #252525;
            border-color: #252525;
        }

        .overdue-summary-card span,
        .overdue-summary-card strong,
        .overdue-summary-card small {
            display: block;
        }

        .overdue-summary-card span {
            margin-top: 11px;
            color: #667085;
            font-size: .72rem;
            font-weight: 700;
        }

        .overdue-summary-card strong {
            margin-top: 6px;
            color: #111827;
            font-size: 1.05rem;
            font-weight: 760;
            letter-spacing: -.02em;
        }

        .overdue-summary-card small {
            margin-top: 4px;
            color: #98a2b3;
            font-size: .72rem;
            line-height: 1.35;
        }

        .overdue-summary-card.hero span,
        .overdue-summary-card.hero strong,
        .overdue-summary-card.hero small {
            color: #ffffff;
        }

    .overdue-summary-icon {
        width: 36px;
        height: 36px;
        border-radius: 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #ffffff;
        color: #252525;
        box-shadow: 0 10px 22px rgba(17, 24, 39, .08);
    }

        .overdue-summary-icon.red {
            color: #d92d20;
            background: #fef3f2;
        }

        .overdue-summary-icon.blue {
            color: #2563eb;
            background: #eff6ff;
        }

        .overdue-summary-icon.amber {
            color: #b7791f;
            background: #fffbeb;
        }

    .overdue-control-panel {
        display: grid;
        grid-template-columns: minmax(260px, 1fr) 190px 190px auto auto;
        gap: 10px;
        padding: 14px;
        margin-bottom: 16px;
        border-radius: 18px;
        background: #fff;
        border: 1px solid #e8eaef;
        box-shadow: 0 10px 24px rgba(17,24,39,.035);
    }

        .overdue-control-panel select,
        .overdue-form-grid input,
        .overdue-form-grid select,
        .overdue-form-grid textarea {
            width: 100%;
            min-height: 40px;
            border-radius: 12px;
            border: 1px solid #e5e7eb;
            background: #fff;
            color: #111827;
            padding: 0 12px;
            font-size: 16px;
            outline: none;
        }

    .overdue-search {
        min-height: 42px;
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 0 13px;
        border-radius: 14px;
        background: #fafafa;
        border: 1px solid #e5e7eb;
        color: #98a2b3;
    }

        .overdue-search input {
            width: 100%;
            border: 0;
            outline: none;
            background: transparent;
            color: #111827;
            font-size: 16px;
        }

    .overdue-table-card {
        overflow: visible;
        border-radius: 22px;
        background: #fff;
        border: 1px solid #e8eaef;
        box-shadow: 0 14px 32px rgba(17,24,39,.045);
    }

    .overdue-table-header {
        padding: 16px 18px;
        border-bottom: 1px solid #f1f2f5;
    }

        .overdue-table-header h2 {
            margin: 0;
            color: #111827;
            font-size: .94rem;
            font-weight: 720;
        }

        .overdue-table-header p {
            margin: 4px 0 0;
            color: #98a2b3;
            font-size: .75rem;
        }

    .overdue-table-wrap {
        overflow-x: auto;
        padding-bottom: 100px;
    }

    .overdue-table {
        width: 100%;
        min-width: 1120px;
        border-collapse: collapse;
    }

        .overdue-table th {
            padding: 12px 16px;
            background: #fafafa;
            color: #667085;
            font-size: .7rem;
            font-weight: 750;
            text-transform: uppercase;
            border-bottom: 1px solid #e8eaef;
            white-space: nowrap;
        }

        .overdue-table td {
            padding: 14px 16px;
            color: #334155;
            font-size: .82rem;
            border-bottom: 1px solid #f1f2f5;
            vertical-align: middle;
        }

    .overdue-muted {
        display: block;
        color: #667085;
        font-size: .74rem;
        margin-top: 2px;
    }

    .overdue-money {
        color: #111827;
        font-weight: 760;
    }

    .overdue-pill,
    .overdue-days {
        display: inline-flex;
        min-height: 27px;
        align-items: center;
        padding: 0 9px;
        border-radius: 999px;
        font-size: .72rem;
        font-weight: 750;
        white-space: nowrap;
    }

        .overdue-pill.unpaid {
            color: #d92d20;
            background: #fef3f2;
        }

        .overdue-pill.partial {
            color: #b7791f;
            background: #fffbeb;
        }

        .overdue-days.low {
            color: #b7791f;
            background: #fffbeb;
        }

        .overdue-days.medium {
            color: #ea580c;
            background: #fff7ed;
        }

        .overdue-days.high {
            color: #d92d20;
            background: #fef3f2;
        }

    .overdue-actions-col,
    .overdue-actions-cell {
        text-align: right;
    }

    .overdue-actions-cell {
        position: relative;
        min-width: 150px;
    }

    .overdue-action-menu {
        position: relative;
        display: inline-block;
    }

    .overdue-action-toggle {
        min-height: 34px;
        border-radius: 11px;
        border: 1px solid #e5e7eb;
        background: #ffffff;
        color: #252525;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 0 11px;
        font-size: .74rem;
        font-weight: 750;
        cursor: pointer;
        box-shadow: 0 8px 18px rgba(17, 24, 39, .04);
    }

    .overdue-action-dropdown {
        position: absolute;
        top: calc(100% + 8px);
        right: 0;
        width: 195px;
        padding: 7px;
        border-radius: 15px;
        background: #ffffff;
        border: 1px solid #e8eaef;
        box-shadow: 0 18px 38px rgba(17, 24, 39, .14);
        z-index: 100;
        display: grid;
        gap: 4px;
        text-align: left;
    }

        .overdue-action-dropdown button {
            width: 100%;
            min-height: 36px;
            border: 0;
            border-radius: 11px;
            background: transparent;
            color: #344054;
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 0 10px;
            font-size: .78rem;
            font-weight: 650;
            text-align: left;
        }

            .overdue-action-dropdown button:hover {
                background: #fafafa;
                color: #252525;
            }

            .overdue-action-dropdown button i {
                width: 18px;
                color: #8FA6A1;
            }

    .overdue-empty {
        margin: 18px;
        padding: 34px 20px;
        border-radius: 18px;
        background: #fafafa;
        border: 1px dashed #d0d5dd;
        text-align: center;
    }

    .overdue-empty-icon {
        width: 42px;
        height: 42px;
        margin: 0 auto 10px;
        border-radius: 16px;
        background: #f2f6f5;
        color: #8FA6A1;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .overdue-empty strong,
    .overdue-empty span {
        display: block;
    }

    .overdue-empty strong {
        color: #111827;
        font-size: .9rem;
        font-weight: 720;
    }

    .overdue-empty span {
        margin-top: 4px;
        color: #667085;
        font-size: .78rem;
    }

    .overdue-pagination {
        padding: 14px 18px;
        border-top: 1px solid #f1f2f5;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        background: #ffffff;
        border-radius: 0 0 22px 22px;
    }

    .overdue-page-info {
        color: #667085;
        font-size: .78rem;
        font-weight: 600;
    }

        .overdue-page-info strong {
            color: #111827;
        }

    .overdue-page-controls {
        display: flex;
