    private bool CanRefundStatus(string status)
    {
        return status == "Completed" || status == "Partially Refunded";
    }

    private async Task OpenRefundModalAsync(int saleId)
    {
        _showRefundModal = true;
        _loadingRefund = true;

        _refundableSale = await RefundService.GetRefundableSaleAsync(saleId);

        _refundRequest = new CreateRefundRequest
        {
            SaleId = saleId,
            ReturnType = "Refund",
            RefundMethod = "Original Payment",
            RestockItems = true
        };

        _refundQuantities = new Dictionary<int, decimal>();

        if (_refundableSale != null)
        {
            foreach (var item in _refundableSale.Items)
            {
                _refundQuantities[item.SaleItemId] = 0;
            }
        }

        _loadingRefund = false;
    }

    private void CloseRefundModal()
    {
        _showRefundModal = false;
        _refundableSale = null;
        _refundRequest = new CreateRefundRequest();
        _refundQuantities.Clear();
    }

    private decimal GetRefundQuantity(int saleItemId)
    {
        return _refundQuantities.TryGetValue(saleItemId, out var qty) ? qty : 0;
    }

    private void UpdateRefundQuantity(int saleItemId, decimal maxQty, string? value)
    {
        if (!decimal.TryParse(value, out var qty))
        {
            qty = 0;
        }

        if (qty < 0)
        {
            qty = 0;
        }

        if (qty > maxQty)
        {
            qty = maxQty;
        }

        _refundQuantities[saleItemId] = qty;
    }

    private void SetFullRefundQuantity(int saleItemId, decimal maxQty)
    {
        _refundQuantities[saleItemId] = maxQty;
    }

    private async Task SaveRefundAsync()
    {
        if (_refundableSale == null)
        {
            ShowMessage("Refund sale could not be loaded.", false);
            return;
        }

        var items = _refundQuantities
            .Where(x => x.Value > 0)
            .Select(x => new CreateRefundItemRequest
            {
                SaleItemId = x.Key,
                Quantity = x.Value
            })
            .ToList();

        if (items.Count == 0)
        {
            ShowMessage("Select at least one item quantity to refund.", false);
            return;
        }

        _savingRefund = true;

        _refundRequest.SaleId = _refundableSale.SaleId;
        _refundRequest.Items = items;

        var result = await RefundService.CreateRefundAsync(_refundRequest);

        _savingRefund = false;

        ShowMessage(result.Message, result.Success);

        if (result.Success)
        {
            CloseRefundModal();

            _salesPage = 1;
            _returnPage = 1;

            await LoadProducts();
            await LoadMySalesAsync();
        }

    }
