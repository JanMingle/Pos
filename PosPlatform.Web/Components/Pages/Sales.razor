@code {
    private List<SaleProductOptionViewModel> _products = new();
    private List<SaleCartLineViewModel> _cart = new();
    private BusinessSettingsFormModel _settings = new();
    private CashierShiftViewModel? _openShift;
    private bool HasOpenShift => _openShift != null;

    private SaleReceiptViewModel? _receipt;
    private List<SaleHistoryRowViewModel> _mySales = new();
    private SalesSummaryViewModel _salesSummary = new();
    private List<BranchOptionViewModel> _branches = new();
    private int? _branchFilter;

    private bool _loadingProducts = true;
    private bool _savingSale;
    private bool _showReceipt;
    private bool _loadingMySales;
    private bool _showAgeConfirmModal;
    private bool _showSaleConfirmModal;
    private bool _showRemoveItemConfirmModal;
    private bool _ageRestrictionConfirmed;

    private int? _pendingRemoveProductId;
    private int? _pendingRemoveProductVariantId;
    private string? _pendingRemoveItemName;

    private string? _searchTerm;
    private string? _barcodeValue;

    private CancellationTokenSource? _productSearchCts;
    private const int ProductSearchDebounceMs = 250;
    private bool _barcodeScanning;
    private string? _message;
    private bool _isSuccess;

    private string _paymentMethod = "Cash";
    private decimal _discountAmount;
    private decimal _amountPaid;

    private DateTime? _fromDate = DateTime.Today;
    private DateTime? _toDate = DateTime.Today;

    private string? _customerName;
    private string? _customerPhone;
    private string? _saleNotes;

    private int _productPage = 1;
    private int _productPageSize = 8;

    private int _salesPage = 1;
    private int _salesPageSize = 8;

    private int _returnPage = 1;
    private int _returnPageSize = 6;

    private decimal Subtotal => _cart.Sum(x => x.LineTotal);
    private decimal DiscountAmount => _settings.AllowDiscounts ? _discountAmount : 0;
    private decimal TaxableAmount => Math.Max(0, Subtotal - DiscountAmount);
    private decimal TaxPreview => _settings.TaxEnabled ? Math.Round(TaxableAmount * (_settings.TaxRate / 100), 2) : 0;
    private decimal TotalPreview => TaxableAmount + TaxPreview;
    private decimal Change => Math.Max(0, _amountPaid - TotalPreview);
    private bool CartHasAgeRestrictedItems => _cart.Any(x => x.AgeRestricted);

    private bool IsCashSale =>
    string.Equals(_paymentMethod, "Cash", StringComparison.OrdinalIgnoreCase);

    private bool CashAmountMissing =>
        IsCashSale && _amountPaid <= 0;

    private bool CashAmountTooLow =>
        IsCashSale && _amountPaid > 0 && _amountPaid < TotalPreview;

    private string? CashPaymentWarning
    {
        get
        {
            if (!IsCashSale)
            {
                return null;
            }

            if (_amountPaid <= 0)
            {
                return "Enter the cash amount given by the customer before completing the sale.";
            }

            if (_amountPaid < TotalPreview)
            {
                return $"Cash amount is short by {Money(TotalPreview - _amountPaid)}.";
            }

            return null;
        }
    }

    private bool IsCompleteSaleButtonDisabled =>
        _savingSale ||
        !HasOpenShift ||
        CashAmountMissing ||
        CashAmountTooLow;

    private List<CustomerOptionViewModel> _customerOptions = new();
    private int? _selectedCustomerId;

    private bool CustomersEnabled => _settings.CustomersEnabled;
    private string SelectedCustomerValue => _selectedCustomerId?.ToString() ?? "";

    private int ProductTotalPages =>
        _products.Count == 0
            ? 1
            : (int)Math.Ceiling(_products.Count / (double)_productPageSize);

    private int SafeProductPage => Math.Min(Math.Max(_productPage, 1), ProductTotalPages);

    private int ProductPageStart =>
        _products.Count == 0
            ? 0
            : ((SafeProductPage - 1) * _productPageSize) + 1;

    private int ProductPageEnd =>
        _products.Count == 0
            ? 0
            : Math.Min(SafeProductPage * _productPageSize, _products.Count);

    private List<SaleProductOptionViewModel> PaginatedProducts =>
        _products
            .Skip((SafeProductPage - 1) * _productPageSize)
            .Take(_productPageSize)
            .ToList();

    private List<SaleHistoryRowViewModel> RecentMySales =>
        _mySales
            .OrderByDescending(x => x.CreatedAt)
            .ToList();

    private int SalesTotalPages =>
        RecentMySales.Count == 0
            ? 1
            : (int)Math.Ceiling(RecentMySales.Count / (double)_salesPageSize);

    private int SafeSalesPage => Math.Min(Math.Max(_salesPage, 1), SalesTotalPages);

    private List<SaleHistoryRowViewModel> PaginatedMySales =>
        RecentMySales
            .Skip((SafeSalesPage - 1) * _salesPageSize)
            .Take(_salesPageSize)
            .ToList();

    private List<SaleReturnHistoryRowViewModel> RecentReturnHistory =>
        _returnHistory
            .OrderByDescending(x => x.CreatedAt)
            .ToList();

    private int ReturnTotalPages =>
        RecentReturnHistory.Count == 0
            ? 1
            : (int)Math.Ceiling(RecentReturnHistory.Count / (double)_returnPageSize);

    private int SafeReturnPage => Math.Min(Math.Max(_returnPage, 1), ReturnTotalPages);

    private List<SaleReturnHistoryRowViewModel> PaginatedReturnHistory =>
        RecentReturnHistory
            .Skip((SafeReturnPage - 1) * _returnPageSize)
            .Take(_returnPageSize)
            .ToList();

    public void Dispose()
    {
        _productSearchCts?.Cancel();
        _productSearchCts?.Dispose();
    }

    protected override async Task OnInitializedAsync()
    {
        if (!await UserAccessService.CanAccessAsync("sales"))
        {
            NavigationManager.NavigateTo("/dashboard");
            return;
        }

        _settings = await BusinessSettingsService.GetSettingsAsync();
        _openShift = await CashierShiftService.GetOpenShiftAsync();
        _branches = await BranchService.GetBranchOptionsAsync();

        if (CustomersEnabled)
        {
            _customerOptions = await CustomerService.GetCustomerOptionsAsync();
        }

        await LoadProducts();
        await LoadMySalesAsync();
    }

    private async Task LoadProducts()
    {
        var searchSnapshot = _searchTerm?.Trim();

        _loadingProducts = true;
        _productPage = 1;

        await InvokeAsync(StateHasChanged);

        var products = await SaleService.SearchProductsAsync(searchSnapshot);

        var currentSearch = _searchTerm?.Trim();

        if (!string.Equals(searchSnapshot, currentSearch, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        _products = products;
        _loadingProducts = false;
    }

    private async Task HandleProductSearchInput(ChangeEventArgs e)
    {
        _searchTerm = e.Value?.ToString();

        _productSearchCts?.Cancel();

        var cts = new CancellationTokenSource();
        _productSearchCts = cts;

        try
        {
            await Task.Delay(ProductSearchDebounceMs, cts.Token);

            if (cts.IsCancellationRequested)
            {
                return;
            }

            await InvokeAsync(async () =>
            {
                await LoadProducts();
                StateHasChanged();
            });
        }
        catch (TaskCanceledException)
        {
            // User is still typing. Ignore cancelled search.
        }
        finally
        {
            if (_productSearchCts == cts)
            {
                _productSearchCts.Dispose();
                _productSearchCts = null;
            }
        }
    }



    private async Task HandleProductSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            _productSearchCts?.Cancel();
            await LoadProducts();
        }
    }

    private async Task ApplyHistoryFilterAsync()
    {
        _salesPage = 1;
        _returnPage = 1;
        await LoadMySalesAsync();
    }

    private async Task LoadMySalesAsync()
    {
        _loadingMySales = true;

        _mySales = await SaleService.GetMySalesAsync(_fromDate, _toDate, _branchFilter);
        _salesSummary = await SaleService.GetMySalesSummaryAsync(_fromDate, _toDate, _branchFilter);
        _returnHistory = await RefundService.GetReturnHistoryAsync(_fromDate, _toDate, _branchFilter);

        _loadingMySales = false;
    }

    private void NextProductPage()
    {
        if (_productPage < ProductTotalPages)
        {
            _productPage++;
        }
    }

    private void PreviousProductPage()
    {
        if (_productPage > 1)
        {
            _productPage--;
        }
    }

    private void NextSalesPage()
    {
        if (_salesPage < SalesTotalPages)
        {
            _salesPage++;
        }
    }

    private void PreviousSalesPage()
    {
        if (_salesPage > 1)
        {
            _salesPage--;
        }
    }

    private void NextReturnPage()
    {
        if (_returnPage < ReturnTotalPages)
        {
            _returnPage++;
        }
    }

    private void PreviousReturnPage()
    {
        if (_returnPage > 1)
        {
            _returnPage--;
        }
    }

    private async Task HandleBarcodeKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await ScanBarcodeAsync();
        }
    }

    private async Task ScanBarcodeAsync()
    {
        var code = _barcodeValue?.Trim();

        if (string.IsNullOrWhiteSpace(code))
        {
            ShowMessage("Scan or type a barcode first.", false);
            return;
        }

        _barcodeScanning = true;

        var product = await SaleService.GetProductByBarcodeAsync(code);

        _barcodeScanning = false;

        if (product == null)
        {
            ShowMessage($"No item found for barcode or SKU: {code}", false);
            return;
        }

        if (IsAddDisabled(product))
        {
            ShowMessage($"{GetProductDisplayName(product)} cannot be added. Check stock or item status.", false);
            return;
        }

        AddToCart(product);

        _barcodeValue = null;
        ShowMessage($"{GetProductDisplayName(product)} added to cart.", true);
    }

    private void AddToCart(SaleProductOptionViewModel product)
    {
        if (IsAddDisabled(product))
        {
            ShowMessage("This item cannot be added because there is no stock available.", false);
            return;
        }

        var productId = GetProductId(product);
        var productVariantId = product.ProductVariantId;

        var existing = _cart.FirstOrDefault(x =>
            x.ProductId == productId &&
            x.ProductVariantId == productVariantId);

        if (existing != null)
        {
            if (existing.TrackStock && !_settings.AllowNegativeStock && existing.Quantity + 1 > existing.AvailableStock)
            {
                ShowMessage($"Not enough stock for {GetCartItemName(existing)}.", false);
                return;
            }

            existing.Quantity += 1;
            return;
        }

        _cart.Add(new SaleCartLineViewModel
        {
            ProductId = productId,
            ProductVariantId = productVariantId,
            ProductName = product.ProductName,
            DisplayName = GetProductDisplayName(product),
            SKU = GetProductSku(product),
            Barcode = product.Barcode,
            VariantName = product.VariantName,
            VariantSize = product.VariantSize,
            VariantColor = product.VariantColor,
            VariantSKU = product.VariantSKU,
            VariantBarcode = product.VariantBarcode,
            ProductType = product.ProductType,
            TrackStock = product.TrackStock,
            AgeRestricted = product.AgeRestricted,
            UnitOfMeasure = product.UnitOfMeasure,
            DurationMinutes = product.DurationMinutes,
            UnitPrice = product.SellingPrice,
            Quantity = 1,
            AvailableStock = product.QuantityInStock
        });

        if (product.AgeRestricted)
        {
            _ageRestrictionConfirmed = false;
        }
    }

    private bool IsAddDisabled(SaleProductOptionViewModel product)
    {
        return product.TrackStock &&
               !_settings.AllowNegativeStock &&
               product.QuantityInStock <= 0;
    }

    private void IncreaseQuantity(int productId, int? productVariantId)
    {
        var item = FindCartItem(productId, productVariantId);
        if (item == null) return;

        if (item.TrackStock && !_settings.AllowNegativeStock && item.Quantity + 1 > item.AvailableStock)
        {
            ShowMessage($"Not enough stock for {GetCartItemName(item)}.", false);
            return;
        }

        item.Quantity += 1;
    }

    private void DecreaseQuantity(int productId, int? productVariantId)
    {
        var item = FindCartItem(productId, productVariantId);
        if (item == null) return;

        if (item.Quantity <= 1)
        {
            RemoveFromCart(productId, productVariantId);
            return;
        }

        item.Quantity -= 1;
    }

    private void UpdateQuantity(int productId, int? productVariantId, string? value)
    {
        var item = FindCartItem(productId, productVariantId);
        if (item == null) return;

        if (!decimal.TryParse(value, out var quantity) || quantity <= 0)
        {
            item.Quantity = 1;
            return;
        }

        if (item.TrackStock && !_settings.AllowNegativeStock && quantity > item.AvailableStock)
        {
            item.Quantity = item.AvailableStock;
            ShowMessage($"Quantity adjusted to available stock for {GetCartItemName(item)}.", false);
            return;
        }

        item.Quantity = quantity;
    }

    private void RemoveFromCart(int productId, int? productVariantId)
    {
        var item = FindCartItem(productId, productVariantId);

        if (item == null)
        {
            return;
        }

        _pendingRemoveProductId = productId;
        _pendingRemoveProductVariantId = productVariantId;
        _pendingRemoveItemName = GetCartItemName(item);
        _showRemoveItemConfirmModal = true;
    }

    private void ConfirmRemoveCartItem()
    {
        if (!_pendingRemoveProductId.HasValue)
        {
            CloseRemoveItemConfirmModal();
            return;
        }

        var item = FindCartItem(_pendingRemoveProductId.Value, _pendingRemoveProductVariantId);

        if (item != null)
        {
            _cart.Remove(item);
        }

        CloseRemoveItemConfirmModal();

        if (!CartHasAgeRestrictedItems)
        {
            _ageRestrictionConfirmed = false;
        }
    }

    private void CloseRemoveItemConfirmModal()
    {
        _showRemoveItemConfirmModal = false;
        _pendingRemoveProductId = null;
        _pendingRemoveProductVariantId = null;
        _pendingRemoveItemName = null;
    }

    private SaleCartLineViewModel? FindCartItem(int productId, int? productVariantId)
    {
        return _cart.FirstOrDefault(x =>
            x.ProductId == productId &&
            x.ProductVariantId == productVariantId);
    }


