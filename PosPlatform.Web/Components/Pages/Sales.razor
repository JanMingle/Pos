@page "/sales"
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@rendermode InteractiveServer
@layout MainLayout
@attribute [Authorize]
@using PosPlatform.Web.Components.Layout
@using PosPlatform.Web.Models.Sales
@using PosPlatform.Web.Models.Settings
@using PosPlatform.Web.Services
@inject SaleService SaleService
@inject CashierShiftService CashierShiftService
@inject BusinessSettingsService BusinessSettingsService
@inject UserAccessService UserAccessService
@inject NavigationManager NavigationManager
@using PosPlatform.Web.Models.Shifts

<PageTitle>Sales</PageTitle>

<section class="sales-page">
    <div class="sales-header">
        <div>
            <div class="sales-kicker">
                <i class="bi bi-cart-check"></i>
                Point of sale
            </div>
            <h1>Make a Sale</h1>
            <p>Sell products, services, packages, vouchers and digital items from one screen.</p>
        </div>

        <button class="sales-ghost-btn" @onclick="ClearCart">
            <i class="bi bi-trash"></i>
            Clear Cart
        </button>
    </div>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <div class="sales-alert @(_isSuccess ? "success" : "danger")">
            <i class="bi @(_isSuccess ? "bi-check-circle" : "bi-exclamation-triangle")"></i>
            <span>@_message</span>
            <button type="button" @onclick="ClearMessage">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
    }

    <div class="sales-settings-strip">
        <div>
            <span>Business</span>
            <strong>@_settings.BusinessName</strong>
        </div>

        <div>
            <span>Currency</span>
            <strong>@_settings.CurrencyCode · @_settings.CurrencySymbol</strong>
        </div>

        <div>
            <span>Tax</span>
            <strong>@GetTaxLabel()</strong>
        </div>

        <div>
            <span>Discounts</span>
            <strong>@(_settings.AllowDiscounts ? "Enabled" : "Disabled")</strong>
        </div>

        <div>
            <span>Customer</span>
            <strong>@(_settings.RequireCustomerForSale ? "Required" : "Optional")</strong>
        </div>
    </div>

    @if (!HasOpenShift)
    {
        <div class="sales-shift-warning">
            <div>
                <strong>No open cashier shift</strong>
                <span>You need to open a shift before completing sales. This keeps cash, card, EFT, and till totals accurate.</span>
            </div>

            <a href="/cashier-shift" class="sales-open-shift-btn">
                <i class="bi bi-cash-coin"></i>
                Open Shift
            </a>
        </div>
    }
    else
    {
        <div class="sales-shift-active">
            <i class="bi bi-check2-circle"></i>
            <span>
                Shift open since @_openShift!.OpenedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
            </span>
        </div>
    }

    <div class="sales-grid">
        <div class="sales-panel">
            <div class="sales-panel-header">
                <div>
                    <h2>Items</h2>
                    <p>Search product name, SKU, barcode or item type.</p>
                </div>
            </div>

            <div class="sales-search-row">
                <div class="sales-search">
                    <i class="bi bi-search"></i>
                    <input @bind="_searchTerm"
                           @bind:event="oninput"
                           placeholder="Search products, services, vouchers..." />
                </div>

                <button class="sales-primary-btn" @onclick="LoadProducts">
                    Search
                </button>
            </div>

            @if (_loadingProducts)
            {
                <div class="sales-empty">
                    <strong>Loading items...</strong>
                    <span>Please wait.</span>
                </div>
            }
            else if (_products.Count == 0)
            {
                <div class="sales-empty">
                    <strong>No items found</strong>
                    <span>Add products or services first, then come back to sell.</span>
                </div>
            }
            else
            {
                <div class="sales-product-list">
                    @foreach (var product in _products)
                    {
                        <div class="sales-product-card">
                            <div class="sales-product-left">
                                <div class="sales-product-avatar">@GetInitials(product.ProductName)</div>

                                <div>
                                    <strong>@product.ProductName</strong>
                                    <span>@product.SKU · @product.ProductType</span>

                                    @if (product.TrackStock)
                                    {
                                        <small>Stock: @product.QuantityInStock.ToString("0.##") @GetUnitLabel(product.UnitOfMeasure)</small>
                                    }
                                    else if (product.ProductType == "Service" && product.DurationMinutes.HasValue)
                                    {
                                        <small>Duration: @product.DurationMinutes minutes</small>
                                    }
                                    else
                                    {
                                        <small>Non-stock item</small>
                                    }

                                    <div class="sales-item-tags">
                                        <em class="@GetTypeClass(product.ProductType)">@product.ProductType</em>

                                        @if (product.TrackStock)
                                        {
                                            <em class="tag-stock">Stock tracked</em>
                                        }
                                        else
                                        {
                                            <em class="tag-muted">No stock</em>
                                        }

                                        @if (product.AgeRestricted)
                                        {
                                            <em class="tag-age">Age restricted</em>
                                        }
                                    </div>
                                </div>
                            </div>

                            <div class="sales-product-right">
                                <strong>@Money(product.SellingPrice)</strong>

                                <button class="sales-add-btn"
                                        disabled="@IsAddDisabled(product)"
                                        @onclick="() => AddToCart(product)">
                                    <i class="bi bi-plus-lg"></i>
                                    Add
                                </button>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <div class="sales-panel">
            <div class="sales-panel-header">
                <div>
                    <h2>Cart</h2>
                    <p>@_cart.Count item@(_cart.Count == 1 ? "" : "s") selected.</p>
                </div>
            </div>

            @if (_cart.Count == 0)
            {
                <div class="sales-empty">
                    <strong>Your cart is empty</strong>
                    <span>Add products or services from the left to start the sale.</span>
                </div>
            }
            else
            {
                @if (CartHasAgeRestrictedItems)
                {
                    <div class="sales-warning-box">
                        <i class="bi bi-exclamation-triangle"></i>
                        <div>
                            <strong>Age-restricted item in cart</strong>
                            <span>Confirm age verification before completing this sale.</span>
                        </div>
                    </div>
                }

                <div class="sales-cart-list">
                    @foreach (var item in _cart)
                    {
                        <div class="sales-cart-item">
                            <div>
                                <strong>@item.ProductName</strong>
                                <span>@item.SKU · @item.ProductType · @Money(item.UnitPrice) each</span>

                                @if (item.TrackStock)
                                {
                                    <small>Available: @item.AvailableStock.ToString("0.##") @GetUnitLabel(item.UnitOfMeasure)</small>
                                }
                                else if (item.ProductType == "Service" && item.DurationMinutes.HasValue)
                                {
                                    <small>Service duration: @item.DurationMinutes minutes</small>
                                }
                                else
                                {
                                    <small>Non-stock item</small>
                                }
                            </div>

                            <div class="sales-cart-controls">
                                <button @onclick="() => DecreaseQuantity(item.ProductId)">-</button>

                                <input type="number"
                                       min="1"
                                       step="1"
                                       value="@item.Quantity"
                                       @onchange="(e) => UpdateQuantity(item.ProductId, e.Value?.ToString())" />

                                <button @onclick="() => IncreaseQuantity(item.ProductId)">+</button>
                            </div>

                            <div class="sales-cart-total">
                                <strong>@Money(item.LineTotal)</strong>
                                <button @onclick="() => RemoveFromCart(item.ProductId)">
                                    <i class="bi bi-x-lg"></i>
                                </button>
                            </div>
                        </div>
                    }
                </div>

                <div class="sales-payment-box">
                    <div class="sales-form-row">
                        <label>Customer Name @(_settings.RequireCustomerForSale ? "*" : "")</label>
                        <input type="text" @bind="_customerName" placeholder="Customer name" />
                    </div>

                    <div class="sales-form-row">
                        <label>Customer Phone</label>
                        <input type="text" @bind="_customerPhone" placeholder="Customer phone" />
                    </div>

                    <div class="sales-form-row">
                        <label>Payment Method</label>
                        <select @bind="_paymentMethod">
                            <option value="Cash">Cash</option>
                            <option value="Card">Card</option>
                            <option value="EFT">EFT</option>
                        </select>
                    </div>

                    @if (_settings.AllowDiscounts)
                    {
                        <div class="sales-form-row">
                            <label>Discount</label>
                            <input type="number" min="0" step="0.01" @bind="_discountAmount" />
                        </div>
                    }
                    else
                    {
                        <div class="sales-info-note">
                            <strong>Discounts disabled</strong>
                            <span>Discounts are switched off in Business Settings.</span>
                        </div>
                    }

                    <div class="sales-form-row">
                        <label>Tax</label>
                        <input type="text" value="@Money(TaxPreview)" readonly />
                    </div>

                    <div class="sales-form-row">
                        <label>Amount Paid</label>
                        <input type="number" min="0" step="0.01" @bind="_amountPaid" />
                    </div>

                    <div class="sales-form-row">
                        <label>Notes</label>
                        <textarea @bind="_saleNotes" placeholder="Optional sale notes"></textarea>
                    </div>

                    @if (CartHasAgeRestrictedItems)
                    {
                        <label class="sales-check-row">
                            <input type="checkbox" @bind="_ageRestrictionConfirmed" />
                            <span>
                                <strong>Age verification confirmed</strong>
                                <small>I confirm the buyer is eligible to purchase the age-restricted item.</small>
                            </span>
                        </label>
                    }
                </div>

                <div class="sales-totals">
                    <div>
                        <span>Subtotal</span>
                        <strong>@Money(Subtotal)</strong>
                    </div>

                    <div>
                        <span>Discount</span>
                        <strong>@Money(DiscountAmount)</strong>
                    </div>

                    <div>
                        <span>@(_settings.TaxEnabled? _settings.TaxName: "Tax")</span>
                        <strong>@Money(TaxPreview)</strong>
                    </div>

                    <div class="final">
                        <span>Total</span>
                        <strong>@Money(TotalPreview)</strong>
                    </div>

                    <div>
                        <span>Change</span>
                        <strong>@Money(Change)</strong>
                    </div>
                </div>

                <button class="sales-complete-btn"
                        disabled="@(_savingSale || !HasOpenShift)"
                        @onclick="CompleteSaleAsync">
                    <i class="bi bi-check2-circle"></i>
                    @(_savingSale ? "Completing..." : HasOpenShift ? "Complete Sale" : "Open Shift Required")
                </button>
            }
        </div>
    </div>

    <div class="sales-history-panel">
        <div class="sales-history-header">
            <div>
                <h2>My Sales</h2>
                <p>View sales completed by the logged-in user.</p>
            </div>

            <div class="sales-date-filters">
                <input type="date" @bind="_fromDate" />
                <input type="date" @bind="_toDate" />

                <button type="button" class="sales-primary-btn" @onclick="LoadMySalesAsync">
                    <i class="bi bi-filter"></i>
                    Filter
                </button>
            </div>
        </div>

        <div class="sales-summary-grid">
            <div class="sales-summary-card">
                <span>Total Sales</span>
                <strong>@Money(_salesSummary.TotalSales)</strong>
            </div>

            <div class="sales-summary-card">
                <span>Transactions</span>
                <strong>@_salesSummary.TotalTransactions</strong>
            </div>

            <div class="sales-summary-card">
                <span>Average Sale</span>
                <strong>@Money(_salesSummary.AverageSale)</strong>
            </div>

            <div class="sales-summary-card">
                <span>Cash Sales</span>
                <strong>@Money(_salesSummary.CashSales)</strong>
            </div>

            <div class="sales-summary-card">
                <span>Card Sales</span>
                <strong>@Money(_salesSummary.CardSales)</strong>
            </div>

            <div class="sales-summary-card">
                <span>EFT Sales</span>
                <strong>@Money(_salesSummary.EftSales)</strong>
            </div>
        </div>

        @if (_loadingMySales)
        {
            <div class="sales-empty">
                <strong>Loading sales...</strong>
                <span>Please wait.</span>
            </div>
        }
        else if (_mySales.Count == 0)
        {
            <div class="sales-empty">
                <strong>No sales found</strong>
                <span>No sales were completed in the selected period.</span>
            </div>
        }
        else
        {
            <div class="sales-history-table-wrap">
                <table class="sales-history-table">
                    <thead>
                        <tr>
                            <th>Receipt</th>
                            <th>Date</th>
                            <th>Payment</th>
                            <th>Items</th>
                            <th>Total</th>
                            <th>Change</th>
                            <th>Status</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var sale in _mySales)
                        {
                            <tr>
                                <td>@sale.SaleNumber</td>
                                <td>@sale.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                <td>@sale.PaymentMethod</td>
                                <td>@sale.ItemCount</td>
                                <td>@Money(sale.TotalAmount)</td>
                                <td>@Money(sale.ChangeAmount)</td>
                                <td>
                                    <span class="sales-status-pill">@sale.Status</span>
                                </td>
                                <td class="text-end">
                                    <button class="sales-mini-btn" @onclick="() => ViewReceiptAsync(sale.SaleId)">
                                        <i class="bi bi-receipt"></i>
                                        Slip
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</section>

@if (_showAgeConfirmModal)
{
    <div class="sales-modal-backdrop">
        <div class="sales-confirm-card">
            <div class="sales-confirm-icon">
                <i class="bi bi-exclamation-triangle"></i>
            </div>

            <h3>Age Verification Required</h3>
            <p>
                This sale contains an age-restricted item. Confirm that the customer is eligible before completing the sale.
            </p>

            <div class="sales-modal-actions">
                <button type="button" class="sales-ghost-btn" @onclick="CloseAgeModal">Cancel</button>
                <button type="button" class="sales-primary-btn" @onclick="ConfirmAgeAndCompleteAsync">
                    Confirm & Complete
                </button>
            </div>
        </div>
    </div>
}

@if (_showReceipt && _receipt != null)
{
    <div class="receipt-backdrop">
        <div class="receipt-card">
            <div class="receipt-top">
                <div>
                    <h3>@_settings.BusinessName</h3>
                    <p>@_settings.ReceiptTitle</p>
                </div>

                <button type="button" @onclick="CloseReceipt">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <div class="receipt-business">
                @if (!string.IsNullOrWhiteSpace(_settings.Address))
                {
                    <span>@_settings.Address</span>
                }

                @if (!string.IsNullOrWhiteSpace(_settings.Phone))
                {
                    <span>@_settings.Phone</span>
                }

                @if (!string.IsNullOrWhiteSpace(_settings.Email))
                {
                    <span>@_settings.Email</span>
                }
            </div>

            <div class="receipt-meta">
                <div>
                    <span>Receipt No.</span>
                    <strong>@_receipt.SaleNumber</strong>
                </div>

                <div>
                    <span>Date</span>
                    <strong>@_receipt.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</strong>
                </div>

                <div>
                    <span>Cashier</span>
                    <strong>@_receipt.CashierName</strong>
                </div>

                <div>
                    <span>Payment</span>
                    <strong>@_receipt.PaymentMethod</strong>
                </div>

                @if (!string.IsNullOrWhiteSpace(_receipt.CustomerName))
                {
                    <div>
                        <span>Customer</span>
                        <strong>@_receipt.CustomerName</strong>
                    </div>
                }
            </div>

            <div class="receipt-items">
                @foreach (var item in _receipt.Items)
                {
                    <div class="receipt-item">
                        <div>
                            <strong>@item.ProductName</strong>
                            <span>@item.SKU · @item.Quantity.ToString("0.##") x @Money(item.UnitPrice)</span>
                        </div>

                        <strong>@Money(item.LineTotal)</strong>
                    </div>
                }
            </div>

            <div class="receipt-totals">
                <div>
                    <span>Subtotal</span>
                    <strong>@Money(_receipt.Subtotal)</strong>
                </div>

                <div>
                    <span>Discount</span>
                    <strong>@Money(_receipt.DiscountAmount)</strong>
                </div>

                <div>
                    <span>@(_settings.TaxEnabled? _settings.TaxName: "Tax")</span>
                    <strong>@Money(_receipt.TaxAmount)</strong>
                </div>

                <div class="receipt-total-final">
                    <span>Total</span>
                    <strong>@Money(_receipt.TotalAmount)</strong>
                </div>

                <div>
                    <span>Amount Paid</span>
                    <strong>@Money(_receipt.AmountPaid)</strong>
                </div>

                <div>
                    <span>Change</span>
                    <strong>@Money(_receipt.ChangeAmount)</strong>
                </div>
            </div>

            <div class="receipt-footer">
                @if (!string.IsNullOrWhiteSpace(_settings.ReceiptFooterMessage))
                {
                    <p>@_settings.ReceiptFooterMessage</p>
                }

                @if (!string.IsNullOrWhiteSpace(_settings.ReturnPolicyText))
                {
                    <small>@_settings.ReturnPolicyText</small>
                }

                <button type="button" class="sales-primary-btn" onclick="window.print()">
                    <i class="bi bi-printer"></i>
                    Print Slip
                </button>
            </div>
        </div>
    </div>
}

<style>
    .sales-page {
        animation: salesIn .22s ease both;
    }

    .sales-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: 18px;
        margin-bottom: 18px;
    }

    .sales-kicker {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: #2563eb;
        font-size: .74rem;
        font-weight: 750;
        letter-spacing: .06em;
        text-transform: uppercase;
        margin-bottom: 8px;
    }

    .sales-header h1 {
        margin: 0;
        color: #0f172a;
        font-size: 1.45rem;
        font-weight: 680;
        letter-spacing: -.03em;
    }

    .sales-header p {
        margin: 6px 0 0;
        color: #64748b;
        font-size: .88rem;
    }

    .sales-settings-strip {
        display: grid;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        gap: 10px;
        margin-bottom: 16px;
    }

        .sales-settings-strip div {
            padding: 13px;
            border-radius: 16px;
            background: #ffffff;
            border: 1px solid #e7edf5;
            box-shadow: 0 12px 28px rgba(15,23,42,.04);
        }

        .sales-settings-strip span,
        .sales-settings-strip strong {
            display: block;
        }

        .sales-settings-strip span {
            color: #64748b;
            font-size: .72rem;
            font-weight: 650;
        }

        .sales-settings-strip strong {
            margin-top: 4px;
            color: #0f172a;
            font-size: .84rem;
            font-weight: 720;
        }

    .sales-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.1fr) minmax(380px, .9fr);
        gap: 16px;
        align-items: start;
    }

    .sales-panel,
    .sales-history-panel {
        background: #ffffff;
        border: 1px solid #e7edf5;
        border-radius: 20px;
        box-shadow: 0 16px 34px rgba(15, 23, 42, .055);
        overflow: hidden;
    }

    .sales-panel-header,
    .sales-history-header {
        padding: 17px 18px;
        border-bottom: 1px solid #edf2f7;
        display: flex;
        justify-content: space-between;
        gap: 14px;
        align-items: center;
    }

        .sales-panel-header h2,
        .sales-history-header h2 {
            margin: 0;
            color: #0f172a;
            font-size: .92rem;
            font-weight: 720;
        }

        .sales-panel-header p,
        .sales-history-header p {
            margin: 4px 0 0;
            color: #94a3b8;
            font-size: .76rem;
        }

    .sales-search-row {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 10px;
        padding: 14px 18px;
        border-bottom: 1px solid #edf2f7;
    }

    .sales-search {
        min-height: 40px;
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 0 13px;
        border-radius: 12px;
        border: 1px solid #e5e7eb;
        background: #f8fafc;
        color: #94a3b8;
    }

        .sales-search input {
            width: 100%;
            border: 0;
            outline: none;
            background: transparent;
            color: #0f172a;
            font-size: .86rem;
        }

    .sales-primary-btn,
    .sales-ghost-btn,
    .sales-add-btn,
    .sales-complete-btn,
    .sales-mini-btn {
        min-height: 38px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 0 14px;
        border-radius: 11px;
        font-size: .8rem;
        font-weight: 650;
        border: 0;
        transition: all .18s ease;
        white-space: nowrap;
    }

    .sales-primary-btn,
    .sales-complete-btn {
        background: #111827;
        color: #ffffff;
    }

    .sales-ghost-btn {
        background: #ffffff;
        color: #475569;
        border: 1px solid #e5e7eb;
    }

    .sales-add-btn {
        background: #eef5ff;
        color: #2563eb;
    }

        .sales-add-btn:disabled {
            opacity: .5;
            cursor: not-allowed;
        }

    .sales-complete-btn {
        width: calc(100% - 36px);
        margin: 0 18px 18px;
        min-height: 44px;
    }

    .sales-alert {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 14px;
        margin-bottom: 16px;
        border-radius: 14px;
        font-size: .84rem;
        font-weight: 600;
        border: 1px solid;
    }

        .sales-alert.success {
            color: #166534;
            background: #f0fdf4;
            border-color: #bbf7d0;
        }

        .sales-alert.danger {
            color: #991b1b;
            background: #fef2f2;
            border-color: #fecaca;
        }

        .sales-alert span {
            flex: 1;
        }

        .sales-alert button {
            border: 0;
            background: transparent;
            color: inherit;
        }

    .sales-product-list,
    .sales-cart-list {
        padding: 14px 18px;
        display: grid;
        gap: 10px;
    }

    .sales-product-card {
        display: flex;
        justify-content: space-between;
        gap: 14px;
        align-items: flex-start;
        padding: 13px;
        border-radius: 16px;
        background: #f8fafc;
        border: 1px solid #e7edf5;
    }

    .sales-product-left {
        display: flex;
        gap: 11px;
        align-items: flex-start;
    }

    .sales-product-avatar {
        width: 40px;
        height: 40px;
        border-radius: 14px;
        background: #eef5ff;
        color: #2563eb;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .8rem;
        font-weight: 750;
        flex: 0 0 auto;
    }

    .sales-product-left strong,
    .sales-cart-item strong {
        display: block;
        color: #0f172a;
        font-size: .86rem;
        font-weight: 720;
    }

    .sales-product-left span,
    .sales-cart-item span,
    .sales-product-left small,
    .sales-cart-item small {
        display: block;
        color: #64748b;
