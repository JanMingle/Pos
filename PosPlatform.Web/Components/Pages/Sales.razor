@page "/sales"
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@using PosPlatform.Web.Models.Refunds
@using PosPlatform.Web.Models.Branches
@rendermode InteractiveServer
@layout MainLayout
@attribute [Authorize]
@implements IDisposable
@using PosPlatform.Web.Components.Layout
@using PosPlatform.Web.Models.Sales
@using PosPlatform.Web.Models.Settings
@using PosPlatform.Web.Services
@inject SaleService SaleService
@inject RefundService RefundService
@inject CustomerService CustomerService
@inject CashierShiftService CashierShiftService
@inject BusinessSettingsService BusinessSettingsService
@inject UserAccessService UserAccessService
@inject NavigationManager NavigationManager
@using PosPlatform.Web.Models.Shifts
@using PosPlatform.Web.Models.Customers
@inject BranchService BranchService
@using Microsoft.AspNetCore.Components.Web

<PageTitle>Sales</PageTitle>

<section class="sales-page">
    <div class="sales-pos-top">
        <div>
            <div class="sales-kicker">
                <i class="bi bi-cart-check"></i>
                Point of sale
            </div>
            <h1>Sell Faster</h1>
            <p>Scan, search, add to cart, take payment and print the slip from one screen.</p>
        </div>

        <div class="sales-top-actions">
            @if (HasOpenShift)
            {
                <div class="sales-shift-pill">
                    <i class="bi bi-check2-circle"></i>
                    <span>Shift open</span>
                </div>
            }
            else
            {
                <a href="/cashier-shift" class="sales-open-shift-btn">
                    <i class="bi bi-cash-coin"></i>
                    Open Shift
                </a>
            }

            <button type="button" class="sales-ghost-btn" @onclick="ClearCart">
                <i class="bi bi-trash"></i>
                Clear Cart
            </button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <div class="sales-alert @(_isSuccess ? "success" : "danger")">
            <i class="bi @(_isSuccess ? "bi-check-circle" : "bi-exclamation-triangle")"></i>
            <span>@_message</span>
            <button type="button" @onclick="ClearMessage">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
    }

    @if (!HasOpenShift)
    {
        <div class="sales-shift-warning">
            <div>
                <strong>No open cashier shift</strong>
                <span>You need to open a shift before completing sales. You can still prepare a cart, but checkout will be blocked.</span>
            </div>

            <a href="/cashier-shift" class="sales-open-shift-btn">
                <i class="bi bi-cash-coin"></i>
                Open Shift
            </a>
        </div>
    }

    <div class="sales-pos-layout">
        <div class="sales-items-panel">
            <div class="sales-panel-header">
                <div>
                    <h2>Items</h2>
                    <p>Showing @ProductPageStart - @ProductPageEnd of @_products.Count item@(_products.Count == 1 ? "" : "s").</p>
                </div>

                <button type="button" class="sales-ghost-btn compact" @onclick="LoadProducts">
                    <i class="bi bi-arrow-clockwise"></i>
                    Refresh
                </button>
            </div>

            <div class="sales-scan-box">
                <div class="sales-barcode-box">
                    <i class="bi bi-upc-scan"></i>
                    <input @bind="_barcodeValue"
                           @bind:event="oninput"
                           @onkeydown="HandleBarcodeKeyDown"
                           autofocus
                           placeholder="Scan barcode or type SKU, then press Enter" />
                </div>

                <button type="button"
                        class="sales-primary-btn"
                        disabled="@(_barcodeScanning ? "disabled" : null)" @onclick="ScanBarcodeAsync">
                    <i class="bi bi-upc"></i>
                    @(_barcodeScanning ? "Checking..." : "Add Scan")
                </button>
            </div>

            <div class="sales-search-row">
                <div class="sales-search">
                    <i class="bi bi-search"></i>
                    <input value="@_searchTerm"
                           @oninput="HandleProductSearchInput"
                           @onkeydown="HandleProductSearchKeyDown"
                           placeholder="Search product, variant, service, SKU or barcode..." />
                </div>

                <button type="button" class="sales-primary-btn" @onclick="LoadProducts">
                    Refresh
                </button>
            </div>

            @if (_loadingProducts)
            {
                <div class="sales-empty">
                    <strong>Loading items...</strong>
                    <span>Please wait while we prepare your POS item list.</span>
                </div>
            }
            else if (_products.Count == 0)
            {
                <div class="sales-empty">
                    <strong>No items found</strong>
                    <span>Search again or add products/services first.</span>
                </div>
            }
            else
            {
                <div class="sales-product-grid">
                    @foreach (var product in PaginatedProducts)
                    {
                        <button type="button"
                                class="sales-product-tile @(IsAddDisabled(product) ? "disabled" : "")"
                                disabled="@(IsAddDisabled(product) ? "disabled" : null)"
                                @onclick="() => AddToCart(product)">
                            <div class="sales-product-tile-top">
                                <div class="sales-product-avatar">@GetInitials(GetProductDisplayName(product))</div>

                                <div class="sales-product-price">
                                    <strong>@Money(product.SellingPrice)</strong>
                                    @if (product.IsVariant)
                                    {
                                        <span>Variant</span>
                                    }
                                </div>
                            </div>

                            <div class="sales-product-name">
                                <strong>@GetProductDisplayName(product)</strong>
                                <span>@GetProductSku(product) · @product.ProductType</span>
                            </div>

                            <div class="sales-product-meta">
                                @if (product.TrackStock)
                                {
                                    <span class="stock @(product.QuantityInStock <= 0 ? "danger" : "")">
                                        Stock: @product.QuantityInStock.ToString("0.##") @GetUnitLabel(product.UnitOfMeasure)
                                    </span>
                                }
                                else if (product.ProductType == "Service" && product.DurationMinutes.HasValue)
                                {
                                    <span>Duration: @product.DurationMinutes min</span>
                                }
                                else
                                {
                                    <span>Non-stock item</span>
                                }
                            </div>

                            <div class="sales-item-tags">
                                <em class="@GetTypeClass(product.ProductType)">@product.ProductType</em>

                                @if (product.IsVariant)
                                {
                                    <em class="tag-variant">Variant</em>
                                }

                                @if (product.AgeRestricted)
                                {
                                    <em class="tag-age">Age</em>
                                }
                            </div>
                        </button>
                    }
                </div>

                <div class="sales-pagination">
                    <button type="button"
                            class="sales-page-btn"
                            disabled="@(_productPage <= 1 ? "disabled" : null)"
                            @onclick="PreviousProductPage">
                        <i class="bi bi-chevron-left"></i>
                        Previous
                    </button>

                    <span>Page @_productPage of @ProductTotalPages</span>

                    <button type="button"
                            class="sales-page-btn"
disabled="@(_productPage >= ProductTotalPages ? "disabled" : null)"
@onclick="NextProductPage">
                        Next
                        <i class="bi bi-chevron-right"></i>
                    </button>
                </div>
            }
        </div>

        <div class="sales-checkout-panel">
            <div class="sales-cart-top">
                <div>
                    <span>Total</span>
                    <strong>@Money(TotalPreview)</strong>
                </div>

                <div class="sales-cart-count">
                    @_cart.Count item@(_cart.Count == 1 ? "" : "s")
                </div>
            </div>

            @if (_cart.Count == 0)
            {
                <div class="sales-empty cart-empty">
                    <strong>Your cart is empty</strong>
                    <span>Scan a barcode or tap an item to start the sale.</span>
                </div>
            }
            else
            {
                @if (CartHasAgeRestrictedItems)
                {
                    <div class="sales-warning-box">
                        <i class="bi bi-exclamation-triangle"></i>
                        <div>
                            <strong>Age-restricted item</strong>
                            <span>Confirm age verification before checkout.</span>
                        </div>
                    </div>
                }

                <div class="sales-cart-list">
                    @foreach (var item in _cart)
                    {
                        <div class="sales-cart-item">
                            <div class="sales-cart-main">
                                <strong>@GetCartItemName(item)</strong>
                                <span>@item.SKU · @item.ProductType · @Money(item.UnitPrice)</span>

                                @if (item.TrackStock)
                                {
                                    <small>Available: @item.AvailableStock.ToString("0.##") @GetUnitLabel(item.UnitOfMeasure)</small>
                                }
                                else if (item.ProductType == "Service" && item.DurationMinutes.HasValue)
                                {
                                    <small>Service duration: @item.DurationMinutes minutes</small>
                                }
                                else
                                {
                                    <small>Non-stock item</small>
                                }
                            </div>

                            <div class="sales-cart-controls">
                                <button type="button" @onclick="() => DecreaseQuantity(item.ProductId, item.ProductVariantId)">-</button>

                                <input type="number"
                                       min="1"
                                       step="1"
                                       value="@item.Quantity"
                                       @onchange="(e) => UpdateQuantity(item.ProductId, item.ProductVariantId, e.Value?.ToString())" />

                                <button type="button" @onclick="() => IncreaseQuantity(item.ProductId, item.ProductVariantId)">+</button>
                            </div>

                            <div class="sales-cart-line-total">
                                <strong>@Money(item.LineTotal)</strong>
                                <button type="button" @onclick="() => RemoveFromCart(item.ProductId, item.ProductVariantId)">
                                    <i class="bi bi-x-lg"></i>
                                </button>
                            </div>
                        </div>
                    }
                </div>

                <div class="sales-payment-box">
                    @if (CustomersEnabled)
                    {
                        <div class="sales-form-row">
                            <label>Customer</label>
                            <select value="@SelectedCustomerValue" @onchange="OnCustomerChanged">
                                <option value="">Walk-in customer</option>

                                @foreach (var customer in _customerOptions)
                                {
                                    <option value="@customer.Id">
                                        @customer.DisplayName
                                        @if (!string.IsNullOrWhiteSpace(customer.Phone))
                                        {
                                            @($" · {customer.Phone}")
                                        }
                                    </option>
                                }
                            </select>
                        </div>
                    }

                    <div class="sales-form-row">
                        <label>Customer Name @(_settings.RequireCustomerForSale ? "*" : "")</label>
                        <input type="text" @bind="_customerName" placeholder="Customer name" />
                    </div>

                    <div class="sales-form-row">
                        <label>Phone</label>
                        <input type="text" @bind="_customerPhone" placeholder="Customer phone" />
                    </div>

                    <div class="sales-form-row">
                        <label>Payment</label>
                        <select value="@_paymentMethod" @onchange="OnPaymentMethodChanged">
                            <option value="Cash">Cash</option>
                            <option value="Card">Card</option>
                            <option value="EFT">EFT</option>
                        </select>
                    </div>

                    @if (_settings.AllowDiscounts)
                    {
                        <div class="sales-form-row">
                            <label>Discount</label>
                            <input type="number" min="0" step="0.01" @bind="_discountAmount" />
                        </div>
                    }

                    <div class="sales-form-row">
                        <label>@(IsCashSale ? "Amount Given *" : "Amount Paid")</label>
                        <input type="number"
                               min="0"
                               step="0.01"
                               value="@_amountPaid"
                               @oninput="OnAmountPaidInput" />
                    </div>

                    @if (!string.IsNullOrWhiteSpace(CashPaymentWarning))
                    {
                        <div class="sales-cash-warning">
                            <i class="bi bi-exclamation-triangle"></i>
                            <span>@CashPaymentWarning</span>
                        </div>
                    }

                    <div class="sales-quick-cash">
                        <button type="button" @onclick="SetExactPayment">Exact</button>
                        <button type="button" @onclick="() => AddPaidAmount(50)">+ @Money(50)</button>
                        <button type="button" @onclick="() => AddPaidAmount(100)">+ @Money(100)</button>
                        <button type="button" @onclick="() => AddPaidAmount(200)">+ @Money(200)</button>
                    </div>

                    <div class="sales-form-row">
                        <label>Notes</label>
                        <textarea @bind="_saleNotes" placeholder="Optional sale notes"></textarea>
                    </div>

                    @if (CartHasAgeRestrictedItems)
                    {
                        <label class="sales-check-row">
                            <input type="checkbox" @bind="_ageRestrictionConfirmed" />
                            <span>
                                <strong>Age verification confirmed</strong>
                                <small>I confirm the buyer is eligible to purchase the age-restricted item.</small>
                            </span>
                        </label>
                    }
                </div>

                <div class="sales-totals">
                    <div>
                        <span>Subtotal</span>
                        <strong>@Money(Subtotal)</strong>
                    </div>

                    <div>
                        <span>Discount</span>
                        <strong>@Money(DiscountAmount)</strong>
                    </div>

                    <div>
                        <span>@(_settings.TaxEnabled? _settings.TaxName: "Tax")</span>
                        <strong>@Money(TaxPreview)</strong>
                    </div>

                    <div class="final">
                        <span>Total</span>
                        <strong>@Money(TotalPreview)</strong>
                    </div>

                    <div>
                        <span>Change</span>
                        <strong>@Money(Change)</strong>
                    </div>
                </div>

                <button type="button"
                        class="sales-complete-btn"
                        disabled="@(IsCompleteSaleButtonDisabled ? "disabled" : null)"
                        @onclick="CompleteSaleAsync">
                    <i class="bi bi-check2-circle"></i>
                    @GetCompleteSaleButtonText()
                </button>
            }
        </div>
    </div>

    <div class="sales-history-panel">
        <div class="sales-history-header">
            <div>
                <h2>Recent Sales</h2>
                <p>Most recent sales first. Use filters when you need to search another period.</p>
            </div>

            <div class="sales-date-filters">
                <input type="date" @bind="_fromDate" />
                <input type="date" @bind="_toDate" />

                <select class="sales-filter-select" @bind="_branchFilter">
                    <option value="">All branches</option>
                    @foreach (var branch in _branches)
                    {
                        <option value="@branch.Id">
                            @branch.Name
                            @if (branch.IsMainBranch)
                            {
                                @(" · Main")
                            }
                        </option>
                    }
                </select>

                <button type="button" class="sales-primary-btn" @onclick="ApplyHistoryFilterAsync">
                    <i class="bi bi-filter"></i>
                    Filter
                </button>
            </div>
        </div>

        <div class="sales-summary-grid">
            <div class="sales-summary-card">
                <span>Total Sales</span>
                <strong>@Money(_salesSummary.TotalSales)</strong>
            </div>

            <div class="sales-summary-card">
                <span>Transactions</span>
                <strong>@_salesSummary.TotalTransactions</strong>
            </div>

            <div class="sales-summary-card">
                <span>Average Sale</span>
                <strong>@Money(_salesSummary.AverageSale)</strong>
            </div>

            <div class="sales-summary-card">
                <span>Cash Sales</span>
                <strong>@Money(_salesSummary.CashSales)</strong>
            </div>

            <div class="sales-summary-card">
                <span>Card Sales</span>
                <strong>@Money(_salesSummary.CardSales)</strong>
            </div>

            <div class="sales-summary-card">
                <span>EFT Sales</span>
                <strong>@Money(_salesSummary.EftSales)</strong>
            </div>
        </div>

        @if (_loadingMySales)
        {
            <div class="sales-empty">
                <strong>Loading sales...</strong>
                <span>Please wait.</span>
            </div>
        }
        else if (RecentMySales.Count == 0)
        {
            <div class="sales-empty">
                <strong>No sales found</strong>
                <span>No sales were completed in the selected period.</span>
            </div>
        }
        else
        {
            <div class="sales-history-table-wrap">
                <table class="sales-history-table">
                    <thead>
                        <tr>
                            <th>Receipt</th>
                            <th>Date</th>
                            <th>Payment</th>
                            <th>Items</th>
                            <th>Total</th>
                            <th>Change</th>
                            <th>Status</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var sale in PaginatedMySales)
                        {
                            <tr>
                                <td>
                                    <strong>@sale.SaleNumber</strong>
                                </td>
                                <td>@sale.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                <td>@sale.PaymentMethod</td>
                                <td>@sale.ItemCount</td>
                                <td class="sales-money-cell">@Money(sale.TotalAmount)</td>
                                <td>@Money(sale.ChangeAmount)</td>
                                <td>
                                    <span class="sales-status-pill">@sale.Status</span>
                                </td>
                                <td class="text-end">
                                    <button type="button" class="sales-mini-btn" @onclick="() => ViewReceiptAsync(sale.SaleId)">
                                        <i class="bi bi-receipt"></i>
                                        Slip
                                    </button>

                                    @if (CanRefundStatus(sale.Status))
                                    {
                                        <button type="button" class="sales-mini-btn refund" @onclick="() => OpenRefundModalAsync(sale.SaleId)">
                                            <i class="bi bi-arrow-counterclockwise"></i>
                                            Refund
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="sales-pagination">
                <button type="button"
                        class="sales-page-btn"
                        disabled="@(_salesPage <= 1 ? "disabled" : null)"
                        @onclick="PreviousSalesPage">
                    <i class="bi bi-chevron-left"></i>
                    Previous
                </button>

                <span>Page @_salesPage of @SalesTotalPages</span>

                <button type="button"
                        class="sales-page-btn"
disabled="@(_salesPage >= SalesTotalPages ? "disabled" : null)"
@onclick="NextSalesPage">
                    Next
                    <i class="bi bi-chevron-right"></i>
                </button>
            </div>
        }
    </div>

    <div class="sales-history-panel">
        <div class="sales-history-header">
            <div>
                <h2>Refund / Return History</h2>
                <p>Recent refunds, returns and voids processed in the selected period.</p>
            </div>
        </div>

        @if (RecentReturnHistory.Count == 0)
        {
            <div class="sales-empty">
                <strong>No refunds found</strong>
                <span>Refunds and returns will appear here after they are processed.</span>
            </div>
        }
        else
        {
            <div class="sales-history-table-wrap">
                <table class="sales-history-table">
                    <thead>
                        <tr>
                            <th>Return No.</th>
                            <th>Sale</th>
                            <th>Date</th>
                            <th>Type</th>
                            <th>Method</th>
                            <th>Processed By</th>
                            <th>Amount</th>
                            <th>Status</th>
                            <th>Reason</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in PaginatedReturnHistory)
                        {
                            <tr>
                                <td>@item.ReturnNumber</td>
                                <td>@item.SaleNumber</td>
                                <td>@item.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                <td>@item.ReturnType</td>
                                <td>@item.RefundMethod</td>
                                <td>@item.ReturnedByName</td>
                                <td class="sales-money-cell">@Money(item.TotalRefundAmount)</td>
                                <td>
                                    <span class="sales-status-pill">@item.Status</span>
                                </td>
                                <td>@(string.IsNullOrWhiteSpace(item.Reason) ? "-" : item.Reason)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="sales-pagination">
                <button type="button"
                        class="sales-page-btn"
                        disabled="@(_returnPage <= 1 ? "disabled" : null)"
                        @onclick="PreviousReturnPage">
                    <i class="bi bi-chevron-left"></i>
                    Previous
                </button>

                <span>Page @_returnPage of @ReturnTotalPages</span>

                <button type="button"
                        class="sales-page-btn"
disabled="@(_returnPage >= ReturnTotalPages ? "disabled" : null)"
@onclick="NextReturnPage">
                    Next
                    <i class="bi bi-chevron-right"></i>
                </button>
            </div>
        }
    </div>
</section>

@if (_showAgeConfirmModal)
{
    <div class="sales-modal-backdrop">
        <div class="sales-confirm-card">
            <div class="sales-confirm-icon">
                <i class="bi bi-exclamation-triangle"></i>
            </div>

            <h3>Age Verification Required</h3>
            <p>This sale contains an age-restricted item. Confirm that the customer is eligible before completing the sale.</p>

            <div class="sales-modal-actions">
                <button type="button" class="sales-ghost-btn" @onclick="CloseAgeModal">Cancel</button>
                <button type="button" class="sales-primary-btn" @onclick="ConfirmAgeAndCompleteAsync">
                    Confirm & Complete
                </button>
            </div>
        </div>
    </div>
}

@if (_showRemoveItemConfirmModal)
{
    <div class="sales-modal-backdrop">
        <div class="sales-confirm-card">
            <div class="sales-confirm-icon danger">
                <i class="bi bi-trash"></i>
            </div>

            <h3>Remove Item?</h3>

            <p>
                Are you sure you want to remove
                <strong>@(_pendingRemoveItemName ?? "this item")</strong>
                from the cart?
            </p>

            <div class="sales-modal-actions">
                <button type="button" class="sales-ghost-btn" @onclick="CloseRemoveItemConfirmModal">
                    Cancel
                </button>

                <button type="button" class="sales-danger-btn" @onclick="ConfirmRemoveCartItem">
                    <i class="bi bi-trash"></i>
                    Yes, Remove
                </button>
            </div>
        </div>
    </div>
}

@if (_showSaleConfirmModal)
{
    <div class="sales-modal-backdrop">
        <div class="sales-confirm-card">
            <div class="sales-confirm-icon">
                <i class="bi bi-question-circle"></i>
            </div>

            <h3>Confirm Sale</h3>

            <p>
                Are you sure you want to complete this sale? This will create the receipt,
                reduce stock where applicable and save the transaction.
            </p>

            <div class="sales-confirm-summary">
                <div>
                    <span>Total</span>
                    <strong>@Money(TotalPreview)</strong>
                </div>

                <div>
                    <span>Payment</span>
                    <strong>@_paymentMethod</strong>
                </div>

                <div>
                    <span>Amount Given</span>
                    <strong>@Money(_amountPaid)</strong>
                </div>

                <div>
                    <span>Change</span>
                    <strong>@Money(Change)</strong>
                </div>
            </div>

            <div class="sales-modal-actions">
                <button type="button" class="sales-ghost-btn" @onclick="CloseSaleConfirmModal">
                    Cancel
                </button>

                <button type="button" class="sales-primary-btn" @onclick="ConfirmSaleAsync">
                    <i class="bi bi-check2-circle"></i>
                    Yes, Complete Sale
                </button>
            </div>
        </div>
    </div>
}

@if (_showRefundModal)
{
    <div class="sales-modal-backdrop">
        <div class="sales-refund-card">
            <div class="sales-refund-header">
                <div>
                    <span>Refund / Return</span>
                    <h3>@(_refundableSale?.SaleNumber ?? "Sale")</h3>
                    <p>Select the items and quantities to refund, return or void.</p>
                </div>

                <button type="button" class="sales-refund-close" @onclick="CloseRefundModal">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            @if (_loadingRefund)
            {
                <div class="sales-empty">
                    <strong>Loading refundable items...</strong>
                    <span>Please wait.</span>
                </div>
            }
            else if (_refundableSale == null)
            {
                <div class="sales-empty">
                    <strong>Sale not found</strong>
                    <span>This sale could not be loaded for refund.</span>
                </div>
            }
            else if (_refundableSale.Items.Count == 0)
            {
                <div class="sales-empty">
                    <strong>No refundable items left</strong>
                    <span>All items on this sale have already been returned or refunded.</span>
                </div>
            }
            else
            {
                <div class="sales-refund-summary">
                    <div>
                        <span>Sale Date</span>
                        <strong>@_refundableSale.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</strong>
                    </div>

                    <div>
                        <span>Cashier</span>
                        <strong>@_refundableSale.CashierName</strong>
                    </div>

                    <div>
                        <span>Payment</span>
                        <strong>@_refundableSale.PaymentMethod</strong>
                    </div>

                    <div>
                        <span>Original Total</span>
                        <strong>@Money(_refundableSale.TotalAmount)</strong>
                    </div>
                </div>

                <div class="sales-refund-options">
                    <div class="sales-form-row">
                        <label>Type</label>
                        <select @bind="_refundRequest.ReturnType">
                            <option value="Refund">Refund</option>
                            <option value="Return">Return</option>
                            <option value="Void">Void</option>
                        </select>
                    </div>

                    <div class="sales-form-row">
                        <label>Refund Method</label>
                        <select @bind="_refundRequest.RefundMethod">
                            <option value="Original Payment">Original Payment</option>
                            <option value="Cash">Cash</option>
                            <option value="Card">Card</option>
                            <option value="EFT">EFT</option>
                            <option value="Store Credit">Store Credit</option>
                        </select>
                    </div>

                    <label class="sales-check-row">
                        <input type="checkbox" @bind="_refundRequest.RestockItems" />
                        <span>
                            <strong>Return stock to inventory</strong>
                            <small>Only stock-tracked items will be added back to stock.</small>
                        </span>
                    </label>

                    <div class="sales-form-row">
                        <label>Reason</label>
                        <textarea @bind="_refundRequest.Reason" placeholder="Example: Customer return, wrong item, cashier mistake..."></textarea>
                    </div>
                </div>

                <div class="sales-refund-table-wrap">
                    <table class="sales-refund-table">
                        <thead>
                            <tr>
                                <th>Item</th>
                                <th>Sold</th>
                                <th>Returned</th>
                                <th>Remaining</th>
                                <th>Refund Qty</th>
                                <th>Amount</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in _refundableSale.Items)
                            {
                                var selectedQty = GetRefundQuantity(item.SaleItemId);
                                var lineAmount = selectedQty * item.UnitPrice;

                                <tr>
                                    <td>
                                        <strong>@item.ProductName</strong>
                                        <span>@item.SKU · @item.ProductType</span>
                                    </td>

                                    <td>@item.QuantitySold.ToString("0.##")</td>
                                    <td>@item.QuantityAlreadyReturned.ToString("0.##")</td>
                                    <td>@item.QuantityRemaining.ToString("0.##")</td>

                                    <td>
                                        <div class="refund-qty-control">
                                            <input type="number"
                                                   min="0"
                                                   step="1"
                                                   value="@selectedQty"
                                                   @onchange="(e) => UpdateRefundQuantity(item.SaleItemId, item.QuantityRemaining, e.Value?.ToString())" />

                                            <button type="button" @onclick="() => SetFullRefundQuantity(item.SaleItemId, item.QuantityRemaining)">
                                                Full
                                            </button>
                                        </div>
                                    </td>

                                    <td>@Money(lineAmount)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="sales-refund-total">
                    <span>Total Refund</span>
                    <strong>@Money(RefundSelectedTotal)</strong>
                </div>

                <div class="sales-modal-actions">
                    <button type="button" class="sales-ghost-btn" @onclick="CloseRefundModal">Cancel</button>

                    <button type="button"
                            class="sales-primary-btn"
disabled="@(_savingRefund ? "disabled" : null)"
@onclick="SaveRefundAsync">
                        <i class="bi bi-arrow-counterclockwise"></i>
                        @(_savingRefund ? "Processing..." : "Process Refund")
                    </button>
                </div>
            }
        </div>
    </div>
}

@if (_showReceipt && _receipt != null)
{
    <div class="receipt-backdrop">
        <div class="receipt-card">
            <div class="receipt-top">
                <div>
                    <h3>@_settings.BusinessName</h3>
                    <p>@_settings.ReceiptTitle</p>
                </div>

                <button type="button" @onclick="CloseReceipt">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <div class="receipt-business">
                @if (!string.IsNullOrWhiteSpace(_settings.Address))
                {
                    <span>@_settings.Address</span>
                }

                @if (!string.IsNullOrWhiteSpace(_settings.Phone))
                {
                    <span>@_settings.Phone</span>
                }

                @if (!string.IsNullOrWhiteSpace(_settings.Email))
                {
                    <span>@_settings.Email</span>
                }
            </div>

            <div class="receipt-meta">
                <div>
                    <span>Receipt No.</span>
                    <strong>@_receipt.SaleNumber</strong>
                </div>

                <div>
                    <span>Date</span>
                    <strong>@_receipt.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</strong>
                </div>

                <div>
                    <span>Cashier</span>
                    <strong>@_receipt.CashierName</strong>
                </div>

                <div>
                    <span>Payment</span>
                    <strong>@_receipt.PaymentMethod</strong>
                </div>

                @if (!string.IsNullOrWhiteSpace(_receipt.CustomerName))
                {
                    <div>
                        <span>Customer</span>
                        <strong>@_receipt.CustomerName</strong>
                    </div>
                }
            </div>

            <div class="receipt-items">
                @foreach (var item in _receipt.Items)
                {
                    <div class="receipt-item">
                        <div>
                            <strong>@item.ProductName</strong>
                            <span>@item.SKU · @item.Quantity.ToString("0.##") x @Money(item.UnitPrice)</span>
                        </div>

                        <strong>@Money(item.LineTotal)</strong>
                    </div>
                }
            </div>

            <div class="receipt-totals">
                <div>
                    <span>Subtotal</span>
                    <strong>@Money(_receipt.Subtotal)</strong>
                </div>

                <div>
                    <span>Discount</span>
                    <strong>@Money(_receipt.DiscountAmount)</strong>
                </div>

                <div>
                    <span>@(_settings.TaxEnabled? _settings.TaxName: "Tax")</span>
                    <strong>@Money(_receipt.TaxAmount)</strong>
                </div>

                <div class="receipt-total-final">
                    <span>Total</span>
                    <strong>@Money(_receipt.TotalAmount)</strong>
                </div>

                <div>
                    <span>Amount Paid</span>
                    <strong>@Money(_receipt.AmountPaid)</strong>
                </div>

                <div>
                    <span>Change</span>
                    <strong>@Money(_receipt.ChangeAmount)</strong>
                </div>
            </div>

            <div class="receipt-footer">
                @if (!string.IsNullOrWhiteSpace(_settings.ReceiptFooterMessage))
                {
                    <p>@_settings.ReceiptFooterMessage</p>
                }

                @if (!string.IsNullOrWhiteSpace(_settings.ReturnPolicyText))
                {
                    <small>@_settings.ReturnPolicyText</small>
                }

                <button type="button" class="sales-primary-btn" onclick="window.print()">
                    <i class="bi bi-printer"></i>
                    Print Slip
                </button>
            </div>
        </div>
    </div>
}

