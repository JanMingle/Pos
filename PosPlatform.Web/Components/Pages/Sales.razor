@code {
    private List<SaleProductOptionViewModel> _products = new();
    private List<SaleCartLineViewModel> _cart = new();
    private BusinessSettingsFormModel _settings = new();
    private CashierShiftViewModel? _openShift;
    private bool HasOpenShift => _openShift != null;

    private SaleReceiptViewModel? _receipt;
    private List<SaleHistoryRowViewModel> _mySales = new();
    private SalesSummaryViewModel _salesSummary = new();

    private bool _loadingProducts = true;
    private bool _savingSale;
    private bool _showReceipt;
    private bool _loadingMySales;
    private bool _showAgeConfirmModal;
    private bool _ageRestrictionConfirmed;

    private string? _searchTerm;
    private string? _message;
    private bool _isSuccess;

    private string _paymentMethod = "Cash";
    private decimal _discountAmount;
    private decimal _amountPaid;

    private DateTime? _fromDate = DateTime.Today;
    private DateTime? _toDate = DateTime.Today;

    private string? _customerName;
    private string? _customerPhone;
    private string? _saleNotes;

    private decimal Subtotal => _cart.Sum(x => x.LineTotal);
    private decimal DiscountAmount => _settings.AllowDiscounts ? _discountAmount : 0;
    private decimal TaxableAmount => Math.Max(0, Subtotal - DiscountAmount);
    private decimal TaxPreview => _settings.TaxEnabled ? Math.Round(TaxableAmount * (_settings.TaxRate / 100), 2) : 0;
    private decimal TotalPreview => TaxableAmount + TaxPreview;
    private decimal Change => Math.Max(0, _amountPaid - TotalPreview);
    private bool CartHasAgeRestrictedItems => _cart.Any(x => x.AgeRestricted);

    protected override async Task OnInitializedAsync()
    {
        if (!await UserAccessService.CanAccessAsync("sales"))
        {
            NavigationManager.NavigateTo("/dashboard");
            return;
        }

        _settings = await BusinessSettingsService.GetSettingsAsync();
        _openShift = await CashierShiftService.GetOpenShiftAsync();

        await LoadProducts();
        await LoadMySalesAsync();
    }

    private async Task LoadProducts()
    {
        _loadingProducts = true;
        _products = await SaleService.SearchProductsAsync(_searchTerm);
        _loadingProducts = false;
    }

    private async Task LoadMySalesAsync()
    {
        _loadingMySales = true;

        _mySales = await SaleService.GetMySalesAsync(_fromDate, _toDate);
        _salesSummary = await SaleService.GetMySalesSummaryAsync(_fromDate, _toDate);

        _loadingMySales = false;
    }

    private void AddToCart(SaleProductOptionViewModel product)
    {
        if (IsAddDisabled(product))
        {
            ShowMessage("This item cannot be added because there is no stock available.", false);
            return;
        }

        var existing = _cart.FirstOrDefault(x => x.ProductId == product.Id);

        if (existing != null)
        {
            if (existing.TrackStock && !_settings.AllowNegativeStock && existing.Quantity + 1 > existing.AvailableStock)
            {
                ShowMessage($"Not enough stock for {existing.ProductName}.", false);
                return;
            }

            existing.Quantity += 1;
            return;
        }

        _cart.Add(new SaleCartLineViewModel
        {
            ProductId = product.Id,
            ProductName = product.ProductName,
            SKU = product.SKU,
            ProductType = product.ProductType,
            TrackStock = product.TrackStock,
            AgeRestricted = product.AgeRestricted,
            UnitOfMeasure = product.UnitOfMeasure,
            DurationMinutes = product.DurationMinutes,
            UnitPrice = product.SellingPrice,
            Quantity = 1,
            AvailableStock = product.QuantityInStock
        });

        if (product.AgeRestricted)
        {
            _ageRestrictionConfirmed = false;
        }
    }

    private bool IsAddDisabled(SaleProductOptionViewModel product)
    {
        return product.TrackStock &&
               !_settings.AllowNegativeStock &&
               product.QuantityInStock <= 0;
    }

    private void IncreaseQuantity(int productId)
    {
        var item = _cart.FirstOrDefault(x => x.ProductId == productId);
        if (item == null) return;

        if (item.TrackStock && !_settings.AllowNegativeStock && item.Quantity + 1 > item.AvailableStock)
        {
            ShowMessage($"Not enough stock for {item.ProductName}.", false);
            return;
        }

        item.Quantity += 1;
    }

    private void DecreaseQuantity(int productId)
    {
        var item = _cart.FirstOrDefault(x => x.ProductId == productId);
        if (item == null) return;

        if (item.Quantity <= 1)
        {
            RemoveFromCart(productId);
            return;
        }

        item.Quantity -= 1;
    }

    private void UpdateQuantity(int productId, string? value)
    {
        var item = _cart.FirstOrDefault(x => x.ProductId == productId);
        if (item == null) return;

        if (!decimal.TryParse(value, out var quantity) || quantity <= 0)
        {
            item.Quantity = 1;
            return;
        }

        if (item.TrackStock && !_settings.AllowNegativeStock && quantity > item.AvailableStock)
        {
            item.Quantity = item.AvailableStock;
            ShowMessage($"Quantity adjusted to available stock for {item.ProductName}.", false);
            return;
        }

        item.Quantity = quantity;
    }

    private void RemoveFromCart(int productId)
    {
        var item = _cart.FirstOrDefault(x => x.ProductId == productId);
        if (item != null)
        {
            _cart.Remove(item);
        }

        if (!CartHasAgeRestrictedItems)
        {
            _ageRestrictionConfirmed = false;
        }
    }

    private async Task CompleteSaleAsync()
    {
        await CompleteSaleInternalAsync(false);
    }

    private async Task ConfirmAgeAndCompleteAsync()
    {
        _ageRestrictionConfirmed = true;
        _showAgeConfirmModal = false;
        await CompleteSaleInternalAsync(true);
    }

    private async Task CompleteSaleInternalAsync(bool forceAgeConfirmed)
    {
        _openShift = await CashierShiftService.GetOpenShiftAsync();

        if (!HasOpenShift)
        {
            ShowMessage("Open a cashier shift before completing sales.", false);
            return;
        }

        if (_cart.Count == 0)
        {
            ShowMessage("Add items before completing the sale.", false);
            return;
        }

        if (_settings.RequireCustomerForSale && string.IsNullOrWhiteSpace(_customerName))
        {
            ShowMessage("Customer name is required for this business.", false);
            return;
        }

        if (CartHasAgeRestrictedItems && !_ageRestrictionConfirmed && !forceAgeConfirmed)
        {
            _showAgeConfirmModal = true;
            return;
        }

        _savingSale = true;

        var request = new CreateSaleRequest
        {
            PaymentMethod = _paymentMethod,
            CustomerName = _customerName,
            CustomerPhone = _customerPhone,
            Notes = _saleNotes,
            DiscountAmount = DiscountAmount,
            TaxAmount = TaxPreview,
            AmountPaid = _amountPaid,
            AgeRestrictionConfirmed = _ageRestrictionConfirmed || forceAgeConfirmed,
            Items = _cart.Select(x => new CreateSaleItemRequest
            {
                ProductId = x.ProductId,
                Quantity = x.Quantity
            }).ToList()
        };

        var result = await SaleService.CompleteSaleAsync(request);

        _savingSale = false;

        if (result.RequiresAgeConfirmation)
        {
            _showAgeConfirmModal = true;
            ShowMessage(result.Message, false);
            return;
        }

        if (result.RequiresOpenShift)
        {
            _openShift = null;
            ShowMessage(result.Message, false);
            return;
        }

        ShowMessage(result.Message, result.Success);

        if (result.Success)
        {
            if (result.SaleId.HasValue)
            {
                _receipt = await SaleService.GetReceiptAsync(result.SaleId.Value);
                _showReceipt = _receipt != null;
            }

            _cart.Clear();
            _discountAmount = 0;
            _amountPaid = 0;
            _paymentMethod = "Cash";
            _customerName = null;
            _customerPhone = null;
            _saleNotes = null;
            _ageRestrictionConfirmed = false;

            _openShift = await CashierShiftService.GetOpenShiftAsync();

            await LoadProducts();
            await LoadMySalesAsync();
        }
    }

    private void ClearCart()
    {
        _cart.Clear();
        _discountAmount = 0;
        _amountPaid = 0;
        _customerName = null;
        _customerPhone = null;
        _saleNotes = null;
        _ageRestrictionConfirmed = false;
    }

    private async Task ViewReceiptAsync(int saleId)
    {
        _receipt = await SaleService.GetReceiptAsync(saleId);

        if (_receipt == null)
        {
            ShowMessage("Receipt could not be found.", false);
            return;
        }

        _showReceipt = true;
    }

    private void CloseReceipt()
    {
        _showReceipt = false;
        _receipt = null;
    }

    private void CloseAgeModal()
    {
        _showAgeConfirmModal = false;
    }

    private void ShowMessage(string message, bool success)
    {
        _message = message;
        _isSuccess = success;
    }

    private void ClearMessage()
    {
        _message = null;
    }

    private string Money(decimal value)
    {
        var symbol = string.IsNullOrWhiteSpace(_settings.CurrencySymbol)
            ? "R"
            : _settings.CurrencySymbol;

        return $"{symbol} {value:0.00}";
    }

    private string GetTaxLabel()
    {
        if (!_settings.TaxEnabled)
        {
            return "Disabled";
        }

        var taxName = string.IsNullOrWhiteSpace(_settings.TaxName) ? "Tax" : _settings.TaxName;
        return $"{taxName} {_settings.TaxRate:0.##}%";
    }

    private string GetTypeClass(string? type)
    {
        return type switch
        {
            "Service" => "tag-service",
            "Package / Bundle" => "tag-package",
            "Voucher" => "tag-voucher",
            "Digital Product" => "tag-digital",
            _ => "tag-physical"
        };
    }

    private string GetUnitLabel(string? unit)
    {
        return string.IsNullOrWhiteSpace(unit) ? "" : unit;
    }

    private string GetInitials(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "P";
        }

        var words = value
            .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Take(2)
            .Select(x => x[0].ToString().ToUpper());

        return string.Join("", words);
    }
}