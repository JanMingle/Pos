    private int GetProductId(SaleProductOptionViewModel product)
    {
        return product.ProductId > 0 ? product.ProductId : product.Id;
    }

    private string GetProductDisplayName(SaleProductOptionViewModel product)
    {
        return string.IsNullOrWhiteSpace(product.DisplayName)
            ? product.ProductName
            : product.DisplayName;
    }

    private string GetProductSku(SaleProductOptionViewModel product)
    {
        if (!string.IsNullOrWhiteSpace(product.VariantSKU))
        {
            return product.VariantSKU;
        }

        return product.SKU;
    }

    private string GetCartItemName(SaleCartLineViewModel item)
    {
        return string.IsNullOrWhiteSpace(item.DisplayName)
            ? item.ProductName
            : item.DisplayName;
    }

    private string GetInitials(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "P";
        }

        var words = value
            .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Take(2)
            .Select(x => x[0].ToString().ToUpper());

        return string.Join("", words);
    }

    private void OnCustomerChanged(ChangeEventArgs e)
    {
        var value = e.Value?.ToString();

        if (!int.TryParse(value, out var customerId))
        {
            _selectedCustomerId = null;
            _customerName = null;
            _customerPhone = null;
            return;
        }

        var customer = _customerOptions.FirstOrDefault(x => x.Id == customerId);

        if (customer == null)
        {
            _selectedCustomerId = null;
            return;
        }

        _selectedCustomerId = customer.Id;
        _customerName = customer.DisplayName;
        _customerPhone = customer.Phone;
    }

