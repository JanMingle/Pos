    private async Task OpenSaleConfirmModalAsync()
    {
        _openShift = await CashierShiftService.GetOpenShiftAsync();

        if (!HasOpenShift)
        {
            ShowMessage("Open a cashier shift before completing sales.", false);
            return;
        }

        if (_cart.Count == 0)
        {
            ShowMessage("Add items before completing the sale.", false);
            return;
        }

        if (_settings.RequireCustomerForSale && string.IsNullOrWhiteSpace(_customerName))
        {
            ShowMessage("Customer name is required for this business.", false);
            return;
        }

        if (IsCashSale && _amountPaid <= 0)
        {
            ShowMessage("Enter the cash amount given by the customer.", false);
            return;
        }

        if (IsCashSale && _amountPaid < TotalPreview)
        {
            ShowMessage($"Cash amount is too low. The customer still needs {Money(TotalPreview - _amountPaid)}.", false);
            return;
        }

        if (!IsCashSale && _amountPaid <= 0)
        {
            _amountPaid = TotalPreview;
        }

        if (CartHasAgeRestrictedItems && !_ageRestrictionConfirmed)
        {
            _showAgeConfirmModal = true;
            return;
        }

        _showSaleConfirmModal = true;
    }

    private async Task ConfirmAgeAndCompleteAsync()
    {
