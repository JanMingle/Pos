@page "/quotes"
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@rendermode InteractiveServer
@layout MainLayout
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Web
@using PosPlatform.Web.Components.Layout
@using PosPlatform.Web.Models.Quotes
@using PosPlatform.Web.Models.Settings
@using PosPlatform.Web.Services
@inject QuoteService QuoteService
@inject InvoiceService InvoiceService
@inject BusinessSettingsService BusinessSettingsService
@inject UserAccessService UserAccessService
@inject NavigationManager NavigationManager
@inject DocumentEmailService DocumentEmailService

<PageTitle>Quotes</PageTitle>

<section class="quotes-page">
    <div class="quotes-top">
        <div>
            <div class="quotes-kicker">
                <i class="bi bi-file-earmark-text"></i>
                Sales documents
            </div>

            <h1>Quotes</h1>
            <p>Create customer quotes, send them to customers and convert accepted quotes into invoices.</p>
        </div>

        <button type="button" class="quotes-primary-btn" @onclick="OpenCreate">
            <i class="bi bi-plus-circle"></i>
            New Quote
        </button>
    </div>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <div class="quotes-alert @(_isSuccess ? "success" : "danger")">
            <i class="bi @(_isSuccess ? "bi-check-circle" : "bi-exclamation-triangle")"></i>
            <span>@_message</span>
            <button type="button" @onclick="ClearMessage">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
    }

    <div class="quotes-summary-grid">
        <div class="quotes-summary-card hero">
            <div class="quotes-summary-icon">
                <i class="bi bi-file-earmark-text"></i>
            </div>
            <span>Total Value</span>
            <strong>@Money(_quotes.Sum(x => x.TotalAmount))</strong>
            <small>For the selected period</small>
        </div>

        <div class="quotes-summary-card">
            <div class="quotes-summary-icon green">
                <i class="bi bi-check2-circle"></i>
            </div>
            <span>Accepted</span>
            <strong>@AcceptedQuotes</strong>
            <small>Converted or ready to invoice</small>
        </div>

        <div class="quotes-summary-card">
            <div class="quotes-summary-icon blue">
                <i class="bi bi-send"></i>
            </div>
            <span>Sent</span>
            <strong>@SentQuotes</strong>
            <small>Shared with customers</small>
        </div>

        <div class="quotes-summary-card">
            <div class="quotes-summary-icon amber">
                <i class="bi bi-pencil-square"></i>
            </div>
            <span>Drafts</span>
            <strong>@DraftQuotes</strong>
            <small>Still being prepared</small>
        </div>
    </div>

    <div class="quotes-settings-strip">
        <div>
            <span>Business</span>
            <strong>@_settings.BusinessName</strong>
        </div>

        <div>
            <span>Currency</span>
            <strong>@CurrencyLabel</strong>
        </div>

        <div>
            <span>Quotes Showing</span>
            <strong>@TotalQuotes</strong>
        </div>

        <div>
            <span>Tax</span>
            <strong>@(_settings.TaxEnabled ? $"{_settings.TaxRate:0.##}%" : "Disabled")</strong>
        </div>
    </div>

    <div class="quotes-control-panel">
        <input type="date" @bind="_fromDate" />
        <input type="date" @bind="_toDate" />

        <select value="@_statusFilter" @onchange="StatusFilterChanged">
            <option value="all">All statuses</option>
            <option value="Draft">Draft</option>
            <option value="Sent">Sent</option>
            <option value="Accepted">Accepted</option>
            <option value="Cancelled">Cancelled</option>
        </select>

        <div class="quotes-search">
            <i class="bi bi-search"></i>
            <input @bind="_searchTerm"
                   @bind:event="oninput"
                   @onkeydown="HandleSearchKeyDown"
                   placeholder="Search quote number or customer" />
        </div>

        <button type="button" class="quotes-secondary-btn" @onclick="ApplyFiltersAsync">
            <i class="bi bi-filter"></i>
            Filter
        </button>

        <button type="button" class="quotes-ghost-btn" @onclick="ResetFiltersAsync">
            <i class="bi bi-arrow-counterclockwise"></i>
            Reset
        </button>
    </div>

    <div class="quotes-table-card">
        <div class="quotes-table-header">
            <div>
                <h2>Quote List</h2>
                <p>Showing @QuotePageStart - @QuotePageEnd of @TotalQuotes quote@(QuotePlural).</p>
            </div>
        </div>

        @if (_loading)
        {
            <div class="quotes-empty">
                <div class="quotes-empty-icon">
                    <i class="bi bi-hourglass-split"></i>
                </div>
                <strong>Loading quotes...</strong>
                <span>Please wait while we load matching customer quotes.</span>
            </div>
        }
        else if (_quotes.Count == 0)
        {
            <div class="quotes-empty">
                <div class="quotes-empty-icon">
                    <i class="bi bi-file-earmark-plus"></i>
                </div>
                <strong>No quotes found</strong>
                <span>Create your first customer quote to get started.</span>

                <button type="button" class="quotes-primary-btn" @onclick="OpenCreate">
                    <i class="bi bi-plus-circle"></i>
                    New Quote
                </button>
            </div>
        }
        else
        {
            <div class="quotes-table-wrap">
                <table class="quotes-table">
                    <thead>
                        <tr>
                            <th>Quote</th>
                            <th>Customer</th>
                            <th>Date</th>
                            <th>Expiry</th>
                            <th>Items</th>
                            <th>Total</th>
                            <th>Status</th>
                            <th>Created By</th>
                            <th class="quotes-actions-col">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var quote in PaginatedQuotes)
                        {
                            <tr>
                                <td>
                                    <strong>@quote.QuoteNumber</strong>
                                    @if (!string.IsNullOrWhiteSpace(quote.Notes))
                                    {
                                        <span class="quotes-muted">@quote.Notes</span>
                                    }
                                </td>

                                <td>@quote.CustomerName</td>
                                <td>@quote.QuoteDate.ToString("yyyy-MM-dd")</td>
                                <td>@(quote.ExpiryDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                                <td>@quote.ItemCount</td>
                                <td class="quotes-money">@Money(quote.TotalAmount)</td>

                                <td>
                                    <span class="quotes-pill @GetStatusClass(quote.Status)">
                                        @quote.Status
                                    </span>
                                </td>

                                <td>@quote.CreatedByName</td>

                                <td class="quotes-actions-cell">
                                    <div class="quotes-action-menu">
                                        <button type="button"
                                                class="quotes-action-toggle"
                                                @onclick="() => ToggleActionMenu(quote.Id)">
                                            <span>Actions</span>
                                            <i class="bi bi-chevron-down"></i>
                                        </button>

                                        @if (_openActionQuoteId == quote.Id)
                                        {
                                            <div class="quotes-action-dropdown">
                                                <button type="button" @onclick="() => ViewQuoteAsync(quote.Id)">
                                                    <i class="bi bi-eye"></i>
                                                    <span>View quote</span>
                                                </button>

                                                <button type="button" @onclick="() => PrintQuote(quote.Id)">
                                                    <i class="bi bi-printer"></i>
                                                    <span>Print quote</span>
                                                </button>

                                                <button type="button" @onclick="() => SendQuoteEmailAsync(quote.Id)">
                                                    <i class="bi bi-envelope"></i>
                                                    <span>Email quote</span>
                                                </button>

                                                <button type="button" @onclick="() => MarkSentAsync(quote.Id)">
                                                    <i class="bi bi-send"></i>
                                                    <span>Mark as sent</span>
                                                </button>

                                                <button type="button" @onclick="() => MarkAcceptedAsync(quote.Id)">
                                                    <i class="bi bi-check-circle"></i>
                                                    <span>Accept & invoice</span>
                                                </button>

                                                <button type="button" class="danger" @onclick="() => MarkCancelledAsync(quote.Id)">
                                                    <i class="bi bi-x-circle"></i>
                                                    <span>Cancel quote</span>
                                                </button>
                                            </div>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="quotes-pagination">
                <div class="quotes-page-info">
                    Showing
                    <strong>@QuotePageStart</strong>
                    -
                    <strong>@QuotePageEnd</strong>
                    of
                    <strong>@TotalQuotes</strong>
                </div>

                <div class="quotes-page-controls">
                    <button type="button"
                            class="@PreviousQuotePageClass"
                            @onclick="PreviousQuotePage">
                        <i class="bi bi-chevron-left"></i>
                        Previous
                    </button>

                    <span class="quotes-page-count">
                        Page @_quotePage of @QuoteTotalPages
                    </span>

                    <button type="button"
                            class="@NextQuotePageClass"
                            @onclick="NextQuotePage">
                        Next
                        <i class="bi bi-chevron-right"></i>
                    </button>
                </div>
            </div>
        }
    </div>
</section>

@if (_showCreate)
{
    <div class="quotes-modal-backdrop">
        <div class="quotes-modal large">
            <div class="quotes-modal-header">
                <div>
                    <span>Create Quote</span>
                    <h4>New customer quote</h4>
                    <p>Add customer details, products/services, discount and notes.</p>
                </div>

                <button type="button" class="quotes-close-btn" @onclick="CloseCreate">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <div class="quotes-create-grid">
                <div class="quotes-panel">
                    <h5>Customer</h5>

                    <div class="quotes-form-grid">
                        <div>
                            <label>Search customer</label>
                            <input class="quotes-input" @bind="_customerSearch" @bind:event="oninput" placeholder="Name, phone or email" />
                        </div>

                        <div class="align-end">
                            <button type="button" class="quotes-secondary-btn full" @onclick="SearchCustomersAsync">
                                <i class="bi bi-search"></i>
                                Search
                            </button>
                        </div>
                    </div>

                    @if (_customers.Count > 0)
                    {
                        <div class="quotes-option-list">
                            @foreach (var customer in _customers)
                            {
                                <button type="button" @onclick="() => SelectCustomer(customer)">
                                    <strong>@customer.DisplayName</strong>
                                    <span>@(customer.Phone ?? "-") · @(customer.Email ?? "-")</span>
                                </button>
                            }
                        </div>
                    }

                    <div class="quotes-form-grid">
                        <div>
                            <label>Customer Name</label>
                            <input class="quotes-input" @bind="_createModel.CustomerName" />
                        </div>

                        <div>
                            <label>Phone</label>
                            <input class="quotes-input" @bind="_createModel.CustomerPhone" />
                        </div>

                        <div>
                            <label>Email</label>
                            <input class="quotes-input" @bind="_createModel.CustomerEmail" />
                        </div>

                        <div>
                            <label>Expiry Date</label>
                            <input type="date" class="quotes-input" @bind="_createModel.ExpiryDate" />
                        </div>
                    </div>

                    <h5 class="mt">Products / Services</h5>

                    <div class="quotes-form-grid">
                        <div>
                            <label>Search product</label>
                            <input class="quotes-input" @bind="_productSearch" @bind:event="oninput" placeholder="Product, SKU or barcode" />
                        </div>

                        <div class="align-end">
                            <button type="button" class="quotes-secondary-btn full" @onclick="SearchProductsAsync">
                                <i class="bi bi-search"></i>
                                Search
                            </button>
                        </div>
                    </div>

                    @if (_products.Count > 0)
                    {
                        <div class="quotes-product-list">
                            @foreach (var product in _products)
                            {
                                <div>
                                    <div>
                                        <strong>@product.ProductName</strong>
                                        <span>@product.SKU · @product.ProductType · @Money(product.SellingPrice)</span>
                                    </div>

                                    <button type="button" class="quotes-mini-btn" @onclick="() => AddProduct(product)">
                                        <i class="bi bi-plus-lg"></i>
                                        Add
                                    </button>
                                </div>
                            }
                        </div>
                    }
                </div>

                <div class="quotes-panel sticky">
                    <h5>Quote Items</h5>

                    @if (_selectedItems.Count == 0)
                    {
                        <div class="quotes-empty small">
                            <strong>No items added</strong>
                            <span>Add products or services from the search list.</span>
                        </div>
                    }
                    else
                    {
                        <div class="quotes-cart-list">
                            @foreach (var item in _selectedItems)
                            {
                                <div class="quotes-cart-item">
                                    <div>
                                        <strong>@item.ProductName</strong>
                                        <span>@item.SKU · @Money(item.SellingPrice)</span>
                                    </div>

                                    <input type="number" min="0.01" step="0.01" @bind="item.Quantity" />

                                    <button type="button" class="quotes-remove-btn" @onclick="() => RemoveProduct(item.ProductId)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            }
                        </div>
                    }

                    <div class="quotes-form-grid mt">
                        <div>
                            <label>Discount (@CurrencyLabel)</label>
                            <input type="number" min="0" step="0.01" class="quotes-input" @bind="_createModel.DiscountAmount" />
                        </div>
                    </div>

                    <div class="quotes-form-grid">
                        <div>
                            <label>Notes</label>
                            <textarea class="quotes-input quotes-textarea" @bind="_createModel.Notes"></textarea>
                        </div>

                        <div>
                            <label>Terms</label>
                            <textarea class="quotes-input quotes-textarea" @bind="_createModel.Terms"></textarea>
                        </div>
                    </div>

                    <div class="quotes-summary">
                        <div>
                            <span>Subtotal</span>
                            <strong>@Money(CreateSubtotal)</strong>
                        </div>

                        <div>
                            <span>Discount</span>
                            <strong>@Money(_createModel.DiscountAmount)</strong>
                        </div>

                        <div>
                            <span>Estimated Tax</span>
                            <strong>@Money(CreateTax)</strong>
                        </div>

                        <div class="final">
                            <span>Estimated Total</span>
                            <strong>@Money(CreateTotal)</strong>
                        </div>
                    </div>

                    <button type="button" class="quotes-primary-btn full @(_saving ? "is-disabled" : "")" @onclick="SaveQuoteAsync">
                        <i class="bi bi-check-circle"></i>
                        @(_saving ? "Saving..." : "Create Quote")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (_selectedQuote != null)
{
    <div class="quotes-modal-backdrop">
        <div class="quotes-modal">
            <div class="quotes-modal-header">
                <div>
                    <span>@_selectedQuote.Status</span>
                    <h4>@_selectedQuote.QuoteNumber</h4>
                    <p>@(_selectedQuote.CustomerName ?? "Walk-in / Unsaved") · @Money(_selectedQuote.TotalAmount)</p>
                </div>

                <button type="button" class="quotes-close-btn" @onclick="CloseDetails">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <div class="quotes-detail-grid">
                <div>
                    <span>Date</span>
                    <strong>@_selectedQuote.QuoteDate.ToString("yyyy-MM-dd")</strong>
                </div>

                <div>
                    <span>Expiry</span>
                    <strong>@(_selectedQuote.ExpiryDate?.ToString("yyyy-MM-dd") ?? "-")</strong>
                </div>

                <div>
                    <span>Customer Phone</span>
                    <strong>@(_selectedQuote.CustomerPhone ?? "-")</strong>
                </div>
            </div>

            <div class="quotes-detail-actions top-actions">
                <button type="button" class="quotes-secondary-btn full" @onclick="() => PrintQuote(_selectedQuote.Id)">
                    <i class="bi bi-printer"></i>
                    Print Quote
                </button>

                <button type="button" class="quotes-secondary-btn full" @onclick="() => SendQuoteEmailAsync(_selectedQuote.Id)">
                    <i class="bi bi-envelope"></i>
                    Email Quote
                </button>
            </div>

            <div class="quotes-table-wrap">
                <table class="quotes-table compact">
                    <thead>
                        <tr>
                            <th>Item</th>
                            <th>SKU</th>
                            <th>Qty</th>
                            <th>Unit</th>
                            <th>Total</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in _selectedQuote.Items)
                        {
                            <tr>
                                <td>@item.ProductName</td>
                                <td>@item.SKU</td>
                                <td>@item.Quantity</td>
                                <td>@Money(item.UnitPrice)</td>
                                <td>@Money(item.LineTotal)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="quotes-summary">
                <div>
                    <span>Subtotal</span>
                    <strong>@Money(_selectedQuote.Subtotal)</strong>
                </div>

                <div>
                    <span>Discount</span>
                    <strong>@Money(_selectedQuote.DiscountAmount)</strong>
                </div>

                <div>
                    <span>Tax</span>
                    <strong>@Money(_selectedQuote.TaxAmount)</strong>
                </div>

                <div class="final">
                    <span>Total</span>
                    <strong>@Money(_selectedQuote.TotalAmount)</strong>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(_selectedQuote.Notes) || !string.IsNullOrWhiteSpace(_selectedQuote.Terms))
            {
                <div class="quotes-notes-grid">
                    <div>
                        <span>Notes</span>
                        <p>@(string.IsNullOrWhiteSpace(_selectedQuote.Notes) ? "-" : _selectedQuote.Notes)</p>
                    </div>

                    <div>
                        <span>Terms</span>
                        <p>@(string.IsNullOrWhiteSpace(_selectedQuote.Terms) ? "-" : _selectedQuote.Terms)</p>
                    </div>
                </div>
            }

            <div class="quotes-detail-actions">
                @if (_selectedQuote.Status != "Sent")
                {
                    <button type="button" class="quotes-secondary-btn full" @onclick="() => MarkSentAsync(_selectedQuote.Id)">
                        <i class="bi bi-send"></i>
                        Mark as Sent
                    </button>
                }

                @if (_selectedQuote.Status != "Accepted")
                {
                    <button type="button" class="quotes-primary-btn full" @onclick="() => MarkAcceptedAsync(_selectedQuote.Id)">
                        <i class="bi bi-check-circle"></i>
                        Accept & Create Invoice
                    </button>
                }

                @if (_selectedQuote.Status != "Cancelled")
                {
                    <button type="button" class="quotes-danger-mini-btn full" @onclick="() => MarkCancelledAsync(_selectedQuote.Id)">
                        <i class="bi bi-x-circle"></i>
                        Cancel Quote
                    </button>
                }

                @if (_selectedQuote.InvoiceId.HasValue)
                {
                    <button type="button" class="quotes-secondary-btn full" @onclick="GoToInvoices">
                        <i class="bi bi-receipt"></i>
                        View Invoice
                    </button>
                }
            </div>
        </div>
    </div>
}

<style>
    .quotes-page {
        animation: quotesIn .22s ease both;
    }

    .quotes-top {
        display: flex;
        justify-content: space-between;
        gap: 18px;
        align-items: flex-end;
        margin-bottom: 16px;
    }

    .quotes-kicker {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: #8FA6A1;
        font-size: .72rem;
        font-weight: 760;
        letter-spacing: .08em;
        text-transform: uppercase;
        margin-bottom: 8px;
    }

    .quotes-top h1 {
        margin: 0;
        color: #111827;
        font-size: 1.45rem;
        font-weight: 720;
        letter-spacing: -.035em;
    }

    .quotes-top p {
        margin: 6px 0 0;
        color: #667085;
        font-size: .88rem;
    }

    .quotes-primary-btn,
    .quotes-secondary-btn,
    .quotes-ghost-btn,
    .quotes-mini-btn,
    .quotes-danger-mini-btn,
    .quotes-page-btn {
        min-height: 38px;
        border-radius: 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 0 14px;
        font-size: .8rem;
        font-weight: 680;
        border: 0;
        white-space: nowrap;
        transition: transform .18s ease;
    }

    .quotes-primary-btn {
        color: #fff;
        background: #252525;
        box-shadow: 0 12px 24px rgba(17,24,39,.12);
    }

    .quotes-secondary-btn {
        color: #8FA6A1;
        background: #f2f6f5;
        border: 1px solid #dce7e4;
    }

    .quotes-ghost-btn,
    .quotes-page-btn {
        color: #475569;
        background: #fff;
        border: 1px solid #e5e7eb;
    }

    .quotes-mini-btn {
        min-height: 32px;
        color: #8FA6A1;
        background: #f2f6f5;
        border: 1px solid #dce7e4;
        padding: 0 10px;
    }

    .quotes-danger-mini-btn {
        min-height: 32px;
        color: #d92d20;
        background: #fef3f2;
        border: 1px solid #fecaca;
        padding: 0 10px;
    }

        .quotes-primary-btn:hover,
        .quotes-secondary-btn:hover,
        .quotes-ghost-btn:hover,
        .quotes-mini-btn:hover,
        .quotes-danger-mini-btn:hover,
        .quotes-page-btn:hover {
            transform: translateY(-1px);
        }

    .quotes-primary-btn.is-disabled,
    .quotes-page-btn.is-disabled {
        opacity: .45;
        cursor: not-allowed;
        transform: none;
    }

    .quotes-alert {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 14px;
        margin-bottom: 16px;
        border-radius: 14px;
        font-size: .84rem;
        font-weight: 600;
        border: 1px solid;
    }

        .quotes-alert.success {
            color: #166534;
            background: #f0fdf4;
            border-color: #bbf7d0;
        }

        .quotes-alert.danger {
            color: #991b1b;
            background: #fef2f2;
            border-color: #fecaca;
        }

        .quotes-alert span {
            flex: 1;
        }

        .quotes-alert button {
            border: 0;
            background: transparent;
            color: inherit;
        }

    .quotes-summary-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 12px;
        margin-bottom: 16px;
    }

    .quotes-summary-card {
        padding: 15px;
        border-radius: 20px;
        background: #ffffff;
        border: 1px solid #e8eaef;
        box-shadow: 0 14px 32px rgba(17, 24, 39, .045);
    }

        .quotes-summary-card.hero {
            background: #252525;
            border-color: #252525;
        }

        .quotes-summary-card span,
        .quotes-summary-card strong,
        .quotes-summary-card small {
            display: block;
        }

        .quotes-summary-card span {
            margin-top: 11px;
            color: #667085;
            font-size: .72rem;
            font-weight: 700;
        }

        .quotes-summary-card strong {
            margin-top: 6px;
            color: #111827;
            font-size: 1.05rem;
            font-weight: 760;
            letter-spacing: -.02em;
        }

        .quotes-summary-card small {
            margin-top: 4px;
            color: #98a2b3;
            font-size: .72rem;
            line-height: 1.35;
        }

        .quotes-summary-card.hero span,
        .quotes-summary-card.hero strong,
        .quotes-summary-card.hero small {
            color: #ffffff;
        }

    .quotes-summary-icon {
        width: 36px;
        height: 36px;
        border-radius: 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
