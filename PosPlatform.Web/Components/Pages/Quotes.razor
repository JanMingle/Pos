@code {
    private BusinessSettingsFormModel _settings = new();
    private List<QuoteListItemViewModel> _quotes = new();

    private bool _loading = true;
    private bool _saving;

    private DateTime? _fromDate = DateTime.Today.AddDays(-30);
    private DateTime? _toDate = DateTime.Today;
    private string _statusFilter = "all";
    private string? _searchTerm;

    private string? _message;
    private bool _isSuccess;

    private bool _showCreate;
    private CreateQuoteModel _createModel = new();

    private string? _customerSearch;
    private List<QuoteCustomerOptionViewModel> _customers = new();

    private string? _productSearch;
    private List<QuoteProductOptionViewModel> _products = new();
    private List<SelectedQuoteItem> _selectedItems = new();

    private QuoteDetailsViewModel? _selectedQuote;

    private string CurrencyLabel =>
        string.IsNullOrWhiteSpace(_settings.CurrencySymbol)
            ? "R"
            : _settings.CurrencySymbol;

    private decimal CreateSubtotal =>
        _selectedItems.Sum(x => x.Quantity * x.SellingPrice);

    private decimal CreateTaxableAmount =>
        Math.Max(0, CreateSubtotal - _createModel.DiscountAmount);

    private decimal CreateTax =>
        _settings.TaxEnabled
            ? Math.Round(CreateTaxableAmount * (_settings.TaxRate / 100), 2)
            : 0;

    private decimal CreateTotal =>
        CreateTaxableAmount + CreateTax;

    protected override async Task OnInitializedAsync()
    {
        if (!await UserAccessService.CanAccessAsync("quotes"))
        {
            NavigationManager.NavigateTo("/dashboard");
            return;
        }

        _settings = await BusinessSettingsService.GetSettingsAsync();
        await LoadQuotesAsync();
    }

    private async Task LoadQuotesAsync()
    {
        _loading = true;

        _quotes = await QuoteService.GetQuotesAsync(
            _fromDate,
            _toDate,
            _statusFilter,
            _searchTerm);

        _loading = false;
    }

    private async Task ResetFiltersAsync()
    {
        _fromDate = DateTime.Today.AddDays(-30);
        _toDate = DateTime.Today;
        _statusFilter = "all";
        _searchTerm = null;

        await LoadQuotesAsync();
    }

    private void OpenCreate()
    {
        _createModel = new CreateQuoteModel
        {
            QuoteDate = DateTime.Today,
            ExpiryDate = DateTime.Today.AddDays(7),
            Terms = "This quote is valid until the expiry date shown above."
        };

        _selectedItems.Clear();
        _customers.Clear();
        _products.Clear();
        _customerSearch = null;
        _productSearch = null;
        _showCreate = true;
    }

    private void CloseCreate()
    {
        _showCreate = false;
    }

    private async Task SearchCustomersAsync()
    {
        _customers = await QuoteService.SearchCustomersAsync(_customerSearch);
    }

    private void SelectCustomer(QuoteCustomerOptionViewModel customer)
    {
        _createModel.CustomerId = customer.Id;
        _createModel.CustomerName = customer.DisplayName;
        _createModel.CustomerPhone = customer.Phone;
        _createModel.CustomerEmail = customer.Email;
        _customers.Clear();
        _customerSearch = null;
    }

    private async Task SearchProductsAsync()
    {
        _products = await QuoteService.SearchProductsAsync(_productSearch);
    }

    private void AddProduct(QuoteProductOptionViewModel product)
    {
        var existing = _selectedItems.FirstOrDefault(x => x.ProductId == product.Id);

        if (existing != null)
        {
            existing.Quantity += 1;
            return;
        }

        _selectedItems.Add(new SelectedQuoteItem
        {
            ProductId = product.Id,
            ProductName = product.ProductName,
            SKU = product.SKU,
            SellingPrice = product.SellingPrice,
            Quantity = 1
        });
    }

    private void RemoveProduct(int productId)
    {
        var item = _selectedItems.FirstOrDefault(x => x.ProductId == productId);

        if (item != null)
        {
            _selectedItems.Remove(item);
        }
    }

    private async Task SaveQuoteAsync()
    {
        if (_saving)
        {
            return;
        }

        if (_selectedItems.Count == 0)
        {
            ShowMessage("Add at least one product or service before creating the quote.", false);
            return;
        }

        if (_selectedItems.Any(x => x.Quantity <= 0))
        {
            ShowMessage("Every quote item must have a quantity greater than zero.", false);
            return;
        }

        if (_createModel.DiscountAmount < 0)
        {
            ShowMessage("Discount cannot be negative.", false);
            return;
        }

        if (_createModel.DiscountAmount > CreateSubtotal)
        {
            ShowMessage("Discount cannot be greater than the subtotal.", false);
            return;
        }

        _saving = true;

        _createModel.Items = _selectedItems
            .Where(x => x.Quantity > 0)
            .Select(x => new CreateQuoteItemModel
            {
                ProductId = x.ProductId,
                Quantity = x.Quantity
            })
            .ToList();

        var result = await QuoteService.CreateQuoteAsync(_createModel);

        _saving = false;
        ShowMessage(result.Message, result.Success);

        if (result.Success)
        {
            _showCreate = false;
            _selectedItems.Clear();
            _products.Clear();
            _customers.Clear();
            await LoadQuotesAsync();
        }
    }

    private async Task ViewQuoteAsync(int quoteId)
    {
        _selectedQuote = await QuoteService.GetQuoteDetailsAsync(quoteId);
    }

    private void CloseDetails()
    {
        _selectedQuote = null;
    }

    private async Task MarkSentAsync(int quoteId)
    {
        await MarkStatusAsync(quoteId, "Sent");
    }

    private async Task MarkAcceptedAsync(int quoteId)
    {
        var statusResult = await QuoteService.UpdateStatusAsync(quoteId, "Accepted");

        if (!statusResult.Success)
        {
            ShowMessage(statusResult.Message, false);
            return;
        }

        var invoiceResult = await InvoiceService.ConvertQuoteToInvoiceAsync(quoteId);

        if (invoiceResult.Success)
        {
            ShowMessage(invoiceResult.Message, true);
        }
        else if (invoiceResult.InvoiceId.HasValue)
        {
            ShowMessage(invoiceResult.Message, false);
        }
        else
        {
            ShowMessage($"Quote accepted, but invoice was not created: {invoiceResult.Message}", false);
        }

        await LoadQuotesAsync();

        if (_selectedQuote?.Id == quoteId)
        {
            _selectedQuote = await QuoteService.GetQuoteDetailsAsync(quoteId);
        }
    }

    private async Task MarkCancelledAsync(int quoteId)
    {
        await MarkStatusAsync(quoteId, "Cancelled");
    }

    private async Task MarkStatusAsync(int quoteId, string status)
    {
        var result = await QuoteService.UpdateStatusAsync(quoteId, status);

        ShowMessage(result.Message, result.Success);

        if (result.Success)
        {
            await LoadQuotesAsync();

            if (_selectedQuote?.Id == quoteId)
            {
                _selectedQuote = await QuoteService.GetQuoteDetailsAsync(quoteId);
            }
        }
    }

    private void GoToInvoices()
    {
        NavigationManager.NavigateTo("/invoices");
    }

    private string Money(decimal value)
    {
        return $"{CurrencyLabel} {value:0.00}";
    }

    private void ShowMessage(string message, bool success)
    {
        _message = message;
        _isSuccess = success;
    }

    private void ClearMessage()
    {
        _message = null;
    }

    private string GetStatusClass(string status)
    {
        return status switch
        {
            "Draft" => "draft",
            "Sent" => "sent",
            "Accepted" => "accepted",
            "Cancelled" => "cancelled",
            _ => "draft"
        };
    }

    private class SelectedQuoteItem
    {
        public int ProductId { get; set; }
        public string ProductName { get; set; } = string.Empty;
        public string SKU { get; set; } = string.Empty;
        public decimal SellingPrice { get; set; }
        public decimal Quantity { get; set; } = 1;
    }
}