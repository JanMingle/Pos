@page "/dashboard"
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@rendermode InteractiveServer
@layout MainLayout
@attribute [Authorize]
@using PosPlatform.Web.Components.Layout
@using PosPlatform.Web.Models.Dashboard
@using PosPlatform.Web.Models.Settings
@using PosPlatform.Web.Services
@inject DashboardService DashboardService
@inject BusinessSettingsService BusinessSettingsService

<PageTitle>Dashboard</PageTitle>

<section class="dash-page">
    <div class="dash-hero">
        <div>
            <div class="dash-kicker">
                <i class="bi bi-speedometer2"></i>
                Control centre
            </div>

            <h1>@Greeting, @_settings.BusinessName</h1>
            <p>Today’s business health, cashier status, low stock alerts and recent activity in one place.</p>

            <div class="dash-branch-badge">
                <i class="bi bi-shop"></i>
                Showing: @_dashboard.SelectedBranchName
            </div>
        </div>

        <div class="dash-actions">
            <select class="dash-branch-select" @bind="_branchFilter">
                <option value="">All branches</option>
                @foreach (var branch in _dashboard.Branches)
                {
                    <option value="@branch.Id">
                        @branch.Name
                        @if (branch.IsMainBranch)
                        {
                            @(" · Main")
                        }
                    </option>
                }
            </select>

            <button type="button" class="dash-secondary-action" @onclick="LoadDashboardAsync">
                <i class="bi bi-filter"></i>
                Filter
            </button>

            <a href="/sales" class="dash-primary-action">
                <i class="bi bi-cart-check"></i>
                New Sale
            </a>

            <a href="/reports" class="dash-secondary-action">
                <i class="bi bi-bar-chart"></i>
                Reports
            </a>
        </div>
    </div>

    @if (_loading)
    {
        <div class="dash-empty">
            <strong>Loading dashboard...</strong>
            <span>Please wait while we prepare your business summary.</span>
        </div>
    }
    else
    {
        <div class="dash-summary-grid">
            <div class="dash-summary-card dark">
                <span>Net Profit Today</span>
                <strong>@Money(_dashboard.TodayNetProfit)</strong>
                <small>After stock cost and expenses</small>
            </div>

            <div class="dash-summary-card">
                <span>Net Sales</span>
                <strong>@Money(_dashboard.TodayNetSales)</strong>
                <small>@_dashboard.TodayTransactionCount transaction@(_dashboard.TodayTransactionCount == 1 ? "" : "s")</small>
            </div>

            <div class="dash-summary-card green">
                <span>Gross Profit</span>
                <strong>@Money(_dashboard.TodayGrossProfit)</strong>
                <small>Sales minus item cost</small>
            </div>

            <div class="dash-summary-card red">
                <span>Expenses</span>
                <strong>@Money(_dashboard.TodayExpenses)</strong>
                <small>@_dashboard.TodayExpenseCount recorded today</small>
            </div>

            <div class="dash-summary-card amber">
                <span>Refunds</span>
                <strong>@Money(_dashboard.TodayRefunds)</strong>
                <small>@_dashboard.TodayRefundCount refund@(_dashboard.TodayRefundCount == 1 ? "" : "s")</small>
            </div>

            <div class="dash-summary-card blue">
                <span>Low Stock</span>
                <strong>@_dashboard.LowStockCount</strong>
                <small>@_dashboard.OutOfStockCount out of stock</small>
            </div>
        </div>

        <div class="dash-grid">
            <div class="dash-panel dash-shift-panel">
                <div class="dash-panel-header">
                    <div>
                        <h2>Cashier Shift</h2>
                        <p>Your current till session status.</p>
                    </div>

                    <a href="/cashier-shift" class="dash-small-link">
                        Open Shifts
                    </a>
                </div>

                @if (_dashboard.OpenShift == null)
                {
                    <div class="dash-shift-empty">
                        <div>
                            <strong>No open shift</strong>
                            <span>Open a cashier shift before making sales.</span>
                        </div>

                        <a href="/cashier-shift">Open Shift</a>
                    </div>
                }
                else
                {
                    <div class="dash-shift-card">
                        <div class="dash-shift-status">
                            <span>Open since</span>
                            <strong>@_dashboard.OpenShift.OpenedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</strong>
                        </div>

                        <div class="dash-shift-metrics">
                            <div>
                                <span>Opening Cash</span>
                                <strong>@Money(_dashboard.OpenShift.OpeningCash)</strong>
                            </div>

                            <div>
                                <span>Cash Sales</span>
                                <strong>@Money(_dashboard.OpenShift.CashSales)</strong>
                            </div>

                            <div>
                                <span>Card Sales</span>
                                <strong>@Money(_dashboard.OpenShift.CardSales)</strong>
                            </div>

                            <div>
                                <span>EFT Sales</span>
                                <strong>@Money(_dashboard.OpenShift.EftSales)</strong>
                            </div>

                            <div>
                                <span>Total Sales</span>
                                <strong>@Money(_dashboard.OpenShift.TotalSales)</strong>
                            </div>

                            <div>
                                <span>Expected Cash</span>
                                <strong>@Money(_dashboard.OpenShift.ExpectedCash)</strong>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="dash-panel">
                <div class="dash-panel-header">
                    <div>
                        <h2>Quick Actions</h2>
                        <p>Common actions for daily operations.</p>
                    </div>
                </div>

                <div class="dash-quick-actions">
                    <a href="/sales">
                        <i class="bi bi-cart-plus"></i>
                        <span>Make Sale</span>
                    </a>

                    <a href="/stock-purchases">
                        <i class="bi bi-box-arrow-in-down"></i>
                        <span>Receive Stock</span>
                    </a>

                    <a href="/expenses">
                        <i class="bi bi-wallet2"></i>
                        <span>Add Expense</span>
                    </a>

                    <a href="/customers">
                        <i class="bi bi-person-plus"></i>
                        <span>Add Customer</span>
                    </a>

                    <a href="/products">
                        <i class="bi bi-box-seam"></i>
                        <span>Products</span>
                    </a>

                    <a href="/reports">
                        <i class="bi bi-bar-chart"></i>
                        <span>Reports</span>
                    </a>
                </div>
            </div>

            <div class="dash-panel">
                <div class="dash-panel-header">
                    <div>
                        <h2>Recent Sales</h2>
                        <p>Latest transactions recorded today.</p>
                    </div>

                    <a href="/sales" class="dash-small-link">View Sales</a>
                </div>

                @if (_dashboard.RecentSales.Count == 0)
                {
                    <DashboardEmpty Text="No sales yet today." />
                }
                else
                {
                    <div class="dash-list">
                        @foreach (var sale in _dashboard.RecentSales)
                        {
                            <div class="dash-list-row">
                                <div>
                                    <strong>@sale.SaleNumber</strong>
                                    <span>@sale.CreatedAt.ToLocalTime().ToString("HH:mm") · @sale.PaymentMethod · @(string.IsNullOrWhiteSpace(sale.CustomerName) ? "Walk-in" : sale.CustomerName)</span>
                                </div>

                                <div class="dash-row-money">
                                    <strong>@Money(sale.TotalAmount)</strong>
                                    <span>@sale.Status</span>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="dash-panel">
                <div class="dash-panel-header">
                    <div>
                        <h2>Low Stock Alerts</h2>
                        <p>Items that need attention.</p>
                    </div>

                    <a href="/stock" class="dash-small-link">View Stock</a>
                </div>

                @if (_dashboard.LowStockItems.Count == 0)
                {
                    <DashboardEmpty Text="No low stock alerts." />
                }
                else
                {
                    <div class="dash-list">
                        @foreach (var item in _dashboard.LowStockItems)
                        {
                            <div class="dash-list-row">
                                <div>
                                    <strong>@item.ProductName</strong>
                                    <span>@item.SKU · Reorder at @item.ReorderLevel.ToString("0.##")</span>
                                </div>

                                <div class="dash-stock-count @(item.QuantityInStock <= 0 ? "danger" : "warning")">
                                    @item.QuantityInStock.ToString("0.##")
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="dash-panel">
                <div class="dash-panel-header">
                    <div>
                        <h2>Recent Expenses</h2>
                        <p>Latest expenses recorded today.</p>
                    </div>

                    <a href="/expenses" class="dash-small-link">View Expenses</a>
                </div>

                @if (_dashboard.RecentExpenses.Count == 0)
                {
                    <DashboardEmpty Text="No expenses recorded today." />
                }
                else
                {
                    <div class="dash-list">
                        @foreach (var expense in _dashboard.RecentExpenses)
                        {
                            <div class="dash-list-row">
                                <div>
                                    <strong>@expense.CategoryName</strong>
                                    <span>@expense.ExpenseNumber · @(string.IsNullOrWhiteSpace(expense.VendorName) ? "No vendor" : expense.VendorName)</span>
                                </div>

                                <div class="dash-row-money negative">
                                    <strong>@Money(expense.TotalAmount)</strong>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="dash-panel">
                <div class="dash-panel-header">
                    <div>
                        <h2>Recent Refunds</h2>
                        <p>Refunds, returns and voids processed today.</p>
                    </div>

                    <a href="/sales" class="dash-small-link">View Refunds</a>
                </div>

                @if (_dashboard.RecentRefunds.Count == 0)
                {
                    <DashboardEmpty Text="No refunds processed today." />
                }
                else
                {
                    <div class="dash-list">
                        @foreach (var refund in _dashboard.RecentRefunds)
                        {
                            <div class="dash-list-row">
                                <div>
                                    <strong>@refund.ReturnNumber</strong>
                                    <span>@refund.CreatedAt.ToLocalTime().ToString("HH:mm") · @refund.ReturnType · @refund.SaleNumber</span>
                                </div>

                                <div class="dash-row-money negative">
                                    <strong>@Money(refund.TotalRefundAmount)</strong>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }
</section>

<style>
    .dash-page {
        animation: dashIn .22s ease both;
    }

    .dash-hero {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: 18px;
        padding: 22px;
        margin-bottom: 18px;
        border-radius: 24px;
        background: radial-gradient(circle at top right, rgba(37,99,235,.16), transparent 32%), linear-gradient(135deg, #111827, #1f2937);
        box-shadow: 0 18px 40px rgba(15,23,42,.16);
        color: #ffffff;
    }

    .dash-kicker {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: rgba(255,255,255,.78);
        font-size: .74rem;
        font-weight: 750;
        letter-spacing: .06em;
        text-transform: uppercase;
        margin-bottom: 8px;
    }

    .dash-hero h1 {
        margin: 0;
        font-size: 1.55rem;
        font-weight: 700;
        letter-spacing: -.03em;
    }

    .dash-hero p {
        margin: 7px 0 0;
        color: rgba(255,255,255,.72);
        font-size: .88rem;
        max-width: 680px;
    }

    .dash-branch-badge {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        min-height: 30px;
        padding: 0 11px;
        margin-top: 10px;
        border-radius: 999px;
        background: rgba(255,255,255,.12);
        color: #ffffff;
        border: 1px solid rgba(255,255,255,.16);
        font-size: .74rem;
        font-weight: 700;
    }

    .dash-actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .dash-branch-select {
        min-height: 40px;
        border-radius: 12px;
        border: 1px solid rgba(255,255,255,.18);
        background: rgba(255,255,255,.12);
        color: #ffffff;
        padding: 0 12px;
        font-size: .82rem;
        font-weight: 650;
        outline: none;
    }

        .dash-branch-select option {
            color: #0f172a;
            background: #ffffff;
        }

    .dash-primary-action,
    .dash-secondary-action {
        min-height: 40px;
        border-radius: 12px;
        padding: 0 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        font-size: .82rem;
        font-weight: 700;
        text-decoration: none;
        white-space: nowrap;
        border: 0;
    }

    .dash-primary-action {
        background: #ffffff;
        color: #111827;
    }

    .dash-secondary-action {
        background: rgba(255,255,255,.12);
        color: #ffffff;
        border: 1px solid rgba(255,255,255,.18);
    }

    .dash-summary-grid {
        display: grid;
        grid-template-columns: repeat(6, minmax(0, 1fr));
        gap: 12px;
        margin-bottom: 16px;
    }

    .dash-summary-card {
        padding: 16px;
        border-radius: 18px;
        background: #ffffff;
        border: 1px solid #e7edf5;
        box-shadow: 0 12px 28px rgba(15,23,42,.045);
    }

        .dash-summary-card span,
        .dash-summary-card strong,
        .dash-summary-card small {
            display: block;
        }

        .dash-summary-card span {
            color: #64748b;
            font-size: .72rem;
            font-weight: 650;
        }

        .dash-summary-card strong {
            margin-top: 6px;
            color: #0f172a;
            font-size: 1.02rem;
            font-weight: 760;
        }

        .dash-summary-card small {
            margin-top: 4px;
            color: #94a3b8;
            font-size: .72rem;
        }

        .dash-summary-card.dark {
            background: #111827;
            border-color: #111827;
        }

            .dash-summary-card.dark span,
            .dash-summary-card.dark strong,
            .dash-summary-card.dark small {
                color: #ffffff;
            }

        .dash-summary-card.green strong {
            color: #16a34a;
        }

        .dash-summary-card.red strong {
            color: #dc2626;
        }

        .dash-summary-card.amber strong {
            color: #d97706;
        }

        .dash-summary-card.blue strong {
            color: #2563eb;
        }

    .dash-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 16px;
        align-items: start;
    }

    .dash-panel {
        background: #ffffff;
        border: 1px solid #e7edf5;
        border-radius: 20px;
        box-shadow: 0 16px 34px rgba(15,23,42,.055);
        overflow: hidden;
    }

    .dash-panel-header {
        padding: 17px 18px;
        border-bottom: 1px solid #edf2f7;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
    }

        .dash-panel-header h2 {
            margin: 0;
            color: #0f172a;
            font-size: .92rem;
            font-weight: 720;
        }

        .dash-panel-header p {
            margin: 4px 0 0;
            color: #94a3b8;
            font-size: .76rem;
        }

    .dash-small-link {
        min-height: 32px;
        padding: 0 11px;
        border-radius: 10px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #eef5ff;
        color: #2563eb;
        font-size: .74rem;
        font-weight: 700;
        text-decoration: none;
        white-space: nowrap;
    }

    .dash-shift-empty {
        margin: 18px;
        padding: 18px;
        border-radius: 16px;
        background: #fff7ed;
        border: 1px solid #fed7aa;
        display: flex;
        justify-content: space-between;
        gap: 14px;
        align-items: center;
    }

        .dash-shift-empty strong,
        .dash-shift-empty span {
            display: block;
        }

        .dash-shift-empty strong {
            color: #9a3412;
            font-size: .9rem;
        }

        .dash-shift-empty span {
            color: #c2410c;
            font-size: .76rem;
            margin-top: 3px;
        }

        .dash-shift-empty a {
            min-height: 36px;
            border-radius: 10px;
            padding: 0 12px;
            background: #111827;
            color: #ffffff;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            font-size: .78rem;
            font-weight: 700;
            white-space: nowrap;
        }

    .dash-shift-card {
        padding: 18px;
    }

    .dash-shift-status {
        padding: 14px;
        margin-bottom: 12px;
        border-radius: 16px;
        background: #ecfdf5;
        border: 1px solid #bbf7d0;
    }

        .dash-shift-status span,
        .dash-shift-status strong {
            display: block;
        }

        .dash-shift-status span {
            color: #15803d;
            font-size: .72rem;
            font-weight: 650;
        }

        .dash-shift-status strong {
            margin-top: 4px;
            color: #166534;
            font-size: .88rem;
        }

    .dash-shift-metrics {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px;
    }

        .dash-shift-metrics div {
            padding: 13px;
            border-radius: 16px;
            background: #f8fafc;
            border: 1px solid #e7edf5;
        }

        .dash-shift-metrics span,
        .dash-shift-metrics strong {
            display: block;
        }

        .dash-shift-metrics span {
            color: #64748b;
            font-size: .72rem;
            font-weight: 650;
        }

        .dash-shift-metrics strong {
            margin-top: 4px;
            color: #0f172a;
            font-size: .84rem;
        }

    .dash-quick-actions {
        padding: 18px;
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px;
    }

        .dash-quick-actions a {
            min-height: 58px;
            padding: 12px;
            border-radius: 16px;
            background: #f8fafc;
            border: 1px solid #e7edf5;
            display: flex;
            align-items: center;
            gap: 10px;
            color: #0f172a;
            text-decoration: none;
            font-size: .84rem;
            font-weight: 700;
        }

        .dash-quick-actions i {
            width: 34px;
            height: 34px;
            border-radius: 12px;
            background: #eef5ff;
            color: #2563eb;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

    .dash-list {
        padding: 14px 18px;
        display: grid;
        gap: 10px;
    }

    .dash-list-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 14px;
        padding: 13px;
        border-radius: 16px;
        background: #f8fafc;
        border: 1px solid #e7edf5;
    }

        .dash-list-row strong,
        .dash-list-row span {
            display: block;
        }

        .dash-list-row strong {
            color: #0f172a;
            font-size: .84rem;
            font-weight: 720;
        }

        .dash-list-row span {
            margin-top: 3px;
            color: #64748b;
            font-size: .72rem;
        }

    .dash-row-money {
        text-align: right;
        white-space: nowrap;
    }

        .dash-row-money.negative strong {
            color: #dc2626;
        }

    .dash-stock-count {
        min-width: 42px;
        min-height: 32px;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: .78rem;
        font-weight: 800;
    }

        .dash-stock-count.warning {
            color: #b45309;
            background: #fffbeb;
        }

        .dash-stock-count.danger {
            color: #dc2626;
            background: #fef2f2;
        }

    .dash-empty {
        margin: 18px 0;
        padding: 34px 20px;
        border-radius: 16px;
        background: #f8fafc;
        border: 1px dashed #dbe3ef;
        text-align: center;
    }

        .dash-empty strong,
        .dash-empty span {
            display: block;
        }

        .dash-empty strong {
            color: #0f172a;
            font-size: .9rem;
        }

        .dash-empty span {
            margin-top: 4px;
            color: #64748b;
            font-size: .78rem;
        }

    @@keyframes dashIn {
        from {
            opacity: 0;
            transform: translateY(8px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@media (max-width: 1199px) {
        .dash-summary-grid {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }
    }

    @@media (max-width: 991px) {
        .dash-hero,
        .dash-panel-header,
        .dash-shift-empty {
            flex-direction: column;
            align-items: flex-start;
        }

            .dash-actions,
            .dash-actions a,
            .dash-actions button,
            .dash-branch-select,
            .dash-shift-empty a {
                width: 100%;
            }

        .dash-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 640px) {
        .dash-summary-grid,
        .dash-shift-metrics,
        .dash-quick-actions {
            grid-template-columns: 1fr;
        }

        .dash-list-row {
            align-items: flex-start;
        }
    }
</style>

@code {
    private BusinessSettingsFormModel _settings = new();
    private DashboardViewModel _dashboard = new();

    private bool _loading = true;
    private int? _branchFilter;

    private string Greeting
    {
        get
        {
            var hour = DateTime.Now.Hour;

            if (hour < 12)
            {
                return "Good morning";
            }

            if (hour < 17)
            {
                return "Good afternoon";
            }

            return "Good evening";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _settings = await BusinessSettingsService.GetSettingsAsync();
        await LoadDashboardAsync();
    }

    private async Task LoadDashboardAsync()
    {
        _loading = true;
        _dashboard = await DashboardService.GetDashboardAsync(_branchFilter);
        _loading = false;
    }

    private string Money(decimal value)
    {
        var symbol = string.IsNullOrWhiteSpace(_settings.CurrencySymbol)
            ? "R"
            : _settings.CurrencySymbol;

        return $"{symbol} {value:0.00}";
    }
}