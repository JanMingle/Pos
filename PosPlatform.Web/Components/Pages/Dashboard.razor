@code {
    private BusinessSettingsFormModel _settings = new();
    private DashboardViewModel _dashboard = new();

    private bool _loading = true;
    private int? _branchFilter;

    private string Greeting
    {
        get
        {
            var hour = DateTime.Now.Hour;

            if (hour < 12)
            {
                return "Good morning";
            }

            if (hour < 17)
            {
                return "Good afternoon";
            }

            return "Good evening";
        }
    }

    private decimal CurrentCashSales => _dashboard.OpenShift?.CashSales ?? 0m;
    private decimal CurrentCardSales => _dashboard.OpenShift?.CardSales ?? 0m;
    private decimal CurrentEftSales => _dashboard.OpenShift?.EftSales ?? 0m;

    private decimal PaymentMixTotal =>
        CurrentCashSales + CurrentCardSales + CurrentEftSales;

    private decimal AverageSaleToday =>
        _dashboard.TodayTransactionCount <= 0
            ? 0
            : _dashboard.TodayNetSales / _dashboard.TodayTransactionCount;

    private decimal MoneyFlowMax =>
        MaxOf(
            _dashboard.TodayNetSales,
            _dashboard.TodayGrossProfit,
            _dashboard.TodayExpenses,
            _dashboard.TodayRefunds,
            Math.Abs(_dashboard.TodayNetProfit));

    private int ActivityMax =>
        Math.Max(1, MaxOfInt(_dashboard.TodayTransactionCount, _dashboard.TodayExpenseCount, _dashboard.TodayRefundCount));

    private int StockAlertMax =>
        Math.Max(1, _dashboard.LowStockCount + _dashboard.OutOfStockCount);

    private string ProfitStatus =>
        _dashboard.TodayNetProfit > 0
            ? "Profitable"
            : _dashboard.TodayNetProfit < 0
                ? "Loss today"
                : "Break-even";

    private string StockHealthStatus =>
        _dashboard.OutOfStockCount > 0
            ? "Needs attention"
            : _dashboard.LowStockCount > 0
                ? "Watch stock"
                : "Healthy";

    private string TopPaymentMethod
    {
        get
        {
            var methods = new List<(string Name, decimal Value)>
            {
                ("Cash", CurrentCashSales),
                ("Card", CurrentCardSales),
                ("EFT", CurrentEftSales)
            };

            var top = methods.OrderByDescending(x => x.Value).FirstOrDefault();

            return top.Value <= 0 ? "No data" : top.Name;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _settings = await BusinessSettingsService.GetSettingsAsync();

        if (!_settings.SetupCompleted)
        {
            Nav.NavigateTo("/setup-business", true); return;
        }

        await LoadDashboardAsync();
    }
    private async Task LoadDashboardAsync()
    {
        _loading = true;
        _dashboard = await DashboardService.GetDashboardAsync(_branchFilter);
        _loading = false;
    }

    private string Money(decimal value)
    {
        var symbol = string.IsNullOrWhiteSpace(_settings.CurrencySymbol)
            ? "R"
            : _settings.CurrencySymbol;

        return $"{symbol} {value:0.00}";
    }

    private decimal MaxOf(params decimal[] values)
    {
        var max = values
            .Select(Math.Abs)
            .DefaultIfEmpty(0)
            .Max();

        return max <= 0 ? 1 : max;
    }

    private int MaxOfInt(params int[] values)
    {
        return values
            .DefaultIfEmpty(0)
            .Max();
    }

    private string GetBarStyle(decimal value, decimal max)
    {
        if (max <= 0)
        {
            return "width:0%;";
        }

        var width = Math.Min(100, Math.Abs(value) / max * 100);

        return $"width:{width.ToString("0.##", CultureInfo.InvariantCulture)}%;";
    }

    private string GetBarStyle(int value, int max)
    {
        if (max <= 0)
        {
            return "width:0%;";
        }

        var width = Math.Min(100, value / (decimal)max * 100);

        return $"width:{width.ToString("0.##", CultureInfo.InvariantCulture)}%;";
    }

    private string PercentageText(decimal value, decimal total)
    {
        if (total <= 0)
        {
            return "0%";
        }

        var percentage = value / total * 100;

        return $"{percentage.ToString("0.##", CultureInfo.InvariantCulture)}%";
    }

    private string GetPaymentDonutStyle()
    {
        if (PaymentMixTotal <= 0)
        {
            return "background:#f3f4f6;";
        }

        var cashEnd = CurrentCashSales / PaymentMixTotal * 100;
        var cardEnd = cashEnd + (CurrentCardSales / PaymentMixTotal * 100);

        var cash = cashEnd.ToString("0.##", CultureInfo.InvariantCulture);
        var card = cardEnd.ToString("0.##", CultureInfo.InvariantCulture);

        return $"background:conic-gradient(#252525 0 {cash}%, #8FA6A1 {cash}% {card}%, #b7791f {card}% 100%);";
    }

    private string GetProfitTextClass(decimal value)
    {
        if (value > 0)
        {
            return "difference-good";
        }

        if (value < 0)
        {
            return "difference-bad";
        }

        return "difference-neutral";
    }
}