@page "/dashboard"
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@rendermode InteractiveServer
@layout MainLayout
@attribute [Authorize]
@using PosPlatform.Web.Components.Layout
@using PosPlatform.Web.Models.Dashboard
@using PosPlatform.Web.Models.Settings
@using PosPlatform.Web.Services
@inject DashboardService DashboardService
@inject BusinessSettingsService BusinessSettingsService
@using PosPlatform.Web.Components.Shared

<PageTitle>Dashboard</PageTitle>

<section class="dash-page">
    <div class="dash-top">
        <div class="dash-title-area">
            <div class="dash-kicker">
                <i class="bi bi-speedometer2"></i>
                Dashboard
            </div>

            <h1>@Greeting, @_settings.BusinessName</h1>
            <p>Track today’s sales, profit, stock alerts, cashier shift and recent business activity.</p>
        </div>

        <div class="dash-toolbar">
            <select class="dash-select" @bind="_branchFilter">
                <option value="">All branches</option>
                @foreach (var branch in _dashboard.Branches)
                {
                    <option value="@branch.Id">
                        @branch.Name
                        @if (branch.IsMainBranch)
                        {
                            @(" · Main")
                        }
                    </option>
                }
            </select>

            <button type="button" class="dash-btn dash-btn-light" @onclick="LoadDashboardAsync">
                <i class="bi bi-filter"></i>
                Filter
            </button>

            <a href="/sales" class="dash-btn dash-btn-dark">
                <i class="bi bi-cart-check"></i>
                New Sale
            </a>
        </div>
    </div>

    <div class="dash-branch-strip">
        <div>
            <span>Current view</span>
            <strong>@_dashboard.SelectedBranchName</strong>
        </div>

        <div>
            <span>Business</span>
            <strong>@_settings.BusinessType</strong>
        </div>

        <div>
            <span>Currency</span>
            <strong>@_settings.CurrencyCode · @_settings.CurrencySymbol</strong>
        </div>

        <div>
            <span>Stock tracking</span>
            <strong>@(_settings.StockTrackingEnabled ? "Enabled" : "Disabled")</strong>
        </div>
    </div>

    <QuoteInvoiceDashboardCards />

    @if (_loading)
    {
        <div class="dash-empty">
            <div class="dash-empty-icon">
                <i class="bi bi-hourglass-split"></i>
            </div>
            <strong>Loading dashboard...</strong>
            <span>Please wait while we prepare your business summary.</span>
        </div>
    }
    else
    {
        <div class="dash-summary-grid">
            <div class="dash-summary-card hero">
                <div class="dash-card-icon">
                    <i class="bi bi-graph-up-arrow"></i>
                </div>
                <span>Net Profit Today</span>
                <strong>@Money(_dashboard.TodayNetProfit)</strong>
                <small>After stock cost and expenses</small>
            </div>

            <div class="dash-summary-card">
                <div class="dash-card-icon soft">
                    <i class="bi bi-receipt"></i>
                </div>
                <span>Net Sales</span>
                <strong>@Money(_dashboard.TodayNetSales)</strong>
                <small>@_dashboard.TodayTransactionCount transaction@(_dashboard.TodayTransactionCount == 1 ? "" : "s")</small>
            </div>

            <div class="dash-summary-card">
                <div class="dash-card-icon green">
                    <i class="bi bi-cash-stack"></i>
                </div>
                <span>Gross Profit</span>
                <strong>@Money(_dashboard.TodayGrossProfit)</strong>
                <small>Sales minus item cost</small>
            </div>

            <div class="dash-summary-card">
                <div class="dash-card-icon red">
                    <i class="bi bi-wallet2"></i>
                </div>
                <span>Expenses</span>
                <strong>@Money(_dashboard.TodayExpenses)</strong>
                <small>@_dashboard.TodayExpenseCount recorded today</small>
            </div>

            <div class="dash-summary-card">
                <div class="dash-card-icon amber">
                    <i class="bi bi-arrow-counterclockwise"></i>
                </div>
                <span>Refunds</span>
                <strong>@Money(_dashboard.TodayRefunds)</strong>
                <small>@_dashboard.TodayRefundCount refund@(_dashboard.TodayRefundCount == 1 ? "" : "s")</small>
            </div>

            <div class="dash-summary-card">
                <div class="dash-card-icon blue">
                    <i class="bi bi-box-seam"></i>
                </div>
                <span>Low Stock</span>
                <strong>@_dashboard.LowStockCount</strong>
                <small>@_dashboard.OutOfStockCount out of stock</small>
            </div>
        </div>

        <div class="dash-main-grid">
            <div class="dash-left-column">
                <div class="dash-panel">
                    <div class="dash-panel-header">
                        <div>
                            <h2>Cashier Shift</h2>
                            <p>Your current till session status.</p>
                        </div>

                        <a href="/cashier-shift" class="dash-panel-link">
                            Open Shifts
                        </a>
                    </div>

                    @if (_dashboard.OpenShift == null)
                    {
                        <div class="dash-shift-empty">
                            <div class="dash-shift-empty-icon">
                                <i class="bi bi-cash-coin"></i>
                            </div>

                            <div>
                                <strong>No open shift</strong>
                                <span>Open a cashier shift before making sales.</span>
                            </div>

                            <a href="/cashier-shift">Open Shift</a>
                        </div>
                    }
                    else
                    {
                        <div class="dash-shift-card">
                            <div class="dash-shift-status">
                                <span>Open since</span>
                                <strong>@_dashboard.OpenShift.OpenedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</strong>
                            </div>

                            <div class="dash-shift-metrics">
                                <div>
                                    <span>Opening Cash</span>
                                    <strong>@Money(_dashboard.OpenShift.OpeningCash)</strong>
                                </div>

                                <div>
                                    <span>Cash Sales</span>
                                    <strong>@Money(_dashboard.OpenShift.CashSales)</strong>
                                </div>

                                <div>
                                    <span>Card Sales</span>
                                    <strong>@Money(_dashboard.OpenShift.CardSales)</strong>
                                </div>

                                <div>
                                    <span>EFT Sales</span>
                                    <strong>@Money(_dashboard.OpenShift.EftSales)</strong>
                                </div>

                                <div>
                                    <span>Total Sales</span>
                                    <strong>@Money(_dashboard.OpenShift.TotalSales)</strong>
                                </div>

                                <div>
                                    <span>Expected Cash</span>
                                    <strong>@Money(_dashboard.OpenShift.ExpectedCash)</strong>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="dash-panel">
                    <div class="dash-panel-header">
                        <div>
                            <h2>Quick Actions</h2>
                            <p>Shortcuts for daily operations.</p>
                        </div>
                    </div>

                    <div class="dash-quick-actions">
                        <a href="/sales">
                            <i class="bi bi-cart-plus"></i>
                            <span>Make Sale</span>
                        </a>

                        <a href="/stock-purchases">
                            <i class="bi bi-box-arrow-in-down"></i>
                            <span>Receive Stock</span>
                        </a>

                        <a href="/products">
                            <i class="bi bi-box-seam"></i>
                            <span>Products</span>
                        </a>

                        <a href="/customers">
                            <i class="bi bi-person-plus"></i>
                            <span>Customers</span>
                        </a>

                        <a href="/expenses">
                            <i class="bi bi-wallet2"></i>
                            <span>Expenses</span>
                        </a>

                        <a href="/reports">
                            <i class="bi bi-bar-chart"></i>
                            <span>Reports</span>
                        </a>
                    </div>
                </div>
            </div>

            <div class="dash-right-column">
                <div class="dash-panel">
                    <div class="dash-panel-header">
                        <div>
                            <h2>Recent Sales</h2>
                            <p>Latest transactions recorded today.</p>
                        </div>

                        <a href="/sales" class="dash-panel-link">View Sales</a>
                    </div>

                    @if (_dashboard.RecentSales.Count == 0)
                    {
                        <DashboardEmpty Text="No sales yet today." />
                    }
                    else
                    {
                        <div class="dash-list">
                            @foreach (var sale in _dashboard.RecentSales)
                            {
                                <div class="dash-list-row">
                                    <div class="dash-list-left">
                                        <div class="dash-list-avatar">
                                            <i class="bi bi-receipt"></i>
                                        </div>

                                        <div>
                                            <strong>@sale.SaleNumber</strong>
                                            <span>@sale.CreatedAt.ToLocalTime().ToString("HH:mm") · @sale.PaymentMethod · @(string.IsNullOrWhiteSpace(sale.CustomerName) ? "Walk-in" : sale.CustomerName)</span>
                                        </div>
                                    </div>

                                    <div class="dash-row-money">
                                        <strong>@Money(sale.TotalAmount)</strong>
                                        <span>@sale.Status</span>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>

                <div class="dash-panel">
                    <div class="dash-panel-header">
                        <div>
                            <h2>Low Stock Alerts</h2>
                            <p>Items that need attention.</p>
                        </div>

                        <a href="/stock" class="dash-panel-link">View Stock</a>
                    </div>

                    @if (_dashboard.LowStockItems.Count == 0)
                    {
                        <DashboardEmpty Text="No low stock alerts." />
                    }
                    else
                    {
                        <div class="dash-list">
                            @foreach (var item in _dashboard.LowStockItems)
                            {
                                <div class="dash-list-row">
                                    <div class="dash-list-left">
                                        <div class="dash-list-avatar warning">
                                            <i class="bi bi-box-seam"></i>
                                        </div>

                                        <div>
                                            <strong>@item.ProductName</strong>
                                            <span>@item.SKU · Reorder at @item.ReorderLevel.ToString("0.##")</span>
                                        </div>
                                    </div>

                                    <div class="dash-stock-count @(item.QuantityInStock <= 0 ? "danger" : "warning")">
                                        @item.QuantityInStock.ToString("0.##")
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>

                <div class="dash-panel two-column-panel">
                    <div class="dash-mini-section">
                        <div class="dash-panel-header compact">
                            <div>
                                <h2>Recent Expenses</h2>
                                <p>Recorded today.</p>
                            </div>

                            <a href="/expenses" class="dash-panel-link">View</a>
                        </div>

                        @if (_dashboard.RecentExpenses.Count == 0)
                        {
                            <DashboardEmpty Text="No expenses recorded today." />
                        }
                        else
                        {
                            <div class="dash-list compact-list">
                                @foreach (var expense in _dashboard.RecentExpenses)
                                {
                                    <div class="dash-list-row">
                                        <div>
                                            <strong>@expense.CategoryName</strong>
                                            <span>@expense.ExpenseNumber · @(string.IsNullOrWhiteSpace(expense.VendorName) ? "No vendor" : expense.VendorName)</span>
                                        </div>

                                        <div class="dash-row-money negative">
                                            <strong>@Money(expense.TotalAmount)</strong>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <div class="dash-mini-section border-left">
                        <div class="dash-panel-header compact">
                            <div>
                                <h2>Recent Refunds</h2>
                                <p>Returns and voids.</p>
                            </div>

                            <a href="/sales" class="dash-panel-link">View</a>
                        </div>

                        @if (_dashboard.RecentRefunds.Count == 0)
                        {
                            <DashboardEmpty Text="No refunds processed today." />
                        }
                        else
                        {
                            <div class="dash-list compact-list">
                                @foreach (var refund in _dashboard.RecentRefunds)
                                {
                                    <div class="dash-list-row">
                                        <div>
                                            <strong>@refund.ReturnNumber</strong>
                                            <span>@refund.CreatedAt.ToLocalTime().ToString("HH:mm") · @refund.ReturnType · @refund.SaleNumber</span>
                                        </div>

                                        <div class="dash-row-money negative">
                                            <strong>@Money(refund.TotalRefundAmount)</strong>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</section>

<style>
    .dash-page {
        animation: dashIn .22s ease both;
    }

    .dash-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: 18px;
        margin-bottom: 16px;
    }

    .dash-title-area {
        min-width: 0;
    }

    .dash-kicker {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: #8FA6A1;
        font-size: .72rem;
        font-weight: 760;
        letter-spacing: .08em;
        text-transform: uppercase;
        margin-bottom: 8px;
    }

    .dash-title-area h1 {
        margin: 0;
        color: #111827;
        font-size: 1.45rem;
        font-weight: 720;
        letter-spacing: -.035em;
    }

    .dash-title-area p {
        margin: 7px 0 0;
        color: #667085;
        font-size: .88rem;
        max-width: 720px;
    }

    .dash-toolbar {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 10px;
        flex-wrap: wrap;
    }

    .dash-select {
        min-height: 40px;
        border-radius: 13px;
        border: 1px solid #e5e7eb;
        background: #ffffff;
        color: #111827;
        padding: 0 12px;
        font-size: 16px;
        outline: none;
        min-width: 180px;
    }

    .dash-btn {
        min-height: 40px;
        border-radius: 13px;
        padding: 0 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        font-size: .8rem;
        font-weight: 680;
        text-decoration: none;
        white-space: nowrap;
        border: 0;
    }

    .dash-btn-dark {
        color: #ffffff;
        background: #252525;
        box-shadow: 0 12px 24px rgba(17, 24, 39, .12);
    }

    .dash-btn-light {
        color: #8FA6A1;
        background: #ffffff;
        border: 1px solid #e5e7eb;
    }

    .dash-branch-strip {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 10px;
        margin-bottom: 14px;
    }

        .dash-branch-strip div {
            padding: 13px 14px;
            border-radius: 18px;
            background: #ffffff;
            border: 1px solid #e8eaef;
            box-shadow: 0 10px 24px rgba(17, 24, 39, .035);
        }

        .dash-branch-strip span,
        .dash-branch-strip strong {
            display: block;
        }

        .dash-branch-strip span {
            color: #98a2b3;
            font-size: .7rem;
            font-weight: 700;
            letter-spacing: .03em;
            text-transform: uppercase;
        }

        .dash-branch-strip strong {
            margin-top: 5px;
            color: #111827;
            font-size: .82rem;
            font-weight: 690;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

    .dash-summary-grid {
        display: grid;
        grid-template-columns: repeat(6, minmax(0, 1fr));
        gap: 12px;
        margin: 16px 0;
    }

    .dash-summary-card {
        padding: 15px;
        border-radius: 20px;
        background: #ffffff;
        border: 1px solid #e8eaef;
        box-shadow: 0 14px 32px rgba(17, 24, 39, .045);
    }

        .dash-summary-card.hero {
            background: #252525;
            border-color: #252525;
        }

        .dash-summary-card span,
        .dash-summary-card strong,
        .dash-summary-card small {
            display: block;
        }

        .dash-summary-card span {
            margin-top: 11px;
            color: #667085;
            font-size: .72rem;
            font-weight: 680;
        }

        .dash-summary-card strong {
            margin-top: 6px;
            color: #111827;
            font-size: 1.05rem;
            font-weight: 760;
            letter-spacing: -.02em;
        }

        .dash-summary-card small {
            margin-top: 4px;
            color: #98a2b3;
            font-size: .72rem;
            line-height: 1.35;
        }

        .dash-summary-card.hero span,
        .dash-summary-card.hero strong,
        .dash-summary-card.hero small {
            color: #ffffff;
        }

    .dash-card-icon {
        width: 36px;
        height: 36px;
        border-radius: 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #ffffff;
        color: #252525;
        box-shadow: 0 10px 22px rgba(17, 24, 39, .08);
    }

        .dash-card-icon.soft {
            color: #252525;
            background: #f3f4f6;
        }

        .dash-card-icon.green {
            color: #8FA6A1;
            background: #f2f6f5;
        }

        .dash-card-icon.red {
            color: #d92d20;
            background: #fef3f2;
        }

        .dash-card-icon.amber {
            color: #b7791f;
            background: #fffbeb;
        }

        .dash-card-icon.blue {
            color: #2563eb;
            background: #eff6ff;
        }

    .dash-main-grid {
        display: grid;
        grid-template-columns: 0.8fr 1.2fr;
        gap: 16px;
        align-items: start;
    }

    .dash-left-column,
    .dash-right-column {
        display: grid;
        gap: 16px;
    }

    .dash-panel {
        background: #ffffff;
        border: 1px solid #e8eaef;
        border-radius: 22px;
        box-shadow: 0 14px 32px rgba(17, 24, 39, .045);
        overflow: hidden;
    }

    .dash-panel-header {
        padding: 16px 18px;
        border-bottom: 1px solid #f1f2f5;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
    }

        .dash-panel-header.compact {
            padding: 15px 16px;
        }

        .dash-panel-header h2 {
            margin: 0;
            color: #111827;
            font-size: .92rem;
            font-weight: 720;
            letter-spacing: -.01em;
        }

        .dash-panel-header p {
            margin: 4px 0 0;
            color: #98a2b3;
            font-size: .74rem;
        }

    .dash-panel-link {
        min-height: 32px;
        padding: 0 11px;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #ffffff;
        color: #8FA6A1;
        border: 1px solid #e5e7eb;
        font-size: .74rem;
        font-weight: 700;
        text-decoration: none;
        white-space: nowrap;
    }

    .dash-shift-empty {
        margin: 16px;
        padding: 16px;
        border-radius: 18px;
        background: #fffbeb;
        border: 1px solid #fde68a;
        display: grid;
        grid-template-columns: auto 1fr auto;
        gap: 12px;
        align-items: center;
    }

    .dash-shift-empty-icon {
        width: 38px;
        height: 38px;
        border-radius: 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #ffffff;
        color: #b7791f;
    }

    .dash-shift-empty strong,
    .dash-shift-empty span {
        display: block;
    }

    .dash-shift-empty strong {
        color: #92400e;
        font-size: .88rem;
        font-weight: 720;
    }

    .dash-shift-empty span {
        margin-top: 3px;
        color: #b45309;
        font-size: .74rem;
    }

    .dash-shift-empty a {
        min-height: 36px;
        border-radius: 12px;
        padding: 0 12px;
        background: #252525;
        color: #ffffff;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        font-size: .76rem;
        font-weight: 700;
        white-space: nowrap;
    }

    .dash-shift-card {
        padding: 16px;
    }

    .dash-shift-status {
        padding: 14px;
        margin-bottom: 12px;
        border-radius: 18px;
        background: #f2f6f5;
        border: 1px solid #dce7e4;
    }

        .dash-shift-status span,
        .dash-shift-status strong {
            display: block;
        }

        .dash-shift-status span {
            color: #8FA6A1;
            font-size: .72rem;
            font-weight: 720;
            text-transform: uppercase;
            letter-spacing: .04em;
        }

        .dash-shift-status strong {
            margin-top: 5px;
            color: #111827;
            font-size: .9rem;
            font-weight: 720;
        }

    .dash-shift-metrics {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px;
    }

        .dash-shift-metrics div {
            padding: 13px;
            border-radius: 16px;
            background: #fafafa;
            border: 1px solid #edf0f3;
        }

        .dash-shift-metrics span,
        .dash-shift-metrics strong {
            display: block;
        }

        .dash-shift-metrics span {
            color: #98a2b3;
            font-size: .7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .03em;
        }

        .dash-shift-metrics strong {
            margin-top: 5px;
            color: #111827;
            font-size: .84rem;
            font-weight: 720;
        }

    .dash-quick-actions {
        padding: 16px;
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px;
    }

        .dash-quick-actions a {
            min-height: 56px;
            padding: 12px;
            border-radius: 17px;
            background: #fafafa;
            border: 1px solid #edf0f3;
            display: flex;
            align-items: center;
            gap: 10px;
            color: #111827;
            text-decoration: none;
            font-size: .82rem;
            font-weight: 690;
            transition: transform .18s ease, background .18s ease;
        }

            .dash-quick-actions a:hover {
                transform: translateY(-1px);
                background: #ffffff;
            }

        .dash-quick-actions i {
            width: 34px;
            height: 34px;
            border-radius: 13px;
            background: #f2f6f5;
            color: #8FA6A1;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

    .dash-list {
        padding: 14px 16px;
        display: grid;
        gap: 10px;
    }

    .compact-list {
        padding: 13px 14px;
    }

    .dash-list-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 14px;
        padding: 12px;
        border-radius: 16px;
        background: #fafafa;
        border: 1px solid #edf0f3;
    }

    .dash-list-left {
        display: flex;
        align-items: center;
        gap: 10px;
        min-width: 0;
    }

    .dash-list-avatar {
        width: 34px;
        height: 34px;
        min-width: 34px;
        border-radius: 13px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #f2f6f5;
        color: #8FA6A1;
    }

        .dash-list-avatar.warning {
            background: #fffbeb;
            color: #b7791f;
        }

    .dash-list-row strong,
    .dash-list-row span {
        display: block;
    }

    .dash-list-row strong {
        color: #111827;
        font-size: .82rem;
        font-weight: 720;
    }

    .dash-list-row span {
        margin-top: 3px;
        color: #667085;
