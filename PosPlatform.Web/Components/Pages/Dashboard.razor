@page "/dashboard"
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@rendermode InteractiveServer
@layout MainLayout
@attribute [Authorize]
@using System.Globalization
@using PosPlatform.Web.Components.Layout
@using PosPlatform.Web.Models.Dashboard
@using PosPlatform.Web.Models.Settings
@using PosPlatform.Web.Services
@using PosPlatform.Web.Components.Shared
@inject DashboardService DashboardService
@inject BusinessSettingsService BusinessSettingsService
@inject NavigationManager Nav

<PageTitle>Dashboard</PageTitle>

<section class="dash-page">
    <div class="dash-hero">
        <div class="dash-hero-content">
            <div class="dash-kicker">
                <i class="bi bi-speedometer2"></i>
                Business dashboard
            </div>

            <h1>@Greeting, @_settings.BusinessName</h1>
            <p>Track today’s sales, profit, stock alerts, cashier shift and recent business activity.</p>

            <div class="dash-hero-badges">
                <span>
                    <i class="bi bi-shop"></i>
                    @_dashboard.SelectedBranchName
                </span>

                <span>
                    <i class="bi bi-briefcase"></i>
                    @_settings.BusinessType
                </span>

                <span>
                    <i class="bi bi-cash"></i>
                    @_settings.CurrencyCode · @_settings.CurrencySymbol
                </span>
            </div>
        </div>

        <div class="dash-hero-actions">
            <select class="dash-select" @bind="_branchFilter">
                <option value="">All branches</option>
                @foreach (var branch in _dashboard.Branches)
                {
                    <option value="@branch.Id">
                        @branch.Name
                        @if (branch.IsMainBranch)
                        {
                            @(" · Main")
                        }
                    </option>
                }
            </select>

            <button type="button" class="dash-btn dash-btn-light" @onclick="LoadDashboardAsync">
                <i class="bi bi-filter"></i>
                Filter
            </button>

            <a href="/sales" class="dash-btn dash-btn-dark">
                <i class="bi bi-cart-check"></i>
                New Sale
            </a>
        </div>
    </div>

    <QuoteInvoiceDashboardCards />

    @if (_loading)
    {
        <div class="dash-empty">
            <div class="dash-empty-icon">
                <i class="bi bi-hourglass-split"></i>
            </div>
            <strong>Loading dashboard...</strong>
            <span>Please wait while we prepare your business summary.</span>
        </div>
    }
    else
    {
        <div class="dash-summary-grid">
            <div class="dash-summary-card hero">
                <div class="dash-card-icon">
                    <i class="bi bi-graph-up-arrow"></i>
                </div>
                <span>Net Profit Today</span>
                <strong>@Money(_dashboard.TodayNetProfit)</strong>
                <small>After stock cost and expenses</small>
            </div>

            <div class="dash-summary-card">
                <div class="dash-card-icon soft">
                    <i class="bi bi-receipt"></i>
                </div>
                <span>Net Sales</span>
                <strong>@Money(_dashboard.TodayNetSales)</strong>
                <small>@_dashboard.TodayTransactionCount transaction@(_dashboard.TodayTransactionCount == 1 ? "" : "s")</small>
            </div>

            <div class="dash-summary-card">
                <div class="dash-card-icon green">
                    <i class="bi bi-cash-stack"></i>
                </div>
                <span>Gross Profit</span>
                <strong>@Money(_dashboard.TodayGrossProfit)</strong>
                <small>Sales minus item cost</small>
            </div>

            <div class="dash-summary-card">
                <div class="dash-card-icon red">
                    <i class="bi bi-wallet2"></i>
                </div>
                <span>Expenses</span>
                <strong>@Money(_dashboard.TodayExpenses)</strong>
                <small>@_dashboard.TodayExpenseCount recorded today</small>
            </div>

            <div class="dash-summary-card">
                <div class="dash-card-icon amber">
                    <i class="bi bi-arrow-counterclockwise"></i>
                </div>
                <span>Refunds</span>
                <strong>@Money(_dashboard.TodayRefunds)</strong>
                <small>@_dashboard.TodayRefundCount refund@(_dashboard.TodayRefundCount == 1 ? "" : "s")</small>
            </div>

            <div class="dash-summary-card">
                <div class="dash-card-icon blue">
                    <i class="bi bi-box-seam"></i>
                </div>
                <span>Low Stock</span>
                <strong>@_dashboard.LowStockCount</strong>
                <small>@_dashboard.OutOfStockCount out of stock</small>
            </div>
        </div>

        <div class="dash-insight-grid">
            <div class="dash-insight-card">
                <span>Today’s Health</span>
                <strong class="@GetProfitTextClass(_dashboard.TodayNetProfit)">
                    @ProfitStatus
                </strong>
                <small>@Money(_dashboard.TodayNetProfit) net profit</small>
            </div>

            <div class="dash-insight-card">
                <span>Average Sale</span>
                <strong>@Money(AverageSaleToday)</strong>
                <small>Based on today’s transactions</small>
            </div>

            <div class="dash-insight-card">
                <span>Payment Mix</span>
                <strong>@TopPaymentMethod</strong>
                <small>Current shift strongest method</small>
            </div>

            <div class="dash-insight-card">
                <span>Stock Health</span>
                <strong>@StockHealthStatus</strong>
                <small>@_dashboard.LowStockCount low · @_dashboard.OutOfStockCount out</small>
            </div>
        </div>

        <div class="dash-chart-grid">
            <div class="dash-chart-card">
                <div class="dash-panel-header">
                    <div>
                        <h2>Today’s Money Flow</h2>
                        <p>Sales, profit, expenses and refunds compared visually.</p>
                    </div>
                </div>

                <div class="dash-bar-chart">
                    <div class="dash-bar-row">
                        <div class="dash-bar-label">
                            <span>Net Sales</span>
                            <strong>@Money(_dashboard.TodayNetSales)</strong>
                        </div>
                        <div class="dash-bar-track">
                            <div class="dash-bar-fill dark" style="@GetBarStyle(_dashboard.TodayNetSales, MoneyFlowMax)"></div>
                        </div>
                    </div>

                    <div class="dash-bar-row">
                        <div class="dash-bar-label">
                            <span>Gross Profit</span>
                            <strong>@Money(_dashboard.TodayGrossProfit)</strong>
                        </div>
                        <div class="dash-bar-track">
                            <div class="dash-bar-fill green" style="@GetBarStyle(_dashboard.TodayGrossProfit, MoneyFlowMax)"></div>
                        </div>
                    </div>

                    <div class="dash-bar-row">
                        <div class="dash-bar-label">
                            <span>Expenses</span>
                            <strong>@Money(_dashboard.TodayExpenses)</strong>
                        </div>
                        <div class="dash-bar-track">
                            <div class="dash-bar-fill red" style="@GetBarStyle(_dashboard.TodayExpenses, MoneyFlowMax)"></div>
                        </div>
                    </div>

                    <div class="dash-bar-row">
                        <div class="dash-bar-label">
                            <span>Refunds</span>
                            <strong>@Money(_dashboard.TodayRefunds)</strong>
                        </div>
                        <div class="dash-bar-track">
                            <div class="dash-bar-fill amber" style="@GetBarStyle(_dashboard.TodayRefunds, MoneyFlowMax)"></div>
                        </div>
                    </div>

                    <div class="dash-bar-row">
                        <div class="dash-bar-label">
                            <span>Net Profit</span>
                            <strong class="@GetProfitTextClass(_dashboard.TodayNetProfit)">
                                @Money(_dashboard.TodayNetProfit)
                            </strong>
                        </div>
                        <div class="dash-bar-track">
                            <div class="dash-bar-fill @(_dashboard.TodayNetProfit >= 0 ? "green" : "red")" style="@GetBarStyle(_dashboard.TodayNetProfit, MoneyFlowMax)"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="dash-chart-card">
                <div class="dash-panel-header">
                    <div>
                        <h2>Payment Mix</h2>
                        <p>Current open shift sales by payment method.</p>
                    </div>

                    <a href="/cashier-shift" class="dash-panel-link">Open Shifts</a>
                </div>

                <div class="dash-donut-layout">
                    <div class="dash-donut" style="@GetPaymentDonutStyle()">
                        <div>
                            <strong>@Money(PaymentMixTotal)</strong>
                            <span>Total shift sales</span>
                        </div>
                    </div>

                    <div class="dash-donut-legend">
                        <div>
                            <span class="legend-dot cash"></span>
                            <strong>Cash</strong>
                            <em>@PercentageText(CurrentCashSales, PaymentMixTotal)</em>
                        </div>

                        <div>
                            <span class="legend-dot card"></span>
                            <strong>Card</strong>
                            <em>@PercentageText(CurrentCardSales, PaymentMixTotal)</em>
                        </div>

                        <div>
                            <span class="legend-dot eft"></span>
                            <strong>EFT</strong>
                            <em>@PercentageText(CurrentEftSales, PaymentMixTotal)</em>
                        </div>
                    </div>
                </div>
            </div>

            <div class="dash-chart-card">
                <div class="dash-panel-header">
                    <div>
                        <h2>Stock Health</h2>
                        <p>Low-stock and out-of-stock risk view.</p>
                    </div>

                    <a href="/stock" class="dash-panel-link">View Stock</a>
                </div>

                <div class="dash-stock-chart">
                    <div class="dash-stock-meter">
                        <div style="@GetBarStyle(_dashboard.LowStockCount, StockAlertMax)"></div>
                    </div>

                    <div class="dash-stock-stats">
                        <div>
                            <span>Low Stock</span>
                            <strong>@_dashboard.LowStockCount</strong>
                        </div>

                        <div>
                            <span>Out of Stock</span>
                            <strong class="danger">@_dashboard.OutOfStockCount</strong>
                        </div>

                        <div>
                            <span>Status</span>
                            <strong>@StockHealthStatus</strong>
                        </div>
                    </div>
                </div>
            </div>

            <div class="dash-chart-card">
                <div class="dash-panel-header">
                    <div>
                        <h2>Today’s Activity</h2>
                        <p>Transactions, expenses and refund counts.</p>
                    </div>
                </div>

                <div class="dash-activity-bars">
                    <div>
                        <span>Sales</span>
                        <strong>@_dashboard.TodayTransactionCount</strong>
                        <div>
                            <em style="@GetBarStyle(_dashboard.TodayTransactionCount, ActivityMax)"></em>
                        </div>
                    </div>

                    <div>
                        <span>Expenses</span>
                        <strong>@_dashboard.TodayExpenseCount</strong>
                        <div>
                            <em class="red" style="@GetBarStyle(_dashboard.TodayExpenseCount, ActivityMax)"></em>
                        </div>
                    </div>

                    <div>
                        <span>Refunds</span>
                        <strong>@_dashboard.TodayRefundCount</strong>
                        <div>
                            <em class="amber" style="@GetBarStyle(_dashboard.TodayRefundCount, ActivityMax)"></em>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="dash-main-grid">
            <div class="dash-left-column">
                <div class="dash-panel">
                    <div class="dash-panel-header">
                        <div>
                            <h2>Cashier Shift</h2>
                            <p>Your current till session status.</p>
                        </div>

                        <a href="/cashier-shift" class="dash-panel-link">
                            Open Shifts
                        </a>
                    </div>

                    @if (_dashboard.OpenShift == null)
                    {
                        <div class="dash-shift-empty">
                            <div class="dash-shift-empty-icon">
                                <i class="bi bi-cash-coin"></i>
                            </div>

                            <div>
                                <strong>No open shift</strong>
                                <span>Open a cashier shift before making sales.</span>
                            </div>

                            <a href="/cashier-shift">Open Shift</a>
                        </div>
                    }
                    else
                    {
                        <div class="dash-shift-card">
                            <div class="dash-shift-status">
                                <span>Open since</span>
                                <strong>@_dashboard.OpenShift.OpenedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</strong>
                            </div>

                            <div class="dash-shift-metrics">
                                <div>
                                    <span>Opening Cash</span>
                                    <strong>@Money(_dashboard.OpenShift.OpeningCash)</strong>
                                </div>

                                <div>
                                    <span>Cash Sales</span>
                                    <strong>@Money(_dashboard.OpenShift.CashSales)</strong>
                                </div>

                                <div>
                                    <span>Card Sales</span>
                                    <strong>@Money(_dashboard.OpenShift.CardSales)</strong>
                                </div>

                                <div>
                                    <span>EFT Sales</span>
                                    <strong>@Money(_dashboard.OpenShift.EftSales)</strong>
                                </div>

                                <div>
                                    <span>Total Sales</span>
                                    <strong>@Money(_dashboard.OpenShift.TotalSales)</strong>
                                </div>

                                <div>
                                    <span>Expected Cash</span>
                                    <strong>@Money(_dashboard.OpenShift.ExpectedCash)</strong>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="dash-panel">
                    <div class="dash-panel-header">
                        <div>
                            <h2>Quick Actions</h2>
                            <p>Shortcuts for daily operations.</p>
                        </div>
                    </div>

                    <div class="dash-quick-actions">
                        <a href="/sales">
                            <i class="bi bi-cart-plus"></i>
                            <span>Make Sale</span>
                        </a>

                        <a href="/stock-purchases">
                            <i class="bi bi-box-arrow-in-down"></i>
                            <span>Receive Stock</span>
                        </a>

                        <a href="/products">
                            <i class="bi bi-box-seam"></i>
                            <span>Products</span>
                        </a>

                        <a href="/customers">
                            <i class="bi bi-person-plus"></i>
                            <span>Customers</span>
                        </a>

                        <a href="/expenses">
                            <i class="bi bi-wallet2"></i>
                            <span>Expenses</span>
                        </a>

                        <a href="/reports">
                            <i class="bi bi-bar-chart"></i>
                            <span>Reports</span>
                        </a>
                    </div>
                </div>
            </div>

            <div class="dash-right-column">
                <div class="dash-panel">
                    <div class="dash-panel-header">
                        <div>
                            <h2>Recent Sales</h2>
                            <p>Latest transactions recorded today.</p>
                        </div>

                        <a href="/sales" class="dash-panel-link">View Sales</a>
                    </div>

                    @if (_dashboard.RecentSales.Count == 0)
                    {
                        <DashboardEmpty Text="No sales yet today." />
                    }
                    else
                    {
                        <div class="dash-list">
                            @foreach (var sale in _dashboard.RecentSales)
                            {
                                <div class="dash-list-row">
                                    <div class="dash-list-left">
                                        <div class="dash-list-avatar">
                                            <i class="bi bi-receipt"></i>
                                        </div>

                                        <div>
                                            <strong>@sale.SaleNumber</strong>
                                            <span>@sale.CreatedAt.ToLocalTime().ToString("HH:mm") · @sale.PaymentMethod · @(string.IsNullOrWhiteSpace(sale.CustomerName) ? "Walk-in" : sale.CustomerName)</span>
                                        </div>
                                    </div>

                                    <div class="dash-row-money">
                                        <strong>@Money(sale.TotalAmount)</strong>
                                        <span>@sale.Status</span>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>

                <div class="dash-panel">
                    <div class="dash-panel-header">
                        <div>
                            <h2>Low Stock Alerts</h2>
                            <p>Items that need attention.</p>
                        </div>

                        <a href="/stock" class="dash-panel-link">View Stock</a>
                    </div>

                    @if (_dashboard.LowStockItems.Count == 0)
                    {
                        <DashboardEmpty Text="No low stock alerts." />
                    }
                    else
                    {
                        <div class="dash-list">
                            @foreach (var item in _dashboard.LowStockItems)
                            {
                                <div class="dash-list-row">
                                    <div class="dash-list-left">
                                        <div class="dash-list-avatar warning">
                                            <i class="bi bi-box-seam"></i>
                                        </div>

                                        <div>
                                            <strong>@item.ProductName</strong>
                                            <span>@item.SKU · Reorder at @item.ReorderLevel.ToString("0.##")</span>
                                        </div>
                                    </div>

                                    <div class="dash-stock-count @(item.QuantityInStock <= 0 ? "danger" : "warning")">
                                        @item.QuantityInStock.ToString("0.##")
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>

                <div class="dash-panel two-column-panel">
                    <div class="dash-mini-section">
                        <div class="dash-panel-header compact">
                            <div>
                                <h2>Recent Expenses</h2>
                                <p>Recorded today.</p>
                            </div>

                            <a href="/expenses" class="dash-panel-link">View</a>
                        </div>

                        @if (_dashboard.RecentExpenses.Count == 0)
                        {
                            <DashboardEmpty Text="No expenses recorded today." />
                        }
                        else
                        {
                            <div class="dash-list compact-list">
                                @foreach (var expense in _dashboard.RecentExpenses)
                                {
                                    <div class="dash-list-row">
                                        <div>
                                            <strong>@expense.CategoryName</strong>
                                            <span>@expense.ExpenseNumber · @(string.IsNullOrWhiteSpace(expense.VendorName) ? "No vendor" : expense.VendorName)</span>
                                        </div>

                                        <div class="dash-row-money negative">
                                            <strong>@Money(expense.TotalAmount)</strong>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <div class="dash-mini-section border-left">
                        <div class="dash-panel-header compact">
                            <div>
                                <h2>Recent Refunds</h2>
                                <p>Returns and voids.</p>
                            </div>

                            <a href="/sales" class="dash-panel-link">View</a>
                        </div>

                        @if (_dashboard.RecentRefunds.Count == 0)
                        {
                            <DashboardEmpty Text="No refunds processed today." />
                        }
                        else
                        {
                            <div class="dash-list compact-list">
                                @foreach (var refund in _dashboard.RecentRefunds)
                                {
                                    <div class="dash-list-row">
                                        <div>
                                            <strong>@refund.ReturnNumber</strong>
                                            <span>@refund.CreatedAt.ToLocalTime().ToString("HH:mm") · @refund.ReturnType · @refund.SaleNumber</span>
                                        </div>

                                        <div class="dash-row-money negative">
                                            <strong>@Money(refund.TotalRefundAmount)</strong>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</section>

<style>
    .dash-page {
        animation: dashIn .22s ease both;
    }

    .dash-hero {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 18px;
        padding: 20px;
        margin-bottom: 16px;
        border-radius: 24px;
        background: radial-gradient(circle at top right, rgba(143, 166, 161, .22), transparent 34%), linear-gradient(135deg, #ffffff, #f8fafc);
        border: 1px solid #e8eaef;
        box-shadow: 0 14px 32px rgba(17, 24, 39, .045);
    }

    .dash-hero-content {
        min-width: 0;
    }

    .dash-kicker {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: #8FA6A1;
        font-size: .72rem;
        font-weight: 760;
        letter-spacing: .08em;
        text-transform: uppercase;
        margin-bottom: 8px;
    }

    .dash-hero h1 {
        margin: 0;
        color: #111827;
        font-size: 1.55rem;
        font-weight: 780;
        letter-spacing: -.04em;
    }

    .dash-hero p {
        margin: 7px 0 0;
        color: #667085;
        font-size: .9rem;
        max-width: 760px;
    }

    .dash-hero-badges {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 14px;
    }

        .dash-hero-badges span {
            min-height: 30px;
            display: inline-flex;
            align-items: center;
            gap: 7px;
            padding: 0 11px;
            border-radius: 999px;
            background: #ffffff;
            border: 1px solid #e8eaef;
            color: #475569;
            font-size: .74rem;
            font-weight: 720;
        }

        .dash-hero-badges i {
            color: #8FA6A1;
        }

    .dash-hero-actions {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 10px;
        flex-wrap: wrap;
    }

    .dash-select {
        min-height: 40px;
        border-radius: 13px;
        border: 1px solid #e5e7eb;
        background: #ffffff;
        color: #111827;
        padding: 0 12px;
        font-size: 16px;
        outline: none;
        min-width: 180px;
    }

    .dash-btn {
        min-height: 40px;
        border-radius: 13px;
        padding: 0 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        font-size: .8rem;
        font-weight: 680;
        text-decoration: none;
        white-space: nowrap;
        border: 0;
        transition: transform .18s ease;
    }

        .dash-btn:hover {
            transform: translateY(-1px);
        }

    .dash-btn-dark {
        color: #ffffff;
        background: #252525;
        box-shadow: 0 12px 24px rgba(17, 24, 39, .12);
    }

    .dash-btn-light {
        color: #8FA6A1;
        background: #ffffff;
        border: 1px solid #e5e7eb;
    }

    .dash-summary-grid,
    .dash-insight-grid,
    .dash-chart-grid {
        display: grid;
        gap: 12px;
        margin: 16px 0;
    }

    .dash-summary-grid {
        grid-template-columns: repeat(6, minmax(0, 1fr));
    }

    .dash-insight-grid {
        grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .dash-chart-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .dash-summary-card,
    .dash-insight-card,
    .dash-chart-card,
    .dash-panel {
        background: #ffffff;
        border: 1px solid #e8eaef;
        box-shadow: 0 14px 32px rgba(17, 24, 39, .045);
    }

    .dash-summary-card,
    .dash-insight-card {
        padding: 15px;
        border-radius: 20px;
    }

        .dash-summary-card.hero {
            background: #252525;
            border-color: #252525;
        }

        .dash-summary-card span,
        .dash-summary-card strong,
        .dash-summary-card small,
        .dash-insight-card span,
        .dash-insight-card strong,
        .dash-insight-card small {
            display: block;
        }

        .dash-summary-card span,
        .dash-insight-card span {
            margin-top: 11px;
            color: #667085;
            font-size: .72rem;
            font-weight: 700;
        }

        .dash-insight-card span {
            margin-top: 0;
        }

        .dash-summary-card strong,
        .dash-insight-card strong {
            margin-top: 6px;
            color: #111827;
            font-size: 1.05rem;
            font-weight: 760;
            letter-spacing: -.02em;
        }

        .dash-summary-card small,
        .dash-insight-card small {
            margin-top: 4px;
            color: #98a2b3;
            font-size: .72rem;
            line-height: 1.35;
        }

        .dash-summary-card.hero span,
        .dash-summary-card.hero strong,
        .dash-summary-card.hero small {
            color: #ffffff;
        }

    .dash-card-icon {
        width: 36px;
        height: 36px;
        border-radius: 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #ffffff;
        color: #252525;
        box-shadow: 0 10px 22px rgba(17, 24, 39, .08);
    }

        .dash-card-icon.soft {
            color: #252525;
            background: #f3f4f6;
        }

        .dash-card-icon.green {
            color: #8FA6A1;
            background: #f2f6f5;
        }

