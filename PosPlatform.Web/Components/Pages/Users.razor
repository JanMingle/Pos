@page "/users"
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@rendermode InteractiveServer
@layout MainLayout
@attribute [Authorize]
@using PosPlatform.Web.Components.Layout
@using PosPlatform.Web.Models.Users
@using PosPlatform.Web.Services
@inject UserManagementService UserManagementService
@inject UserAccessService UserAccessService
@inject NavigationManager NavigationManager

<PageTitle>Users</PageTitle>

<section class="users-page">
    <div class="users-header">
        <div>
            <div class="users-kicker">
                <i class="bi bi-people"></i>
                Access control
            </div>
            <h1>User Management</h1>
            <p>Create users, assign roles, control access and keep your POS operations secure.</p>
        </div>

        <button type="button" class="users-primary-btn" @onclick="OpenAddModal">
            <i class="bi bi-person-plus"></i>
            Add User
        </button>
    </div>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <div class="users-alert @(_isSuccess ? "success" : "danger")">
            <i class="bi @(_isSuccess ? "bi-check-circle" : "bi-exclamation-triangle")"></i>
            <span>@_message</span>
            <button type="button" @onclick="ClearMessage">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
    }

    <div class="users-role-grid">
        @foreach (var role in _roles)
        {
            <div class="users-role-card">
                <div class="users-role-icon @GetRoleClass(role.Name)">
                    <i class="bi @GetRoleIcon(role.Name)"></i>
                </div>

                <div>
                    <strong>@role.Name</strong>
                    <span>@role.Description</span>
                </div>
            </div>
        }
    </div>

    <div class="users-control-panel">
        <div class="users-search">
            <i class="bi bi-search"></i>
            <input @bind="_searchTerm"
                   @bind:event="oninput"
                   placeholder="Search email or phone number" />
        </div>

        <select class="users-filter" @bind="_roleFilter">
            <option value="all">All roles</option>
            @foreach (var role in _roles)
            {
                <option value="@role.Name">@role.Name</option>
            }
        </select>

        <button type="button" class="users-secondary-btn" @onclick="LoadUsersAsync">
            <i class="bi bi-filter"></i>
            Apply
        </button>

        <button type="button" class="users-ghost-btn" @onclick="ResetFiltersAsync">
            <i class="bi bi-arrow-counterclockwise"></i>
            Reset
        </button>
    </div>

    <div class="users-panel">
        <div class="users-panel-header">
            <div>
                <h2>System Users</h2>
                <p>@_users.Count user@(_users.Count == 1 ? "" : "s") showing.</p>
            </div>
        </div>

        @if (_loading)
        {
            <div class="users-empty">
                <strong>Loading users...</strong>
                <span>Please wait while we fetch user records.</span>
            </div>
        }
        else if (_users.Count == 0)
        {
            <div class="users-empty">
                <strong>No users found</strong>
                <span>Create your first user or adjust the filters.</span>
            </div>
        }
        else
        {
            <div class="users-table-wrap">
                <table class="users-table">
                    <thead>
                        <tr>
                            <th>User</th>
                            <th>Phone</th>
                            <th>Role</th>
                            <th>Branch</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var user in _users)
                        {
                            <tr>
                                <td>
                                    <div class="users-user-cell">
                                        <div class="users-avatar">@GetInitials(user.Email)</div>
                                        <div>
                                            <strong>@user.Email</strong>
                                            <span>ID: @user.Id</span>
                                        </div>
                                    </div>
                                </td>

                                <td>@(string.IsNullOrWhiteSpace(user.PhoneNumber) ? "-" : user.PhoneNumber)</td>

                                <td>
                                    <span class="users-role-pill @GetRoleClass(user.RoleName)">
                                        @user.RoleName
                                    </span>
                                </td>

                                <td>@user.BranchName</td>

                                <td>
                                    <span class="users-status-pill @(user.IsDisabled ? "disabled" : "active")">
                                        @user.Status
                                    </span>
                                </td>

                                <td class="text-end">
                                    <div class="users-actions">
                                        <button type="button" class="users-mini-btn edit" @onclick="() => OpenEditModal(user.Id)">
                                            <i class="bi bi-pencil"></i>
                                            Edit
                                        </button>

                                        <button type="button"
                                                class="users-mini-btn @(user.IsDisabled ? "activate" : "disable")"
                                                @onclick="() => ToggleUserStatusAsync(user.Id)">
                                            <i class="bi @(user.IsDisabled ? "bi-unlock" : "bi-lock")"></i>
                                            @(user.IsDisabled ? "Activate" : "Disable")
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</section>

@if (_showModal)
{
    <div class="users-modal-backdrop">
        <div class="users-modal">
            <div class="users-modal-header">
                <div>
                    <span>User setup</span>
                    <h4>@(_form.Id.HasValue ? "Edit User" : "Add User")</h4>
                    <p>Assign the user to a branch and select the correct operational role.</p>
                </div>

                <button type="button" class="users-close-btn" @onclick="CloseModal">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <EditForm Model="_form" OnValidSubmit="SaveUserAsync">
                <DataAnnotationsValidator />
                <ValidationSummary class="users-validation" />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="users-label">Email Address</label>
                        <InputText class="users-input" @bind-Value="_form.Email" />
                    </div>

                    <div class="col-md-6">
                        <label class="users-label">Phone Number</label>
                        <InputText class="users-input" @bind-Value="_form.PhoneNumber" />
                    </div>

                    <div class="col-md-6">
                        <label class="users-label">Role</label>
                        <InputSelect class="users-input" @bind-Value="_form.RoleName">
                            @foreach (var role in _roles)
                            {
                                <option value="@role.Name">@role.Name</option>
                            }
                        </InputSelect>
                    </div>

                    <div class="col-md-6">
                        <label class="users-label">Branch</label>
                        <InputSelect class="users-input" @bind-Value="_form.BranchId">
                            <option value="">Default branch</option>
                            @foreach (var branch in _branches)
                            {
                                <option value="@branch.Id">@branch.Name</option>
                            }
                        </InputSelect>
                    </div>

                    <div class="col-md-6">
                        <label class="users-label">
                            Password @(_form.Id.HasValue ? "(leave blank to keep current)" : "")
                        </label>
                        <InputText type="password" class="users-input" @bind-Value="_form.Password" />
                    </div>

                    <div class="col-md-6">
                        <label class="users-label">Confirm Password</label>
                        <InputText type="password" class="users-input" @bind-Value="_form.ConfirmPassword" />
                    </div>
                </div>

                <div class="users-role-help">
                    <strong>@_form.RoleName</strong>
                    <span>@GetRoleDescription(_form.RoleName)</span>
                </div>

                <div class="users-modal-actions">
                    <button type="button" class="users-ghost-btn" @onclick="CloseModal">Cancel</button>
                    <button type="submit" class="users-primary-btn" disabled="@_saving">
                        <i class="bi bi-check2-circle"></i>
                        @(_saving ? "Saving..." : "Save User")
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

<style>
