    @@media (max-width: 768px) {
        .users-header {
            flex-direction: column;
            align-items: flex-start;
        }

            .users-header .users-primary-btn {
                width: 100%;
            }

        .users-role-grid,
        .users-control-panel {
            grid-template-columns: 1fr;
        }

        .users-modal-actions {
            flex-direction: column-reverse;
        }

            .users-modal-actions button {
                width: 100%;
            }
    }
</style>

@code {
    private List<UserListItemViewModel> _users = new();
    private List<RoleOptionViewModel> _roles = new();
    private List<BranchOptionViewModel> _branches = new();

    private UserFormModel _form = new()
    {
        RoleName = "Sales User"
    };

    private bool _loading = true;
    private bool _saving;
    private bool _showModal;

    private string? _searchTerm;
    private string _roleFilter = "all";

    private string? _message;
    private bool _isSuccess;

    protected override async Task OnInitializedAsync()
    {
        if (!await UserAccessService.CanAccessAsync("users"))
        {
            NavigationManager.NavigateTo("/dashboard");
            return;
        }

        _roles = await UserManagementService.GetRoleOptionsAsync();
        _branches = await UserManagementService.GetBranchesAsync();

        await LoadUsersAsync();
    }

    private async Task LoadUsersAsync()
    {
        _loading = true;
        _users = await UserManagementService.GetUsersAsync(_searchTerm, _roleFilter);
        _loading = false;
    }

    private async Task ResetFiltersAsync()
    {
        _searchTerm = null;
        _roleFilter = "all";
        await LoadUsersAsync();
    }

    private void OpenAddModal()
    {
        _form = new UserFormModel
        {
            RoleName = "Sales User"
        };

        _showModal = true;
    }

    private async Task OpenEditModal(int id)
    {
        var model = await UserManagementService.GetUserFormAsync(id);

        if (model == null)
        {
            ShowMessage("User not found.", false);
            return;
        }

        _form = model;
        _showModal = true;
    }

    private void CloseModal()
    {
        _showModal = false;
        _form = new UserFormModel
        {
            RoleName = "Sales User"
        };
    }

    private async Task SaveUserAsync()
    {
        _saving = true;

        var result = await UserManagementService.SaveUserAsync(_form);

        _saving = false;
        ShowMessage(result.Message, result.Success);

        if (result.Success)
        {
            CloseModal();
            await LoadUsersAsync();
        }
    }

    private async Task ToggleUserStatusAsync(int userId)
    {
        var result = await UserManagementService.ToggleUserStatusAsync(userId);

        ShowMessage(result.Message, result.Success);

        if (result.Success)
        {
            await LoadUsersAsync();
        }
    }

    private void ShowMessage(string message, bool success)
    {
        _message = message;
        _isSuccess = success;
    }

    private void ClearMessage()
    {
        _message = null;
    }

    private string GetRoleDescription(string roleName)
    {
        return _roles.FirstOrDefault(x => x.Name == roleName)?.Description ?? "";
    }

    private string GetRoleClass(string roleName)
    {
        return roleName switch
        {
            "Owner" => "owner",
            "Admin" => "admin",
            "Sales User" => "sales",
            "Inventory User" => "inventory",
            "Accounting User" => "accounting",
            "Manager" => "manager",
            "Viewer" => "viewer",
            _ => "viewer"
        };
    }

    private string GetRoleIcon(string roleName)
    {
        return roleName switch
        {
            "Owner" => "bi-gem",
            "Admin" => "bi-shield-lock",
            "Sales User" => "bi-cart-check",
            "Inventory User" => "bi-boxes",
            "Accounting User" => "bi-calculator",
            "Manager" => "bi-person-badge",
            "Viewer" => "bi-eye",
            _ => "bi-person"
        };
    }

    private string GetInitials(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "U";
        }

        var emailName = value.Split('@')[0];

        var words = emailName
            .Split(new[] { '.', '-', '_' }, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Take(2)
            .Select(x => x[0].ToString().ToUpper());

        var result = string.Join("", words);

        return string.IsNullOrWhiteSpace(result) ? "U" : result;
    }
}