@using PosPlatform.Web.Services
@inject UserAccessService UserAccessService

<aside class="pos-sidebar">
    <div class="pos-sidebar-brand">
        <div class="pos-brand-logo">P</div>

        <div class="pos-brand-text">
            <div class="pos-brand-title">POS Platform</div>
            <div class="pos-brand-subtitle">@_roleName</div>
        </div>
    </div>

    <div class="pos-nav-section">Dashboard</div>

    <nav class="pos-sidebar-nav">
        <NavLink href="/dashboard" class="pos-nav-link" Match="NavLinkMatch.All">
            <span class="pos-nav-icon"><i class="bi bi-grid-1x2"></i></span>
            <span class="pos-nav-text">Dashboard</span>
        </NavLink>

        @if (_canProducts || _canBarcodeLabels || _canStock || _canSales || _canBranches)
        {
            <div class="pos-nav-section">Operations</div>
        }

        @if (_canProducts)
        {
            <NavLink href="/products" class="pos-nav-link">
                <span class="pos-nav-icon"><i class="bi bi-box-seam"></i></span>
                <span class="pos-nav-text">Products</span>
            </NavLink>
        }

        @if (_canBarcodeLabels)
        {
            <NavLink href="/barcode-labels" class="pos-nav-link">
                <span class="pos-nav-icon"><i class="bi bi-upc-scan"></i></span>
                <span class="pos-nav-text">Barcode Labels</span>
            </NavLink>
        }

        @if (_canStock)
        {
            <NavLink href="/stock" class="pos-nav-link">
                <span class="pos-nav-icon"><i class="bi bi-graph-up-arrow"></i></span>
                <span class="pos-nav-text">Stock</span>
            </NavLink>
        }

        @if (_canStockPurchases)
        {
            <NavLink href="/stock-purchases" class="pos-nav-link">
                <span class="pos-nav-icon"><i class="bi bi-box-arrow-in-down"></i></span>
                <span class="pos-nav-text">Stock Purchases</span>
            </NavLink>
        }

        @if (_canSuppliers)
        {
            <NavLink href="/suppliers" class="pos-nav-link">
                <span class="pos-nav-icon"><i class="bi bi-truck"></i></span>
                <span class="pos-nav-text">Suppliers</span>
            </NavLink>
        }

        @if (_canSales)
        {
            <NavLink href="/sales" class="pos-nav-link">
                <span class="pos-nav-icon"><i class="bi bi-cart-check"></i></span>
                <span class="pos-nav-text">Sales</span>
            </NavLink>
        }

        @if (_canCashierShift)
        {
            <NavLink href="/cashier-shift" class="pos-nav-link">
                <span class="pos-nav-icon"><i class="bi bi-cash-coin"></i></span>
                <span class="pos-nav-text">Cashier Shift</span>
            </NavLink>
        }

        @if (_canCustomers)
        {
            <NavLink href="/customers" class="pos-nav-link">
                <span class="pos-nav-icon"><i class="bi bi-person-lines-fill"></i></span>
                <span class="pos-nav-text">Customers</span>
            </NavLink>
        }

        @if (_canBranches)
        {
            <NavLink href="/branches" class="pos-nav-link">
                <span class="pos-nav-icon"><i class="bi bi-shop"></i></span>
                <span class="pos-nav-text">Branches</span>
            </NavLink>
        }

        @if (_canStockTransfers)
        {
            <NavLink href="/stock-transfers" class="pos-nav-link">
                <span class="pos-nav-icon"><i class="bi bi-arrow-left-right"></i></span>
                <span class="pos-nav-text">Stock Transfers</span>
            </NavLink>
        }

        @if (_canUsers || _canReports || _canAuditTrail || _canSettings)
        {
            <div class="pos-nav-section">Management</div>
        }

        @if (_canUsers)
        {
            <NavLink href="/users" class="pos-nav-link">
                <span class="pos-nav-icon"><i class="bi bi-people"></i></span>
                <span class="pos-nav-text">Users</span>
            </NavLink>
        }

        @if (_canReports)
        {
            <NavLink href="/reports" class="pos-nav-link">
                <span class="pos-nav-icon"><i class="bi bi-bar-chart"></i></span>
                <span class="pos-nav-text">Reports</span>
            </NavLink>
        }

        @if (_canAuditTrail)
        {
            <NavLink href="/audit-trail" class="pos-nav-link">
                <span class="pos-nav-icon"><i class="bi bi-shield-lock"></i></span>
                <span class="pos-nav-text">Audit Trail</span>
            </NavLink>
        }

        @if (_canExpenses)
        {
            <NavLink href="/expenses" class="pos-nav-link">
                <span class="pos-nav-icon"><i class="bi bi-wallet2"></i></span>
                <span class="pos-nav-text">Expenses</span>
            </NavLink>
        }

        @if (_canSettings)
        {
            <NavLink href="/settings" class="pos-nav-link">
                <span class="pos-nav-icon"><i class="bi bi-gear"></i></span>
                <span class="pos-nav-text">Settings</span>
            </NavLink>
        }
    </nav>

    <div class="pos-sidebar-card">
        <div class="pos-sidebar-card-icon">
            <i class="bi bi-shield-check"></i>
        </div>

        <div class="pos-sidebar-card-text">
            <strong>@_roleName</strong>
            <span>Access enabled</span>
        </div>
    </div>
</aside>

@code {
    private string _roleName = "Loading...";

    private bool _canProducts;
    private bool _canBarcodeLabels;
    private bool _canStock;
    private bool _canSales;
    private bool _canBranches;
    private bool _canUsers;
    private bool _canReports;
    private bool _canSettings;
    private bool _canCashierShift;
    private bool _canCustomers;
    private bool _canSuppliers;
    private bool _canStockPurchases;
    private bool _canExpenses;
    private bool _canStockTransfers;
    private bool _canAuditTrail;

    protected override async Task OnInitializedAsync()
    {
        _roleName = await UserAccessService.GetCurrentRoleAsync();

        _canProducts = await UserAccessService.CanAccessAsync("products");
        _canBarcodeLabels = await UserAccessService.CanAccessAsync("barcode-labels");
        _canStock = await UserAccessService.CanAccessAsync("stock");
        _canSales = await UserAccessService.CanAccessAsync("sales");
        _canBranches = await UserAccessService.CanAccessAsync("branches");
        _canUsers = await UserAccessService.CanAccessAsync("users");
        _canReports = await UserAccessService.CanAccessAsync("reports");
        _canSettings = await UserAccessService.CanAccessAsync("settings");
        _canCashierShift = await UserAccessService.CanAccessAsync("cashier-shift");
        _canCustomers = await UserAccessService.CanAccessAsync("customers");
        _canSuppliers = await UserAccessService.CanAccessAsync("suppliers");
        _canStockPurchases = await UserAccessService.CanAccessAsync("stock-purchases");
        _canExpenses = await UserAccessService.CanAccessAsync("expenses");
        _canStockTransfers = await UserAccessService.CanAccessAsync("stock-transfers");
        _canAuditTrail = await UserAccessService.CanAccessAsync("audit-trail");
    }
}