@inherits LayoutComponentBase

<div class="public-shell">
    <header class="public-header">
        <div class="public-container header-inner">
            <a href="/" class="brand-wrap text-decoration-none">
                <div class="brand-box">J</div>

                <div class="brand-copy">
                    <div class="brand-title">JMingle</div>
                    <div class="brand-subtitle">Multi-tenant business system</div>
                </div>
            </a>

            <nav class="public-nav">
                <a href="/" class="nav-item">Home</a>
                <a href="/login" class="nav-item">Login</a>
                <a href="/register-business" class="public-cta-btn">
                    Register Business
                    <i class="bi bi-arrow-right"></i>
                </a>
            </nav>
        </div>
    </header>

    <main class="public-main">
        @Body
    </main>

    <footer class="public-footer">
        <div class="public-container footer-inner">
            <div>
                <strong>JMingle</strong><br />
                <span class="footer-text">Sales, stock, branches, invoices, users and reports in one system.</span>
            </div>

            <div class="footer-links">
                <a href="/">Home</a>
                <a href="/login">Login</a>
                <a href="/register-business">Register</a>
            </div>

            <div class="footer-text">
                © @DateTime.Now.Year JMingle
            </div>
        </div>
    </footer>
</div>

<style>
    /* Important: allow public website pages to scroll normally */
    html,
    body {
        height: auto !important;
        min-height: 100%;
        overflow-y: auto !important;
        overflow-x: hidden !important;
    }

    .public-shell {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        background: radial-gradient(circle at 10% 0%, rgba(143, 166, 161, .22), transparent 28%), radial-gradient(circle at 88% 10%, rgba(37, 99, 235, .12), transparent 28%), linear-gradient(180deg, #ffffff 0%, #f6f7f9 48%, #ffffff 100%);
        color: #111827;
    }

    .public-main {
        flex: 1 1 auto;
        min-height: 0;
    }

    .public-container {
        width: min(1180px, calc(100% - 32px));
        margin: 0 auto;
    }

    .public-header {
        position: sticky;
        top: 0;
        z-index: 1000;
        width: 100%;
        background: rgba(255, 255, 255, .88);
        border-bottom: 1px solid rgba(232, 234, 239, .9);
        backdrop-filter: blur(18px);
        box-shadow: 0 10px 30px rgba(17, 24, 39, .045);
    }

        .public-header::before {
            content: "";
            display: block;
            width: 100%;
            height: 4px;
            background: linear-gradient(90deg, #252525, #8FA6A1, #2563eb, #b7791f);
        }

    .header-inner {
        min-height: 76px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 22px;
    }

    .brand-wrap {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        min-width: 0;
        color: inherit;
    }

    .brand-box {
        width: 46px;
        height: 46px;
        min-width: 46px;
        border-radius: 17px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: radial-gradient(circle at top right, rgba(255,255,255,.35), transparent 40%), linear-gradient(135deg, #252525, #8FA6A1);
        color: #ffffff;
        font-size: 1rem;
        font-weight: 850;
        box-shadow: 0 14px 30px rgba(17, 24, 39, .16);
    }

    .brand-copy {
        min-width: 0;
    }

    .brand-title {
        color: #111827;
        font-size: 1rem;
        font-weight: 850;
        line-height: 1.1;
        letter-spacing: -.03em;
    }

    .brand-subtitle {
        margin-top: 3px;
        color: #667085;
        font-size: .72rem;
        font-weight: 650;
        white-space: nowrap;
    }

    .public-nav {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 8px;
        flex-wrap: wrap;
    }

    .nav-item {
        min-height: 38px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0 13px;
        border-radius: 999px;
        color: #475569;
        font-size: .82rem;
        font-weight: 750;
        text-decoration: none;
        transition: background .18s ease, color .18s ease, transform .18s ease;
    }

        .nav-item:hover {
            background: #f2f6f5;
            color: #252525;
            transform: translateY(-1px);
        }

    .public-cta-btn {
        min-height: 40px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 0 16px;
        border-radius: 999px;
        color: #ffffff;
        background: linear-gradient(135deg, #252525, #3a3a3a);
        font-size: .82rem;
        font-weight: 800;
        text-decoration: none;
        box-shadow: 0 14px 28px rgba(17, 24, 39, .14);
        transition: transform .18s ease, box-shadow .18s ease;
    }

        .public-cta-btn:hover {
            color: #ffffff;
            transform: translateY(-1px);
            box-shadow: 0 18px 36px rgba(17, 24, 39, .20);
        }

    .public-footer {
        margin-top: auto;
        background: radial-gradient(circle at top left, rgba(143, 166, 161, .16), transparent 28%), #111827;
        color: #ffffff;
    }

    .footer-inner {
        min-height: 110px;
        display: grid;
        grid-template-columns: 1fr auto auto;
        gap: 22px;
        align-items: center;
        padding: 24px 0;
    }

    .public-footer strong {
        color: #ffffff;
        font-size: .96rem;
        font-weight: 820;
    }

    .footer-text {
        color: rgba(255, 255, 255, .68);
        font-size: .8rem;
        line-height: 1.5;
    }

    .footer-links {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

        .footer-links a {
            min-height: 32px;
            display: inline-flex;
            align-items: center;
            padding: 0 11px;
            border-radius: 999px;
            background: rgba(255, 255, 255, .08);
            color: rgba(255, 255, 255, .78);
            border: 1px solid rgba(255, 255, 255, .10);
            font-size: .76rem;
            font-weight: 700;
            text-decoration: none;
        }

            .footer-links a:hover {
                color: #ffffff;
                background: rgba(255, 255, 255, .14);
            }

    @@media (max-width: 768px) {
        .header-inner {
            min-height: auto;
            padding: 14px 0;
            flex-direction: column;
            align-items: flex-start;
        }

        .public-nav {
            width: 100%;
            justify-content: flex-start;
        }

        .nav-item,
        .public-cta-btn {
            flex: 1 1 auto;
        }

        .footer-inner {
            grid-template-columns: 1fr;
            text-align: left;
        }
    }

    @@media (max-width: 520px) {
        .public-container {
            width: min(100% - 24px, 1180px);
        }

        .brand-subtitle {
            white-space: normal;
        }

        .public-nav {
            display: grid;
            grid-template-columns: 1fr;
        }

        .nav-item,
        .public-cta-btn {
            width: 100%;
        }
    }
</style>