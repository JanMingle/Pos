@inherits LayoutComponentBase
@implements IDisposable
@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.JSInterop
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<input type="checkbox" id="sidebarToggle" class="pos-sidebar-toggle" />

<div class="pos-shell">
    <label for="sidebarToggle" class="pos-sidebar-backdrop"></label>

    <NavMenu />

    <div class="pos-main">
        <header class="pos-topbar">
            <div class="pos-topbar-left">
                <label for="sidebarToggle" class="pos-menu-button" title="Toggle menu">
                    <i class="bi bi-list"></i>
                </label>

                <div class="pos-topbar-title-wrap">
                    <div class="pos-topbar-eyebrow">Workspace</div>
                    <div class="pos-topbar-title">Business Control Center</div>
                </div>
            </div>

            <div class="pos-topbar-actions">
                <div class="pos-topbar-date">
                    <i class="bi bi-calendar2-week"></i>
                    <span>@DateTime.Now.ToString("dd MMM yyyy")</span>
                </div>

                <a href="/" class="pos-icon-button" title="Website">
                    <i class="bi bi-globe2"></i>
                </a>

                <div class="pos-user-pill">
                    <div class="pos-user-avatar">P</div>
                    <div class="pos-user-text">
                        <strong>Owner</strong>
                        <span>POS Platform</span>
                    </div>
                </div>

                <form method="post" action="/account/logout" class="d-inline">
                    <AntiforgeryToken />
                    <button type="submit" class="pos-logout-button">
                        <i class="bi bi-box-arrow-right"></i>
                        <span>Logout</span>
                    </button>
                </form>
            </div>
        </header>

        <main class="pos-content">
            @Body
        </main>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        NavigationManager.LocationChanged += HandleLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await ScrollToTopAsync();
        }
    }

    private async void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        await InvokeAsync(async () =>
        {
            await Task.Delay(80);
            await ScrollToTopAsync();
            await CloseMobileSidebarAsync();
        });
    }

    private async Task ScrollToTopAsync()
    {
        try
        {
            await JS.InvokeVoidAsync(
                "eval",
                "const main = document.querySelector('.pos-main'); if (main) { main.scrollTo({ top: 0, left: 0 }); } else { window.scrollTo(0, 0); }"
            );
        }
        catch
        {
            // Ignore during prerender or if JS is not ready yet.
        }
    }

    private async Task CloseMobileSidebarAsync()
    {
        try
        {
            await JS.InvokeVoidAsync(
                "eval",
                "const sidebarToggle = document.getElementById('sidebarToggle'); if (sidebarToggle) sidebarToggle.checked = false;"
            );
        }
        catch
        {
            // Ignore during prerender or if JS is not ready yet.
        }
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= HandleLocationChanged;
    }
}